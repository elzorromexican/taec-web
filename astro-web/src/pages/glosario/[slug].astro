---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { r } from '../../utils/paths';

import { slugify } from '../../utils/slugify';

// Genera todas las rutas posibles basándose en los .md de src/content/glosario
export async function getStaticPaths() {
  const terms = await getCollection('glosario');
  return terms.map(term => ({
    params: { slug: term.id.replace(/\.mdx?$/, '') },
    props: { term },
  }));
}

const { term } = Astro.props;

// Obtener los términos del glosario que comparten etiquetas (Circular Interlinking Glosario-a-Glosario)
const allTerms = await getCollection('glosario');
const relatedTermsFound = allTerms
  .filter(t => t.id !== term.id && t.data.related?.some((rTag: string) => term.data.related?.includes(rTag)))
  .slice(0, 3);

// relatedPosts query eliminado por no existencia en schema (H-08)

const schema = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  "name": term.data.title,
  "description": term.data.description,
  "inDefinedTermSet": "https://nuevo.taec.com.mx/glosario"
};
---

<BaseLayout 
  title={`${term.data.title} - Glosario e-learning | TAEC`}
  description={term.data.description}
  section="Recursos"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <main style="background: #faf8f3; min-height: 70vh; padding: clamp(32px, 5vw, 64px) clamp(16px, 3vw, 24px) 80px;">
    <div style="max-width: 680px; margin: 0 auto; background: #ffffff; border: 1px solid #e7e3db; border-radius: 8px; padding: clamp(24px, 5vw, 48px); box-shadow: 0 4px 16px rgba(0,0,0,0.05); overflow: hidden;">
      
      <a href={r('/glosario')} style="font-family: monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; text-decoration: none; color: #78716c; margin-bottom: 32px; display: inline-block; transition: color 0.15s;">
        &larr; Volver al Glosario
      </a>
      
      <div style="font-family: monospace; font-size: 11px; color: #1d4ed8; text-transform: uppercase; margin-bottom: 10px; background: #eff6ff; display: inline-block; padding: 4px 10px; border-radius: 4px;">
        {term.data.category || 'Término'}
      </div>
      
      <h1 style="font-family: var(--font-display, Georgia, serif); font-size: clamp(2rem, 3.5vw, 2.5rem); font-weight: 700; color: #1c1917; margin-top: 0; margin-bottom: 24px; line-height: 1.15; letter-spacing: -0.01em;">
        {term.data.title}
      </h1>
      
      <div style="font-size: 1.05rem; line-height: 1.75; color: #44403c;">
        {term.data.description}
      </div>
      
      {term.data.related && term.data.related.length > 0 && (
        <div style="margin-top: 48px; padding-top: 32px; border-top: 1px solid #e7e3db;">
          <h3 style="font-size: 14px; font-weight: 600; color: #1c1917; margin-bottom: 12px; margin-top:0;">Explorar etiquetas:</h3>
          <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            {term.data.related.map((rTag: string) => (
              <a href={r(`/glosario/etiqueta/${slugify(rTag)}`)} class="hover-tag" style="font-family: monospace; background: #f0fdf4; color: #166534; padding: 4px 12px; border-radius: 4px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.04em; text-decoration: none; transition: background 0.2s;">
                {rTag}
              </a>
            ))}
          </div>
        </div>
      )}

      {relatedTermsFound.length > 0 && (
        <div style="margin-top: 48px; padding-top: 32px; border-top: 1px solid #e7e3db;">
          <h3 style="font-size: 14px; font-weight: 600; color: #1c1917; margin-bottom: 16px; margin-top:0;">Términos Recomendados:</h3>
          <div style="display: grid; gap: 16px;">
            {relatedTermsFound.map((t: any) => (
              <a href={r(`/glosario/${t.id.replace(/\\.mdx?$/, '')}`)} style="display: flex; flex-direction: column; padding: 16px; border: 1px solid #e2e8f0; border-radius: 8px; text-decoration: none; background: #f8fafc; transition: transform 0.2s;" class="term-rel-card">
                <span style="font-family: var(--font-display, Georgia, serif); font-size: 1.1rem; color: #0f172a; font-weight: 600; margin-bottom: 6px;">{t.data.title}</span>
                <span style="font-family: monospace; font-size: 11px; color: #64748b;">Concepto &rarr;</span>
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </main>
</BaseLayout>

<style is:global>
.hover-tag:hover { background: #dcfce7 !important; color: #14532d !important; }
.term-rel-card:hover { transform: translateY(-2px); box-shadow: 0 8px 16px rgba(0,0,0,0.06); border-color: #cbd5e1; }
.prose-content img { max-width: 100%; height: auto; border-radius: 8px; box-shadow: 0 4px 16px rgba(0,0,0,0.05); }
.prose-content p { overflow-wrap: break-word; word-break: break-word; }
.prose-content a { overflow-wrap: break-word; word-break: break-word; }
</style>
