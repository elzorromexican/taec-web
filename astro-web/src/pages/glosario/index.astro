---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroComercial from '../../components/ui/HeroComercial.astro';
import { getCollection } from 'astro:content';
import { r } from '../../utils/paths';

const terms = await getCollection('glosario');
terms.sort((a, b) => a.data.title.localeCompare(b.data.title));

// Extraer primera letra de cada término
const letters = [...new Set(terms.map(t => {
  const char = t.data.title.charAt(0).toUpperCase();
  // Validar si es número u otro símbolo
  if (/[A-ZÁÉÍÓÚÑ]/.test(char)) return char;
  return '#';
}))].sort();
---

<BaseLayout 
  title="Glosario e-learning | TAEC"
  description="Diccionario de referencia para profesionales de L&D en LATAM. Términos de plataformas, estándares y tecnología educativa."
  section="Recursos"
  page="glosario.html"
>
  <HeroComercial 
    eyebrow="TAEC · Recursos"
    titleHtml="Glosario <br/> <span class='text-accent'>e-learning</span>"
    subtitle="Diccionario de referencia para profesionales de L&D en LATAM. Términos de plataformas, estándares, metodologías y tecnología educativa."
    theme="general"
  />

  <main style="max-width: 1080px; margin: 64px auto; padding: 0 24px 80px;">
    
    <!-- Módulo de Búsqueda y Filtro -->
    <div style="background: #ffffff; border: 1px solid #e7e3db; padding: 32px; border-radius: 12px; box-shadow: 0 4px 16px rgba(0,0,0,0.05); margin-bottom: 48px;">
      
      <div style="margin-bottom: 24px; position: relative;">
        <!-- Icono Lupa SVG -->
        <svg style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); width: 20px; height: 20px; color: #a8a29e;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input 
          type="text" 
          id="search-input"
          autocomplete="off"
          spellcheck="false" 
          placeholder="Buscar por término o palabra clave en la definición..." 
          style="width: 100%; padding: 16px 20px 16px 48px; font-size: 16px; border: 1.5px solid #e7e3db; border-radius: 8px; outline: none; font-family: var(--font-body, sans-serif); transition: border-color 0.2s; -webkit-appearance: none;"
        />
      </div>

      <div style="display: flex; flex-wrap: wrap; gap: 8px; justify-content: center;">
        <button class="letter-btn active" data-letter="ALL">Todos</button>
        {letters.map(letter => (
          <button class="letter-btn" data-letter={letter}>{letter}</button>
        ))}
      </div>
    </div>

    <!-- Resultados -->
    <div style="display: flex; align-items: baseline; justify-content: space-between; border-bottom: 2px solid #1c1917; padding-bottom: 10px; margin-bottom: 32px;">
      <h2 style="font-family: var(--font-display, Georgia, serif); font-size: 1.5rem; font-weight: 700;">Índice y Definiciones</h2>
      <span style="font-family: monospace; font-size: 11px; color: #78716c; text-transform: uppercase;" id="results-count">{terms.length} términos</span>
    </div>

    <div id="glosario-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
      {terms.map(term => {
        const char = term.data.title.charAt(0).toUpperCase();
        const letter = /[A-ZÁÉÍÓÚÑ]/.test(char) ? char : '#';
        return (
          <a class="glosario-item" href={r(`/glosario/${term.id.replace(/\.mdx?$/, '')}`)} data-title={term.data.title.toLowerCase()} data-desc={term.data.description.toLowerCase()} data-letter={letter} style="text-decoration: none; color: inherit; display: block;">
            <article style="background: #ffffff; border: 1px solid #e7e3db; padding: 20px 24px; border-radius: 8px; box-shadow: 0 1px 4px rgba(0,0,0,0.07); height: 100%; transition: transform 0.2s, box-shadow 0.2s;">
              <div style="font-family: monospace; font-size: 10px; color: #1d4ed8; text-transform: uppercase; margin-bottom: 6px;">
                {term.data.category || 'Término'}
              </div>
              <h3 style="font-family: var(--font-body, sans-serif); font-size: 0.95rem; font-weight: 700; margin-bottom: 8px; line-height: 1.35; color: #1c1917;">
                {term.data.title}
              </h3>
              <p style="font-size: 13px; color: #44403c; line-height: 1.5; margin-bottom: 14px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                {term.data.description}
              </p>
              <span style="font-family: monospace; font-size: 11px; text-transform: uppercase; color: #1d4ed8; font-weight: 600;">Ver definición &rarr;</span>
            </article>
          </a>
        )
      })}
    </div>

    <!-- Empty State -->
    <div id="no-results" style="display: none; text-align: center; padding: 64px 20px; background: #ffffff; border: 1.5px dashed #e7e3db; border-radius: 8px; margin-top: 20px;">
      <svg style="width: 48px; height: 48px; color: #d6d3d1; margin: 0 auto 16px;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 15l-3-3m0 0l3-3m-3 3h8M3 12a9 9 0 1118 0 9 9 0 01-18 0z" />
      </svg>
      <h3 style="margin: 0 0 8px; color: #1c1917; font-size: 18px;">No se encontraron términos</h3>
      <p style="margin: 0; color: #78716c; font-size: 14px;">Intenta buscar con otra palabra clave o quita el filtro alfabético.</p>
    </div>

  </main>
</BaseLayout>

<style>
/* Utilities y micro-animaciones */
.letter-btn {
  background: transparent; border: 1px solid #e7e3db; border-radius: 4px; font-family: monospace; font-size: 14px; padding: 6px 12px; cursor: pointer; color: #44403c; transition: all 0.2s ease;
}
.letter-btn:hover { background: #f5f5f4; border-color: #d6d3d1; }
.letter-btn.active { background: #1c1917; color: #ffffff; border-color: #1c1917; font-weight: 600; }

input:focus { border-color: #1d4ed8 !important; box-shadow: 0 0 0 3px rgba(29, 78, 216, 0.1); }

/* Efecto hover sobre tarjetas */
.glosario-item article:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); border-color: #dce7f9; }
.glosario-item article:hover span { color: #1e3a8a; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search-input');
    const letterBtns = document.querySelectorAll('.letter-btn');
    const items = document.querySelectorAll('.glosario-item');
    const noResults = document.getElementById('no-results');
    const resultsCount = document.getElementById('results-count');
    
    let currentSearch = '';
    let currentLetter = 'ALL';

    // Normalizar string para quitar tildes (ej: Educación -> educacion) en la búsqueda
    const normalize = (str) => {
      return str.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();
    };

    function filterItems() {
      let visibleCount = 0;
      
      const searchNormalized = normalize(currentSearch);

      items.forEach(item => {
        const titleOrig = item.getAttribute('data-title');
        const descOrig = item.getAttribute('data-desc');
        const letterOrig = item.getAttribute('data-letter');
        
        // Remove accents for fuzzy matching
        const titleStr = normalize(titleOrig);
        const descStr = normalize(descOrig);
        
        // Match Search (title OR description)
        let matchesSearch = true;
        if (searchNormalized) {
          matchesSearch = titleStr.includes(searchNormalized) || descStr.includes(searchNormalized);
        }
        
        // Match Letter
        let matchesLetter = true;
        if (currentLetter !== 'ALL') {
          matchesLetter = (letterOrig === currentLetter);
        }
        
        if (matchesSearch && matchesLetter) {
          item.style.display = 'block';
          visibleCount++;
        } else {
          item.style.display = 'none';
        }
      });
      
      // Update UI Counters
      resultsCount.textContent = `${visibleCount} término${visibleCount !== 1 ? 's' : ''}`;
      noResults.style.display = visibleCount === 0 ? 'block' : 'none';
    }

    searchInput.addEventListener('input', (e) => {
      currentSearch = e.target.value.trim();
      filterItems();
    });

    letterBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        // Remover clase activa de todos
        letterBtns.forEach(b => b.classList.remove('active'));
        // Agregar activa al que se clickeó
        e.target.classList.add('active');
        
        // Actualizar filtro
        currentLetter = e.target.getAttribute('data-letter');
        
        // UX Fix: Limpiar la búsqueda textual al cambiar de letra para no dejarlo en 0 resultados ocultos
        if (searchInput) {
          searchInput.value = '';
          currentSearch = '';
        }
        
        filterItems();
      });
    });
  });
</script>
