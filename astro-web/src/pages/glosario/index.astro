---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroComercial from '../../components/ui/HeroComercial.astro';
import { getCollection } from 'astro:content';
import { r } from '../../utils/paths';

const terms = await getCollection('glosario');
terms.sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<BaseLayout 
  title="Glosario e-learning | TAEC"
  description="Diccionario de referencia para profesionales de L&D en LATAM. Términos de plataformas, estándares y tecnología educativa."
  section="Recursos"
  page="glosario.html"
>
  <HeroComercial 
    eyebrow="TAEC · Recursos"
    titleHtml="Glosario <br/> <span class='text-accent'>e-learning</span>"
    subtitle="Diccionario de referencia para profesionales de L&D en LATAM. Términos de plataformas, estándares, metodologías y tecnología educativa."
    theme="general"
  />

  <main style="max-width: 1080px; margin: 64px auto; padding: 0 24px 80px;">
    <div style="display: flex; align-items: baseline; justify-content: space-between; border-bottom: 2px solid #1c1917; padding-bottom: 10px; margin-bottom: 32px;">
      <h2 style="font-family: var(--font-display, Georgia, serif); font-size: 1.5rem; font-weight: 700;">Índice alfabético</h2>
      <span style="font-family: monospace; font-size: 11px; color: #78716c; text-transform: uppercase;">{terms.length} términos</span>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
      {terms.map(term => (
        <a href={r(`/glosario/${term.id.replace(/\.mdx?$/, '')}`)} style="text-decoration: none; color: inherit; display: block;">
          <article style="background: #ffffff; border: 1px solid #e7e3db; padding: 20px 24px; border-radius: 8px; box-shadow: 0 1px 4px rgba(0,0,0,0.07); height: 100%; transition: transform 0.2s, box-shadow 0.2s;">
            <div style="font-family: monospace; font-size: 10px; color: #1d4ed8; text-transform: uppercase; margin-bottom: 6px;">
              {term.data.category || 'Término'}
            </div>
            <h3 style="font-family: var(--font-body, sans-serif); font-size: 0.95rem; font-weight: 700; margin-bottom: 8px; line-height: 1.35; color: #1c1917;">
              {term.data.title}
            </h3>
            <p style="font-size: 13px; color: #44403c; line-height: 1.5; margin-bottom: 14px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
              {term.data.description}
            </p>
            <span style="font-family: monospace; font-size: 11px; text-transform: uppercase; color: #1d4ed8; font-weight: 600;">Ver definición &rarr;</span>
          </article>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>
