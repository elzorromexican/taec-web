<script>
// ── Precios base ──
const PRICES = {
  personal: { std: '1,299', ai: '1,549', mxn_std: '~$26,500 MXN', mxn_ai: '~$31,600 MXN' },
  teams: {
    std:      '1,499', mxn_std:   'Nueva suscripción',
    ai:       '1,749', mxn_ai:    'Nueva suscripción',
    promo:    '1,198', mxn_promo: 'Promo Q2 · Nueva suscripción'
  }
};

let aiActive = false;
let isMexico = false;

// ── Helpers ──
function el(id: string): HTMLElement | null {
  return document.getElementById(id) as HTMLElement | null;
}
function setText(id: string, val: string) {
  const node = el(id); if (node) node.textContent = val;
}
function setDisplay(id: string, display: string) {
  const node = el(id); if (node) node.style.display = display;
}

// ── Geo-detection & Session ──
async function initSession() {
  const savedToggle = sessionStorage.getItem('aiToggle');
  const savedGeo = sessionStorage.getItem('isMexico');

  if (savedToggle !== null && savedGeo !== null) {
    aiActive = savedToggle === 'true';
    isMexico = savedGeo === 'true';
    if (aiActive) activateAI(aiActive);
  } else {
    try {
      const res  = await fetch('/api/get-promo?path=articulate');
      const data = await res.json() as { countryCode: string, promo?: { id: string } };
      isMexico = data.countryCode === 'MX';
      sessionStorage.setItem('isMexico', String(isMexico));
      if (data.promo?.id === 'art-teams-ai-q2-mx') {
        activateAI(true);
      }
    } catch (_) { }
  }
}

// ── Toggle principal (llamado desde onclick en HTML) ──
function toggleAI() { activateAI(!aiActive); }

function activateAI(state: boolean) {
  aiActive = state;
  sessionStorage.setItem('aiToggle', String(aiActive));

  // Toggle visual
  const knob   = el('toggleKnob');
  const btn    = el('aiToggle');
  const lblStd = el('label-std');
  const lblAi  = el('label-ai');

  if (knob)   knob.style.left       = aiActive ? '28px' : '4px';
  if (btn)  { btn.style.background  = aiActive ? 'var(--blue)' : 'var(--border)';
              btn.setAttribute('aria-pressed', String(aiActive)); }
  if (lblStd) lblStd.style.color    = aiActive ? 'var(--muted)' : 'var(--navy)';
  if (lblAi)  lblAi.style.color     = aiActive ? 'var(--navy)'  : 'var(--muted)';

  // Precios Personal
  setText('price-personal', aiActive ? PRICES.personal.ai    : PRICES.personal.std);
  setText('mxn-personal',   aiActive ? PRICES.personal.mxn_ai : PRICES.personal.mxn_std);

  // Precios Teams
  const teamsPromo = aiActive && isMexico;
  setText('price-teams', teamsPromo ? PRICES.teams.promo    : (aiActive ? PRICES.teams.ai    : PRICES.teams.std));
  setText('mxn-teams',   teamsPromo ? PRICES.teams.mxn_promo : (aiActive ? PRICES.teams.mxn_ai : PRICES.teams.mxn_std));

  // AI features
  setDisplay('ai-feature-personal', aiActive    ? 'flex'  : 'none');
  setDisplay('ai-feature-teams',    aiActive    ? 'flex'  : 'none');

  // Promo MX
  setDisplay('promo-ribbon-teams',   teamsPromo ? 'block' : 'none');
  setDisplay('price-teams-original', teamsPromo ? 'block' : 'none');
  setDisplay('promo-chip-teams',     teamsPromo ? 'block' : 'none');
  
  // Apagar visualmente las otras tarjetas
  const cardPersonal = document.getElementById('card-personal');
  const cardTrial = document.getElementById('card-trial');
  
  if (cardPersonal) {
    cardPersonal.style.opacity = teamsPromo ? '0.4' : '1';
    cardPersonal.style.filter = teamsPromo ? 'grayscale(0.8)' : 'none';
  }
  if (cardTrial) {
    cardTrial.style.opacity = teamsPromo ? '0.4' : '1';
    cardTrial.style.filter = teamsPromo ? 'grayscale(0.8)' : 'none';
  }

  // Mostrar barra MX solo cuando hay promo activa
  const barMx = el('bar-promo-mx');
  if (barMx) barMx.style.display = (aiActive && isMexico) ? 'block' : 'none';
}

// ── Init ──
function initializeFeatures() {
  const btn = el('aiToggle');
  if (btn && !btn.hasAttribute('data-init')) {
    btn.addEventListener('click', toggleAI);
    btn.setAttribute('data-init', 'true');
  }
  initSession();
}

document.addEventListener('astro:page-load', initializeFeatures);
</script>

