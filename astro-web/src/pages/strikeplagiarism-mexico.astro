---
import { getBookingUrl } from "../data/contact";
// CHANGELOG: 2026-03-20 - Landing StrikePlagiarism completa. Contenido basado en doc estratégico DDC.
import ProductPageLayout from "../layouts/ProductPageLayout.astro";
import { r } from "../utils/paths";

const bookingUrl = getBookingUrl();

const beneficios = [
	{
		icon: "🤖",
		title: "Detección de IA en español >99% precisión",
		description:
			"Identifica contenido generado por IA en más de 30 idiomas. En español: precisión superior al 99% con menos del 1% de falsos positivos — dato publicado por el proveedor.",
	},
	{
		icon: "🌐",
		title: "Bases de datos globales y repositorios",
		description:
			"Comparación contra revistas científicas, repositorios institucionales, publicaciones académicas, fuentes abiertas de internet y archivos internos de la institución.",
	},
	{
		icon: "🔗",
		title: "Integración nativa con LMS vía LTI 1.3",
		description:
			"Conexión directa con Canvas, Blackboard, Moodle, Brightspace y OJS. El flujo de entrega y revisión no sale del LMS — sin cambiar procesos existentes.",
	},
	{
		icon: "🔒",
		title: "RGPD, ISO 27001 y opción on-premise",
		description:
			"Servidores en la Unión Europea, cifrado SSL, certificación ISO/IEC 27001:2022. Para instituciones con requisitos estrictos de privacidad: opción de instalación on-premise.",
	},
];

const capacidades = [
	{
		icon: "📊",
		label: "Informe de similitud interactivo",
		desc: "Coeficientes por fuente, desglose de coincidencias, análisis de citas, alertas de parafraseo y manipulación detectada.",
	},
	{
		icon: "🤖",
		label: "Detección de contenido IA",
		desc: "Más de 30 idiomas. En español: >99% precisión, <1% falsos positivos. Identificación de texto generado por herramientas como ChatGPT.",
	},
	{
		icon: "🌐",
		label: "Verificación en múltiples bases de datos",
		desc: "Revistas científicas, repositorios, publicaciones, fuentes de internet y archivos institucionales propios.",
	},
	{
		icon: "🔗",
		label: "LTI 1.3 — integración con LMS",
		desc: "Canvas, Blackboard, Moodle, Brightspace, OJS. El proceso de entrega no sale del LMS habitual.",
	},
	{
		icon: "📋",
		label: "Gestión de asignaciones",
		desc: "Configura reglas de entrega, plazos, permisos y acceso al informe por alumno o institución.",
	},
	{
		icon: "🪪",
		label: "LDAP y SSO",
		desc: "Autenticación centralizada integrada con el directorio institucional — sin cuentas adicionales.",
	},
	{
		icon: "🏗️",
		label: "Opción on-premise",
		desc: "Instalación en servidores propios para instituciones con políticas estrictas de soberanía de datos.",
	},
	{
		icon: "🌍",
		label: "Soporte en +15 idiomas",
		desc: "Interfaz, informes y soporte disponible en más de 15 idiomas, incluido español.",
	},
];

const pasos = [
	{
		num: "01",
		title: "El alumno entrega su trabajo",
		desc: "Desde el LMS habitual (Canvas, Moodle, etc.) o directamente en StrikePlagiarism. El proceso no cambia para el alumno.",
	},
	{
		num: "02",
		title: "El sistema analiza el documento",
		desc: "Comparación contra bases de datos globales, repositorios y archivos internos. Detección simultánea de similitud, parafraseo y posible contenido generado por IA.",
	},
	{
		num: "03",
		title: "El revisor obtiene el informe",
		desc: "Informe interactivo con coeficiente de similitud, fuentes identificadas, fragmentos marcados, análisis de citas y alertas de manipulación. Disponible en minutos.",
	},
	{
		num: "04",
		title: "Decisión con respaldo documental",
		desc: "El informe es exportable y está disponible como evidencia para apelaciones, comités académicos o auditorías editoriales.",
	},
];

const faqs = [
	{
		question: "¿StrikePlagiarism detecta contenido generado por ChatGPT o IA?",
		answerHtml:
			"Sí. StrikePlagiarism incluye <strong>detección de contenido generado por IA</strong> en más de 30 idiomas. En español, el proveedor publica una precisión superior al 99% con menos del 1% de falsos positivos. Es uno de sus diferenciadores más relevantes dado el contexto actual.",
	},
	{
		question: "¿En qué se diferencia de Turnitin?",
		answerHtml:
			"Las diferencias principales: <strong>precio más accesible</strong> para instituciones latinoamericanas, <strong>opción on-premise</strong> (Turnitin no la ofrece), <strong>servidores en la UE</strong> con cumplimiento RGPD, y soporte comercial y técnico en español con presencia local en LATAM a través de TAEC.",
	},
	{
		question: "¿Funciona con Moodle?",
		answerHtml:
			"Sí. StrikePlagiarism tiene integración nativa vía <strong>LTI 1.3</strong> con Moodle, Canvas, Blackboard, Brightspace y OJS. El alumno entrega desde el LMS habitual y el instructor recibe el informe directamente en la misma plataforma.",
	},
	{
		question: "¿Los documentos de los alumnos quedan almacenados?",
		answerHtml:
			"Depende de la configuración. Por defecto, los documentos pueden agregarse al repositorio institucional para comparaciones futuras — una práctica estándar en plataformas de integridad académica. Para instituciones con requisitos de privacidad específicos, existe la <strong>opción on-premise</strong> con control total de los datos.",
	},
	{
		question: "¿Solo sirve para universidades?",
		answerHtml:
			"No. Además de educación superior, StrikePlagiarism sirve para <strong>editoriales y publicaciones científicas</strong> (verificación pre-publicación), <strong>centros de investigación</strong>, <strong>organismos certificadores</strong> con producción de materiales y <strong>organizaciones con LMS</strong> que requieren integridad en evaluaciones escritas.",
	},
	{
		question: "¿TAEC puede implementar StrikePlagiarism en México?",
		answerHtml:
			"Sí. TAEC acompaña desde la evaluación de la necesidad, la integración con tu LMS, la configuración de políticas de integridad y la capacitación del equipo académico. Soporte en español y seguimiento cercano en horario CDMX.",
	},
];
---

<ProductPageLayout
  meta={{
    title: "StrikePlagiarism en México | Integridad académica, similitud e IA | TAEC",
    description: "StrikePlagiarism con TAEC: detección de similitud, parafraseo y contenido generado por IA. Integración con Moodle, Canvas y Blackboard. Más de 1,500 instituciones. Demo en español.",
    page: "strikeplagiarism-mexico.html"
  }}
  hero={{
    eyebrow: "StrikePlagiarism · Integridad académica",
    titleHtml: `Integridad académica con más evidencia<br>y <em>menos adivinanza</em>`,
    subtitle: "StrikePlagiarism ayuda a detectar similitud, parafraseo avanzado y posible contenido generado por IA — con informes claros, integración con LMS y evidencia lista para usar.",
    features: [
      "Detección de IA en español: >99% precisión, <1% falsos positivos",
      "Comparación contra bases de datos globales y repositorios",
      "Integración nativa LTI 1.3 — Moodle, Canvas, Blackboard, Brightspace",
      "Más de 1,500 organizaciones en el mundo",
      "RGPD · ISO/IEC 27001:2022 · Opción on-premise",
      "Implementación y soporte en español · CDMX"
    ],
    primaryBtn: { label: "Solicitar demo →", url: bookingUrl, target: "_blank" },
    secondaryBtn: { label: "Hablar con un especialista", url: getBookingUrl('strikeplagiarism') },
    cardBadgeText: "INTEGRIDAD ACADÉMICA · IA · LMS",
    cardLogoSrc: r("/assets/logos/strikeplagiarism-icon.png"),
    theme: "general",
    brandColor: "#7f1933"
  }}
  beneficios={{
    eyebrow: "Por qué StrikePlagiarism con TAEC",
    title: "Evidencia real para decisiones serias",
    subtitle: "Para instituciones y organizaciones que necesitan que su proceso de revisión sea robusto, trazable y defendible.",
    cards: beneficios,
    columns: 2,
    theme: "general"
  }}
  faqs={{
    eyebrow: "Preguntas frecuentes",
    title: "Todo sobre StrikePlagiarism en México",
    faqs: faqs,
    theme: "general"
  }}
  cta={{
    title: "¿Listo para construir un proceso de integridad con respaldo real?",
    subtitle: "Agenda una demo con nuestro equipo en CDMX. Te mostramos StrikePlagiarism con casos reales de instituciones en México y LATAM — sin costo, sin compromiso.",
    primaryBtnText: "Solicitar demo →",
    primaryBtnUrl: bookingUrl,
    primaryBtnTarget: "_blank",
    theme: "general"
  }}
>

  <!-- ── EL PROBLEMA ── -->
  <section class="pp-section pp-section-alt">
    <div class="pp-section-inner">
      <p class="pp-section-label">El reto real</p>
      <h2 class="pp-section-title">El problema no es solo encontrar texto parecido.<br>El problema es sostener una política seria de integridad.</h2>
      <p class="pp-section-sub">El contexto cambió. Más entregas digitales, parafraseo sofisticado y herramientas de IA generativa cambiaron la naturaleza del problema — y el nivel de evidencia que se necesita para tomar decisiones.</p>
      <div class="pp-grid-3">
        <div class="pp-card">
          <span class="pp-card-icon">✍️</span>
          <h3 class="pp-card-title">Parafraseo que los detectores básicos no capturan</h3>
          <p class="pp-card-desc">Cambiar sinónimos o reordenar oraciones ya no es la técnica más común. Los detectores que solo buscan coincidencias textuales son insuficientes para el nivel actual de sofisticación.</p>
        </div>
        <div class="pp-card">
          <span class="pp-card-icon">🤖</span>
          <h3 class="pp-card-title">IA generativa como nuevo estándar del fraude</h3>
          <p class="pp-card-desc">Texto generado por ChatGPT u otras herramientas tiene baja similitud con fuentes existentes — un detector de similitud solo no es suficiente para identificarlo con precisión.</p>
        </div>
        <div class="pp-card">
          <span class="pp-card-icon">⚖️</span>
          <h3 class="pp-card-title">Decisiones sin evidencia defendible</h3>
          <p class="pp-card-desc">Sin un informe documentado y trazable, las apelaciones de los alumnos son difíciles de resolver. La integridad académica necesita el mismo rigor documental que cualquier proceso formal.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CÓMO FUNCIONA ── -->
  <section class="pp-section pp-section-dark">
    <div class="pp-section-inner">
      <p class="pp-section-label">Proceso</p>
      <h2 class="pp-section-title pp-section-title--light">Cómo funciona StrikePlagiarism</h2>
      <div class="pp-grid-4">
        {pasos.map(p => (
          <div class="pp-card pp-card--dark">
            <span class="pp-card-num">{p.num}</span>
            <h3 class="pp-card-title pp-card-title--light">{p.title}</h3>
            <p class="pp-card-desc pp-card-desc--light">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CAPACIDADES ── -->
  <section class="pp-section">
    <div class="pp-section-inner">
      <p class="pp-section-label">Capacidades clave</p>
      <h2 class="pp-section-title">Un sistema de integridad completo, no solo un detector</h2>
      <div class="pp-grid-4">
        {capacidades.map(c => (
          <div class="pp-card">
            <span class="pp-card-icon">{c.icon}</span>
            <h3 class="pp-card-title">{c.label}</h3>
            <p class="pp-card-desc">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PERFIL IDEAL ── -->
  <section class="pp-section pp-section-alt">
    <div class="pp-section-inner">
      <p class="pp-section-label">¿Para quién es?</p>
      <h2 class="pp-section-title">StrikePlagiarism encaja cuando la integridad del contenido es parte del proceso</h2>
      <div class="pp-grid-3">
        <div class="perfil-col">
          <h3>Casos de uso principales</h3>
          <ul>
            <li>Educación superior — tesis, trabajos finales y evaluaciones escritas</li>
            <li>Editoriales y publicaciones científicas — verificación pre-publicación</li>
            <li>Certificación y evaluación formal con producción de materiales</li>
            <li>Instituciones con LMS que requieren integridad en entregas</li>
            <li>Organizaciones con alta exigencia de privacidad y soberanía de datos</li>
          </ul>
        </div>
        <div class="perfil-col">
          <h3>Perfil de organización ideal</h3>
          <ul>
            <li>Universidades con procesos formales de revisión académica</li>
            <li>Editoriales académicas y centros de investigación</li>
            <li>Organismos certificadores con materiales producidos externamente</li>
            <li>Instituciones con LMS que buscan flujo integrado de entrega y revisión</li>
            <li>Más de 1,500 organizaciones en el mundo ya lo usan</li>
          </ul>
        </div>
        <div class="perfil-col perfil-col--taec">
          <h3>Lo que TAEC hace por ti</h3>
          <ul>
            <li>Evaluación de la necesidad y política de integridad</li>
            <li>Integración con tu LMS actual (Moodle, Canvas, etc.)</li>
            <li>Configuración de reglas y flujos de revisión</li>
            <li>Capacitación del equipo académico en español</li>
            <li>Soporte operativo en horario CDMX</li>
          </ul>
          <p class="perfil-cierre">No se trata de perseguir coincidencias. Se trata de construir un proceso de revisión más serio, más claro y más defendible.</p>
        </div>
      </div>
    </div>
  </section>

</ProductPageLayout>

<style is:global>
:root { --brand: #7f1933; }

.perfil-col h3 { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #94A3B8; margin-bottom: 16px; }
.perfil-col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
.perfil-col ul li { font-size: 14px; color: #374151; line-height: 1.5; padding-left: 18px; position: relative; }
.perfil-col ul li::before { content: "→"; position: absolute; left: 0; color: #7f1933; font-weight: 700; }
.perfil-col--taec { background: white; border: 1.5px solid #FCE7F3; border-radius: 14px; padding: 24px; }
.perfil-col--taec h3 { color: #7f1933; }
.perfil-cierre { margin-top: 20px; font-size: 13px; color: #9CA3AF; line-height: 1.7; font-style: italic; border-top: 1px solid #E2E8F0; padding-top: 16px; }
</style>
