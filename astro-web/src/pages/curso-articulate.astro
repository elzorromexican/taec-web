---
import { contactData } from '../data/contact';
import BaseLayout from '../layouts/BaseLayout.astro';

import { r } from '../utils/paths';
---

<BaseLayout 
  title="Articulate 360 — Diseño de Cursos Interactivos | TAEC"
  description="Aprende a crear cursos e-learning profesionales con Articulate 360. De cero a publicar en LMS en 2 días. Curso abierto virtual en vivo."
  section="Capacitación"
  page="curso-articulate.html"
>
  <style is:global>

  /* ── COURSE HERO ── */
    .course-hero {
      background: linear-gradient(135deg, #1a4a8a 0%, #3179C2 60%, #1a5fa8 100%);
      padding: 72px 5% 64px;
    }
    .course-hero-inner { max-width: 780px; margin: 0 auto; }
    .course-tag {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(255,255,255,.15); color: rgba(255,255,255,.9);
      font-size: 11px; font-weight: 700; letter-spacing: 1.5px;
      text-transform: uppercase; padding: 4px 14px; border-radius: 4px;
      margin-bottom: 24px;
    }
    .course-hero h1 {
      font-family: var(--font-display); font-size: 42px;
      color: var(--white); line-height: 1.15; margin-bottom: 20px;
    }
    .course-hero p {
      font-size: 18px; color: rgba(255,255,255,.82); line-height: 1.7; margin-bottom: 36px;
    }
    .course-badges { display: flex; gap: 12px; flex-wrap: wrap; }
    .course-badge {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.2);
      color: var(--white); font-size: 13px; font-weight: 600;
      padding: 6px 16px; border-radius: 100px;
    }

    /* ── COURSE CONTENT ── */
    .course-content { max-width: 1100px; margin: 0 auto; padding: 64px 5%; display: grid; grid-template-columns: 1fr 340px; gap: 48px; align-items: start; }
    @media (max-width: 900px) { .course-content { grid-template-columns: 1fr; } }

    .section-title { font-family: var(--font-display); font-size: 26px; color: var(--navy); margin-bottom: 24px; }
    .modules-list { list-style: none; display: flex; flex-direction: column; gap: 12px; margin-bottom: 48px; }
    .modules-list li {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 14px 18px; background: var(--light); border-radius: 10px;
      font-size: 14px; font-weight: 500; color: var(--text);
      border-left: 3px solid var(--accent);
    }
    .modules-list li::before {
      content: counter(module-counter);
      counter-increment: module-counter;
      display: flex; align-items: center; justify-content: center;
      min-width: 24px; height: 24px; background: var(--accent);
      color: white; font-size: 12px; font-weight: 700;
      border-radius: 50%; flex-shrink: 0; margin-top: 1px;
    }
    .modules-list { counter-reset: module-counter; }

    /* ── DETAILS CARD ── */
    .details-card {
      background: var(--white); border: 1px solid var(--border);
      border-radius: 16px; padding: 28px; box-shadow: 0 4px 24px rgba(0,0,0,.07);
      position: sticky; top: 88px;
    }
    .details-card h3 { font-family: var(--font-display); font-size: 20px; color: var(--navy); margin-bottom: 20px; }
    .detail-row { display: flex; align-items: flex-start; gap: 10px; padding: 10px 0; border-bottom: 1px solid var(--border); }
    .detail-row:last-of-type { border-bottom: none; }
    .detail-icon { font-size: 18px; flex-shrink: 0; width: 24px; text-align: center; }
    .detail-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .7px; color: var(--muted); display: block; margin-bottom: 2px; }
    .detail-value { font-size: 14px; font-weight: 600; color: var(--text); }

    .cta-buttons { display: flex; flex-direction: column; gap: 10px; margin-top: 24px; }
    .btn-primary-full { display: block; text-align: center; background: var(--orange); color: var(--white); padding: 14px 20px; border-radius: 9px; font-weight: 700; font-size: 15px; transition: background .15s; }
    .btn-primary-full:hover { background: #d97b0e; }
    .btn-wa-full { display: flex; align-items: center; justify-content: center; gap: 8px; background: #25D366; color: var(--white); padding: 13px 20px; border-radius: 9px; font-weight: 700; font-size: 14px; transition: background .15s; }
    .btn-wa-full:hover { background: #1ebe5c; }
    .btn-wa-full svg { width: 18px; height: 18px; fill: white; flex-shrink: 0; }
  

      .levels-row { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 40px; }
      .level-pill { display: inline-flex; align-items: center; justify-content: center; padding: 10px 20px; background: var(--light); border: 2px solid var(--blue); border-radius: 100px; font-size: 14px; font-weight: 700; color: var(--blue); transition: background .15s, color .15s; }
      .level-pill:hover { background: var(--blue); color: var(--white); }
      .ai-block { background: #EFF6FF; border: 1px solid #BFDBFE; border-radius: 12px; padding: 20px 24px; margin-bottom: 40px; }
      .ai-block h3 { font-size: 15px; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
      .ai-block p { font-size: 14px; color: var(--dark); line-height: 1.65; }
    
  </style>

<main id="main-content">

<!-- ══ HERO ══ -->
<section class="course-hero">
  <div class="course-hero-inner">
    <span class="course-tag">Capacitación Abierta</span>
    <h1>Articulate 360 — Cursos Certificados</h1>
    <p>Te enseñamos a utilizar todas las herramientas incluidas en Articulate 360. Aprenderás a dominar la suite completa de la mano de expertos. Descubre los secretos para sacarle el máximo provecho a Articulate 360 y crea cursos e-learning sobresalientes.</p>
    <div class="course-badges">
      <span class="course-badge">💻 On-line</span>
      <span class="course-badge">📊 Varios niveles</span>
      <span class="course-badge">📋 Temario disponible</span>
    </div>
  </div>
</section>

<!-- ══ CONTENT ══ -->
<div class="course-content">
  <div>
    <h2 class="section-title">Niveles disponibles</h2>
    <style>
      .levels-row { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 40px; }
      .level-pill { display: inline-flex; align-items: center; justify-content: center; padding: 10px 20px; background: var(--light); border: 2px solid var(--blue); border-radius: 100px; font-size: 14px; font-weight: 700; color: var(--blue); transition: background .15s, color .15s; }
      .level-pill:hover { background: var(--blue); color: var(--white); }
      .ai-block { background: #EFF6FF; border: 1px solid #BFDBFE; border-radius: 12px; padding: 20px 24px; margin-bottom: 40px; }
      .ai-block h3 { font-size: 15px; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
      .ai-block p { font-size: 14px; color: var(--dark); line-height: 1.65; }
    </style>
    <div class="levels-row">
      <span class="level-pill">Básico</span>
      <span class="level-pill">Avanzado</span>
      <span class="level-pill">Experto</span>
      <span class="level-pill">Rise 360+</span>
      <span class="level-pill">Completo</span>
    </div>

    <div class="ai-block">
      <h3>Creación de contenidos con IA — Articulate 360 AI Assistant</h3>
      <p>Crea cursos en línea hasta 9 veces más rápido con IA integrada en Rise y Storyline. Aprende a usar las funciones de inteligencia artificial para acelerar la producción de contenidos e-learning sin sacrificar calidad.</p>
    </div>

    <h2 class="section-title">¿Qué aprenderás?</h2>
    <ul class="modules-list">
      <li>Storyline 360: interfaz, diapositivas, capas, estados y timeline</li>
      <li>Variables, triggers y lógica interactiva</li>
      <li>Rise 360: cursos tipo web responsivos</li>

      <li>Content Library 360: assets profesionales</li>
      <li>Peek 360: capturas rápidas de pantalla</li>
      <li>Articulate 360 AI Assistant: producción acelerada con IA</li>
      <li>Exportación SCORM/xAPI y publicación en LMS</li>
    </ul>
  </div>

  <div>
    <div class="details-card">
      <h3>Detalles del curso</h3>
      <div class="detail-row">
        <span class="detail-icon">💻</span>
        <div>
          <span class="detail-label">Formato</span>
          <span class="detail-value">On-line</span>
        </div>
      </div>
      <div class="detail-row">
        <span class="detail-icon">📊</span>
        <div>
          <span class="detail-label">Niveles</span>
          <span class="detail-value">Básico · Avanzado · Experto · Rise 360+ · Completo</span>
        </div>
      </div>
      <div class="detail-row">
        <span class="detail-icon">📋</span>
        <div>
          <span class="detail-label">Temario</span>
          <span class="detail-value">Disponible por nivel</span>
        </div>
      </div>
      <div class="detail-row">
        <span class="detail-icon">🏆</span>
        <div>
          <span class="detail-label">Certificado</span>
          <span class="detail-value">Certificado TAEC digital</span>
        </div>
      </div>
      <div class="cta-buttons">
        <a href={r('/contacto')} class="btn-primary-full">Ver temario / Inscribirme →</a>
        <a href={contactData.whatsapp.url} target="_blank" rel="noopener noreferrer" class="btn-wa-full">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          WhatsApp
        </a>
      </div>
    </div>
  </div>
</div>

</main>
</BaseLayout>
