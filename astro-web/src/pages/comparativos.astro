---
import BaseLayout from '../layouts/BaseLayout.astro';

import { r } from '../utils/paths';
---

<BaseLayout 
  title="Comparativos de herramientas e-learning – Articulate, Vyond y más | TAEC"
  description="Tablas de comparación detalladas entre herramientas e-learning: Articulate 360 vs Captivate vs iSpring, Vyond vs Camtasia vs Genially. Para tomar decisiones de compra informadas."
  section="Soluciones"
  page="comparativos.html"
>
  <style is:global>

    .nav-item::after { display: none !important; }
    .nav-item.open > .mega-menu { display: grid !important; }
    .nav-item.open > .simple-dropdown { display: grid !important; }
    .nav-item.open > .nav-link { background: var(--light); color: var(--blue); }
    .nav-item.open > .nav-link svg { transform: rotate(180deg); }

    /* ── HERO ── */
    .glo-hero { background: linear-gradient(135deg, #001f3d 0%, #004775 60%, #0077b6 100%); padding: 56px 5% 64px; color: white; }
    .glo-hero-inner { max-width: 1100px; margin: 0 auto; }
    .glo-breadcrumb { font-size: 13px; color: rgba(255,255,255,.5); margin-bottom: 20px; }
    .glo-breadcrumb a { color: rgba(255,255,255,.5); transition: color .15s; }
    .glo-breadcrumb a:hover { color: white; }
    .glo-breadcrumb span { margin: 0 6px; }
    .glo-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--teal); margin-bottom: 12px; }
    .glo-hero h1 { font-family: var(--font-display); font-size: clamp(28px, 3.5vw, 44px); font-weight: 400; color: white; line-height: 1.2; margin-bottom: 12px; }
    .glo-hero-sub { font-size: 16px; color: rgba(255,255,255,.7); max-width: 560px; }

    /* ── CONTROLES ── */
    .glo-controls { background: var(--white); border-bottom: 1px solid var(--border); padding: 20px 5%; position: sticky; top: 68px; z-index: 100; }
    .glo-controls-inner { max-width: 1100px; margin: 0 auto; display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
    .glo-search { flex: 1; min-width: 200px; position: relative; }
    .glo-search input { width: 100%; border: 1.5px solid var(--border); border-radius: 8px; padding: 10px 16px 10px 40px; font-size: 14px; font-family: var(--font-body); color: var(--text); background: var(--light); outline: none; transition: border-color .15s; }
    .glo-search input:focus { border-color: var(--blue); background: white; }
    .glo-search svg { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: #94A3B8; pointer-events: none; }
    .glo-count { font-size: 13px; color: #64748B; white-space: nowrap; flex-shrink: 0; }

    /* ── COMPARATIVOS MAIN ── */
    .comp-main { padding: 40px 5% 72px; }
    .comp-main-inner { max-width: 960px; margin: 0 auto; }

    /* ── COMP CARD ── */
    .comp-card { border: 1.5px solid var(--border); border-radius: 12px; margin-bottom: 16px; overflow: hidden; transition: border-color .15s, box-shadow .15s; }
    .comp-card:hover { border-color: #CBD5E1; box-shadow: 0 4px 16px rgba(0,0,0,.06); }
    .comp-card-header { padding: 18px 22px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; background: var(--white); }
    .comp-card-header:hover { background: var(--light); }
    .comp-card-meta { display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0; }
    .comp-card-title { font-size: 16px; font-weight: 700; color: var(--text); }
    .comp-card-badge { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; background: #EFF6FF; color: var(--blue); border: 1px solid #BFDBFE; border-radius: 4px; padding: 2px 7px; white-space: nowrap; flex-shrink: 0; }
    .comp-card-toggle { width: 28px; height: 28px; border-radius: 7px; border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 18px; color: var(--blue); flex-shrink: 0; transition: all .2s; font-weight: 400; line-height: 1; }
    .comp-card.open .comp-card-toggle { background: var(--navy); color: white; border-color: var(--navy); transform: rotate(45deg); }
    .comp-card-body { display: none; border-top: 1px solid var(--border); overflow-x: auto; }
    .comp-card.open .comp-card-body { display: block; }

    /* ── COMP TABLE ── */
    .comp-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .comp-table td, .comp-table th { padding: 10px 14px; border: 1px solid var(--border); }
    .comp-table th { background: var(--navy); color: white; font-size: 11px; letter-spacing: .5px; text-transform: uppercase; font-weight: 700; }
    .comp-table tr:nth-child(even) td { background: var(--light); }

    /* ── EMPTY ── */
    .glo-empty { text-align: center; padding: 64px 24px; display: none; }
    .glo-empty p { font-size: 15px; color: #94A3B8; }

    /* ── REC TABS ── */
    .rec-tabs{background:#F8FAFC;border-bottom:1px solid var(--border);padding:0 5%;overflow-x:auto}
    .rec-tabs-inner{max-width:1100px;margin:0 auto;display:flex;gap:0}
    .rec-tab{display:inline-flex;align-items:center;padding:14px 18px;font-size:13px;font-weight:600;color:#64748B;border-bottom:3px solid transparent;transition:color .15s,border-color .15s;white-space:nowrap;text-decoration:none}
    .rec-tab:hover{color:var(--blue)}
    .rec-tab.active{color:var(--navy);border-bottom-color:var(--navy)}
  
  </style>

<main id="main-content">

<!-- ══ HERO ══ -->
<section class="glo-hero">
  <div class="glo-hero-inner">
    <p class="glo-breadcrumb"><a href={r('/recursos')}>Recursos</a><span>›</span>Comparativos</p>
    <p class="glo-eyebrow">Comparativos</p>
    <h1>Compara las mejores herramientas e-learning</h1>
    <p class="glo-hero-sub">Tablas de análisis detalladas entre las principales soluciones del mercado. Criterios objetivos para que elijas con información.</p>
  </div>
</section>

<!-- ══ CONTROLES ══ -->
<div class="glo-controls">
  <div class="glo-controls-inner">
    <div class="glo-search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="search" id="compSearch" placeholder="Buscar comparativo…" aria-label="Buscar comparativo" />
    </div>
    <span class="glo-count" id="compCount"></span>
  </div>
</div>

<!-- ══ COMPARATIVOS ══ -->
<section class="comp-main">
  <div class="comp-main-inner" id="compContent">
    <!-- INICIO_COMPARATIVOS — generado por Apps Script -->
    <!-- FIN_COMPARATIVOS -->
  </div>
  <div class="glo-empty" id="compEmpty">
    <p>No se encontraron comparativos con ese criterio.</p>
  </div>
</section>

</main>
</BaseLayout>
