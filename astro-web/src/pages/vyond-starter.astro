---
import { getBookingUrl } from '../data/contact';
import { vendors } from '../data/vendors';
import { contactData } from '../data/contact';
import BaseLayout from '../layouts/BaseLayout.astro';

import { r, base } from '../utils/paths';
---

<BaseLayout 
  title="Vyond Starter en México — Crea videos animados con IA | TAEC"
  description="Empieza a crear videos animados para capacitación con Vyond Starter. Acceso a Vyond Go (IA), Studio y plantillas profesionales. Partner oficial en México."
  section="Soluciones"
  page="vyond-starter.html"
>
<style is:global>
  .plan-selector{background:#F8FAFC;padding:16px 5%;border-bottom:1px solid var(--border)}
  .plan-selector-inner{max-width:1100px;margin:0 auto;display:flex;gap:24px;align-items:center}
  .plan-tab{font-size:14px;font-weight:600;color:#64748B;padding-bottom:8px;border-bottom:2px solid transparent;position:relative;top:1px}
  .plan-tab.active{color:#C84D16;border-bottom-color:#C84D16}
  .plan-tab:hover:not(.active){color:#111827}
  .vp-hero{padding:80px 5%;color:white}
  .vp-hero-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:48px;align-items:center}
  .vp-logo-pill img{height:20px;width:auto}
  .vp-logo-pill{display:inline-block;background:white;padding:6px 16px;border-radius:20px;margin-bottom:16px}
  .vp-tag{display:inline-block;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:700;margin-bottom:16px}
  .vp-hero h1{font-size:clamp(32px,4vw,48px);font-weight:900;line-height:1.1;margin-bottom:20px}
  .vp-hero-sub{font-size:18px;color:rgba(255,255,255,.9);margin-bottom:32px;line-height:1.5}
  .vp-btns{display:flex;gap:16px;align-items:center}
  .btn-vp-primary{padding:12px 24px;border-radius:8px;font-weight:700;text-align:center}
  .btn-vp-ghost{padding:12px 24px;border-radius:8px;font-weight:700;color:white;border:1px solid rgba(255,255,255,.3);text-align:center}
  .vp-hero-card{background:rgba(0,0,0,.2);border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:32px}
  .vp-hero-feats{display:flex;flex-direction:column;gap:12px}
  .vp-feat{display:flex;align-items:flex-start;gap:10px;font-size:14px;color:rgba(255,255,255,.9)}
  .vp-feat-check{color:#FFCBA4;font-weight:700}
  .plan-cards{padding:80px 5%;background:#F8FAFC}
  .plan-cards-inner{max-width:1100px;margin:0 auto}
  .plan-cards-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:24px;margin-top:40px}
  .plan-card{background:white;border-radius:16px;padding:32px;border:1px solid var(--border);position:relative;display:flex;flex-direction:column}
  .plan-card.current{border-color:#C84D16;box-shadow:0 10px 30px rgba(0,0,0,.05)}
  .plan-card-badge{position:absolute;top:-12px;left:32px;background:#C84D16;color:white;font-size:11px;font-weight:800;padding:4px 12px;border-radius:20px;text-transform:uppercase}
  .plan-card-name{font-size:24px;font-weight:800;color:#111827;margin-bottom:8px}
  .plan-card-desc{font-size:14px;color:#64748B;margin-bottom:24px;padding-bottom:24px;border-bottom:1px solid var(--border)}
  .plan-card-feats{list-style:none;padding:0;margin:0 0 32px 0;display:flex;flex-direction:column;gap:12px;flex:1}
  .plan-card-feats li{position:relative;padding-left:24px;font-size:14px;color:#334155}
  .plan-card-feats li::before{content:"✓";position:absolute;left:0;color:#C84D16;font-weight:700}
  .plan-card-cta{text-align:center;padding:12px;border-radius:8px;font-weight:700;display:block}
  .plan-card-cta-primary{background:#111827;color:white}
  .plan-card-cta-outline{border:1px solid var(--border);color:#111827}
  .feat-section{padding:80px 5%;background:white}
  .feat-inner{max-width:1100px;margin:0 auto}
  .feat-title{font-size:32px;font-weight:800;color:#111827;text-align:center;margin-bottom:16px}
  .feat-sub{font-size:16px;color:#64748B;text-align:center;margin-bottom:48px;max-width:600px;margin-inline:auto}
  .feat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:32px}
  .feat-card{background:#F8FAFC;padding:24px;border-radius:12px}
  .feat-icon{font-size:32px;margin-bottom:16px}
  .feat-name{font-size:18px;font-weight:700;color:#111827;margin-bottom:8px}
  .feat-desc{font-size:14px;color:#475569;line-height:1.5}
  .usecase-section{padding:80px 5%;background:#F8FAFC}
  .usecase-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 2fr;gap:48px}
  .usecase-label{font-size:11px;font-weight:700;color:#C84D16;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}
  .usecase-title{font-size:32px;font-weight:800;color:#111827;margin-bottom:16px;line-height:1.1}
  .usecase-sub{font-size:16px;color:#64748B;line-height:1.5}
  .usecase-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
  .usecase-card{background:white;padding:24px;border-radius:12px;border:1px solid var(--border)}
  .usecase-card-title{font-size:16px;font-weight:700;color:#111827;margin-bottom:8px}
  .usecase-card-desc{font-size:14px;color:#64748B;line-height:1.5}
  .vp-cta{padding:80px 5%;background:linear-gradient(135deg,#1a0a00 0%,#3d1200 100%);text-align:center}
  .vp-cta h2{font-size:clamp(28px,3vw,36px);font-weight:800;color:white;margin-bottom:16px}
  .vp-cta p{font-size:18px;color:rgba(255,255,255,.8);margin-bottom:40px;max-width:600px;margin-inline:auto}
  .vp-cta-btns{display:flex;gap:16px;justify-content:center}
  .btn-cta-white{background:white;color:#C84D16;padding:14px 28px;border-radius:8px;font-weight:700;display:inline-block}
  .btn-cta-outline{border:2px solid rgba(255,255,255,.3);color:white;padding:14px 28px;border-radius:8px;font-weight:700;display:inline-block}
  @media(max-width:768px){.vp-hero-inner,.usecase-inner{grid-template-columns:1fr}.usecase-grid{grid-template-columns:1fr}}
</style>

<main id="main-content">

<!-- plan tabs -->
<div class="plan-selector">
  <div class="plan-selector-inner"><a href={r('/vyond-starter')} class="plan-tab  active">Vyond Starter</a>
<a href={r('/vyond-professional')} class="plan-tab">Vyond Professional</a>
<a href={r('/vyond-enterprise')} class="plan-tab">Vyond Enterprise</a></div>
</div>

<!-- hero -->
<section class="vp-hero" style="background:linear-gradient(135deg, #2d1200 0%, #7B2800 55%, #E86820 100%)">
  <div class="vp-hero-inner">
    <div>
      <div class="vp-logo-pill"><img src={`${base}assets/logos/vyond.svg`} alt="Vyond" /></div>
      <span class="vp-tag" style="background:rgba(200,77,22,.2);color:#FFCBA4">Plan de entrada · 1–5 usuarios</span>
      <h1>Crea tus primeros <em style="color:#FFCBA4">videos animados</em> con IA</h1>
      <p class="vp-hero-sub">El punto de partida ideal para diseñadores instruccionales y profesionales de L&D que quieren producir videos de capacitación sin experiencia previa en animación.</p>
      <div class="vp-btns">
        <a href={vendors.vyond.signup} class="btn-vp-primary" style="background:white;color:#E86820">Probar Vyond (15 días) →</a>
        <a href={getBookingUrl('vyond')} class="btn-vp-ghost">Hablar con un especialista</a>
      </div>
    </div>
    <div class="vp-hero-card">
      <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:#FFCBA4;margin-bottom:16px">Incluido en Vyond Starter</div>
      <div class="vp-hero-feats"><div class="vp-feat"><span class="vp-feat-check">✓</span><span>Acceso completo a Vyond Go con generación de video por IA</span></div>
<div class="vp-feat"><span class="vp-feat-check">✓</span><span>Vyond Studio — animación fotograma a fotograma</span></div>
<div class="vp-feat"><span class="vp-feat-check">✓</span><span>3,000 créditos de IA al mes incluidos</span></div>
<div class="vp-feat"><span class="vp-feat-check">✓</span><span>Exportación MP4 / GIF lista para cualquier LMS</span></div>
<div class="vp-feat"><span class="vp-feat-check">✓</span><span>Librería con 40,000+ props y personajes profesionales</span></div></div>
    </div>
  </div>
</section>

<!-- plan comparison -->
<section class="plan-cards">
  <div class="plan-cards-inner">
    <h2 style="font-size:22px;font-weight:800;color:#111827;margin-bottom:6px;text-align:center">Compara los planes Vyond</h2>
    <p style="text-align:center;color:#64748B;font-size:14px;margin-bottom:36px">Elige el plan que mejor se adapta al tamaño y necesidades de tu equipo</p>
    <div class="plan-cards-grid"><div class="plan-card current">
      <div class="plan-card-badge">Plan actual</div>
      <div class="plan-card-name">Vyond Starter</div>
      <div class="plan-card-desc">Desde USD $39 / usuario / mes</div>
      <ul class="plan-card-feats"><li>Vyond Go (IA)</li>
<li>Vyond Studio + Mobile</li>
<li>3,000 créditos IA/mes</li>
<li>Videos hasta 20 min</li></ul>
      <a href={vendors.vyond.signup} class="plan-card-cta plan-card-cta-primary">Probar Vyond (15 días)</a>
    </div>
<div class="plan-card">
      
      <div class="plan-card-name">Vyond Professional</div>
      <div class="plan-card-desc">Desde USD $55 / usuario / mes</div>
      <ul class="plan-card-feats"><li>Todo Starter incluido</li>
<li>5,000 créditos IA/mes</li>
<li>Colaboración de equipo</li>
<li>Videos hasta 40 min</li></ul>
      <a href={r('/vyond-professional')} class="plan-card-cta plan-card-cta-outline">Ver plan →</a>
    </div>
<div class="plan-card">
      
      <div class="plan-card-name">Vyond Enterprise</div>
      <div class="plan-card-desc">Precio personalizado — consultar</div>
      <ul class="plan-card-feats"><li>Todo Professional incluido</li>
<li>Créditos IA ilimitados</li>
<li>SSO / SCIM / API</li>
<li>Videos hasta 90 min</li></ul>
      <a href={r('/vyond-enterprise')} class="plan-card-cta plan-card-cta-outline">Ver plan →</a>
    </div></div>
  </div>
</section>

<!-- features -->
<section class="feat-section">
  <div class="feat-inner">
    <h2 class="feat-title">Todo lo que incluye Starter</h2>
    <p class="feat-sub">Las herramientas esenciales para empezar a producir videos animados de calidad profesional desde el primer día.</p>
    <div class="feat-grid"><div class="feat-card"><div class="feat-icon">🎬</div><div class="feat-name">Vyond Studio</div><div class="feat-desc">Editor completo de animación: personajes, escenas, fondos y texto animado con control total fotograma a fotograma.</div></div>
<div class="feat-card"><div class="feat-icon">🤖</div><div class="feat-name">Vyond Go — IA</div><div class="feat-desc">Genera videos animados completos desde texto en segundos. Incluye 3,000 créditos de IA mensuales.</div></div>
<div class="feat-card"><div class="feat-icon">📱</div><div class="feat-name">Vyond Mobile</div><div class="feat-desc">Crea y edita desde tu teléfono. Ideal para capturas de pantalla y videos rápidos de microlearning.</div></div>
<div class="feat-card"><div class="feat-icon">🎭</div><div class="feat-name">3 estilos de personaje</div><div class="feat-desc">Contemporary, Whiteboard y Business Friendly. Personaliza expresiones, ropa, accesorios y lip-sync automático.</div></div>
<div class="feat-card"><div class="feat-icon">🔊</div><div class="feat-name">Text-to-Speech</div><div class="feat-desc">Genera narración en más de 70 idiomas directamente desde el editor sin grabar audio manualmente.</div></div>
<div class="feat-card"><div class="feat-icon">📤</div><div class="feat-name">Exportación MP4 / GIF</div><div class="feat-desc">Archivos listos para SCORM, Articulate 360, Moodle, YouTube o cualquier plataforma corporativa.</div></div></div>
  </div>
</section>

<!-- use cases -->
<section class="usecase-section">
  <div class="usecase-inner">
    <div>
      <div class="usecase-label">¿Para quién?</div>
      <h2 class="usecase-title">¿Para quién es Vyond Starter?</h2>
      <p class="usecase-sub">Starter es perfecto para profesionales independientes y equipos pequeños que dan sus primeros pasos en la producción de video de capacitación.</p>
      <a href={r('/vyond-mexico')} style="display:inline-block;margin-top:20px;font-size:13px;font-weight:600;color:var(--vy)">← Ver todos los planes Vyond</a>
    </div>
    <div class="usecase-grid"><div class="usecase-card"><div class="usecase-card-title">🎓 Diseñadores instruccionales</div><div class="usecase-card-desc">Crea videos explicativos, micro-lecciones y escenarios interactivos sin necesidad de un equipo de producción.</div></div>
<div class="usecase-card"><div class="usecase-card-title">👩‍💼 Freelancers de e-learning</div><div class="usecase-card-desc">Ofrece producción de video como servicio adicional a tus clientes sin invertir en software costoso.</div></div>
<div class="usecase-card"><div class="usecase-card-title">🏫 Docentes y formadores</div><div class="usecase-card-desc">Produce materiales audiovisuales dinámicos para tus cursos presenciales y virtuales.</div></div>
<div class="usecase-card"><div class="usecase-card-title">🚀 Startups y PYMES</div><div class="usecase-card-desc">Comunica procesos, onboarding y procedimientos en video sin depender de agencias externas.</div></div></div>
  </div>
</section>

<!-- cta band -->
<section class="vp-cta">
  <h2>¿Listo para empezar con Vyond Starter?</h2>
  <p>Prueba gratis por 14 días o consulta con nuestro equipo la licencia anual con soporte en español.</p>
  <div class="vp-cta-btns">
    <a href={vendors.vyond.signup} class="btn-cta-white" style="color:#E86820">Probar Vyond (15 días) →</a>
    <a href={contactData.whatsapp.url} target="_blank" rel="noopener noreferrer" class="btn-cta-outline">WhatsApp TAEC</a>
  </div>
</section>

</main>
</BaseLayout>
