---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { r } from '../../utils/paths';

export async function getStaticPaths() {
  const cursos = await getCollection('cursos');
  return cursos.map((curso) => ({
    params: { slug: curso.id.replace(/\.mdx?$/, '') },
    props: { curso },
  }));
}

const { curso } = Astro.props;
const { Content } = await curso.render();

const TITLE = curso.data.titulo || curso.id;
const PRECIO = curso.data.precio_usd || 0;
const CATEGORIA = curso.data.categoria || 'Curso';
const DESC = curso.data.descripcion || 'Capacitación Oficial TAEC';
const IMAGE = curso.data.portada || '/images/cursos/default.webp';
---

<BaseLayout 
  title={`${TITLE} | Capacitación TAEC`}
  description={DESC}
  section="Cursos"
  page={`capacitacion/${curso.id}.html`}
>
  <div style="background: linear-gradient(135deg, var(--navy-slate) 0%, #1e293b 100%); padding: 80px 24px 64px; border-bottom: 1px solid #334155;">
    <div style="max-width: 1080px; margin: 0 auto;">
      <a href={r("/capacitacion/")} style="font-family: monospace; font-size: 13px; color: #94a3b8; text-decoration: none; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px; display: inline-flex; align-items: center; gap: 6px; margin-bottom: 32px; transition: color 0.2s;">
        &larr; Volver al Catálogo
      </a>
      
      <div style="display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 24px;">
        <span style="font-family: monospace; font-size: 12px; background: rgba(59, 130, 246, 0.15); color: #93c5fd; padding: 6px 12px; border-radius: 6px; font-weight: 800; text-transform: uppercase;">
          {CATEGORIA}
        </span>
        <span style="font-family: monospace; font-size: 12px; background: rgba(16, 185, 129, 0.15); color: #6ee7b7; padding: 6px 12px; border-radius: 6px; font-weight: 800; text-transform: uppercase;">
          Diploma Oficial
        </span>
      </div>

      <h1 style="font-family: var(--font-display, Georgia, serif); font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 800; color: #f8fafc; line-height: 1.1; margin-bottom: 24px; text-wrap: balance;">
        {TITLE}
      </h1>

      <p style="font-size: 1.15rem; color: #94a3b8; line-height: 1.6; max-width: 600px; margin-bottom: 40px; text-wrap: pretty;">
        {DESC}
      </p>

      <div style="display: flex; flex-wrap: wrap; gap: 24px; align-items: center; background: rgba(255,255,255,0.05); padding: 24px 32px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); max-width: max-content;">
        
        <div style="display: flex; flex-direction: column;">
          <span style="font-family: monospace; font-size: 12px; color: #94a3b8; text-transform: uppercase; margin-bottom: 4px;">Inversión:</span>
          <span style="font-size: 2rem; font-weight: 800; color: #ffffff;">
            ${PRECIO.toLocaleString()} <span style="font-size: 1rem; color: #64748b;">USD + IVA</span>
          </span>
        </div>

        <div style="width: 1px; height: 48px; background: rgba(255,255,255,0.1);"></div>

        <a href="https://tienda.taec.com.mx/" target="_blank" class="buy-btn" style="text-decoration: none; font-family: monospace; font-size: 14px; font-weight: 700; text-transform: uppercase; padding: 16px 32px; border-radius: 8px; background: linear-gradient(135deg, #3b82f6, #2563eb); color: #ffffff; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3); transition: all 0.3s ease;">
          Inscribirse Ahora &rarr;
        </a>
      </div>
    </div>
  </div>

  <main style="max-width: 1080px; margin: 0 auto; padding: 64px 24px; display: grid; grid-template-columns: 1fr 340px; gap: 64px; align-items: start;">
    
    <!-- CONTENIDO PRINCIPAL -->
    <article class="curso-content" style="background: #ffffff; padding: 48px; border-radius: 16px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);">
      <Content />
    </article>

    <!-- SIDEBAR DE ACCIONES -->
    <aside style="position: sticky; top: 120px;">
      
      <div style="background: #ffffff; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05); margin-bottom: 24px;">
        <div style="padding: 24px; background: #f8fafc; border-bottom: 1px solid #e2e8f0;">
          <h3 style="margin: 0; font-family: var(--font-display, Georgia, serif); font-size: 1.25rem; font-weight: 700; color: var(--navy-slate);">Recursos del Curso</h3>
        </div>
        
        <div style="display: flex; flex-direction: column;">
          
          <a href="#" class="sidebar-action" style="padding: 20px 24px; display: flex; align-items: center; gap: 16px; text-decoration: none; border-bottom: 1px solid #f1f5f9; color: #334155; transition: all 0.2s;">
            <div style="background: #eef2ff; color: #4f46e5; width: 40px; height: 40px; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
              <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            </div>
            <div>
              <strong style="display: block; font-size: 15px; margin-bottom: 2px;">Descargar Temario Oficial</strong>
              <span style="font-size: 13px; color: #64748b;">Archivo PDF detallado</span>
            </div>
          </a>

          <a href="https://www.taec.com.mx/calendario.php" target="_blank" class="sidebar-action" style="padding: 20px 24px; display: flex; align-items: center; gap: 16px; text-decoration: none; border-bottom: 1px solid #f1f5f9; color: #334155; transition: all 0.2s;">
            <div style="background: #fff7ed; color: #ea580c; width: 40px; height: 40px; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
              <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            </div>
            <div>
              <strong style="display: block; font-size: 15px; margin-bottom: 2px;">Ver Próximas Fechas</strong>
              <span style="font-size: 13px; color: #64748b;">Consultar calendario en vivo</span>
            </div>
          </a>
          
          <a href="#contacto" class="sidebar-action" style="padding: 20px 24px; display: flex; align-items: center; gap: 16px; text-decoration: none; color: #334155; transition: all 0.2s;">
            <div style="background: #f0fdf4; color: #16a34a; width: 40px; height: 40px; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
              <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
            </div>
            <div>
              <strong style="display: block; font-size: 15px; margin-bottom: 2px;">Hablar con Consultor</strong>
              <span style="font-size: 13px; color: #64748b;">Preguntas técnicas o a medida</span>
            </div>
          </a>

        </div>
      </div>
      
    </aside>

  </main>

</BaseLayout>

<style>
/* Markdown Styles para el Temario */
.curso-content h2 { font-family: var(--font-display, Georgia, serif); font-size: 1.75rem; color: var(--navy-slate); margin-top: 2.5rem; margin-bottom: 1rem; border-bottom: 2px solid #e2e8f0; padding-bottom: 8px; }
.curso-content h3 { font-family: var(--font-body, sans-serif); font-size: 1.25rem; color: #1e293b; margin-top: 2rem; margin-bottom: 0.75rem; font-weight: 800; }
.curso-content p { color: #475569; line-height: 1.7; font-size: 1.05rem; margin-bottom: 1.5rem; }
.curso-content ul { padding-left: 20px; color: #475569; margin-bottom: 2rem; }
.curso-content li { margin-bottom: 8px; line-height: 1.6; font-size: 1.05rem; }

/* Efectos Interactivos */
.buy-btn:hover { background: linear-gradient(135deg, #2563eb, #1d4ed8) !important; transform: translateY(-2px); box-shadow: 0 8px 20px rgba(37, 99, 235, 0.4) !important; }

.sidebar-action:hover { background: #f8fafc !important; }
.sidebar-action:hover strong { color: #2563eb !important; }
</style>
