---
// CHANGELOG: 2026-05-03 - Recortar título SEO a max 60 chars (Issue #216)
import { contactData, getBookingUrl } from "../data/contact";
import BaseLayout from "../layouts/BaseLayout.astro";

import { r } from "../utils/paths";
---

<BaseLayout 
  title="Nosotros | 18 años de e-learning en México | TAEC"
  description="TAEC: Tecnología Avanzada para la Educación y la Capacitación. Desde 2007 en CDMX, con oficinas en Bogotá y Santiago de Chile. +1,500 clientes en 17 países."
  section=""
  page="nosotros.html"
>
  <style is:global>

  /* ── HERO ── */
    .hero { background:linear-gradient(135deg, var(--navy) 0%, #00355a 100%); padding:72px 5% 80px; }
    .hero-inner { max-width:1200px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center; }
    .hero-tag { display:inline-flex; align-items:center; gap:8px; background:rgba(168,219,217,.15); color:var(--teal); font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; padding:4px 12px; border-radius:4px; margin-bottom:18px; }
    .hero h1 { font-family:var(--font-display); font-size:42px; line-height:1.15; color:var(--white); margin-bottom:16px; }
    .hero h1 em { color:var(--teal); font-style:normal; }
    .hero-sub { color:#94A3B8; font-size:16px; line-height:1.8; margin-bottom:10px; }
    .hero-razon { font-size:12px; color:rgba(168,219,217,.7); font-style:italic; margin-bottom:28px; }
    .hero-actions { display:flex; gap:12px; flex-wrap:wrap; }
    .btn-primary { display:inline-block; background:var(--orange); color:var(--white); padding:13px 26px; border-radius:8px; font-weight:700; font-size:14px; transition:background .15s; }
    .btn-primary:hover { background:#d97b0e; }
    .btn-ghost { display:inline-block; border:1.5px solid rgba(255,255,255,.3); color:var(--white); padding:13px 26px; border-radius:8px; font-weight:600; font-size:14px; transition:border-color .15s,background .15s; }
    .btn-ghost:hover { border-color:rgba(255,255,255,.6); background:rgba(255,255,255,.06); }
    .hero-card { background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1); border-radius:16px; padding:28px; }
    .hero-card-title { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1.5px; color:var(--teal); margin-bottom:20px; }
    .stat-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:20px; }
    .stat-box { background:rgba(255,255,255,.06); border-radius:10px; padding:16px; text-align:center; }
    .stat-box .num { font-family:var(--font-display); font-size:28px; color:var(--white); line-height:1; }
    .stat-box .lbl { font-size:11px; color:#94A3B8; margin-top:4px; }
    .offices-row { border-top:1px solid rgba(255,255,255,.08); padding-top:16px; display:flex; flex-direction:column; gap:8px; }
    .office-item { display:flex; align-items:center; gap:10px; font-size:13px; color:#CBD5E1; }
    .office-dot { width:8px; height:8px; border-radius:50%; background:var(--teal); flex-shrink:0; }

    /* ── STATS BAND ── */
    .stats-band { background:var(--light); padding:40px 5%; border-bottom:1px solid var(--border); }
    .stats-inner { max-width:1200px; margin:0 auto; display:grid; grid-template-columns:repeat(4,1fr); gap:24px; text-align:center; }
    .stat-item .n { font-family:var(--font-display); font-size:40px; color:var(--navy); line-height:1; }
    .stat-item .l { font-size:13px; color:var(--dark); margin-top:4px; }

    /* ── QUIÉNES SOMOS ── */
    .quienes { padding:80px 5%; }
    .quienes-inner { max-width:1200px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:start; }
    .section-label { font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:1.5px; color:var(--blue); margin-bottom:8px; }
    .section-title { font-family:var(--font-display); font-size:34px; color:var(--navy); margin-bottom:20px; line-height:1.2; }
    .body-text { font-size:15px; color:var(--dark); line-height:1.85; margin-bottom:16px; }
    .valores-grid { display:flex; flex-direction:column; gap:14px; }
    .valor-card { background:var(--light); border-radius:12px; padding:18px; display:flex; gap:14px; align-items:flex-start; }
    .valor-icon { font-size:22px; flex-shrink:0; width:42px; height:42px; display:flex; align-items:center; justify-content:center; background:var(--white); border-radius:10px; box-shadow:0 1px 4px rgba(0,0,0,.06); }
    .valor-text strong { display:block; font-size:14px; font-weight:700; color:var(--navy); margin-bottom:3px; }
    .valor-text span { font-size:13px; color:var(--dark); line-height:1.6; }

    /* ── MERCADOS ── */
    .mercados { background:var(--navy); padding:72px 5%; }
    .mercados-inner { max-width:1200px; margin:0 auto; }
    .mercados-inner .section-title { color:var(--white); }
    .mercados-inner .section-label { color:var(--teal); }
    .mercados-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:24px; margin-top:40px; }
    .mercado-card { background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1); border-radius:14px; padding:28px; }
    .mercado-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
    .mercado-icon { font-size:30px; }
    .mercado-pct { font-family:var(--font-display); font-size:32px; color:var(--teal); }
    .mercado-card h3 { font-size:16px; font-weight:700; color:var(--white); margin-bottom:8px; }
    .mercado-card p { font-size:13px; color:#94A3B8; line-height:1.7; }
    .mercado-bar { height:4px; background:rgba(255,255,255,.1); border-radius:2px; margin-top:16px; }
    .mercado-bar-fill { height:100%; border-radius:2px; background:var(--teal); }
    .mercado-tags { display:flex; flex-wrap:wrap; gap:6px; margin-top:12px; }
    .mercado-tag { font-size:11px; font-weight:600; background:rgba(168,219,217,.12); color:var(--teal); border:1px solid rgba(168,219,217,.2); border-radius:4px; padding:2px 8px; }

    /* ── SERVICIOS ── */
    .servicios-sec { padding:72px 5%; background:var(--light); }
    .servicios-inner { max-width:1200px; margin:0 auto; }
    .servicios-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin-top:40px; }
    .serv-card { background:var(--white); border:1px solid var(--border); border-radius:12px; padding:24px; }
    .serv-card .ico { font-size:28px; margin-bottom:12px; }
    .serv-card h3 { font-size:15px; font-weight:700; color:var(--navy); margin-bottom:8px; }
    .serv-card p { font-size:13px; color:var(--dark); line-height:1.7; }

    /* ── PARTNERS ── */
    .partners { padding:72px 5%; }
    .partners-inner { max-width:1200px; margin:0 auto; text-align:center; }
    .partners-sub { font-size:15px; color:var(--dark); margin-bottom:40px; }
    .partners-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; text-align:left; }
    .partner-card { border:1px solid var(--border); border-radius:14px; padding:28px; display:flex; flex-direction:column; gap:10px; transition:box-shadow .2s; }
    .partner-card:hover { box-shadow:0 4px 20px rgba(0,0,0,.08); }
    .p-icon { width:52px; height:52px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:26px; }
    .p-icon.orange { background:#FEF3E2; }
    .p-icon.purple { background:#F5F3FF; }
    .p-icon.green { background:#ECFDF5; }
    .partner-card strong { font-size:15px; font-weight:700; color:var(--navy); }
    .partner-card span { font-size:13px; color:var(--dark); line-height:1.6; }
    .partner-since { display:inline-block; font-size:11px; font-weight:700; background:var(--light); color:var(--dark); border-radius:20px; padding:2px 10px; width:fit-content; }

    /* ── OFICINAS ── */
    .oficinas { background:var(--light); padding:72px 5%; }
    .oficinas-inner { max-width:1200px; margin:0 auto; }
    .oficinas-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:24px; margin-top:40px; }
    .oficina-card { background:var(--white); border:1px solid var(--border); border-radius:14px; padding:28px; }
    .oficina-hq { border:2px solid var(--blue); }
    .hq-badge { display:inline-block; background:var(--blue); color:var(--white); font-size:10px; font-weight:700; padding:2px 8px; border-radius:4px; margin-bottom:12px; }
    .oficina-flag { font-size:28px; margin-bottom:12px; }
    .sede { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:var(--blue); margin-bottom:6px; }
    .oficina-card h3 { font-size:17px; font-weight:700; color:var(--navy); margin-bottom:10px; }
    .oficina-card p { font-size:13px; color:var(--dark); line-height:1.7; }

    /* ── CTA ── */
    .cta-band { background:var(--orange); padding:56px 5%; }
    .cta-inner { max-width:900px; margin:0 auto; display:flex; align-items:center; justify-content:space-between; gap:32px; flex-wrap:wrap; }
    .cta-text h2 { font-family:var(--font-display); font-size:28px; color:var(--white); margin-bottom:8px; }
    .cta-text p { font-size:15px; color:rgba(255,255,255,.85); }
    .cta-btns { display:flex; gap:12px; flex-wrap:wrap; }
    .btn-cta-band { display:inline-block; background:var(--white); color:var(--orange); font-weight:700; font-size:14px; padding:13px 26px; border-radius:8px; white-space:nowrap; transition:background .15s; }
    .btn-cta-band:hover { background:#fff7ed; }
    .btn-wa { display:inline-flex; align-items:center; gap:8px; background:#25D366; color:var(--white); padding:13px 22px; border-radius:8px; font-weight:700; font-size:14px; }
    .btn-wa svg { width:18px; height:18px; fill:white; flex-shrink:0; }

    /* ── RESPONSIVE ── */
    @media (max-width:960px) {
      .hero-inner { grid-template-columns:1fr; gap:36px; }
      .quienes-inner { grid-template-columns:1fr; gap:36px; }
      .mercados-grid { grid-template-columns:1fr; gap:16px; }
      .servicios-grid { grid-template-columns:1fr 1fr; }
      .partners-grid { grid-template-columns:1fr; }
      .oficinas-grid { grid-template-columns:1fr; }
      .stats-inner { grid-template-columns:1fr 1fr; }
      .hero h1 { font-size:32px; }
    }
    @media (max-width:768px) {
      .footer-grid { grid-template-columns:1fr; gap:28px; }
      .footer-bottom { flex-direction:column; text-align:center; gap:16px; }
      .cta-inner { flex-direction:column; text-align:center; }
      .cta-btns { justify-content:center; }
    }
    @media (max-width:480px) {
      .servicios-grid { grid-template-columns:1fr; }
      .stat-item .n { font-size:30px; }
    }
  

    /* ── Dropdown open state (JS-managed) ── */
    .nav-item.open > .mega-menu        { display: grid !important; }
    .nav-item.open > .simple-dropdown  { display: grid !important; }
    .nav-item.open > .nav-link         { background: var(--light); color: var(--blue); }
    .nav-item.open > .nav-link svg     { transform: rotate(180deg); }
  
  </style>

<main id="main-content">

<!-- ══ HERO ══ -->
<section class="hero">
  <div class="hero-inner">
    <div>
      <span class="hero-tag">Empresa · Desde 2007</span>
      <h1>Tecnología al servicio del <em>aprendizaje corporativo</em></h1>
      <p class="hero-sub">Somos Tecnología Avanzada para la Educación y la Capacitación, S.A. de C.V. Desde la Ciudad de México impulsamos el aprendizaje digital en organizaciones de México y América Latina.</p>
      <p class="hero-razon">Tecnología Avanzada para la Educación y la Capacitación, S.A. de C.V.</p>
      <div class="hero-actions">
        <a href={getBookingUrl()} target="_blank" rel="noopener noreferrer" class="btn-primary">Agendar diagnóstico →</a>
        <a href={r('/contacto')} class="btn-ghost">Escríbenos</a>
      </div>
    </div>
    <div class="hero-card">
      <p class="hero-card-title">En números</p>
      <div class="stat-row">
        <div class="stat-box">
          <div class="num">18</div>
          <div class="lbl">años de experiencia</div>
        </div>
        <div class="stat-box">
          <div class="num">+1,500</div>
          <div class="lbl">clientes en LATAM</div>
        </div>
        <div class="stat-box">
          <div class="num">17</div>
          <div class="lbl">países atendidos</div>
        </div>
        <div class="stat-box">
          <div class="num">+200</div>
          <div class="lbl">proyectos entregados</div>
        </div>
      </div>
      <div class="offices-row">
        <div class="office-item"><span class="office-dot"></span>🇲🇽 Ciudad de México (sede central)</div>
        <div class="office-item"><span class="office-dot"></span>🇨🇴 Bogotá, Colombia</div>
        <div class="office-item"><span class="office-dot"></span>🇨🇱 Santiago de Chile</div>
      </div>
    </div>
  </div>
</section>

<!-- ══ STATS BAND ══ -->
<section class="stats-band" aria-label="Estadísticas TAEC">
  <div class="stats-inner">
    <div class="stat-item">
      <div class="n">2007</div>
      <div class="l">Año de fundación en CDMX</div>
    </div>
    <div class="stat-item">
      <div class="n">+1,500</div>
      <div class="l">Clientes en México y LATAM</div>
    </div>
    <div class="stat-item">
      <div class="n">17</div>
      <div class="l">Países con presencia activa</div>
    </div>
    <div class="stat-item">
      <div class="n">+200</div>
      <div class="l">Proyectos completos entregados</div>
    </div>
  </div>
</section>

<!-- ══ QUIÉNES SOMOS ══ -->
<section class="quienes">
  <div class="quienes-inner">
    <div>
      <p class="section-label">Quiénes somos</p>
      <h2 class="section-title">18 años construyendo el futuro del aprendizaje corporativo</h2>
      <p class="body-text">TAEC fue fundada en la Ciudad de México en 2007 con una misión clara: hacer que la tecnología educativa sea accesible, práctica y medible para las organizaciones de México y América Latina.</p>
      <p class="body-text">Hoy contamos con más de 1,500 clientes en 17 países (incluyendo México, Estados Unidos, Europa y LATAM), oficinas en CDMX, Bogotá y Santiago de Chile, y más de 200 proyectos completos entregados. Somos partners oficiales de las principales herramientas del mundo: Articulate, Vyond y Totara.</p>
      <p class="body-text">Atendemos los mercados corporativo, gubernamental y académico, ofreciendo desde herramientas de autoría y plataformas LMS hasta evaluaciones en línea, microlearning y cursos a la medida — todo con soporte en español y facturación mexicana.</p>
    </div>
    <div class="valores-grid">
      <div class="valor-card">
        <div class="valor-icon" aria-hidden="true">🎯</div>
        <div class="valor-text">
          <strong>Resultados medibles</strong>
          <span>No vendemos cursos, acompañamos estrategias. Cada proyecto se diseña para impactar indicadores reales de la organización.</span>
        </div>
      </div>
      <div class="valor-card">
        <div class="valor-icon" aria-hidden="true">🤝</div>
        <div class="valor-text">
          <strong>Partner, no proveedor</strong>
          <span>Nuestros clientes nos llaman cuando tienen un reto, no solo cuando quieren comprar. Eso no se construye de la noche a la mañana — son 18 años de trabajo.</span>
        </div>
      </div>
      <div class="valor-card">
        <div class="valor-icon" aria-hidden="true">🌎</div>
        <div class="valor-text">
          <strong>Contexto latinoamericano</strong>
          <span>Soporte en español, factura electrónica mexicana, precios en pesos y comprensión real de las necesidades de equipos L&amp;D en LATAM.</span>
        </div>
      </div>
      <div class="valor-card">
        <div class="valor-icon" aria-hidden="true">⚡</div>
        <div class="valor-text">
          <strong>Tecnología + Creatividad + IA</strong>
          <span>Combinamos las mejores herramientas del mercado con diseño instruccional, creatividad audiovisual e inteligencia artificial.</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ MERCADOS ══ -->
<section class="mercados">
  <div class="mercados-inner">
    <p class="section-label">Mercados que atendemos</p>
    <h2 class="section-title">Soluciones para cada sector</h2>
    <div class="mercados-grid">
      <div class="mercado-card">
        <div class="mercado-top">
          <div class="mercado-icon" aria-hidden="true">🏢</div>
          <div class="mercado-pct">70%</div>
        </div>
        <h3>Corporativo</h3>
        <p>Empresas medianas y grandes que necesitan capacitar equipos de forma escalable, medible y con alto impacto en resultados de negocio.</p>
        <div class="mercado-bar"><div class="mercado-bar-fill" style="width:70%"></div></div>
        <div class="mercado-tags">
          <span class="mercado-tag">RRHH</span>
          <span class="mercado-tag">Ventas</span>
          <span class="mercado-tag">Compliance</span>
          <span class="mercado-tag">Onboarding</span>
        </div>
      </div>
      <div class="mercado-card">
        <div class="mercado-top">
          <div class="mercado-icon" aria-hidden="true">🎓</div>
          <div class="mercado-pct">20%</div>
        </div>
        <h3>Académico</h3>
        <p>Universidades, institutos y centros de formación que modernizar su oferta educativa con herramientas digitales de primer nivel.</p>
        <div class="mercado-bar"><div class="mercado-bar-fill" style="width:20%"></div></div>
        <div class="mercado-tags">
          <span class="mercado-tag">Universidades</span>
          <span class="mercado-tag">Ed. continua</span>
          <span class="mercado-tag">Aulas virtuales</span>
        </div>
      </div>
      <div class="mercado-card">
        <div class="mercado-top">
          <div class="mercado-icon" aria-hidden="true">🏛️</div>
          <div class="mercado-pct">10%</div>
        </div>
        <h3>Gubernamental</h3>
        <p>Dependencias e instituciones públicas que requieren plataformas robustas y soluciones de capacitación masiva para servidores públicos.</p>
        <div class="mercado-bar"><div class="mercado-bar-fill" style="width:10%"></div></div>
        <div class="mercado-tags">
          <span class="mercado-tag">Plataformas LMS</span>
          <span class="mercado-tag">Certificaciones</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ SERVICIOS ══ -->
<section class="servicios-sec">
  <div class="servicios-inner">
    <p class="section-label">Lo que hacemos</p>
    <h2 class="section-title">Un rango completo de soluciones e-learning</h2>
    <div class="servicios-grid">
      <div class="serv-card">
        <div class="ico" aria-hidden="true">✏️</div>
        <h3>Diseño de cursos e-learning</h3>
        <p>Producción a medida: diseño instruccional, guiones, desarrollo en Articulate o Vyond, revisión y publicación en tu LMS.</p>
      </div>
      <div class="serv-card">
        <div class="ico" aria-hidden="true">⏱️</div>
        <h3>Microlearning</h3>
        <p>Formatos cortos, efectivos y adaptados a móvil para reforzar conocimientos clave en el momento de trabajo.</p>
      </div>
      <div class="serv-card">
        <div class="ico" aria-hidden="true">🎮</div>
        <h3>Gamificación</h3>
        <p>Mecánicas de juego integradas al aprendizaje para aumentar motivación, engagement y retención del conocimiento.</p>
      </div>
      <div class="serv-card">
        <div class="ico" aria-hidden="true">🖥️</div>
        <h3>Plataformas LMS</h3>
        <p>Implementación, hosting SaaS, personalización y soporte de Moodle, Totara, Ottolearn y otras plataformas líderes.</p>
      </div>
      <div class="serv-card">
        <div class="ico" aria-hidden="true">📋</div>
        <h3>Evaluaciones en línea</h3>
        <p>Exámenes seguros con Proctorizer y detección de plagio con StrikePlagiarism.</p>
      </div>
      <div class="serv-card">
        <div class="ico" aria-hidden="true">📚</div>
        <h3>Contenidos de catálogo</h3>
        <p>Acceso a miles de cursos listos: 7 Minutes Learning, Custom Guide — integrados a tu LMS existente.</p>
      </div>
    </div>
  </div>
</section>

<!-- ══ PARTNERS ══ -->
<section class="partners">
  <div class="partners-inner">
    <p class="section-label">Alianzas estratégicas</p>
    <h2 class="section-title">Partners oficiales de las mejores herramientas</h2>
    <p class="partners-sub">No revendemos licencias — somos partners certificados con soporte local, capacitación y acompañamiento en español.</p>
    <div class="partners-grid">
      <div class="partner-card">
        <div class="p-icon orange" aria-hidden="true">🏆</div>
        <strong>Articulate</strong>
        <span>Partner oficial desde 2007. La suite más usada para crear cursos e-learning interactivos en el mundo.</span>
        <span class="partner-since">Partner desde 2007</span>
      </div>
      <div class="partner-card">
        <div class="p-icon purple" aria-hidden="true">🎬</div>
        <strong>Vyond</strong>
        <span>Partner oficial para México y LATAM. La plataforma líder en animación y video corporativo para e-learning.</span>
        <span class="partner-since">Partner oficial LATAM</span>
      </div>
      <div class="partner-card">
        <div class="p-icon green" aria-hidden="true">🌿</div>
        <strong>Totara</strong>
        <span>Partner certificado de Totara Learn, Engage y Perform — el LMS más flexible para grandes organizaciones.</span>
        <span class="partner-since">Partner certificado</span>
      </div>
    </div>
  </div>
</section>

<!-- ══ OFICINAS ══ -->
<section class="oficinas">
  <div class="oficinas-inner">
    <p class="section-label">Dónde estamos</p>
    <h2 class="section-title">Tres oficinas, una misma pasión por el aprendizaje</h2>
    <div class="oficinas-grid">
      <div class="oficina-card oficina-hq">
        <div class="hq-badge">Sede central</div>
        <div class="oficina-flag" aria-hidden="true">🇲🇽</div>
        <div class="sede">México</div>
        <h3>Ciudad de México</h3>
        <p>Fundada aquí en 2007. Nuestra sede principal, desde donde coordinamos proyectos para todo México y LATAM.</p>
        <p style="margin-top:12px;font-size:13px;">
          <a href={`tel:${contactData.phone.replace(/ /g,'')}`} style="color:var(--blue);font-weight:600;">📞 {contactData.phone}</a><br>
          <a href={`mailto:${contactData.email}`} style="color:var(--blue);font-weight:600;">✉ {contactData.email}</a>
        </p>
      </div>
      <div class="oficina-card">
        <div class="oficina-flag" aria-hidden="true">🇨🇴</div>
        <div class="sede">Colombia</div>
        <h3>Bogotá</h3>
        <p>
          Carrera 7 #82-66 Ofic. 220<br>
          Bogotá D.C., Colombia<br><br>
          📞 <a href="tel:+5716015085750" style="color:var(--blue);font-weight:600;">+57 601 508 5750</a><br>
          📞 <a href={`tel:${contactData.phone.replace(/ /g,'')}`} style="color:var(--blue);font-weight:600;">{contactData.phone}</a><br>
          🌐 <a href="https://www.taec.com.co/" target="_blank" rel="noopener noreferrer" style="color:var(--blue);font-weight:600;">taec.com.co</a>
        </p>
      </div>
      <div class="oficina-card">
        <div class="oficina-flag" aria-hidden="true">🇨🇱</div>
        <div class="sede">Chile</div>
        <h3>Santiago de Chile</h3>
        <p>
          Padre Mariano 210, Of. 704<br>
          Providencia, Santiago, Chile<br><br>
          📞 <a href="tel:+56552532523" style="color:var(--blue);font-weight:600;">+56 (55) 253 2523</a><br>
          📞 <a href={`tel:${contactData.phone.replace(/ /g,'')}`} style="color:var(--blue);font-weight:600;">{contactData.phone}</a><br>
          🌐 <a href="https://www.taec.cl/" target="_blank" rel="noopener noreferrer" style="color:var(--blue);font-weight:600;">taec.cl</a>
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ══ CTA ══ -->
