---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
function r(url: string): string {
  if (!url || url.startsWith('http://') || url.startsWith('https://') || url.startsWith('//')) return url;
  return base.replace(/\/$/, '') + url;
}
---

<BaseLayout 
  title="Estándares e-learning – SCORM, xAPI, cmi5, LTI | TAEC"
  description="Fichas técnicas sobre los estándares del sector e-learning: SCORM 1.2, SCORM 2004, xAPI (Tin Can), cmi5, LTI, AICC. Referencia rápida para implementadores y diseñadores instruccionales."
  section="Recursos"
  page="estandares.html"
>
  <style is:global>

    .nav-item::after { display: none !important; }
    .nav-item.open > .mega-menu { display: grid !important; }
    .nav-item.open > .simple-dropdown { display: grid !important; }
    .nav-item.open > .nav-link { background: var(--light); color: var(--blue); }
    .nav-item.open > .nav-link svg { transform: rotate(180deg); }

    /* ── HERO ── */
    .glo-hero { background: linear-gradient(135deg, #001f3d 0%, #004775 60%, #0077b6 100%); padding: 56px 5% 64px; color: white; }
    .glo-hero-inner { max-width: 1100px; margin: 0 auto; }
    .glo-breadcrumb { font-size: 13px; color: rgba(255,255,255,.5); margin-bottom: 20px; }
    .glo-breadcrumb a { color: rgba(255,255,255,.5); transition: color .15s; }
    .glo-breadcrumb a:hover { color: white; }
    .glo-breadcrumb span { margin: 0 6px; }
    .glo-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--teal); margin-bottom: 12px; }
    .glo-hero h1 { font-family: var(--font-display); font-size: clamp(28px, 3.5vw, 44px); font-weight: 400; color: white; line-height: 1.2; margin-bottom: 12px; }
    .glo-hero-sub { font-size: 16px; color: rgba(255,255,255,.7); max-width: 560px; }

    /* ── CONTROLES ── */
    .glo-controls { background: var(--white); border-bottom: 1px solid var(--border); padding: 20px 5%; position: sticky; top: 68px; z-index: 100; }
    .glo-controls-inner { max-width: 1100px; margin: 0 auto; display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
    .glo-search { flex: 1; min-width: 200px; position: relative; }
    .glo-search input { width: 100%; border: 1.5px solid var(--border); border-radius: 8px; padding: 10px 16px 10px 40px; font-size: 14px; font-family: var(--font-body); color: var(--text); background: var(--light); outline: none; transition: border-color .15s; }
    .glo-search input:focus { border-color: var(--blue); background: white; }
    .glo-search svg { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: #94A3B8; pointer-events: none; }
    .glo-count { font-size: 13px; color: #64748B; white-space: nowrap; flex-shrink: 0; }

    /* ── FILTROS DE CATEGORÍA ── */
    .est-filters { padding: 16px 5% 0; background: var(--white); }
    .est-filters-inner { max-width: 1100px; margin: 0 auto; display: flex; gap: 8px; flex-wrap: wrap; padding-bottom: 16px; border-bottom: 1px solid var(--border); }
    .est-filter-btn { font-size: 12px; font-weight: 600; padding: 5px 12px; border-radius: 20px; border: 1.5px solid var(--border); color: #64748B; background: var(--white); cursor: pointer; transition: all .15s; }
    .est-filter-btn:hover { border-color: var(--blue); color: var(--blue); }
    .est-filter-btn.active { background: var(--navy); color: white; border-color: var(--navy); }

    /* ── ESTÁNDARES GRID ── */
    .est-main { padding: 40px 5% 72px; }
    .est-main-inner { max-width: 1100px; margin: 0 auto; }
    .est-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    @media (max-width: 720px) { .est-grid { grid-template-columns: 1fr; } }

    /* ── EST CARD ── */
    .est-card { border: 1.5px solid var(--border); border-radius: 12px; overflow: hidden; transition: border-color .15s, box-shadow .15s; display: flex; flex-direction: column; }
    .est-card:hover { border-color: #CBD5E1; box-shadow: 0 4px 16px rgba(0,0,0,.06); }
    .est-card-header { padding: 18px 20px; cursor: pointer; display: flex; align-items: flex-start; gap: 14px; background: var(--white); }
    .est-card-header:hover { background: var(--light); }
    .est-card-icon { font-size: 28px; line-height: 1; flex-shrink: 0; margin-top: 2px; }
    .est-card-info { flex: 1; min-width: 0; }
    .est-card-name { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 5px; }
    .est-card-cat { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; background: #F0FDF4; color: #16A34A; border: 1px solid #BBF7D0; border-radius: 4px; padding: 2px 7px; display: inline-block; margin-bottom: 6px; }
    .est-card-desc { font-size: 13px; color: #4B5563; line-height: 1.6; }
    .est-card-toggle { width: 26px; height: 26px; border-radius: 6px; border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 16px; color: var(--blue); flex-shrink: 0; transition: all .2s; margin-top: 2px; }
    .est-card.open .est-card-toggle { background: var(--navy); color: white; border-color: var(--navy); transform: rotate(45deg); }
    .est-card-body { display: none; border-top: 1px solid var(--border); padding: 16px 20px; background: var(--light); }
    .est-card.open .est-card-body { display: block; }
    .est-card-body dl { display: grid; grid-template-columns: auto 1fr; gap: 6px 16px; font-size: 13px; }
    .est-card-body dt { font-weight: 700; color: var(--navy); white-space: nowrap; }
    .est-card-body dd { color: #4B5563; }

    /* ── EMPTY ── */
    .glo-empty { text-align: center; padding: 64px 24px; display: none; }
    .glo-empty p { font-size: 15px; color: #94A3B8; }

    /* ── REC TABS ── */
    .rec-tabs{background:#F8FAFC;border-bottom:1px solid var(--border);padding:0 5%;overflow-x:auto}
    .rec-tabs-inner{max-width:1100px;margin:0 auto;display:flex;gap:0}
    .rec-tab{display:inline-flex;align-items:center;padding:14px 18px;font-size:13px;font-weight:600;color:#64748B;border-bottom:3px solid transparent;transition:color .15s,border-color .15s;white-space:nowrap;text-decoration:none}
    .rec-tab:hover{color:var(--blue)}
    .rec-tab.active{color:var(--navy);border-bottom-color:var(--navy)}
  
  </style>

<main id="main-content">

<!-- ══ HERO ══ -->
<section class="glo-hero">
  <div class="glo-hero-inner">
    <p class="glo-breadcrumb"><a href={r('/recursos')}>Recursos</a><span>›</span>Estándares</p>
    <p class="glo-eyebrow">Estándares</p>
    <h1>Guía de estándares técnicos e-learning</h1>
    <p class="glo-hero-sub">SCORM, xAPI, cmi5, LTI, AICC — todo lo que necesitas saber para implementar correctamente. 30 fichas de referencia rápida.</p>
  </div>
</section>

<!-- ══ CONTROLES ══ -->
<div class="glo-controls">
  <div class="glo-controls-inner">
    <div class="glo-search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="search" id="estSearch" placeholder="Buscar estándar…" aria-label="Buscar estándar" />
    </div>
    <span class="glo-count" id="estCount"></span>
  </div>
</div>

<!-- ══ FILTROS DE CATEGORÍA ══ -->
<div class="est-filters">
  <div class="est-filters-inner" id="estFilters">
    <!-- Generado por JS -->
  </div>
</div>

<!-- ══ ESTÁNDARES ══ -->
<section class="est-main">
  <div class="est-main-inner">
    <div class="est-grid" id="estContent">
      <!-- INICIO_ESTANDARES — generado por Apps Script -->
      <!-- FIN_ESTANDARES -->
    </div>
    <div class="glo-empty" id="estEmpty">
      <p>No se encontraron estándares con ese criterio.</p>
    </div>
  </div>
</section>

</main>
</BaseLayout>
