---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Quiz e-learning – Pon a prueba tu conocimiento L&amp;D | TAEC"
  description="Flashcards interactivas de e-learning. 75 preguntas sobre SCORM, xAPI, LMS, diseño instruccional y más. Ideal para preparar certificaciones o reforzar conceptos."
  section="Recursos"
  page="quiz.html"
>
  <style is:global>

    .nav-item::after { display: none !important; }
    .nav-item.open > .mega-menu { display: grid !important; }
    .nav-item.open > .simple-dropdown { display: grid !important; }
    .nav-item.open > .nav-link { background: var(--light); color: var(--blue); }
    .nav-item.open > .nav-link svg { transform: rotate(180deg); }

    /* ── HERO ── */
    .glo-hero { background: linear-gradient(135deg, #001f3d 0%, #004775 60%, #0077b6 100%); padding: 56px 5% 64px; color: white; }
    .glo-hero-inner { max-width: 1100px; margin: 0 auto; }
    .glo-breadcrumb { font-size: 13px; color: rgba(255,255,255,.5); margin-bottom: 20px; }
    .glo-breadcrumb a { color: rgba(255,255,255,.5); transition: color .15s; }
    .glo-breadcrumb a:hover { color: white; }
    .glo-breadcrumb span { margin: 0 6px; }
    .glo-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--teal); margin-bottom: 12px; }
    .glo-hero h1 { font-family: var(--font-display); font-size: clamp(28px, 3.5vw, 44px); font-weight: 400; color: white; line-height: 1.2; margin-bottom: 12px; }
    .glo-hero-sub { font-size: 16px; color: rgba(255,255,255,.7); max-width: 560px; }

    /* ── QUIZ MAIN ── */
    .quiz-main { padding: 48px 5% 80px; }
    .quiz-main-inner { max-width: 680px; margin: 0 auto; }

    /* ── FLASHCARD DATA STORE (hidden) ── */
    #flashcardsData { display: none; }

    /* ── FLASHCARD UI ── */
    .quiz-scene { width: 100%; perspective: 1200px; margin-bottom: 28px; }
    .flashcard {
      width: 100%;
      height: 280px;
      cursor: pointer;
      position: relative;
    }
    .flashcard-inner {
      position: relative;
      width: 100%;
      height: 100%;
      transition: transform .5s cubic-bezier(.4,0,.2,1);
      transform-style: preserve-3d;
    }
    .flashcard.flipped .flashcard-inner {
      transform: rotateY(180deg);
    }
    .flashcard-front,
    .flashcard-back {
      position: absolute;
      inset: 0;
      border-radius: 16px;
      backface-visibility: hidden;
      -webkit-backface-visibility: hidden;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 32px 36px;
      text-align: center;
      box-shadow: 0 8px 32px rgba(0,71,117,.15);
    }
    .flashcard-front {
      background: var(--navy);
      color: white;
    }
    .flashcard-back {
      background: var(--white);
      color: var(--text);
      border: 2px solid var(--border);
      transform: rotateY(180deg);
    }
    .flashcard-front .fc-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--teal);
      margin-bottom: 16px;
    }
    .flashcard-back .fc-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: 16px;
    }
    .flashcard-front .fc-text {
      font-family: var(--font-display);
      font-size: clamp(16px, 2.5vw, 22px);
      font-weight: 400;
      line-height: 1.4;
      color: white;
    }
    .flashcard-back .fc-text {
      font-size: 15px;
      color: var(--text);
      line-height: 1.7;
    }
    .flashcard-front .fc-hint {
      position: absolute;
      bottom: 16px;
      font-size: 11px;
      color: rgba(255,255,255,.35);
      letter-spacing: .3px;
    }
    .flashcard-back .fc-hint {
      position: absolute;
      bottom: 16px;
      font-size: 11px;
      color: #94A3B8;
      letter-spacing: .3px;
    }

    /* ── QUIZ CONTROLS ── */
    .quiz-controls { display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
    .quiz-nav { display: flex; gap: 10px; align-items: center; }
    .quiz-btn {
      font-family: var(--font-body);
      font-size: 13px;
      font-weight: 700;
      padding: 9px 18px;
      border-radius: 8px;
      border: 1.5px solid var(--border);
      background: var(--white);
      color: var(--text);
      cursor: pointer;
      transition: background .15s, border-color .15s, color .15s;
    }
    .quiz-btn:hover { background: var(--light); border-color: #CBD5E1; }
    .quiz-btn:disabled { opacity: .4; cursor: default; }
    .quiz-btn.primary { background: var(--navy); color: white; border-color: var(--navy); }
    .quiz-btn.primary:hover { background: #005a8e; border-color: #005a8e; }
    .quiz-counter {
      font-size: 13px;
      font-weight: 700;
      color: #64748B;
      background: var(--light);
      border: 1.5px solid var(--border);
      border-radius: 8px;
      padding: 7px 14px;
      white-space: nowrap;
    }
    .quiz-shuffle {
      font-family: var(--font-body);
      font-size: 13px;
      font-weight: 600;
      padding: 9px 16px;
      border-radius: 8px;
      border: 1.5px solid var(--border);
      background: var(--white);
      color: #64748B;
      cursor: pointer;
      transition: background .15s, border-color .15s, color .15s;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .quiz-shuffle:hover { background: var(--light); border-color: #CBD5E1; color: var(--text); }

    /* ── PROGRESS BAR ── */
    .quiz-progress { margin-bottom: 20px; }
    .quiz-progress-bar {
      width: 100%;
      height: 4px;
      background: var(--border);
      border-radius: 2px;
      overflow: hidden;
    }
    .quiz-progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--blue) 0%, var(--teal) 100%);
      border-radius: 2px;
      transition: width .3s ease;
    }

    /* ── EMPTY STATE ── */
    .quiz-empty { text-align: center; padding: 64px 24px; display: none; }
    .quiz-empty p { font-size: 15px; color: #94A3B8; }

    /* ── REC TABS ── */
    .rec-tabs{background:#F8FAFC;border-bottom:1px solid var(--border);padding:0 5%;overflow-x:auto}
    .rec-tabs-inner{max-width:1100px;margin:0 auto;display:flex;gap:0}
    .rec-tab{display:inline-flex;align-items:center;padding:14px 18px;font-size:13px;font-weight:600;color:#64748B;border-bottom:3px solid transparent;transition:color .15s,border-color .15s;white-space:nowrap;text-decoration:none}
    .rec-tab:hover{color:var(--blue)}
    .rec-tab.active{color:var(--navy);border-bottom-color:var(--navy)}
  
  </style>

<main id="main-content">

<!-- ══ HERO ══ -->
<section class="glo-hero">
  <div class="glo-hero-inner">
    <p class="glo-breadcrumb"><a href="/recursos">Recursos</a><span>›</span>Quiz &amp; Flashcards</p>
    <p class="glo-eyebrow">Quiz &amp; Flashcards</p>
    <h1>Pon a prueba tu conocimiento de e-learning</h1>
    <p class="glo-hero-sub">75 flashcards sobre los conceptos esenciales del sector. Haz clic para revelar la respuesta — un concepto a la vez.</p>
  </div>
</section>

<!-- ══ QUIZ ══ -->
<section class="quiz-main">
  <div class="quiz-main-inner">

    <!-- INICIO_FLASHCARDS — generado por Apps Script -->
    <!-- FIN_FLASHCARDS -->

    <!-- Contenedor UI del quiz (se muestra cuando hay flashcards) -->
    <div id="quizUI" style="display:none;">
      <!-- Progress bar -->
      <div class="quiz-progress">
        <div class="quiz-progress-bar">
          <div class="quiz-progress-fill" id="progressFill"></div>
        </div>
      </div>

      <!-- Flashcard -->
      <div class="quiz-scene">
        <div class="flashcard" id="flashcard" role="button" tabindex="0" aria-label="Flashcard — haz clic para voltear">
          <div class="flashcard-inner">
            <div class="flashcard-front">
              <span class="fc-label">Pregunta</span>
              <p class="fc-text" id="fcFront"></p>
              <span class="fc-hint">Haz clic para ver la respuesta</span>
            </div>
            <div class="flashcard-back">
              <span class="fc-label">Respuesta</span>
              <p class="fc-text" id="fcBack"></p>
              <span class="fc-hint">Haz clic para volver a la pregunta</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Controls -->
      <div class="quiz-controls">
        <div class="quiz-nav">
          <button class="quiz-btn" id="btnPrev" aria-label="Tarjeta anterior">&#8592; Anterior</button>
          <span class="quiz-counter" id="quizCounter">1 / 1</span>
          <button class="quiz-btn primary" id="btnNext" aria-label="Siguiente tarjeta">Siguiente &#8594;</button>
        </div>
        <button class="quiz-shuffle" id="btnShuffle" aria-label="Barajar tarjetas">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/></svg>
          Barajar
        </button>
      </div>
    </div>

    <!-- Estado vacío (no hay flashcards aún) -->
    <div class="quiz-empty" id="quizEmpty">
      <p>Las flashcards se cargarán desde Google Sheets a través de Apps Script.</p>
    </div>

  </div>
</section>

</main>
</BaseLayout>
