---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Storyline 360 en México – Cursos Interactivos Avanzados | TAEC"
  description="Storyline 360: crea experiencias de aprendizaje totalmente personalizadas e inmersivas. Partner oficial Articulate en México. Solicita demo."
  section="Soluciones"
  page="articulate-storyline360.html"
>
  <style is:global>

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    :root {
      --navy:#004775; --blue:#3179C2; --teal:#A8DBD9; --orange:#F59E0B; --green:#10B981;
      --dark:#111827; --muted:#6B7280; --light:#F3F4F6; --white:#FFFFFF; --border:#E5E7EB;
      --art:#C1258A;
    }
    body { font-family:'Inter',sans-serif; color:var(--dark); background:var(--white); }
    a { color:inherit; text-decoration:none; }
    /* ── header (copied from articulate-360-mexico) ── */
    header { position:sticky; top:0; z-index:100; background:var(--white); border-bottom:1px solid var(--border); }
    .header-inner { max-width:1200px; margin:0 auto; padding:0 24px; height:64px; display:flex; align-items:center; gap:32px; }
    .logo-link img { height:32px; width:auto; display:block; }
    header nav { display:flex; align-items:center; gap:4px; flex:1; }
    .nav-link { background:none; border:none; cursor:pointer; font-family:inherit; font-size:14px; font-weight:600; color:var(--dark); padding:6px 12px; border-radius:8px; display:inline-flex; align-items:center; gap:4px; transition:background .15s,color .15s; }
    .nav-link svg { width:14px; height:14px; flex-shrink:0; }
    .header-inner nav > a { font-size:14px; font-weight:600; color:var(--dark); padding:6px 12px; border-radius:8px; transition:background .15s,color .15s; }
    .header-inner nav > a:hover, .nav-link:hover, .nav-item:hover > .nav-link { background:var(--light); color:var(--blue); }
    .header-actions { display:flex; align-items:center; gap:12px; margin-left:auto; }
    .btn-tienda { font-size:13px; font-weight:600; color:var(--blue); border:1.5px solid var(--blue); padding:7px 16px; border-radius:7px; transition:background .15s,color .15s; }
    .btn-tienda:hover { background:var(--blue); color:var(--white); }
    .btn-cta { font-size:13px; font-weight:700; background:var(--orange); color:var(--white); padding:8px 18px; border-radius:8px; transition:background .15s; white-space:nowrap; }
    .btn-cta:hover { background:#d97706; }
    /* mega menu */
    .nav-item { position:relative; }
    .mega-menu { display:none; position:absolute; top:100%; left:50%; transform:translateX(-50%); min-width:720px; background:white; border:1px solid var(--border); border-radius:12px; padding:20px; grid-template-columns:repeat(3,1fr); gap:20px; box-shadow:0 8px 32px rgba(0,0,0,.12); z-index:200; }
    .simple-dropdown { display:none; position:absolute; top:100%; left:50%; transform:translateX(-50%); min-width:380px; background:white; border:1px solid var(--border); border-radius:12px; padding:20px; grid-template-columns:repeat(2,1fr); gap:20px; box-shadow:0 8px 32px rgba(0,0,0,.12); z-index:200; }
    .nav-item:hover > .mega-menu, .nav-item:hover > .simple-dropdown { display:grid; }
    .mega-col { display:flex; flex-direction:column; gap:6px; }
    .mega-head { font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:1px; color:var(--muted); margin-bottom:2px; }
    .mega-col > a { font-size:13px; font-weight:500; color:var(--dark); padding:4px 8px; border-radius:6px; }
    .mega-sub { display:flex; flex-direction:column; gap:3px; padding-left:12px; border-left:2px solid var(--border); margin:2px 0 4px; }
    .mega-sub a { font-size:12px; color:var(--muted); padding:3px 6px; border-radius:4px; display:flex; align-items:center; gap:6px; }
    .mega-col > a:hover, .mega-sub a:hover { background:var(--light); color:var(--blue); }
    .mega-divider { border-top:1px solid var(--border); margin:4px 0; }
    .badge-new { font-size:9px; font-weight:700; background:rgba(245,158,11,.15); color:#d97706; padding:1px 5px; border-radius:3px; flex-shrink:0; }
    .badge-saas { font-size:9px; font-weight:700; background:rgba(168,219,217,.3); color:var(--navy); padding:1px 5px; border-radius:3px; flex-shrink:0; }
    /* hamburger */
    .hamburger { display:none; background:none; border:none; cursor:pointer; padding:6px; flex-direction:column; gap:5px; }
    .hamburger span { display:block; width:22px; height:2px; background:var(--dark); border-radius:2px; transition:.2s; }
    /* mobile nav */
    .mobile-nav { display:none; flex-direction:column; background:white; border-bottom:1px solid var(--border); padding:12px 24px 20px; gap:4px; }
    .mobile-nav.open { display:flex; }
    .mob-toggle { background:none; border:none; cursor:pointer; font-size:14px; font-weight:600; color:var(--dark); padding:8px 0; display:flex; justify-content:space-between; align-items:center; width:100%; }
    .mob-toggle svg { width:16px; height:16px; }
    .mob-section { display:none; flex-direction:column; gap:2px; padding:4px 0 8px 12px; }
    .mob-section.open { display:flex; }
    .mob-cat { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:var(--muted); padding:6px 0 2px; }
    .mobile-nav > a { font-size:14px; font-weight:600; color:var(--dark); padding:8px 0; border-top:1px solid var(--border); }
    .mob-section a { font-size:13px; color:var(--dark); padding:5px 8px; border-radius:6px; }
    .nav-item.open>.mega-menu{display:grid!important}
    .nav-item.open>.simple-dropdown{display:grid!important}
    /* skip link */
    .skip-link{position:absolute;top:-60px;left:16px;background:var(--navy);color:var(--white);padding:8px 16px;border-radius:0 0 8px 8px;font-size:14px;font-weight:600;z-index:9999;text-decoration:none;transition:top .2s}
    .skip-link:focus{top:0}
    *:focus-visible{outline:3px solid var(--blue);outline-offset:2px;border-radius:4px}
    /* ── product tabs ── */
    .art-tabs{background:#F8FAFC;border-bottom:1px solid var(--border);padding:0 5%;overflow-x:auto}
    .art-tabs-inner{max-width:1100px;margin:0 auto;display:flex;gap:0}
    .art-tab{display:inline-flex;align-items:center;padding:14px 18px;font-size:13px;font-weight:600;color:#64748B;border-bottom:3px solid transparent;transition:color .15s,border-color .15s;white-space:nowrap}
    .art-tab:hover{color:var(--art)}
    .art-tab.active{color:var(--art);border-bottom-color:var(--art)}
    /* ── hero ── */
    .art-hero{background:linear-gradient(135deg, #050E14 0%, #0B3347 45%, #13668D 100%);padding:72px 5% 80px}
    .art-hero-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center}
    .art-logo-pill{display:inline-flex;background:white;border-radius:10px;padding:10px 20px;margin-bottom:20px;box-shadow:0 2px 14px rgba(0,0,0,.2)}
    .art-logo-pill img{height:34px;width:auto}
    .art-logo-badge{display:inline-flex;align-items:center;justify-content:center;width:56px;height:56px;border-radius:50%;background:rgba(255,255,255,.15);border:2px solid rgba(255,255,255,.3);font-size:16px;font-weight:800;color:white;margin-bottom:20px;font-family:'Inter',sans-serif}
    .art-tag{display:inline-block;font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;padding:4px 12px;border-radius:4px;margin-bottom:16px;background:rgba(193,37,138,.22);color:#FFB3E0}
    .art-product-eyebrow{font-size:clamp(22px,2.4vw,32px);font-weight:900;color:#7DD3FC;letter-spacing:-.01em;margin-bottom:10px;line-height:1}
    .art-hero h1{font-size:clamp(26px,3.5vw,44px);font-weight:800;color:white;line-height:1.18;margin-bottom:16px}
    .art-hero h1 em{font-style:normal;color:#FFB3E0}
    .art-hero-sub{font-size:16px;color:rgba(255,255,255,.8);margin-bottom:28px;line-height:1.65}
    .art-btns{display:flex;gap:12px;flex-wrap:wrap}
    .btn-art-primary{background:#C1258A;color:white;font-weight:700;font-size:14px;padding:12px 24px;border-radius:8px;transition:background .15s}
    .btn-art-primary:hover{background:#96197a}
    .btn-art-ghost{background:rgba(255,255,255,.12);color:white;font-weight:600;font-size:14px;padding:12px 24px;border-radius:8px;border:1.5px solid rgba(255,255,255,.3);transition:background .15s}
    .btn-art-ghost:hover{background:rgba(255,255,255,.2)}
    /* capability card */
    .art-cap-card{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.14);border-radius:16px;padding:28px}
    .art-cap-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:#FFB3E0;margin-bottom:14px}
    .art-cap-list{list-style:none;display:flex;flex-direction:column;gap:10px}
    .art-cap-list li{display:flex;align-items:flex-start;gap:10px;font-size:13px;color:rgba(255,255,255,.88);line-height:1.5}
    .art-cap-dot{flex-shrink:0;font-size:8px;margin-top:4px}
    /* ── features grid ── */
    .art-feats{padding:72px 5%;background:white}
    .art-feats-inner{max-width:1100px;margin:0 auto}
    .art-section-label{font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--art);margin-bottom:10px}
    .art-section-title{font-size:clamp(22px,2.5vw,32px);font-weight:800;color:#111827;margin-bottom:10px}
    .art-section-sub{font-size:16px;color:#475569;line-height:1.65;margin-bottom:44px;max-width:640px}
    .art-feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
    .art-feat-card{background:#F8FAFC;border:1px solid var(--border);border-radius:14px;padding:26px}
    .art-feat-icon{font-size:30px;margin-bottom:12px}
    .art-feat-title{font-size:15px;font-weight:700;color:#111827;margin-bottom:8px}
    .art-feat-desc{font-size:13px;color:#475569;line-height:1.55}
    /* ── quote ── */
    .art-quote{background:linear-gradient(135deg, #1a0014 0%, #3d0030 60%, #C1258A 100%);padding:56px 5%;text-align:center}
    .art-quote-inner{max-width:760px;margin:0 auto}
    .art-quote-text{font-size:clamp(16px,2vw,22px);color:white;line-height:1.65;font-style:italic;margin-bottom:20px}
    .art-quote-author{font-size:13px;color:#FFB3E0;font-weight:700}
    .art-quote-role{font-size:12px;color:rgba(255,255,255,.5);margin-top:3px}
    /* ── CTA band ── */
    .art-cta-band{background:var(--art);padding:48px 5%;text-align:center}
    .art-cta-band h2{font-size:28px;font-weight:800;color:white;margin-bottom:10px}
    .art-cta-band p{font-size:16px;color:rgba(255,255,255,.85);margin-bottom:28px}
    .art-cta-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
    .btn-cta-white{background:white;color:var(--art);font-weight:700;font-size:15px;padding:13px 28px;border-radius:8px}
    .btn-cta-ghost{background:transparent;color:white;font-weight:600;font-size:15px;padding:13px 28px;border-radius:8px;border:2px solid rgba(255,255,255,.5)}
  
  </style>

<main id="main-content">
<div class="art-tabs"><div class="art-tabs-inner">
      <a href="/articulate-360-mexico" class="art-tab">Articulate 360</a>
      <a href="/articulate-rise360" class="art-tab">Rise 360</a>
      <a href="/articulate-storyline360" class="art-tab active">Storyline 360</a>
      <a href="/articulate-review360" class="art-tab">Review 360</a>
      <a href="/articulate-reach" class="art-tab">Reach 360</a>
      <a href="/articulate-ai-assistant" class="art-tab">AI Assistant</a>
      <a href="/articulate-localization" class="art-tab">Localization</a>
    </div></div>

<!-- ══ HERO ══ -->
<section class="art-hero">
  <div class="art-hero-inner">
    <div>      <p class="art-product-eyebrow">Storyline 360</p>
      <h1>Diseña experiencias de aprendizaje <em>totalmente personalizadas</em></h1>
      <p class="art-hero-sub">Storyline 360 es el estándar de la industria para crear cursos interactivos complejos, simuladores de software, escenarios ramificados y experiencias inmersivas.</p>
      <div class="art-btns">
        <a href="https://articulate.com/es/360/trial/" target="_blank" rel="noopener noreferrer" class="btn-art-primary">Solicitar demo gratuita →</a>
        <a href="/articulate-360-mexico" class="btn-art-ghost">Ver Articulate 360 completo</a>
      </div>
    </div>
    <div>
      <!-- Storyline 360 CSS Mockup -->
      <div style="background:#1E293B;border-radius:12px;overflow:hidden;font-family:Inter,sans-serif;">
        <div style="background:#0F172A;padding:10px 14px;display:flex;align-items:center;gap:6px;">
          <span style="width:10px;height:10px;border-radius:50%;background:#EF4444;display:inline-block;"></span>
          <span style="width:10px;height:10px;border-radius:50%;background:#F59E0B;display:inline-block;"></span>
          <span style="width:10px;height:10px;border-radius:50%;background:#10B981;display:inline-block;"></span>
          <div style="flex:1;background:#1E293B;border-radius:4px;height:20px;margin-left:8px;display:flex;align-items:center;padding:0 10px;">
            <span style="font-size:10px;color:#64748B;">Storyline 360 — slide editor</span>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:80px 1fr;min-height:280px;">
          <!-- Slides panel -->
          <div style="background:#0F172A;padding:10px 6px;display:flex;flex-direction:column;gap:6px;">
            <div style="background:#C1258A;border-radius:4px;height:48px;display:flex;align-items:center;justify-content:center;font-size:8px;color:white;font-weight:700;border:2px solid #E879B8;">1</div>
            <div style="background:#1E293B;border-radius:4px;height:48px;display:flex;align-items:center;justify-content:center;font-size:8px;color:#64748B;">2</div>
            <div style="background:#1E293B;border-radius:4px;height:48px;display:flex;align-items:center;justify-content:center;font-size:8px;color:#64748B;">3</div>
            <div style="background:#1E293B;border-radius:4px;height:48px;display:flex;align-items:center;justify-content:center;font-size:8px;color:#64748B;">4</div>
          </div>
          <!-- Canvas -->
          <div style="background:#2D3748;padding:16px;">
            <div style="background:#C1258A;border-radius:6px;padding:12px;margin-bottom:10px;">
              <div style="height:7px;background:rgba(255,255,255,.4);border-radius:3px;width:70%;margin-bottom:5px;"></div>
              <div style="height:5px;background:rgba(255,255,255,.25);border-radius:3px;width:50%;"></div>
            </div>
            <div style="background:#374151;border-radius:6px;padding:10px;margin-bottom:8px;">
              <div style="height:5px;background:#4B5563;border-radius:3px;width:90%;margin-bottom:4px;"></div>
              <div style="height:5px;background:#4B5563;border-radius:3px;width:75%;"></div>
            </div>
            <!-- Timeline -->
            <div style="background:#0F172A;border-radius:6px;padding:8px 10px;">
              <div style="font-size:9px;color:#64748B;margin-bottom:6px;">LÍNEA DE TIEMPO</div>
              <div style="display:flex;flex-direction:column;gap:4px;">
                <div style="background:#C1258A;height:6px;border-radius:3px;width:80%;"></div>
                <div style="background:#7C3AED;height:6px;border-radius:3px;width:60%;margin-left:10px;"></div>
                <div style="background:#0EA5E9;height:6px;border-radius:3px;width:70%;"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ FEATURES ══ -->
<section class="art-feats">
  <div class="art-feats-inner">
    <p class="art-section-label">Funcionalidades clave</p>
    <h2 class="art-section-title">Todo lo que puedes hacer con Storyline 360</h2>
    <p class="art-section-sub">Incluido en tu suscripción Articulate 360 con soporte en español de TAEC.</p>
    <div class="art-feat-grid">
        <div class="art-feat-card">
          <div class="art-feat-icon">🎯</div>
          <h3 class="art-feat-title">Diapositivas desde PPT</h3>
          <p class="art-feat-desc">Importa tu PowerPoint y conviértelo en un curso interactivo en minutos.</p>
        </div>
        <div class="art-feat-card">
          <div class="art-feat-icon">🖥️</div>
          <h3 class="art-feat-title">Simuladores de software</h3>
          <p class="art-feat-desc">Graba tu pantalla y genera automáticamente simulaciones Try/Show/Test.</p>
        </div>
        <div class="art-feat-card">
          <div class="art-feat-icon">🌐</div>
          <h3 class="art-feat-title">Interactivos 360°</h3>
          <p class="art-feat-desc">Crea experiencias inmersivas con imágenes y videos 360° de banco o propios.</p>
        </div>
        <div class="art-feat-card">
          <div class="art-feat-icon">🎙️</div>
          <h3 class="art-feat-title">Audio con IA</h3>
          <p class="art-feat-desc">Genera narración a partir de texto, edita la onda sonora y añade CC exportables.</p>
        </div>
        <div class="art-feat-card">
          <div class="art-feat-icon">📤</div>
          <h3 class="art-feat-title">Exporta a todo</h3>
          <p class="art-feat-desc">LMS/LRS, web, video, Word, Review 360 y Reach 360 en un clic.</p>
        </div>
        <div class="art-feat-card">
          <div class="art-feat-icon">♿</div>
          <h3 class="art-feat-title">Accesibilidad</h3>
          <p class="art-feat-desc">Configura el curso para WCAG 2.1 y amplía tu alcance de aprendizaje.</p>
        </div>
    </div>
  </div>
</section>

<!-- ══ QUOTE ══ -->
<section class="art-quote">
  <div class="art-quote-inner">
    <p class="art-quote-text">""Storyline 360 nos permite crear simuladores de nuestros sistemas internos. Los colaboradores aprenden haciendo, no leyendo manuales.""</p>
    <p class="art-quote-author">Gerente de L&D</p>
    <p class="art-quote-role">Empresa de servicios financieros · cliente TAEC</p>
  </div>
</section>

<!-- ══ CTA BAND ══ -->
<section class="art-cta-band">
  <div style="max-width:700px;margin:0 auto;">
    <h2>¿Listo para probar Storyline 360?</h2>
    <p>Como partner oficial de Articulate en México, TAEC te ofrece demo en español, onboarding y soporte local.</p>
    <div class="art-cta-btns">
      <a href="https://articulate.com/es/360/trial/" target="_blank" rel="noopener noreferrer" class="btn-cta-white">Solicitar demo gratuita →</a>
      <a href="/contacto" class="btn-cta-ghost">Hablar con un especialista</a>
    </div>
  </div>
</section>
</main>
<a href="https://wa.me/5215527758279" class="wa-float" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp TAEC">
