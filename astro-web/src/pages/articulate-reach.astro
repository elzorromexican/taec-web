---
import { getBookingUrl } from '../data/contact';
import { vendors } from '../data/vendors';
import BaseLayout from '../layouts/BaseLayout.astro';

import { r, base } from '../utils/paths';
---

<BaseLayout 
  title="Reach 360 en México – Distribución de Cursos eLearning | TAEC"
  description="Reach 360: distribuye cursos de Storyline y Rise a cualquier audiencia sin LMS. Partner oficial Articulate en México. Solicita demo con TAEC."
  section="Soluciones"
  page="articulate-reach.html"
>
  <link rel="stylesheet" href={`${base}assets/css/art-pricing.css`} slot="head" />

<main id="main-content">
<div class="art-tabs"><div class="art-tabs-inner">
      <a href={r('/articulate-360-mexico')} class="art-tab">Articulate 360</a>
      <a href={r('/articulate-rise360')} class="art-tab">Rise 360</a>
      <a href={r('/articulate-storyline360')} class="art-tab">Storyline 360</a>
      <a href={r('/articulate-review360')} class="art-tab">Review 360</a>
      <a href={r('/articulate-reach')} class="art-tab active">Reach 360</a>
      <a href={r('/articulate-ai-assistant')} class="art-tab">AI Assistant</a>
      <a href={r('/articulate-localization')} class="art-tab">Localization</a>
    </div></div>

<!-- ══ HERO ══ -->
<section class="art-hero">
  <div class="art-hero-inner">
    <div>      <p class="art-product-eyebrow">Reach 360</p>
      <h1>Distribuye tu capacitación a <em>cualquier audiencia</em> en minutos</h1>
      <p class="art-hero-sub">Reach 360 complementa tu LMS actual o lo reemplaza para audiencias externas. Publica cursos de Rise, Storyline o de terceros y gestiona el aprendizaje con informes exportables.</p>
      <div class="art-btns">
        <a href={vendors.articulate.trial} target="_blank" rel="noopener noreferrer" class="btn-art-primary">Descargar prueba (30 días) →</a>
        <a href={r('/articulate-360-mexico')} class="btn-art-ghost">Ver Articulate 360 completo</a>
      </div>
    </div>
    <div>
      <!-- Reach 360 CSS Mockup -->
      <div style="background:#1E293B;border-radius:12px;overflow:hidden;font-family:Inter,sans-serif;">
        <div style="background:var(--navy-slate);padding:10px 14px;display:flex;align-items:center;gap:6px;">
          <span style="width:10px;height:10px;border-radius:50%;background:#EF4444;display:inline-block;"></span>
          <span style="width:10px;height:10px;border-radius:50%;background:#F59E0B;display:inline-block;"></span>
          <span style="width:10px;height:10px;border-radius:50%;background:var(--check-green);display:inline-block;"></span>
          <div style="flex:1;background:#1E293B;border-radius:4px;height:20px;margin-left:8px;display:flex;align-items:center;padding:0 10px;">
            <span style="font-size:10px;color:#64748B;">reach360.articulate.com</span>
          </div>
        </div>
        <div style="padding:16px;min-height:280px;background:#F8FAFC;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
            <span style="font-size:11px;font-weight:700;color:var(--navy-slate);">Mi Biblioteca</span>
            <div style="background:#0EA5E9;border-radius:4px;padding:4px 10px;font-size:9px;color:white;font-weight:700;">+ Añadir curso</div>
          </div>
          <div style="display:flex;flex-direction:column;gap:8px;">
            <div style="background:white;border-radius:8px;padding:10px 12px;display:flex;align-items:center;gap:10px;box-shadow:0 1px 4px rgba(0,0,0,.08);">
              <div style="width:36px;height:36px;background:#0EA5E9;border-radius:6px;flex-shrink:0;"></div>
              <div style="flex:1;">
                <div style="height:6px;background:#E2E8F0;border-radius:3px;width:70%;margin-bottom:4px;"></div>
                <div style="height:5px;background:#E2E8F0;border-radius:3px;width:40%;"></div>
              </div>
              <div style="background:#DCFCE7;border-radius:4px;padding:3px 7px;font-size:8px;color:#16A34A;font-weight:700;">EN VIVO</div>
            </div>
            <div style="background:white;border-radius:8px;padding:10px 12px;display:flex;align-items:center;gap:10px;box-shadow:0 1px 4px rgba(0,0,0,.08);">
              <div style="width:36px;height:36px;background:#7C3AED;border-radius:6px;flex-shrink:0;"></div>
              <div style="flex:1;">
                <div style="height:6px;background:#E2E8F0;border-radius:3px;width:80%;margin-bottom:4px;"></div>
                <div style="height:5px;background:#E2E8F0;border-radius:3px;width:50%;"></div>
              </div>
              <div style="background:#DCFCE7;border-radius:4px;padding:3px 7px;font-size:8px;color:#16A34A;font-weight:700;">EN VIVO</div>
            </div>
            <div style="background:white;border-radius:8px;padding:10px 12px;display:flex;align-items:center;gap:10px;box-shadow:0 1px 4px rgba(0,0,0,.08);">
              <div style="width:36px;height:36px;background:#F59E0B;border-radius:6px;flex-shrink:0;"></div>
              <div style="flex:1;">
                <div style="height:6px;background:#E2E8F0;border-radius:3px;width:60%;margin-bottom:4px;"></div>
                <div style="height:5px;background:#E2E8F0;border-radius:3px;width:45%;"></div>
              </div>
              <div style="background:#FEF3C7;border-radius:4px;padding:3px 7px;font-size:8px;color:#D97706;font-weight:700;">BORRADOR</div>
            </div>
          </div>
        </div>
      </div>
      </div>
  </div>
</section>

<!-- ══ FEATURES ══ -->
<section class="art-feats">
  <div class="art-feats-inner">
    <p class="art-section-label">Funcionalidades clave</p>
    <h2 class="art-section-title">Todo lo que puedes hacer con Reach 360</h2>
    <p class="art-section-sub">Incluido en tu suscripción Articulate 360 con soporte en español de TAEC.</p>
    <div class="art-feat-grid">
        <div class="art-feat-card">
          <div class="art-feat-icon">🚀</div>
          <h3 class="art-feat-title">Publica en minutos</h3>
          <p class="art-feat-desc">Sube cursos de Rise, Storyline o de terceros y compártelos con un enlace.</p>
        </div>
        <div class="art-feat-card">
          <div class="art-feat-icon">👷</div>
          <h3 class="art-feat-title">Audiencias externas</h3>
          <p class="art-feat-desc">Capacita a trabajadores sin escritorio, contratistas, socios y clientes.</p>
        </div>
        <div class="art-feat-card">
          <div class="art-feat-icon">📈</div>
          <h3 class="art-feat-title">Seguimiento completo</h3>
          <p class="art-feat-desc">Analiza la actividad de los alumnos con informes exportables y dashboards.</p>
        </div>
        <div class="art-feat-card">
          <div class="art-feat-icon">💰</div>
          <h3 class="art-feat-title">Precios flexibles</h3>
          <p class="art-feat-desc">Gestiona necesidades de formación variable con modelo de precios por uso.</p>
        </div>
        <div class="art-feat-card">
          <div class="art-feat-icon">🔗</div>
          <h3 class="art-feat-title">Se integra con tu LMS</h3>
          <p class="art-feat-desc">Complementa —no reemplaza— tu LMS actual para audiencias de difícil acceso.</p>
        </div>
        <div class="art-feat-card">
          <div class="art-feat-icon">📤</div>
          <h3 class="art-feat-title">Múltiples formatos</h3>
          <p class="art-feat-desc">Publica en Reach 360, LMS (SCORM), web o PDF desde un mismo proyecto.</p>
        </div>
    </div>
  </div>
</section>

<!-- ══ PRICING ══ -->
<section class="art-pricing-public">
  <div class="art-pricing-inner">
    <div class="art-pricing-card">
      <div class="art-pricing-col-left">
        <div class="art-pricing-icon">🚀</div>
        <h3 class="art-pricing-name">Reach Pro</h3>
      </div>
      <div class="art-pricing-col-center">
        <ul class="art-pricing-features">
          <li><span class="feat-check">✓</span> Distribuye los cursos en unos pocos clics</li>
          <li><span class="feat-check">✓</span> Implementación cero</li>
          <li><span class="feat-check">✓</span> Reportes y análisis robustos del alumnado</li>
          <li><span class="feat-check">✓</span> Gestión sencilla de contenidos, usuarios y alumnado</li>
          <li><span class="feat-check">✓</span> Paneles de control intuitivos para el alumnado</li>
          <li><span class="feat-check">✓</span> Integración nativa de Articulate 360</li>
        </ul>
      </div>
      <div class="art-pricing-col-right">
        <span class="price-label">A partir de</span>
        <div class="price-amount">$3,600</div>
        <div class="price-period">USD · 1,200 estudiantes activos / año</div>
        <div class="price-note">Solo disponible a través del contacto de ventas</div>
      </div>
    </div>
  </div>
</section>

<!-- ══ QUOTE ══ -->
<section class="art-quote">
  <div class="art-quote-inner">
    <p class="art-quote-text">""Reach 360 nos permitió capacitar a nuestra red de distribuidores en 12 países sin necesidad de un LMS adicional.""</p>
    <p class="art-quote-author">Director de Operaciones</p>
    <p class="art-quote-role">Empresa de distribución · cliente TAEC</p>
  </div>
</section>

<!-- ══ CTA BAND ══ -->
<section class="art-cta-band">
  <div style="max-width:700px;margin:0 auto;">
    <h2>¿Listo para probar Reach 360?</h2>
    <p>Como partner oficial de Articulate en México, TAEC te ofrece demo en español, onboarding y soporte local.</p>
    <div class="art-cta-btns">
      <a href={vendors.articulate.trial} target="_blank" rel="noopener noreferrer" class="btn-cta-white">Descargar prueba (30 días) →</a>
      <a href={getBookingUrl('articulate')} class="btn-cta-ghost">Hablar con un especialista</a>
    </div>
  </div>
</section>
</main>
</BaseLayout>
