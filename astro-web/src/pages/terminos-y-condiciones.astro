    font-family: 'Inter', system-ui, sans-serif;
  }
  .legal-wrapper {
    max-width: 800px;
    margin: 0 auto;
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.01);
    overflow: hidden;
  }
  .legal-content {
    padding: 60px;
    color: #334155;
  }
  .legal-content h1 {
    font-size: 2.25rem;
    font-weight: 800;
    color: #0f172a;
    margin: 0 0 0.5rem 0;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .subtitle {
    font-size: 1.1rem;
    color: #64748b;
    margin-bottom: 2.5rem !important;
    font-weight: 500;
  }
  .legal-content p {
    margin-bottom: 1.25rem;
    line-height: 1.75;
    font-size: 1.05rem;
  }
  @media (max-width: 640px) {
    .legal-container { padding: 40px 16px; }
    .legal-content { padding: 32px 24px; }
