---
// CHANGELOG: 2026-05-03 - Recortar título SEO a max 60 chars (Issue #216)
import VyondNav from "../components/ui/VyondNav.astro";
import { contactData, getBookingUrl } from "../data/contact";
import BaseLayout from "../layouts/BaseLayout.astro";

import { base, r } from "../utils/paths";
---

<BaseLayout 
  title="Vyond Professional en México | Video Corporativo | TAEC"
  description="Escala la producción de video de capacitación con Vyond Professional. Colaboración de equipo, más créditos IA y soporte prioritario. Partner oficial en México."
  section="Soluciones"
  page="vyond-professional.html"
>
<style is:global>
  .vp-hero{padding:80px 5%;color:white}
  .vp-hero-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:48px;align-items:center}
  .vp-logo-pill img{height:20px;width:auto}
  .vp-logo-pill{display:inline-block;background:white;padding:6px 16px;border-radius:20px;margin-bottom:16px}
  .vp-tag{display:inline-block;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:700;margin-bottom:16px}
  .vp-hero h1{font-size:clamp(32px,4vw,48px);font-weight:900;line-height:1.1;margin-bottom:20px}
  .vp-hero-sub{font-size:18px;color:rgba(255,255,255,.9);margin-bottom:32px;line-height:1.5}
  .vp-btns{display:flex;gap:16px;align-items:center}
  .btn-vp-primary{padding:12px 24px;border-radius:8px;font-weight:700;text-align:center}
  .btn-vp-ghost{padding:12px 24px;border-radius:8px;font-weight:700;color:white;border:1px solid rgba(255,255,255,.3);text-align:center}
  .vp-hero-card{background:rgba(0,0,0,.2);border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:32px}
  .vp-hero-feats{display:flex;flex-direction:column;gap:12px}
  .vp-feat{display:flex;align-items:flex-start;gap:10px;font-size:14px;color:rgba(255,255,255,.9)}
  .vp-feat-check{color:#FFCBA4;font-weight:700}
  
  .plan-cards{padding:80px 5%;background:#F8FAFC}
  .plan-cards-inner{max-width:1100px;margin:0 auto}
  .plan-section-title{font-size:22px;font-weight:800;color:#111827;margin-bottom:6px;text-align:center}
  .plan-section-sub{text-align:center;color:#64748B;font-size:14px;margin-bottom:36px;margin-left:auto;margin-right:auto}
  .plan-cards-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:24px;margin-top:40px}
  .plan-card{background:white;border-radius:16px;padding:32px;border:1px solid var(--border);position:relative;display:flex;flex-direction:column}
  .plan-card.current{border-color:#C84D16;box-shadow:0 10px 30px rgba(0,0,0,.05)}
  .plan-card-badge{position:absolute;top:-12px;left:32px;background:#C84D16;color:white;font-size:11px;font-weight:800;padding:4px 12px;border-radius:20px;text-transform:uppercase}
  .plan-card-name{font-size:24px;font-weight:800;color:#111827;margin-bottom:8px}
  .plan-card-desc{font-size:14px;color:#64748B;margin-bottom:24px;padding-bottom:24px;border-bottom:1px solid var(--border)}
  .plan-card-feats{list-style:none;padding:0;margin:0 0 32px 0;display:flex;flex-direction:column;gap:12px;flex:1}
  .plan-card-feats li{position:relative;padding-left:24px;font-size:14px;color:#334155}
  .plan-card-feats li::before{content:"✓";position:absolute;left:0;color:#C84D16;font-weight:700}
  .plan-card-cta{text-align:center;padding:12px;border-radius:8px;font-weight:700;display:block}
  .plan-card-cta-primary{background:#111827;color:white}
  .plan-card-cta-outline{border:1px solid var(--border);color:#111827}
  
  .feat-section{padding:80px 5%;background:white}
  .feat-inner{max-width:1100px;margin:0 auto}
  .feat-title{font-size:32px;font-weight:800;color:#111827;text-align:center;margin-bottom:16px}
  .feat-sub{font-size:16px;color:#64748B;text-align:center;margin-bottom:48px;max-width:600px;margin-inline:auto}
  .feat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:32px}
  .feat-card{background:#F8FAFC;padding:24px;border-radius:12px}
  .feat-icon{font-size:32px;margin-bottom:16px}
  .feat-name{font-size:18px;font-weight:700;color:#111827;margin-bottom:8px}
  .feat-desc{font-size:14px;color:#475569;line-height:1.5}
  
  .usecase-section{padding:80px 5%;background:#F8FAFC}
  .usecase-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 2fr;gap:48px}
  .usecase-label{font-size:11px;font-weight:700;color:#C84D16;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}
  .usecase-title{font-size:32px;font-weight:800;color:#111827;margin-bottom:16px;line-height:1.1}
  .usecase-sub{font-size:16px;color:#64748B;line-height:1.5}
  .usecase-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
  .usecase-card{background:white;padding:24px;border-radius:12px;border:1px solid var(--border)}
  .usecase-card-title{font-size:16px;font-weight:700;color:#111827;margin-bottom:8px}
  .usecase-card-desc{font-size:14px;color:#64748B;line-height:1.5}
  
  .vp-cta{padding:80px 5%;background:linear-gradient(135deg,#1a0a00 0%,#3d1200 100%);text-align:center}
  .vp-cta h2{font-size:clamp(28px,3vw,36px);font-weight:800;color:white;margin-bottom:16px}
  .vp-cta p{font-size:18px;color:rgba(255,255,255,.8);margin-bottom:40px;max-width:600px;margin-inline:auto}
  .vp-cta-btns{display:flex;gap:16px;justify-content:center}
  .btn-cta-white{background:white;color:#C84D16;padding:14px 28px;border-radius:8px;font-weight:700;display:inline-block}
  .btn-cta-outline{border:2px solid rgba(255,255,255,.3);color:white;padding:14px 28px;border-radius:8px;font-weight:700;display:inline-block}

  @media(max-width:768px){
    .vp-hero-inner, .usecase-inner{grid-template-columns:1fr}
    .usecase-grid{grid-template-columns:1fr}
  }
</style>

<main id="main-content">
<VyondNav />

<!-- hero -->
<section class="vp-hero" style="background:linear-gradient(135deg, #1a0a00 0%, #3d1200 55%, #C84D16 100%)">
  <div class="vp-hero-inner">
    <div>
      <div class="vp-logo-pill"><img src={`${base}assets/logos/vyond.svg`} alt="Vyond" /></div>
      <span class="vp-tag" style="background:rgba(200,77,22,.25);color:#FFCBA4">Para equipos L&D · Múltiples usuarios</span>
      <h1>Escala la producción de video de <em style="color:#FFCBA4">tu equipo</em></h1>
      <p class="vp-hero-sub">La opción ideal para áreas de Capacitación y L&D que necesitan producir volúmenes mayores de video animado con colaboración entre varios diseñadores.</p>
      <div class="vp-btns">
        <a href={r('/contacto')} class="btn-vp-primary" style="background:white;color:#C84D16">Solicitar cotización →</a>
        <a href={getBookingUrl('vyond')} class="btn-vp-ghost">Hablar con un especialista</a>
      </div>
    </div>
    <div class="vp-hero-card">
      <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:#FFCBA4;margin-bottom:16px">Incluido en Vyond Professional</div>
      <div class="vp-hero-feats"><div class="vp-feat"><span class="vp-feat-check">✓</span><span>Todo lo incluido en Starter</span></div>
<div class="vp-feat"><span class="vp-feat-check">✓</span><span>5,000 créditos de IA al mes — más capacidad de generación</span></div>
<div class="vp-feat"><span class="vp-feat-check">✓</span><span>Compartir proyectos y plantillas entre miembros del equipo</span></div>
<div class="vp-feat"><span class="vp-feat-check">✓</span><span>Videos de hasta 40 minutos de duración</span></div>
<div class="vp-feat"><span class="vp-feat-check">✓</span><span>Soporte prioritario con tiempos de respuesta más rápidos</span></div>
<div class="vp-feat"><span class="vp-feat-check">✓</span><span>Acceso a templates corporativos y recursos adicionales</span></div></div>
    </div>
  </div>
</section>

<!-- plan comparison -->
<section class="plan-cards">
  <div class="plan-cards-inner">
    <h2 class="plan-section-title">Compara los planes Vyond</h2>
    <p class="plan-section-sub">Elige el plan que mejor se adapta al tamaño y necesidades de tu equipo</p>
    <div class="plan-cards-grid">
<div class="plan-card current">
      <div class="plan-card-badge">Plan actual</div>
      <div class="plan-card-name">Vyond Professional</div>
      <div class="plan-card-desc">Desde USD $55 / usuario / mes</div>
      <ul class="plan-card-feats"><li>Todo Starter incluido</li>
<li>5,000 créditos IA/mes</li>
<li>Colaboración de equipo</li>
<li>Videos hasta 40 min</li></ul>
      <a href={r('/contacto')} class="plan-card-cta plan-card-cta-primary">Solicitar cotización</a>
    </div>
<div class="plan-card">
      
      <div class="plan-card-name">Vyond Enterprise</div>
      <div class="plan-card-desc">Precio personalizado — consultar</div>
      <ul class="plan-card-feats"><li>Todo Professional incluido</li>
<li>Créditos IA ilimitados</li>
<li>SSO / SCIM / API</li>
<li>Videos hasta 90 min</li></ul>
      <a href={r('/vyond-enterprise')} class="plan-card-cta plan-card-cta-outline">Ver plan →</a>
    </div></div>
  </div>
</section>

<!-- features -->
<section class="feat-section">
  <div class="feat-inner">
    <h2 class="feat-title">Todo lo que incluye Professional</h2>
    <p class="feat-sub">Pensado para equipos que necesitan producir más contenido, colaborar eficientemente y mantener coherencia de marca en todos sus videos.</p>
    <div class="feat-grid"><div class="feat-card"><div class="feat-icon">👥</div><div class="feat-name">Colaboración de equipo</div><div class="feat-desc">Comparte proyectos, escenas y plantillas entre todos los miembros. Mantén la consistencia de marca con un repositorio compartido.</div></div>
<div class="feat-card"><div class="feat-icon">⚡</div><div class="feat-name">5,000 créditos IA/mes</div><div class="feat-desc">Mayor capacidad para generar videos con Vyond Go. Produce más en menos tiempo con el poder de la inteligencia artificial.</div></div>
<div class="feat-card"><div class="feat-icon">🎞️</div><div class="feat-name">Videos hasta 40 min</div><div class="feat-desc">Ideal para cursos completos, inducciones corporativas y módulos de capacitación de larga duración.</div></div>
<div class="feat-card"><div class="feat-icon">🎨</div><div class="feat-name">Plantillas de marca</div><div class="feat-desc">Crea y comparte plantillas con los colores, tipografías y elementos visuales de tu empresa para toda el área de L&D.</div></div>
<div class="feat-card"><div class="feat-icon">🔔</div><div class="feat-name">Soporte prioritario</div><div class="feat-desc">Acceso a soporte técnico con tiempos de respuesta mejorados. Complementado con la atención en español de TAEC.</div></div>
<div class="feat-card"><div class="feat-icon">📊</div><div class="feat-name">Reportes de uso</div><div class="feat-desc">Visualiza el consumo de créditos y producción del equipo para optimizar recursos y planificar capacidades.</div></div></div>
  </div>
</section>

<!-- use cases -->
<section class="usecase-section">
  <div class="usecase-inner">
    <div>
      <div class="usecase-label">¿Para quién?</div>
      <h2 class="usecase-title">¿Para quién es Vyond Professional?</h2>
      <p class="usecase-sub">Professional está diseñado para equipos de Capacitación, L&D y Recursos Humanos en organizaciones medianas y grandes que producen video de forma continua.</p>
      <a href={r('/vyond-mexico')} style="display:inline-block;margin-top:20px;font-size:13px;font-weight:600;color:var(--vy)">← Ver todos los planes Vyond</a>
    </div>
    <div class="usecase-grid"><div class="usecase-card"><div class="usecase-card-title">🏢 Áreas de Capacitación corporativa</div><div class="usecase-card-desc">Produce cursos de inducción, compliance, habilidades técnicas y soft skills con una sola herramienta para todo el equipo.</div></div>
<div class="usecase-card"><div class="usecase-card-title">📚 Equipos de L&D</div><div class="usecase-card-desc">Diseña y produce experiencias de aprendizaje basadas en video sin depender de proveedores externos o agencias.</div></div>
<div class="usecase-card"><div class="usecase-card-title">👔 Departamentos de RRHH</div><div class="usecase-card-desc">Comunica políticas, procedimientos y cambios organizacionales con videos animados claros y profesionales.</div></div>
<div class="usecase-card"><div class="usecase-card-title">🌐 Empresas con múltiples sedes</div><div class="usecase-card-desc">Distribuye el mismo video en diferentes idiomas gracias a la localización automática por IA de Vyond.</div></div></div>
  </div>
</section>

<!-- cta band -->
<section class="vp-cta">
  <h2>¿Tu equipo está listo para producir más video?</h2>
  <p>Solicita una demo personalizada para tu equipo o cotiza las licencias anuales con soporte TAEC incluido.</p>
  <div class="vp-cta-btns">
    <a href={r('/contacto')} class="btn-cta-white" style="color:#C84D16">Solicitar cotización →</a>
    <a href={contactData.whatsapp.url} target="_blank" rel="noopener noreferrer" class="btn-cta-outline">WhatsApp TAEC</a>
  </div>
</section>

</main>
</BaseLayout>
