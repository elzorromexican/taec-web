---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
function r(url: string): string {
  if (!url || url.startsWith('http://') || url.startsWith('https://') || url.startsWith('//')) return url;
  return base.replace(/\/$/, '') + url;
}
---

<BaseLayout 
  title="Blog TAEC – e-learning, L&D y tecnología educativa | TAEC"
  description="Tendencias, noticias y reflexiones del mundo e-learning en México y LATAM. Publicaciones sobre herramientas, metodologías y estrategia L&D."
  section="Recursos"
  page="blog.html"
>
  <style is:global>

    .nav-item::after { display: none !important; }
    .nav-item.open > .mega-menu { display: grid !important; }
    .nav-item.open > .simple-dropdown { display: grid !important; }
    .nav-item.open > .nav-link { background: var(--light); color: var(--blue); }
    .nav-item.open > .nav-link svg { transform: rotate(180deg); }

    /* ── HERO ── */
    .blog-hero { background: linear-gradient(135deg, #001f3d 0%, #004775 60%, #0077b6 100%); padding: 56px 5% 64px; color: white; }
    .blog-hero-inner { max-width: 1100px; margin: 0 auto; }
    .blog-breadcrumb { font-size: 13px; color: rgba(255,255,255,.5); margin-bottom: 20px; }
    .blog-breadcrumb a { color: rgba(255,255,255,.5); transition: color .15s; }
    .blog-breadcrumb a:hover { color: white; }
    .blog-breadcrumb span { margin: 0 6px; }
    .blog-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--teal); margin-bottom: 12px; }
    .blog-hero h1 { font-family: var(--font-display); font-size: clamp(28px, 3.5vw, 44px); font-weight: 400; color: white; line-height: 1.2; margin-bottom: 12px; }
    .blog-hero-sub { font-size: 16px; color: rgba(255,255,255,.7); max-width: 560px; }

    /* ── CONTROLES ── */
    .blog-controls { background: var(--white); border-bottom: 1px solid var(--border); padding: 20px 5%; position: sticky; top: 68px; z-index: 100; }
    .blog-controls-inner { max-width: 1100px; margin: 0 auto; display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
    .blog-search { flex: 1; min-width: 200px; position: relative; }
    .blog-search input { width: 100%; border: 1.5px solid var(--border); border-radius: 8px; padding: 10px 16px 10px 40px; font-size: 14px; font-family: var(--font-body); color: var(--text); background: var(--light); outline: none; transition: border-color .15s; }
    .blog-search input:focus { border-color: var(--blue); background: white; }
    .blog-search svg { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: #94A3B8; pointer-events: none; }
    .blog-count { font-size: 13px; color: #64748B; white-space: nowrap; flex-shrink: 0; }

    /* ── FILTROS ── */
    .blog-filters { padding: 16px 5% 0; background: var(--white); }
    .blog-filters-inner { max-width: 1100px; margin: 0 auto; display: flex; gap: 8px; flex-wrap: wrap; padding-bottom: 16px; border-bottom: 1px solid var(--border); }
    .filter-tag { font-size: 12px; font-weight: 600; padding: 5px 12px; border-radius: 20px; border: 1.5px solid var(--border); color: #64748B; background: var(--white); cursor: pointer; transition: all .15s; white-space: nowrap; }
    .filter-tag:hover { border-color: var(--blue); color: var(--blue); }
    .filter-tag.active { background: var(--navy); color: white; border-color: var(--navy); }

    /* ── POSTS GRID ── */
    .blog-main { padding: 40px 5% 72px; }
    .blog-main-inner { max-width: 1100px; margin: 0 auto; }
    .blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }

    /* ── POST CARD ── */
    .post-card { background: var(--white); border: 1.5px solid var(--border); border-radius: 14px; padding: 24px; display: flex; flex-direction: column; gap: 0; transition: box-shadow .2s, transform .2s, border-color .2s; cursor: pointer; }
    .post-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,.08); transform: translateY(-2px); border-color: #CBD5E1; }
    .post-card-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; flex-wrap: wrap; }
    .post-tag { font-size: 10px; font-weight: 700; letter-spacing: .8px; text-transform: uppercase; padding: 3px 8px; border-radius: 4px; background: #EFF6FF; color: var(--blue); border: 1px solid #BFDBFE; }
    .post-date { font-size: 12px; color: #94A3B8; }
    .post-card h3 { font-size: 15px; font-weight: 700; color: var(--text); line-height: 1.4; margin-bottom: 10px; }
    .post-card p { font-size: 13px; color: #64748B; line-height: 1.7; flex: 1; }

    /* ── EMPTY STATE ── */
    .blog-empty { text-align: center; padding: 64px 24px; display: none; }
    .blog-empty p { font-size: 15px; color: #94A3B8; }

    /* ── REC TABS ── */
    .rec-tabs{background:#F8FAFC;border-bottom:1px solid var(--border);padding:0 5%;overflow-x:auto}
    .rec-tabs-inner{max-width:1100px;margin:0 auto;display:flex;gap:0}
    .rec-tab{display:inline-flex;align-items:center;padding:14px 18px;font-size:13px;font-weight:600;color:#64748B;border-bottom:3px solid transparent;transition:color .15s,border-color .15s;white-space:nowrap;text-decoration:none}
    .rec-tab:hover{color:var(--blue)}
    .rec-tab.active{color:var(--navy);border-bottom-color:var(--navy)}
  
  </style>

<main id="main-content">

<!-- ══ HERO ══ -->
<section class="blog-hero">
  <div class="blog-hero-inner">
    <p class="blog-breadcrumb"><a href={r('/recursos')}>Recursos</a><span>›</span>Blog</p>
    <p class="blog-eyebrow">Blog TAEC</p>
    <h1>E-learning, L&D y tecnología educativa</h1>
    <p class="blog-hero-sub">Tendencias, herramientas y reflexiones del mundo del aprendizaje corporativo en México y LATAM.</p>
  </div>
</section>

<!-- ══ CONTROLES ══ -->
<div class="blog-controls">
  <div class="blog-controls-inner">
    <div class="blog-search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="search" id="blogSearch" placeholder="Buscar por título o tema…" aria-label="Buscar posts" />
    </div>
    <span class="blog-count" id="blogCount"></span>
  </div>
</div>

<!-- ══ FILTROS ══ -->
<div class="blog-filters">
  <div class="blog-filters-inner" id="filterBar">
    <!-- Generado por JS desde los datos -->
  </div>
</div>

<!-- ══ POSTS ══ -->
<section class="blog-main">
  <div class="blog-main-inner">
    <div class="blog-grid" id="blogGrid">
      <!-- INICIO_POSTS — generado por Apps Script -->
      <!-- FIN_POSTS -->
    </div>
    <div class="blog-empty" id="blogEmpty">
      <p>No se encontraron posts con ese criterio.</p>
    </div>
  </div>
</section>

</main>
</BaseLayout>
