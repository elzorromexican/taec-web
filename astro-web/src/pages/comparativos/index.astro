---
import { getCollection } from "astro:content";
import HeroComercial from "../../components/ui/HeroComercial.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const items = await getCollection("comparativos");
---

<BaseLayout 
  title="Comparativos | Herramientas e-learning TAEC"
  description="Comparativos prácticos de plataformas LMS, herramientas de autoría y soluciones tecnológicas para proyectos de e-learning."
  section="Recursos"
  page="comparativos.html"
>
  <HeroComercial 
    eyebrow="TAEC · Recursos"
    titleHtml="<span class='text-accent'>Comparativos</span> de Herramientas"
    subtitle="Análisis estructurados de LMS, herramientas de autoría y software de creación para potenciar tu stack tecnológico."
    theme="general"
    cardBadgeText="Toma de Decisiones ⚖️"
    features={[
      "Elegir una plataforma errónea le cuesta en promedio a las empresas $20k USD por pérdida de tiempo y despliegue.",
      "El 45% de los corporativos latinoamericanos abandonan su Sistema de Gestión (LMS) al tercer año de contrato por falta de escalabilidad técnica.",
      "Compara métricas ocultas: nivel de personalización de código, costo real de soporte técnico regional y capacidad de integraciones API."
    ]}
  />

  <main style="max-width: 960px; margin: 64px auto; padding: 0 24px 80px;">
    
    <div style="display: flex; align-items: baseline; justify-content: space-between; border-bottom: 2px solid #1c1917; padding-bottom: 10px; margin-bottom: 32px;">
      <h2 style="font-family: var(--font-display, Georgia, serif); font-size: 1.5rem; font-weight: 700;">Directorios Comparativos</h2>
      <span style="font-family: monospace; font-size: 11px; color: #78716c; text-transform: uppercase;">{items.length} comparativos</span>
    </div>

    <div style="display: flex; flex-direction: column; gap: 20px;">
      {items.map(item => {
        return (
          <details class="comp-accordion" style="border: 1px solid #e7e3db; border-radius: 8px; background: #ffffff; overflow: hidden; transition: box-shadow 0.15s;">
            <summary style="list-style: none; cursor: pointer; padding: 24px 28px; user-select: none; display: flex; align-items: flex-start; gap: 16px;">
              <div style="flex: 1;">
                <h3 style="font-family: var(--font-body, sans-serif); font-size: 1.1rem; font-weight: 700; color: #1c1917; line-height: 1.3; margin-top: 0; margin-bottom: 8px;">
                  {item.data.title}
                </h3>
                {item.data.description && (
                  <p style="font-size: 14px; color: #44403c; line-height: 1.5; margin: 0;">
                    {item.data.description}
                  </p>
                )}
                {item.data.date && (
                  <div style="font-family: monospace; font-size: 10px; color: #78716c; margin-top: 12px; text-transform: uppercase;">
                    Actualizado: {item.data.date}
                  </div>
                )}
              </div>
              <div class="comp-chevron" style="font-size: 24px; line-height: 1; color: #1d4ed8; transition: transform 0.2s;">
                &darr;
              </div>
            </summary>
            
            <div class="comp-body-content" style="padding: 0 28px 28px; overflow-x: auto;">
              <!-- El contenido Markdown de la tabla extraída -->
              <div class="prose-table" set:html={item.body} />
            </div>
          </details>
        )
      })}
    </div>

  </main>
</BaseLayout>

<style is:global>
.comp-accordion[open] { box-shadow: 0 4px 16px rgba(0,0,0,0.05); border-color: #dce7f9; }
.comp-accordion[open] summary { border-bottom: 1px solid #e7e3db; margin-bottom: 20px; }
.comp-accordion[open] .comp-chevron { transform: rotate(180deg); }

.prose-table table { width: 100%; border-collapse: collapse; font-size: 13px; font-family: var(--font-body, sans-serif); }
.prose-table th { font-family: monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; background: #1c1917; color: #fff; padding: 12px 16px; text-align: left; }
.prose-table td { padding: 12px 16px; border-bottom: 1px solid #e7e3db; vertical-align: top; color: #44403c; }
.prose-table tr:hover td { background: #eff6ff; }
.prose-table a { color: #1d4ed8; text-decoration: none; }
.prose-table a:hover { text-decoration: underline; }

.prose-table th.col-hl { background: #1d4ed8; color: #fff; }
.prose-table td.col-hl { background: #f8fafc; font-weight: 600; color: #1e40af; }
.prose-table tr:hover td.col-hl { background: #dbeafe; }
</style>
