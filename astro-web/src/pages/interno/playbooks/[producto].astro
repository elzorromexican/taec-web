---
export const prerender = false;

import IntranetLayout from '../../../layouts/IntranetLayout.astro';
import KBViewer from '../../../components/interno/KBViewer';
import { supabase } from '../../../lib/supabase';

// En Astro SSR, el parametro dinámico se extrae directamente
const { producto } = Astro.params;

if (!producto) {
  return Astro.redirect('/interno/dashboard');
}

// Usamos el token fresco que el middleware validó (puede haber renovado el JWT)
// Nunca leer el cookie directamente: puede estar expirado si setSession() lo refrescó
const accessToken = Astro.locals.accessToken || "";

// Re-instanciamos Supabase inyectando el header de Auth
import { createClient } from '@supabase/supabase-js';
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const scopedSupabase = createClient(supabaseUrl, supabaseAnonKey, {
  global: { headers: { Authorization: `Bearer ${accessToken}` } }
});

// Sacamos los contenidos de la base de datos de manera dinámica
const { data: kbItems, error } = await scopedSupabase
  .from('kb_items')
  .select('*')
  .eq('producto', producto) 
  .contains('audiencia', ['interno'])
  .order('orden', { ascending: true });

if (error) {
  console.error("Error cargando KB para:", producto, error);
}

// Mapeo exhaustivo para unificar las secciones de todos los productos
const CATEGORY_MAP: Record<string, { id: string, label: string, color: string, order: number }> = {
  comercial: { id: 'comercial', label: 'La Matriz Comercial', color: '#185FA5', order: 1 },
  tecnica: { id: 'tecnica', label: 'La Matriz Técnica', color: '#0F6E56', order: 2 },
  troubleshooting: { id: 'troubleshooting', label: 'Troubleshooting', color: '#D85A30', order: 3 },
  objeciones: { id: 'objeciones', label: 'Las Objeciones', color: '#993556', order: 4 },
};

const LEGACY_MAP: Record<string, string> = {
  'tecnico': 'tecnica',
  'ventas': 'comercial',
  'pre-ventas': 'comercial',
  'uso': 'tecnica',
  'admin': 'tecnica',
  'soporte': 'troubleshooting',
  'errores': 'troubleshooting'
};

// Extraemos las secciones presentes para generar los tabs y las unificamos.
const seccionesMap = new Map();
if (kbItems) {
  kbItems.forEach((item: any) => {
    let baseId = item.seccion?.toLowerCase() || 'comercial';
    let mappedId = LEGACY_MAP[baseId] || baseId;

    if (CATEGORY_MAP[mappedId]) {
      item.seccion = CATEGORY_MAP[mappedId].id;
      item.seccion_label = CATEGORY_MAP[mappedId].label;
      item.seccion_color = CATEGORY_MAP[mappedId].color;
      item.cat_order = CATEGORY_MAP[mappedId].order;
    } else {
      item.cat_order = 99;
    }

    if (!seccionesMap.has(item.seccion)) {
      seccionesMap.set(item.seccion, {
        id: item.seccion,
        label: item.seccion_label,
        color: item.seccion_color,
        order: item.cat_order
      });
    }
  });
}
const seccionesList = Array.from(seccionesMap.values()).sort((a: any, b: any) => a.order - b.order);

// Diccionario opcional para capitalizar o mejorar los nombres en la UI
const titles: Record<string, string> = {
  'rise360': 'Rise 360',
  'storyline360': 'Storyline 360',
  'review360': 'Review 360',
  'reach360': 'Reach 360',
  'aiassistant': 'AI Assistant',
  'localization': 'Localization',
  'vyondgo': 'Vyond Go (IA)',
  'vyondstudio': 'Vyond Studio',
  'vyondmobile': 'Vyond Mobile',
  'vyondenterprise': 'Vyond Enterprise',
  'vyondprofessional': 'Vyond Professional',
  'moodle': 'Moodle Workspace',
  'totara': 'Totara LMS',
  'pifinilearn': 'Pifini Learn',
  'ottolearn': 'Ottolearn',
  'lys': 'Lys LMS',
  'ddc': 'Desarrollo de Contenidos (DDC)',
  'class': 'Class (Videoclases)',
  'proctorizer': 'Proctorizer',
  'strikeplagiarism': 'StrikePlagiarism',
  '7minutes': '7minutes Microlearning',
  'customguide': 'Custom Guide'
};
const displayName = titles[producto] || producto.toUpperCase();

// Consultamos los metadatos visuales del producto
const { data: playbookMeta } = await scopedSupabase
  .from('kb_playbooks')
  .select('*')
  .eq('id_producto', producto)
  .single();

let heroPattern = 'pattern-grid';
let heroIconKey = 'box';

// Fallback por defecto si no existe en BD
let pageMetadata = [
  { label: 'Categoría SaaS', value: 'EdTech / e-Learning' },
  { label: 'Distribución', value: 'Vía Partner Exclusivo' },
  { label: 'Soporte', value: 'Gestionado por TAEC' }
];

if (playbookMeta) {
  if (playbookMeta.familia === 'vyond') heroPattern = 'pattern-dots';
  else if (playbookMeta.familia === 'lms') heroPattern = 'pattern-boxes';
  else if (playbookMeta.familia === 'servicios') heroPattern = 'pattern-waves';
  else heroPattern = 'pattern-grid';

  heroIconKey = playbookMeta.svg_icon || 'box';

  pageMetadata = [];
  if (playbookMeta.meta_l1) pageMetadata.push({ label: playbookMeta.meta_l1, value: playbookMeta.meta_v1 || '' });
  if (playbookMeta.meta_l2) pageMetadata.push({ label: playbookMeta.meta_l2, value: playbookMeta.meta_v2 || '' });
  if (playbookMeta.meta_l3) pageMetadata.push({ label: playbookMeta.meta_l3, value: playbookMeta.meta_v3 || '' });
}

const getSVGPath = (key: string) => {
  switch(key) {
    case 'clapperboard': return '<path d="M20.2 6 3 11l-.9-2.4c-.3-1.1.4-2.2 1.5-2.5l13.5-4c1.1-.3 2.2.4 2.5 1.5l.1.4Z"/><path d="m2.6 15.6 2.2-.6"/><path d="m7.8 14 2.2-.6"/><path d="m13 12.5 2.2-.6"/><path d="m18.2 11 2.2-.6"/><path d="m2 18 1.4-3.8"/><path d="m7 16.5 1.4-3.8"/><path d="m12 15 1.4-3.8"/><path d="m17 13.5 1.4-3.8"/><rect width="18" height="12" x="3" y="11" rx="2" ry="2"/>';
    case 'smartphone': return '<rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/>';
    case 'sparkles': return '<path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/>';
    case 'building': return '<rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/>';
    case 'check-circle': return '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/>';
    default: return '<rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><path d="M3 9h18"/><path d="M9 21V9"/>';
  }
}
---

<IntranetLayout title={`Playbook: ${displayName} | TAEC Hub`} description={`Base de conocimientos B2B para ${displayName}`}>
  
  <header class={`playbook-hero ${heroPattern}`}>
    <div class="hero-watermark">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" set:html={getSVGPath(heroIconKey)}></svg>
    </div>

    <div class="hero-inner">
      <div class="hero-eyebrow">Playbook Comercial</div>
      <h1 class="hero-title">{displayName}</h1>
      <p class="hero-desc">Documentación técnica, notas operativas y resoluciones estructuradas para el equipo de ventas TAEC. Vende con criterio, no con hype.</p>
      
      <div class="hero-metadata">
        {pageMetadata.map(md => (
          <div class="md-pill">
            <span class="md-label">{md.label}</span>
            <span class="md-value">{md.value}</span>
          </div>
        ))}
      </div>
    </div>
  </header>
  
  {kbItems && kbItems.length > 0 ? (
    <KBViewer 
      client:load 
      items={kbItems} 
      secciones={seccionesList} 
    />
  ) : (
    <div class="empty-state">
      <div class="empty-icon">🚧</div>
      <h3>Playbook en construcción</h3>
      <p>Aún no hay registros en la base de datos para el producto <strong>{producto}</strong>.</p>
      <p class="small">El equipo administrativo editar los datos desde Supabase en la tabla <code>kb_items</code> usando el label identificador <code>{producto}</code> en la columna <code>producto</code>.</p>
    </div>
  )}

</IntranetLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;500&display=swap');

  .playbook-hero {
    position: relative;
    overflow: hidden;
    background-color: #1B2A4A;
    padding: 3rem 2.5rem 2.5rem;
    border-bottom: 3px solid #FF6B35;
    border-radius: 12px;
    margin-bottom: 2rem;
    color: white;
    font-family: 'DM Sans', sans-serif;
  }

  /* WATERMARK (Opción 3 UX) */
  .hero-watermark {
    position: absolute;
    right: -2rem;
    bottom: -3.5rem;
    z-index: 1;
    pointer-events: none;
    opacity: 0.05;
    transform: rotate(-15deg);
  }
  .hero-watermark svg {
    width: 380px;
    height: 380px;
    color: #ffffff;
  }

  /* PATRONES MONOCROMÁTICOS (Opción 1 UX) */
  .pattern-grid {
    background-image: 
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 24px 24px;
  }
  .pattern-dots {
    background-image: radial-gradient(rgba(255,255,255,0.1) 1.5px, transparent 1.5px);
    background-size: 20px 20px;
  }
  .pattern-waves {
    background-image: repeating-radial-gradient(
      circle at 0 100%, 
      transparent 0, 
      transparent 12px, 
      rgba(255,255,255,0.03) 12px, 
      rgba(255,255,255,0.03) 13px
    );
  }
  .pattern-boxes {
    background-image: 
      linear-gradient(rgba(255,255,255,0.03) 2px, transparent 2px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 2px, transparent 2px),
      linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
    background-size: 60px 60px, 60px 60px, 12px 12px, 12px 12px;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 860px;
    margin: 0 auto;
  }
  .hero-eyebrow {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #0D9488;
    margin-bottom: 10px;
  }
  .hero-title {
    font-family: 'DM Serif Display', serif;
    font-size: 34px;
    color: white;
    line-height: 1.15;
    font-weight: 400;
    margin-top: 0;
    margin-bottom: 12px;
  }
  .hero-desc {
    font-size: 14px;
    color: rgba(255,255,255,0.7);
    max-width: 600px;
    line-height: 1.6;
    margin: 0;
  }

  /* METADATA PILLS (Opción 2) */
  .hero-metadata {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
  .md-pill {
    background: rgba(255,255,255,0.08);
    border: 1px dashed rgba(255,255,255,0.18);
    padding: 0.5rem 0.8rem;
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .md-label {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.55);
    font-weight: 600;
  }
  .md-value {
    font-size: 13px;
    color: white;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .empty-state {
    background: #fff;
    border: 1px dashed #cbd5e1;
    border-radius: 1rem;
    padding: 4rem 2rem;
    text-align: center;
    color: #64748b;
  }
  .empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }
  .empty-state h3 {
    margin: 0 0 0.5rem 0;
    color: #1e293b;
    font-size: 1.25rem;
  }
  .empty-state p { margin: 0; }
  .empty-state .small {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: #94a3b8;
  }
  .empty-state code {
    background: #f1f5f9;
    padding: 0.15rem 0.35rem;
    border-radius: 4px;
    color: #ef4444;
  }
</style>
