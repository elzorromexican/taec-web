---
/**
 * @name dashboard.astro
 * @version 1.1
 * @description Lobby corporativo y dashboard general de TAEC.
 * @inputs N/A
 * @outputs Renderizado de accesos directos
 * @dependencies IntranetLayout.astro
 * @created 2026-03-01
 * @updated 2026-04-04 12:12:00
 */
import IntranetLayout from '../../layouts/IntranetLayout.astro';
---

<IntranetLayout title="Dashboard Intranet | TAEC" description="Lobby corporativo">
  
  <!-- DASHBOARD HERO -->
  <div class="dashboard-hero">
    <h1>El Hub Comercial.</h1>
    <p>Bienvenido a la terminal central de herramientas, cotizadores y playbooks de TAEC.</p>
  </div>

  <!-- AVISOS IMPORTANTES (Hardcodeados temporalmente) -->
  <div class="dashboard-section mt-10">
    <h2 class="section-title">Novedades de la Semana</h2>
    
    <div class="news-grid">
      <div class="news-card important border-t-orange">
        <div class="news-badge orange">Uso Interno</div>
        <h3>Nueva versión del Cotizador DDC 2026</h3>
        <p>⚠️ <strong>Exclusivo para el equipo comercial TAEC.</strong> Hemos relocalizado la calculadora financiera de Desarrollo de Contenidos. Esta herramienta está diseñada para ayudarles a formular estimaciones rápidas de costos con sus prospectos. Ingresen desde el menú izquierdo en la pestaña "Cotizadores".</p>
        <span class="news-date">06 Abr 2026</span>
      </div>

      <div class="news-card border-t-blue">
        <div class="news-badge blue">Promoción Q2</div>
        <h3>Localization integrado (Uso Libre)</h3>
        <p>Articulate 360 ha integrado "Localization" de uso libre para traducir cursos internamente. <strong>Ojo:</strong> No se pueden exportar ni publicar sin adquirir el paquete base y los paquetes adicionales. Tenemos una promoción activa durante todo el Q2 con un <strong>25% de descuento</strong> en todos los paquetes de Localization.</p>
        <span class="news-date">06 Abr 2026</span>
      </div>
    </div>
  </div>

  <!-- QUICK LINKS (GOOGLE DRIVE ETC) -->
  <div class="dashboard-section mt-10">
    <h2 class="section-title">Accesos Directos (Drive)</h2>
    <div class="grid-links">
      <div class="quick-link-card disabled"
           title="Disponible próximamente — Fase 3"
           role="img"
           aria-label="Formatos Comerciales — no disponible aún">
        <span class="icon">📁</span>
        <h4>Formatos Comerciales</h4>
        <p>Abre el Drive general de ventas.</p>
      </div>
      <div class="quick-link-card disabled"
           title="Disponible próximamente — Fase 3"
           role="img"
           aria-label="Machotes de Contrato — no disponible aún">
        <span class="icon">📄</span>
        <h4>Machotes de Contrato</h4>
        <p>NDAs y plantillas pre-aprobadas.</p>
      </div>
      <div class="quick-link-card disabled"
           title="Disponible próximamente — Fase 3"
           role="img"
           aria-label="Zoho CRM — no disponible aún">
        <span class="icon">🔐</span>
        <h4>Zoho CRM</h4>
        <p>Atajo al sistema de Tickets.</p>
      </div>
    </div>
  </div>

</IntranetLayout>

<style>
  .dashboard-hero h1 {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #0f172a;
    margin: 0;
  }
  .dashboard-hero p {
    font-size: 1rem;
    color: #64748b;
    margin-top: 0.25rem;
  }
  .mt-10 { margin-top: 1.5rem; }
  .mt-4 { margin-top: 1rem; }
  
  .section-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid #e2e8f0;
    padding-bottom: 0.5rem;
  }

  .news-grid {
    display: grid;
    /* Fuerza estrictamente 2 columnas para no wrap */
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .news-card {
    background: #fff;
    /* Borde modular corporativo, sin sombra flotante */
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 1.25rem;
    box-shadow: none;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .border-t-orange { border-top: 3px solid #f97316; }
  .border-t-blue { border-top: 3px solid #3b82f6; }

  .news-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }
  .news-badge.orange { background: #ffedd5; color: #c2410c; }
  .news-badge.blue { background: #dbeafe; color: #1d4ed8; }

  .news-card h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.1rem;
    color: #0f172a;
  }
  .news-card p {
    margin: 0 0 1rem 0;
    color: #475569;
    font-size: 0.95rem;
    line-height: 1.5;
    /* Truncado visual de 3 líneas */
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
    text-overflow: ellipsis;
    flex-grow: 1; /* Empuja la fecha hacia abajo uniformemente */
  }
  .news-date {
    font-size: 0.8rem;
    color: #94a3b8;
    font-weight: 500;
    margin-top: auto;
  }

  .grid-links {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.5rem;
  }
  .quick-link-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 1rem;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }
  .quick-link-card:hover {
    box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);
    border-color: #cbd5e1;
    transform: translateY(-2px);
  }
  .quick-link-card.disabled {
    cursor: not-allowed;
    opacity: 0.6;
  }
  .quick-link-card.disabled:hover {
    box-shadow: none;
    border-color: #e2e8f0;
    transform: none;
  }
  .quick-link-card .icon {
    font-size: 2rem;
    margin-bottom: 1rem;
    display: block;
  }
  .quick-link-card h4 {
    margin: 0 0 0.25rem 0;
    font-size: 1rem;
    color: #0f172a;
  }
  .quick-link-card p {
    margin: 0;
    font-size: 0.8rem;
    color: #64748b;
  }
</style>
