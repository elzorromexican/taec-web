---
/**
 * @name dashboard.astro
 * @version 1.1
 * @description Lobby corporativo y dashboard general de TAEC.
 * @inputs N/A
 * @outputs Renderizado de accesos directos
 * @dependencies IntranetLayout.astro
 * @created 2026-03-01
 * @updated 2026-04-04 12:12:00
 */
export const prerender = false;
import IntranetLayout from '../../layouts/IntranetLayout.astro';
import { createClient } from '@supabase/supabase-js';

const accessToken = Astro.locals.accessToken || "";
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const scopedSupabase = createClient(supabaseUrl, supabaseAnonKey, {
  global: { headers: { Authorization: `Bearer ${accessToken}` } }
});

const { data: novedades } = await scopedSupabase
  .from('intranet_novedades')
  .select('*')
  .eq('activo', true)
  .order('orden', { ascending: true })
  .order('created_at', { ascending: false });
---

<IntranetLayout title="Dashboard Intranet | TAEC" description="Lobby corporativo">
  
  <!-- DASHBOARD HERO -->
  <div class="dashboard-hero">
    <h1>El Hub Comercial.</h1>
    <p>Bienvenido a la terminal central de herramientas, cotizadores y playbooks de TAEC.</p>
  </div>

  <!-- AVISOS IMPORTANTES (Dinámicos vía Supabase) -->
  <div class="dashboard-section mt-10">
    <div style="display: flex; justify-content: space-between; align-items: baseline; border-bottom: 1px solid #e2e8f0; margin-bottom: 1.5rem;">
      <h2 class="section-title" style="border-bottom: none; margin-bottom: 0;">Novedades de la Semana</h2>
      {Astro.locals?.rol === 'admin' && (
        <a href="/interno/admin" style="font-size: 0.85rem; color: #3b82f6; text-decoration: none; font-weight: bold;">✚ Gestionar Avisos</a>
      )}
    </div>
    
    <div class="news-grid">
      {novedades && novedades.length > 0 ? (
        novedades.map((nov: any) => (
          <div class={`news-card border-t-${nov.badge_color}`}>
            <div class={`news-badge ${nov.badge_color}`}>{nov.badge_text}</div>
            <h3>{nov.titulo}</h3>
            <div set:html={nov.contenido} style="font-size: 0.95rem; color: #475569; margin-bottom: 1rem; line-height: 1.5; flex-grow: 1;" />
            <span class="news-date">{nov.fecha_display}</span>
          </div>
        ))
      ) : (
        <p style="color: #64748b;">No hay novedades para mostrar en este momento.</p>
      )}
    </div>
  </div>

  <!-- QUICK LINKS (GOOGLE DRIVE ETC) -->
  <div class="dashboard-section mt-10">
    <h2 class="section-title">Accesos Directos (Drive)</h2>
    <div class="grid-links">
      <div class="quick-link-card disabled"
           title="Disponible próximamente — Fase 3"
           role="img"
           aria-label="Formatos Comerciales — no disponible aún">
        <span class="icon">📁</span>
        <h4>Formatos Comerciales</h4>
        <p>Abre el Drive general de ventas.</p>
      </div>
      <div class="quick-link-card disabled"
           title="Disponible próximamente — Fase 3"
           role="img"
           aria-label="Machotes de Contrato — no disponible aún">
        <span class="icon">📄</span>
        <h4>Machotes de Contrato</h4>
        <p>NDAs y plantillas pre-aprobadas.</p>
      </div>
      <div class="quick-link-card disabled"
           title="Disponible próximamente — Fase 3"
           role="img"
           aria-label="Zoho CRM — no disponible aún">
        <span class="icon">🔐</span>
        <h4>Zoho CRM</h4>
        <p>Atajo al sistema de Tickets.</p>
      </div>
    </div>
  </div>

</IntranetLayout>

<style>
  .dashboard-hero h1 {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #0f172a;
    margin: 0;
  }
  .dashboard-hero p {
    font-size: 1rem;
    color: #64748b;
    margin-top: 0.25rem;
  }
  .mt-10 { margin-top: 1.5rem; }
  .mt-4 { margin-top: 1rem; }
  
  .section-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid #e2e8f0;
    padding-bottom: 0.5rem;
  }

  .news-grid {
    display: grid;
    /* Fuerza estrictamente 2 columnas para no wrap */
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .news-card {
    background: #fff;
    /* Borde modular corporativo, sin sombra flotante */
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 1.25rem;
    box-shadow: none;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .border-t-orange { border-top: 3px solid #f97316; }
  .border-t-blue { border-top: 3px solid #3b82f6; }

  .news-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }
  .news-badge.orange { background: #ffedd5; color: #c2410c; }
  .news-badge.blue { background: #dbeafe; color: #1d4ed8; }

  .news-card h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.1rem;
    color: #0f172a;
  }
  .news-card p {
    margin: 0 0 1rem 0;
    color: #475569;
    font-size: 0.95rem;
    line-height: 1.5;
    /* Mayor tolerancia vertical (espacio disponible) */
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 6;
    overflow: hidden;
    text-overflow: ellipsis;
    flex-grow: 1; /* Empuja la fecha hacia abajo uniformemente */
  }
  .news-date {
    font-size: 0.8rem;
    color: #94a3b8;
    font-weight: 500;
    margin-top: auto;
  }

  .grid-links {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.5rem;
  }
  .quick-link-card {
    background: #ffffff;
    border: 2px solid #cbd5e1;
    border-radius: 1rem;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }
  .quick-link-card:hover {
    box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);
    border-color: #94a3b8;
    transform: translateY(-2px);
  }
  
  /* HIGH CONTRAST DISABLED CARDS (Accessibility) */
  .quick-link-card.disabled {
    cursor: not-allowed;
    opacity: 1; /* NUNCA usar opacidad o la legibilidad WCAG falla */
    background: #f8fafc;
    border: 2px dashed #64748b; /* slate-500 (Alto contraste contra blanco) */
  }
  .quick-link-card.disabled:hover {
    box-shadow: none;
    transform: none;
  }
  .quick-link-card.disabled .icon {
    filter: grayscale(100%) opacity(70%);
  }
  .quick-link-card.disabled h4 {
    color: #1e293b; /* slate-800 - Fuerte contraste */
  }
  .quick-link-card.disabled p {
    color: #475569; /* slate-600 */
  }
  
  .quick-link-card .icon {
    font-size: 2rem;
    margin-bottom: 1rem;
    display: block;
  }
  .quick-link-card h4 {
    margin: 0 0 0.25rem 0;
    font-size: 1rem;
    color: #0f172a;
  }
  .quick-link-card p {
    margin: 0;
    font-size: 0.8rem;
    color: #64748b;
  }
</style>
