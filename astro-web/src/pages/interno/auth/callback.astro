---
export const prerender = false;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Verificando credenciales...</title>
  <style>
    body { background-color: #0f172a; color: white; font-family: system-ui, sans-serif; display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0; }
    .loader { border: 4px solid #334155; border-top: 4px solid #3b82f6; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin: 0 auto 1.5rem auto; }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    h2 { margin: 0 0 0.5rem 0; font-weight: 600; letter-spacing: -0.02em; }
    p { color: #94a3b8; font-size: 0.95rem; margin: 0; }
  </style>
</head>
<body>
  
  <div style="text-align:center;">
    <div class="loader"></div>
    <h2 id="statusMessage">Estableciendo conexión segura...</h2>
    <p>Por favor no cierres esta ventana.</p>
  </div>

  <script>
    import { supabase } from '../../../lib/supabase';

    // Para ver si llegó con hash de tokens:
    if (window.location.hash.includes('access_token')) {
       document.getElementById('statusMessage').innerText = "Procesando tokens recibidos...";
    } else {
       document.getElementById('statusMessage').innerText = "ATENCIÓN: No llegaron tokens en la URL.";
    }
    
    supabase.auth.onAuthStateChange((event, session) => {
      if ((event === 'SIGNED_IN' || event === 'INITIAL_SESSION') && session) {
        const maxAge = 60 * 60 * 24 * 7;
        document.cookie = `sb-access-token=${session.access_token}; Path=/; Max-Age=${maxAge}; SameSite=Lax;`;
        document.cookie = `sb-refresh-token=${session.refresh_token}; Path=/; Max-Age=${maxAge}; SameSite=Lax;`;
        window.location.href = '/interno/dashboard';
      }
    });

    setTimeout(async () => {
       const { data } = await supabase.auth.getSession();
       if (!data.session) {
         document.getElementById('statusMessage').innerText = "Fallo Crítico: Supabase no procesó la sesión.";
         alert("Debug info:\nURL Actual: " + window.location.href + "\nHash: " + window.location.hash);
         setTimeout(() => { window.location.href = '/interno/login?error=fallback_auth'; }, 4000);
       }
    }, 4000);
  </script>

</body>
</html>
