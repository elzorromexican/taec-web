---
import { getBookingUrl } from "../data/contact";
import BaseLayout from "../layouts/BaseLayout.astro";

import { r } from "../utils/paths";
---

<BaseLayout 
  title="Blog y Recursos – e-learning para México y LATAM | TAEC"
  description="Glosario de e-learning, artículos, comparativos de herramientas, estándares, radar de tendencias y flashcards. El hub de conocimiento TAEC para profesionales de L&D en México y LATAM."
  section="Recursos"
  page="recursos.html"
>
  <style is:global>

  /* ── HERO ── */
    .rec-hero { background: linear-gradient(135deg, #001f3d 0%, #004775 60%, #0077b6 100%); padding: 72px 5% 80px; color: white; }
    .rec-hero-inner { max-width: 900px; margin: 0 auto; text-align: center; }
    .rec-eyebrow { font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--teal); margin-bottom: 16px; }
    .rec-hero h1 { font-family: var(--font-display); font-size: clamp(32px, 4.5vw, 56px); font-weight: 400; color: white; line-height: 1.15; margin-bottom: 20px; }
    .rec-hero h1 em { color: var(--teal); font-style: normal; }
    .rec-hero-sub { font-size: 18px; color: rgba(255,255,255,.75); line-height: 1.7; max-width: 640px; margin: 0 auto 36px; }
    .rec-stats { display: flex; gap: 40px; justify-content: center; flex-wrap: wrap; margin-top: 12px; }
    .rec-stat { text-align: center; }
    .rec-stat-num { font-size: 28px; font-weight: 800; color: white; line-height: 1; }
    .rec-stat-lbl { font-size: 12px; color: rgba(255,255,255,.55); margin-top: 4px; }

    /* ── SECCIONES GRID ── */
    .rec-sections { padding: 72px 5%; background: var(--light); }
    .rec-sections-inner { max-width: 1100px; margin: 0 auto; }
    .rec-label { font-size: 11px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; color: var(--blue); margin-bottom: 10px; text-align: center; }
    .rec-title { font-family: var(--font-display); font-size: clamp(24px, 2.8vw, 36px); font-weight: 400; color: var(--text); text-align: center; margin-bottom: 8px; }
    .rec-subtitle { text-align: center; color: #64748B; font-size: 15px; margin-bottom: 52px; }
    .rec-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }

    /* ── SECTION CARD ── */
    .sec-card { background: var(--white); border: 1.5px solid var(--border); border-radius: 16px; padding: 32px 28px; display: flex; flex-direction: column; gap: 0; transition: box-shadow .2s, transform .2s, border-color .2s; text-decoration: none; color: inherit; }
    .sec-card:hover { box-shadow: 0 8px 32px rgba(49,121,194,.12); transform: translateY(-3px); border-color: var(--blue); }
    .sec-card-icon { font-size: 36px; margin-bottom: 16px; line-height: 1; }
    .sec-card-count { display: inline-block; font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--blue); background: #EFF6FF; border: 1px solid #BFDBFE; border-radius: 4px; padding: 2px 8px; margin-bottom: 12px; }
    .sec-card-name { font-size: 20px; font-weight: 800; color: var(--text); margin-bottom: 10px; line-height: 1.2; }
    .sec-card-desc { font-size: 14px; color: #64748B; line-height: 1.7; flex: 1; margin-bottom: 24px; }
    .sec-card-link { font-size: 14px; font-weight: 700; color: var(--blue); display: flex; align-items: center; gap: 6px; transition: gap .15s; }
    .sec-card:hover .sec-card-link { gap: 10px; }

    /* ── CARD FEATURED (Blog y Artículos) ── */
    .sec-card.featured { border-color: var(--navy); }
    .sec-card.featured:hover { border-color: var(--orange); box-shadow: 0 8px 32px rgba(242,139,28,.12); }
    .sec-card.featured .sec-card-count { color: var(--orange); background: #FEF3E2; border-color: #FDE68A; }
    .sec-card.featured .sec-card-link { color: var(--orange); }

    /* ── CTA BOTTOM ── */
    .rec-cta { background: var(--navy); padding: 56px 5%; text-align: center; color: white; }
    .rec-cta h2 { font-family: var(--font-display); font-size: clamp(22px, 2.5vw, 32px); font-weight: 400; margin-bottom: 12px; }
    .rec-cta p { font-size: 16px; color: rgba(255,255,255,.7); margin-bottom: 28px; }
    .btn-rec-primary { background: var(--orange); color: white; font-weight: 700; font-size: 15px; padding: 14px 28px; border-radius: 8px; display: inline-flex; align-items: center; gap: 8px; transition: opacity .15s; }
    .btn-rec-primary:hover { opacity: .9; }

    /* ── WHATSAPP ── */

    /* ── REC TABS ── */
    .rec-tabs{background:#F8FAFC;border-bottom:1px solid var(--border);padding:0 5%;overflow-x:auto}
    .rec-tabs-inner{max-width:1100px;margin:0 auto;display:flex;gap:0}
    .rec-tab{display:inline-flex;align-items:center;padding:14px 18px;font-size:13px;font-weight:600;color:#64748B;border-bottom:3px solid transparent;transition:color .15s,border-color .15s;white-space:nowrap;text-decoration:none}
    .rec-tab:hover{color:var(--blue)}
    .rec-tab.active{color:var(--navy);border-bottom-color:var(--navy)}
  
  </style>

<main id="main-content">

<!-- ══ HERO ══ -->
<section class="rec-hero">
  <div class="rec-hero-inner">
    <p class="rec-eyebrow">Blog &amp; Recursos</p>
    <h1>Conocimiento práctico para <em>profesionales de e-learning</em></h1>
    <p class="rec-hero-sub">Glosario, artículos de fondo, comparativos de herramientas, estándares técnicos y más — todo en español, pensado para México y LATAM.</p>
    <div class="rec-stats">
      <div class="rec-stat"><div class="rec-stat-num">456</div><div class="rec-stat-lbl">recursos totales</div></div>
      <div class="rec-stat"><div class="rec-stat-num">232</div><div class="rec-stat-lbl">términos de glosario</div></div>
      <div class="rec-stat"><div class="rec-stat-num">93</div><div class="rec-stat-lbl">posts de blog</div></div>
      <div class="rec-stat"><div class="rec-stat-num">18</div><div class="rec-stat-lbl">artículos de profundidad</div></div>
    </div>
  </div>
</section>

<!-- ══ SECCIONES ══ -->
<section class="rec-sections">
  <div class="rec-sections-inner">
    <p class="rec-label">Explora por sección</p>
    <h2 class="rec-title">¿Qué estás buscando?</h2>
    <p class="rec-subtitle">Cada sección tiene un propósito distinto — desde consulta rápida hasta análisis estratégico.</p>

    <div class="rec-grid">

      <!-- Blog -->
      <a href={r('/blog')} class="sec-card featured">
        <div class="sec-card-icon">✍️</div>
        <span class="sec-card-count">93 publicaciones</span>
        <h3 class="sec-card-name">Blog TAEC</h3>
        <p class="sec-card-desc">Tendencias, noticias y reflexiones del mundo e-learning. Actualizaciones frecuentes sobre herramientas, metodologías y el mercado de L&D en LATAM.</p>
        <span class="sec-card-link">Leer el blog →</span>
      </a>

      <!-- Artículos -->
      <a href={r('/articulos')} class="sec-card featured">
        <div class="sec-card-icon">📖</div>
        <span class="sec-card-count">18 artículos</span>
        <h3 class="sec-card-name">Artículos</h3>
        <p class="sec-card-desc">Análisis de fondo sobre diseño instruccional, implementación de LMS, accesibilidad, IA en el aprendizaje y estrategia L&D. Para quienes quieren ir más allá.</p>
        <span class="sec-card-link">Explorar artículos →</span>
      </a>

      <!-- Glosario -->
      <a href={r('/glosario')} class="sec-card">
        <div class="sec-card-icon">📚</div>
        <span class="sec-card-count">232 términos</span>
        <h3 class="sec-card-name">Glosario e-learning</h3>
        <p class="sec-card-desc">Diccionario de referencia con los términos esenciales del e-learning: SCORM, xAPI, LMS, Kirkpatrick, diseño instruccional y mucho más. Búsqueda instantánea.</p>
        <span class="sec-card-link">Consultar glosario →</span>
      </a>

      <!-- Comparativos -->
      <a href={r('/comparativos')} class="sec-card">
        <div class="sec-card-icon">⚖️</div>
        <span class="sec-card-count">2 comparativos</span>
        <h3 class="sec-card-name">Comparativos</h3>
        <p class="sec-card-desc">Tablas de comparación detalladas entre herramientas: Articulate vs Captivate vs iSpring, Vyond vs Camtasia vs Genially. Para tomar decisiones informadas.</p>
        <span class="sec-card-link">Ver comparativos →</span>
      </a>

      <!-- Estándares -->
      <a href={r('/estandares')} class="sec-card">
        <div class="sec-card-icon">📋</div>
        <span class="sec-card-count">30 fichas</span>
        <h3 class="sec-card-name">Estándares</h3>
        <p class="sec-card-desc">Fichas técnicas sobre los estándares del sector: SCORM 1.2, SCORM 2004, xAPI (Tin Can), cmi5, LTI, AICC. Referencia rápida para implementadores.</p>
        <span class="sec-card-link">Ver estándares →</span>
      </a>

      <!-- Radar -->
      <a href={r('/radar')} class="sec-card">
        <div class="sec-card-icon">📡</div>
        <span class="sec-card-count">6 ediciones</span>
        <h3 class="sec-card-name">Radar eLearning</h3>
        <p class="sec-card-desc">Informe periódico de tendencias e innovaciones en el sector e-learning. Tecnologías emergentes, cambios del mercado y lo que viene para los equipos L&D de LATAM.</p>
        <span class="sec-card-link">Ver ediciones →</span>
      </a>

      <!-- Quiz -->
      <a href={r('/quiz')} class="sec-card">
        <div class="sec-card-icon">🧠</div>
        <span class="sec-card-count">75 flashcards</span>
        <h3 class="sec-card-name">Quiz &amp; Flashcards</h3>
        <p class="sec-card-desc">Pon a prueba tu conocimiento de e-learning con flashcards interactivas. Ideal para preparar certificaciones, reforzar conceptos o simplemente explorar el campo.</p>
        <span class="sec-card-link">Empezar el quiz →</span>
      </a>

    </div>
  </div>
</section>

<!-- ══ CTA ══ -->
<section class="rec-cta">
  <h2>¿Tienes un proyecto de e-learning en mente?</h2>
  <p>El conocimiento es el primer paso — el segundo es hablar con alguien que lo haya hecho antes.</p>
  <a href={getBookingUrl()} target="_blank" rel="noopener noreferrer" class="btn-rec-primary">Agendar diagnóstico gratuito →</a>
</section>

</main>
</BaseLayout>
