---
// CHANGELOG: 2026-03-20 - Landing CustomGuide completa. Contenido basado en doc estratégico DDC.
import ProductPageLayout from '../layouts/ProductPageLayout.astro';
import { getBookingUrl } from '../data/contact';
import { r } from '../utils/paths';

const bookingUrl = getBookingUrl();

const pilares = [
  {
    icon: "📚",
    title: "Más de 300 cursos personalizables",
    desc: "Microsoft Office, Google Workspace y alfabetización digital. Listos para cargar en tu LMS en formato SCORM — sin tiempo de producción.",
    badge: "100% SCORM"
  },
  {
    icon: "🖥️",
    title: "LMS integrado",
    desc: "Si no tienes LMS o prefieres un entorno separado, CustomGuide incluye su propio sistema de gestión de aprendizaje con seguimiento de progreso.",
    badge: "Incluido"
  },
  {
    icon: "🎯",
    title: "Evaluaciones de habilidades",
    desc: "Skill assessments para identificar brechas antes y después de la capacitación. Mejora media documentada del 56% en habilidades evaluadas.",
    badge: "+56% mejora"
  },
  {
    icon: "📋",
    title: "Hojas de trucos con tu marca",
    desc: "Referencias rápidas para el día a día — personalizables con el logo y colores de tu organización. El usuario las consulta sin entrar al LMS.",
    badge: "Marca propia"
  }
];

const beneficios = [
  { icon: "⚡", title: "Listo para usar desde el primer día", description: "Sin tiempo de producción, sin autoría desde cero. Los 300+ cursos están producidos, actualizados y disponibles para desplegar en tu LMS o en la plataforma propia." },
  { icon: "🤖", title: "Course Builder con IA", description: "Si necesitas cursos adicionales o personalizados, el Course Builder con IA permite crear contenido nuevo con drag & drop — sin herramientas de autoría externas." },
  { icon: "📊", title: "4.9/5 en G2 — más de 3,000 clientes", description: "Una de las plataformas mejor calificadas en su categoría. Utilizada por bibliotecas, asociaciones, gobierno, ONGs y empresas en múltiples industrias." },
  { icon: "🎨", title: "Personalización con tu marca", description: "Cursos editables con tu identidad visual. Las hojas de trucos llevan tu logo. La experiencia del usuario refleja tu organización — no un proveedor externo." }
];

const faqs = [
  {
    question: "¿Qué temas cubre el catálogo de CustomGuide?",
    answerHtml: "El catálogo se especializa en <strong>herramientas digitales de trabajo</strong>: Microsoft Office (Word, Excel, PowerPoint, Outlook, Teams), Google Workspace (Docs, Sheets, Slides, Gmail, Meet) y alfabetización digital general. Más de 300 cursos editables listos para usar."
  },
  {
    question: "¿Los cursos son compatibles con nuestro LMS?",
    answerHtml: "Sí. Los cursos son <strong>100% compatibles con SCORM</strong> — el estándar universal de e-learning. Puedes cargarlos en Moodle, Totara, Canvas, Cornerstone, Blackboard o cualquier LMS que acepte SCORM. Si no tienes LMS, CustomGuide incluye el suyo propio."
  },
  {
    question: "¿Qué es el Course Builder con IA?",
    answerHtml: "Una herramienta de <strong>creación de cursos con drag & drop e inteligencia artificial</strong> incluida en CustomGuide. Permite crear cursos nuevos o complementar el catálogo existente con contenido propio — sin necesidad de Articulate, Rise ni herramientas de autoría adicionales."
  },
  {
    question: "¿Las evaluaciones de habilidades sirven antes y después del curso?",
    answerHtml: "Sí. Los <strong>skill assessments</strong> permiten medir el nivel de habilidad antes de la capacitación (para identificar brechas y personalizar rutas) y después (para medir el impacto real). CustomGuide documenta una mejora media del <strong>56% en habilidades evaluadas</strong>."
  },
  {
    question: "¿Para qué tipo de organizaciones funciona mejor?",
    answerHtml: "Especialmente para: <strong>empresas que capacitan en Microsoft o Google Workspace</strong>, equipos de RH o L&D con poco tiempo de desarrollo de contenido, <strong>bibliotecas, asociaciones, gobierno y ONGs</strong> que necesitan formación digital accesible, y organizaciones con LMS propio que buscan un catálogo sólido sin desarrollar desde cero."
  },
  {
    question: "¿TAEC puede implementar CustomGuide en México?",
    answerHtml: "Sí. TAEC acompaña la evaluación del catálogo según tu audiencia, la integración con tu LMS o la configuración del LMS integrado de CustomGuide, y el soporte posterior. Contacta con nuestro equipo para una demo con acceso al catálogo completo."
  }
];

const casos = [
  { icon: "🏢", title: "Capacitación en herramientas digitales", desc: "Microsoft 365 y Google Workspace para toda la organización — desde empleados nuevos hasta usuarios avanzados." },
  { icon: "🚀", title: "Onboarding digital", desc: "Inducción tecnológica desde el primer día. El nuevo colaborador aprende las herramientas que va a usar antes de su primera semana." },
  { icon: "🏛️", title: "Gobierno, bibliotecas y ONGs", desc: "Acceso a formación digital de calidad para instituciones con presupuesto limitado y alto volumen de usuarios." },
  { icon: "⚙️", title: "Academias internas sin tiempo de desarrollo", desc: "Catálogo listo para complementar el LMS existente — sin meses de producción de contenido propio." }
];
---

<ProductPageLayout
  meta={{
    title: "CustomGuide en México | Cursos personalizables, LMS y capacitación digital lista para usar | TAEC",
    description: "CustomGuide con TAEC: más de 300 cursos SCORM de Microsoft y Google Workspace, LMS integrado, skill assessments y Course Builder con IA. Demo en español.",
    page: "customguide-mexico.html"
  }}
  hero={{
    eyebrow: "CustomGuide · Capacitación digital lista para usar",
    titleHtml: `Capacitación lista para usar,<br>personalizable y <em>fácil de desplegar</em>`,
    subtitle: "CustomGuide ayuda a capacitar a personal, usuarios o comunidad con más de 300 cursos editables de Microsoft y Google Workspace — listos para tu LMS, con evaluaciones de habilidades y Course Builder con IA incluido.",
    features: [
      "+300 cursos personalizables — Microsoft Office y Google Workspace",
      "100% SCORM compatible — funciona en cualquier LMS",
      "LMS integrado incluido si no tienes plataforma propia",
      "Skill assessments — mejora media documentada del 56%",
      "Course Builder con IA — crea cursos propios sin herramientas externas",
      "Más de 3,000 clientes · 4.9/5 en G2"
    ],
    primaryBtn: { label: "Solicitar demo del catálogo →", url: bookingUrl, target: "_blank" },
    secondaryBtn: { label: "Hablar con un especialista", url: getBookingUrl('customguide') },
    cardBadgeText: "MICROSOFT · GOOGLE · SCORM · IA",
    cardLogoSrc: r("/assets/logos/customguide.svg"),
    theme: "general",
    brandColor: "#f8ab1f",
    btnTextDark: true
  }}
  beneficios={{
    eyebrow: "Por qué CustomGuide con TAEC",
    title: "Una base sólida cuando necesitas capacitar rápido y medir mejor",
    subtitle: "Para equipos de RH y L&D que necesitan desplegar formación digital sin reinventar la rueda cada semana.",
    cards: beneficios,
    columns: 2,
    theme: "general"
  }}
  faqs={{
    eyebrow: "Preguntas frecuentes",
    title: "Todo sobre CustomGuide en México",
    faqs: faqs,
    theme: "general"
  }}
  cta={{
    title: "¿Listo para ver el catálogo con tu equipo?",
    subtitle: "Agenda una demo con acceso al catálogo completo. Te ayudamos a evaluar qué cursos aplican para tu audiencia y cómo integrarlo con tu LMS — sin costo, sin compromiso.",
    primaryBtnText: "Solicitar demo del catálogo →",
    primaryBtnUrl: bookingUrl,
    primaryBtnTarget: "_blank",
    theme: "general"
  }}
>

  <!-- ── EL PROBLEMA ── -->
  <section class="pp-section pp-section-alt">
    <div class="pp-section-inner">
      <p class="pp-section-label">El reto real</p>
      <h2 class="pp-section-title">El problema es desplegar formación útil<br>sin gastar meses armando todo desde cero.</h2>
      <p class="pp-section-sub">Muchas organizaciones necesitan capacitar a su gente en las herramientas digitales del día a día — pero producir ese contenido desde cero requiere tiempo, presupuesto y expertise que no siempre están disponibles.</p>
      <div class="pp-grid-3">
        <div class="pp-card">
          <span class="pp-card-num">01</span>
          <h3 class="pp-card-title">Meses de producción antes de poder capacitar</h3>
          <p class="pp-card-desc">Desarrollar un curso de Excel o Teams desde cero con Articulate o Rise requiere diseño instruccional, grabaciones, revisiones y QA. CustomGuide elimina ese proceso — el contenido ya está producido.</p>
        </div>
        <div class="pp-card">
          <span class="pp-card-num">02</span>
          <h3 class="pp-card-title">Sin visibilidad de quién sabe qué</h3>
          <p class="pp-card-desc">Sin evaluaciones previas a la capacitación, todos toman el mismo curso independientemente de su nivel real. Los skill assessments permiten personalizar rutas y medir el impacto real de la formación.</p>
        </div>
        <div class="pp-card">
          <span class="pp-card-num">03</span>
          <h3 class="pp-card-title">Usuarios que no recuerdan lo que aprendieron</h3>
          <p class="pp-card-desc">El curso se completa y el usuario vuelve al trabajo sin una referencia rápida. Las hojas de trucos con marca resuelven ese gap — consulta inmediata sin volver a entrar al LMS.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 4 PILARES ── -->
  <section class="pp-section pp-section-dark">
    <div class="pp-section-inner">
      <p class="pp-section-label">La propuesta</p>
      <h2 class="pp-section-title pp-section-title--light">Cuatro pilares en una sola plataforma</h2>
      <div class="pp-grid-4">
        {pilares.map(p => (
          <div class="pp-card pp-card--dark pilar-card">
            <div class="pilar-top">
              <span class="pilar-icon">{p.icon}</span>
              <span class="pilar-badge">{p.badge}</span>
            </div>
            <h3 class="pp-card-title pp-card-title--light">{p.title}</h3>
            <p class="pp-card-desc pp-card-desc--light">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CASOS DE USO ── -->
  <section class="pp-section">
    <div class="pp-section-inner">
      <p class="pp-section-label">Casos de uso</p>
      <h2 class="pp-section-title">Dónde funciona mejor CustomGuide</h2>
      <div class="pp-grid-4">
        {casos.map(c => (
          <div class="pp-card">
            <span class="pp-card-icon">{c.icon}</span>
            <h3 class="pp-card-title">{c.title}</h3>
            <p class="pp-card-desc">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PERFIL IDEAL ── -->
  <section class="pp-section pp-section-alt">
    <div class="pp-section-inner">
      <p class="pp-section-label">¿Para quién es?</p>
      <h2 class="pp-section-title">CustomGuide encaja cuando necesitas capacitar rápido con contenido que ya funciona</h2>
      <div class="pp-grid-3">
        <div class="perfil-col">
          <h3>Perfil de organización ideal</h3>
          <ul>
            <li>Empresas que capacitan en Microsoft 365 o Google Workspace</li>
            <li>Equipos de RH o L&D con poco tiempo de desarrollo</li>
            <li>Bibliotecas, asociaciones, gobierno y organizaciones sin fines de lucro</li>
            <li>Organizaciones con LMS que buscan catálogo SCORM listo</li>
            <li>Empresas sin LMS que necesitan plataforma + contenido en un solo paso</li>
          </ul>
        </div>
        <div class="perfil-col">
          <h3>Casos de uso principales</h3>
          <ul>
            <li>Capacitación digital en herramientas de trabajo (Microsoft, Google)</li>
            <li>Onboarding tecnológico desde el primer día</li>
            <li>Academias internas con poco tiempo de desarrollo de contenido</li>
            <li>Comunidades, bibliotecas y gobierno con usuarios de perfil variado</li>
            <li>Programas mixtos con LMS propio o LMS integrado de CustomGuide</li>
          </ul>
        </div>
        <div class="perfil-col perfil-col--taec">
          <h3>Lo que TAEC hace por ti</h3>
          <ul>
            <li>Evaluación del catálogo según tu audiencia y necesidades</li>
            <li>Definición: LMS propio con SCORM o LMS integrado de CustomGuide</li>
            <li>Acompañamiento en demo y configuración inicial</li>
            <li>Soporte posterior en español · CDMX</li>
          </ul>
          <p class="perfil-cierre">No se trata de comprar un paquete de cursos y esperar milagros. Se trata de usar una base sólida cuando necesitas capacitar rápido, medir mejor y no reinventar la rueda cada semana.</p>
        </div>
      </div>
    </div>
  </section>

</ProductPageLayout>

<style is:global>
:root { --brand: #f8ab1f; }

/* ── 4 PILARES (Specifics) ── */
.pilar-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 14px; }
.pilar-icon { font-size: 28px; }
.pilar-badge { font-size: 10px; font-weight: 700; background: rgba(248,171,31,.2); color: var(--brand); padding: 3px 8px; border-radius: 4px; white-space: nowrap; }

/* ── PERFIL IDEAL (Specifics) ── */
.perfil-col h3 { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #94A3B8; margin-bottom: 16px; }
.perfil-col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
.perfil-col ul li { font-size: 14px; color: #374151; line-height: 1.5; padding-left: 18px; position: relative; }
.perfil-col ul li::before { content: "→"; position: absolute; left: 0; color: var(--brand); font-weight: 700; }
.perfil-col--taec { background: white; border: 1.5px solid #FED7AA; border-radius: 14px; padding: 24px; }
.perfil-col--taec h3 { color: #92400E; }
.perfil-cierre { margin-top: 20px; font-size: 13px; color: #9CA3AF; line-height: 1.7; font-style: italic; border-top: 1px solid #E2E8F0; padding-top: 16px; }

</style>
