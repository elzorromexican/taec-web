---
import { contactData } from "../data/contact";
import BaseLayout from "../layouts/BaseLayout.astro";

import { r } from "../utils/paths";
---

<BaseLayout 
  title="Grupos a Medida — Diseña tu Programa | TAEC"
  description="Combina módulos de diferentes herramientas y crea un programa de capacitación integral para tu equipo de e-learning."
  section="Capacitación"
  page="curso-cerrado-grupos.html"
>
  <style is:global>

    .nav-item::after { display: none !important; }
    .nav-item.open > .mega-menu { display: grid !important; }
    .nav-item.open > .simple-dropdown { display: grid !important; }
    .nav-item.open > .nav-link { background: var(--light); color: var(--blue); }
    .nav-item.open > .nav-link svg { transform: rotate(180deg); }

    .course-hero { background: linear-gradient(135deg, #a85d08 0%, #F28B1C 60%, #c47010 100%); padding: 72px 5% 64px; }
    .course-hero-inner { max-width: 780px; margin: 0 auto; }
    .course-tag { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,.15); color: rgba(255,255,255,.9); font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; padding: 4px 14px; border-radius: 4px; margin-bottom: 24px; }
    .course-hero h1 { font-family: var(--font-display); font-size: 42px; color: var(--white); line-height: 1.15; margin-bottom: 20px; }
    .course-hero p { font-size: 18px; color: rgba(255,255,255,.88); line-height: 1.7; margin-bottom: 36px; }
    .course-badges { display: flex; gap: 12px; flex-wrap: wrap; }
    .course-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,.15); border: 1px solid rgba(255,255,255,.25); color: var(--white); font-size: 13px; font-weight: 600; padding: 6px 16px; border-radius: 100px; }

    .course-content { max-width: 1100px; margin: 0 auto; padding: 64px 5%; display: grid; grid-template-columns: 1fr 340px; gap: 48px; align-items: start; }
    @media (max-width: 900px) { .course-content { grid-template-columns: 1fr; } }
    .section-title { font-family: var(--font-display); font-size: 26px; color: var(--navy); margin-bottom: 24px; }
    .section-block { margin-bottom: 40px; }
    .section-block h3 { font-size: 16px; font-weight: 700; color: var(--navy); margin-bottom: 16px; padding-bottom: 8px; border-bottom: 2px solid var(--accent); display: inline-block; }
    .build-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 8px; }
    .build-card { background: var(--light); border: 1px solid var(--border); border-radius: 10px; padding: 14px; border-left: 3px solid var(--accent); }
    .build-card-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .7px; color: var(--muted); display: block; margin-bottom: 4px; }
    .build-card-value { font-size: 13px; font-weight: 500; color: var(--text); }
    .programs-list { display: flex; flex-direction: column; gap: 12px; }
    .program-card { background: var(--light); border: 1px solid var(--border); border-radius: 12px; padding: 16px 20px; }
    .program-name { font-size: 14px; font-weight: 700; color: var(--navy); margin-bottom: 4px; }
    .program-desc { font-size: 13px; color: var(--dark); }
    .program-hrs { display: inline-block; font-size: 11px; font-weight: 700; background: rgba(242,139,28,.12); color: var(--orange); border-radius: 4px; padding: 2px 8px; margin-top: 6px; }
    .includes-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
    .includes-list li { display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--text); }
    .includes-list li::before { content: "✓"; color: var(--accent); font-weight: 700; flex-shrink: 0; }

    .details-card { background: var(--white); border: 1px solid var(--border); border-radius: 16px; padding: 28px; box-shadow: 0 4px 24px rgba(0,0,0,.07); position: sticky; top: 88px; }
    .details-card h3 { font-family: var(--font-display); font-size: 20px; color: var(--navy); margin-bottom: 20px; }
    .detail-row { display: flex; align-items: flex-start; gap: 10px; padding: 10px 0; border-bottom: 1px solid var(--border); }
    .detail-row:last-of-type { border-bottom: none; }
    .detail-icon { font-size: 18px; flex-shrink: 0; width: 24px; text-align: center; }
    .detail-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .7px; color: var(--muted); display: block; margin-bottom: 2px; }
    .detail-value { font-size: 14px; font-weight: 600; color: var(--text); }
    .cta-buttons { display: flex; flex-direction: column; gap: 10px; margin-top: 24px; }
    .btn-primary-full { display: block; text-align: center; background: var(--orange); color: var(--white); padding: 14px 20px; border-radius: 9px; font-weight: 700; font-size: 15px; transition: background .15s; }
    .btn-primary-full:hover { background: #d97b0e; }
    .btn-wa-full { display: flex; align-items: center; justify-content: center; gap: 8px; background: #25D366; color: var(--white); padding: 13px 20px; border-radius: 9px; font-weight: 700; font-size: 14px; transition: background .15s; }
    .btn-wa-full:hover { background: #1ebe5c; }
    .btn-wa-full svg { width: 18px; height: 18px; fill: white; flex-shrink: 0; }
    .footer-inner { max-width: 1200px; margin: 0 auto; }
    .footer-grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 48px; padding-bottom: 40px; border-bottom: 1px solid rgba(255,255,255,.07); }
    .footer-brand a img, .footer-brand .logo-link img { height: 34px; filter: brightness(0) invert(1); display:block; }
    .footer-brand p { font-size: 13px; color: #4B6275; line-height: 1.7; margin-top: 14px; }
    .footer-contact { margin-top: 18px; display: flex; flex-direction: column; gap: 6px; }
    .footer-contact a { font-size: 13px; color: #64748B; display: flex; align-items: center; gap: 6px; transition: color .15s; text-decoration: none; }
    .footer-contact a:hover { color: #A8DBD9; }
    .footer-col h4 { font-size: 11px; font-weight: 700; color: #94A3B8; margin-bottom: 16px; letter-spacing: .8px; text-transform: uppercase; }
    .footer-col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 9px; }
    .footer-col ul li a { font-size: 13px; color: #64748B; text-decoration: none; transition: color .15s; }
    .footer-col ul li a:hover { color: #A8DBD9; }
    .footer-bottom { padding-top: 20px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; border-top: 1px solid rgba(255,255,255,.07); margin-top: 4px; }
    .footer-bottom p { font-size: 12px; color: #334155; }
    .footer-bottom a { color: #475569; transition: color .15s; text-decoration: none; }
    .footer-bottom a:hover { color: #A8DBD9; }
    .footer-social { display: flex; gap: 10px; }
    .footer-social a { width: 36px; height: 36px; border-radius: 8px; border: 1px solid rgba(255,255,255,.1); display: inline-flex; align-items: center; justify-content: center; color: #64748B; font-size: 11px; font-weight: 700; text-decoration: none; transition: background .15s, color .15s, border-color .15s; }
    .footer-social a:hover { background: #3179C2; color: #fff; border-color: #3179C2; }
    .skip-link { position: absolute; top: -60px; left: 16px; background: var(--navy); color: var(--white); padding: 8px 16px; border-radius: 0 0 8px 8px; font-size: 14px; font-weight: 600; z-index: 9999; text-decoration: none; transition: top .2s; }
    .skip-link:focus { top: 0; }
    *:focus-visible { outline: 3px solid var(--blue); outline-offset: 2px; border-radius: 4px; }
    @media (max-width: 768px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: 28px; } .footer-bottom { flex-direction: column; text-align: center; gap: 16px; } .course-hero h1 { font-size: 28px; } .course-hero p { font-size: 15px; } .build-grid { grid-template-columns: 1fr; } }
    @media (max-width: 600px) { .footer-grid { grid-template-columns: 1fr; gap: 24px; } }
  
  </style>

<main id="main-content">
<section class="course-hero">
  <div class="course-hero-inner">
    <span class="course-tag">Capacitación Cerrada</span>
    <h1>Grupos a Medida — Diseña tu Programa</h1>
    <p>Combina módulos de diferentes herramientas y crea un programa de capacitación integral para tu equipo de e-learning.</p>
    <div class="course-badges">
      <span class="course-badge">🔧 Flexible</span>
      <span class="course-badge">🛠 Multitool</span>
      <span class="course-badge">🖥 Virtual o Presencial</span>
    </div>
  </div>
</section>

<div class="course-content">
  <div>
    <h2 class="section-title">Diseña tu programa</h2>

    <div class="section-block">
      <h3>Arma tu programa</h3>
      <div class="build-grid">
        <div class="build-card"><span class="build-card-label">Herramientas</span><span class="build-card-value">Elige las que necesita tu equipo</span></div>
        <div class="build-card"><span class="build-card-label">Duración</span><span class="build-card-value">Define las horas totales</span></div>
        <div class="build-card"><span class="build-card-label">Modalidad</span><span class="build-card-value">Virtual o presencial en CDMX</span></div>
        <div class="build-card"><span class="build-card-label">Fechas</span><span class="build-card-value">Fija el calendario que te convenga</span></div>
      </div>
    </div>

    <div class="section-block">
      <h3>Programas populares</h3>
      <div class="programs-list">
        <div class="program-card">
          <div class="program-name">Arranque e-learning</div>
          <div class="program-desc">Fundamentos + Articulate básico</div>
          <span class="program-hrs">24 hrs</span>
        </div>
        <div class="program-card">
          <div class="program-name">Producción audiovisual</div>
          <div class="program-desc">Vyond + Articulate</div>
          <span class="program-hrs">24 hrs</span>
        </div>
        <div class="program-card">
          <div class="program-name">Stack completo</div>
          <div class="program-desc">Diseño instruccional + Articulate + Moodle</div>
          <span class="program-hrs">48 hrs</span>
        </div>
        <div class="program-card">
          <div class="program-name">Actualización de equipo</div>
          <div class="program-desc">Storyline avanzado + xAPI</div>
          <span class="program-hrs">16 hrs</span>
        </div>
      </div>
    </div>

    <div class="section-block">
      <h3>Incluye</h3>
      <ul class="includes-list">
        <li>Instructor dedicado</li>
        <li>Material didáctico</li>
        <li>Proyecto práctico grupal</li>
        <li>Certificados individuales</li>
        <li>Grabación de sesiones (opcional)</li>
      </ul>
    </div>
  </div>

  <div>
    <div class="details-card">
      <h3>Diseñemos juntos</h3>
      <div class="detail-row"><span class="detail-icon">🔧</span><div><span class="detail-label">Tipo</span><span class="detail-value">Programa a medida</span></div></div>
      <div class="detail-row"><span class="detail-icon">⏱</span><div><span class="detail-label">Duración</span><span class="detail-value">Flexible según módulos elegidos</span></div></div>
      <div class="detail-row"><span class="detail-icon">🖥</span><div><span class="detail-label">Modalidad</span><span class="detail-value">Virtual o presencial en CDMX</span></div></div>
      <div class="detail-row"><span class="detail-icon">👥</span><div><span class="detail-label">Grupo</span><span class="detail-value">Tu equipo completo</span></div></div>
      <div class="detail-row"><span class="detail-icon">🏆</span><div><span class="detail-label">Certificados</span><span class="detail-value">Individuales por participante</span></div></div>
      <div class="cta-buttons">
        <a href={r('/contacto')} class="btn-primary-full">Diseñar mi programa →</a>
        <a href={contactData.whatsapp.url} target="_blank" rel="noopener noreferrer" class="btn-wa-full"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>WhatsApp</a>
      </div>
    </div>
  </div>
</div>
</main>
</BaseLayout>
