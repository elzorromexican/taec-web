---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroComercial from '../components/ui/HeroComercial.astro';
import GridBeneficios from '../components/ui/GridBeneficios.astro';
import FAQAccordion from '../components/ui/FAQAccordion.astro';
import CtaFinal from '../components/ui/CtaFinal.astro';

const appsVyond = [
  { icon: "⚡", title: "Vyond Go", description: "Tu creador de video instantáneo con IA. Escribe un prompt como «Curso de onboarding», presiona Vyond Go y en segundos tienes un video listo. Edita texto, personajes y voz directamente, o llévalo a Vyond Studio para personalizarlo a fondo." },
  { icon: "🎬", title: "Vyond Studio", description: "El editor de video completo con drag-and-drop. Genera fondos e imágenes con IA, sincroniza audio en 70+ idiomas, elimina fondos de fotos, personaliza movimientos de personajes filmando un video como prompt, y crea tu propio avatar desde una foto." },
  { icon: "📱", title: "Vyond Mobile", description: "Creación de video en cualquier lugar. Descarga la app gratuita (Android / iOS), usa Smart Capture para que la IA combine props, fondos y personajes de la librería con tus fotos. Los cambios se sincronizan en todos tus dispositivos al instante." }
];

const faqsVyond = [
  { question: "¿Cómo accedo a Vyond Go?", answerHtml: "Todos los usuarios de Vyond tienen acceso automático a Vyond Go. Lo encuentras seleccionando \"Crear con IA\" desde el botón +Crear en la página de listado de videos." },
  { question: "¿Cuánto tiempo pueden durar los videos creados en Vyond?", answerHtml: "Los usuarios de Vyond Enterprise pueden crear videos de hasta 90 minutos de duración. Los usuarios de Vyond Professional pueden crear videos de hasta 40 minutos." },
  { question: "¿En qué formatos puedo exportar mis videos?", answerHtml: "Los videos de Vyond se exportan fácilmente en los formatos comunes GIF y MP4, compatibles con cualquier LMS, plataforma web o red social." },
  { question: "¿Cuáles son los 3 estilos de personajes disponibles?", answerHtml: "<strong>Whiteboard:</strong> simple, sin color, ideal para entornos educativos donde quieres enfocar la atención del usuario.<br/><strong>Contemporary:</strong> moderno y colorido, adecuado para casi cualquier propósito.<br/><strong>Business friendly:</strong> más formal, ideal para presentaciones y material de marketing." },
  { question: "¿Puedo crear mi propio avatar IA personalizado?", answerHtml: "Los avatares personalizados no están incluidos en las licencias base pero se pueden solicitar como add-on. El proceso requiere grabar un video de 2 minutos como entrenamiento. Solo tú tienes acceso a tu avatar, aunque puedes compartirlo con tu equipo. Contáctanos para más información." },
  { question: "¿Cuáles son las diferencias clave entre Enterprise y Professional?", answerHtml: "<strong>Enterprise:</strong> colaboración entre equipos, créditos de IA prácticamente ilimitados, ideal para grandes organizaciones. Videos hasta 90 min.<br/><strong>Professional:</strong> perfecto para equipos y empresas medianas. Cada generación en Vyond Go usa 400 créditos. Videos hasta 40 min.<br/>Contáctanos y te ayudamos a elegir el plan correcto para tu organización." },
  { question: "¿Hay límite en la generación de imágenes con IA?", answerHtml: "Para usuarios Enterprise prácticamente no hay límite. Los usuarios Professional tienen un sistema de créditos. Consúltanos para más detalles sobre los planes disponibles en México." }
];

const base = import.meta.env.BASE_URL;
function r(url: string): string {
  if (!url || url.startsWith('http://') || url.startsWith('https://') || url.startsWith('//')) return url;
  return base.replace(/\/$/, '') + url;
}
---

<BaseLayout 
  title="Vyond en México – Animación para e-learning | TAEC"
  description="Crea videos animados profesionales para capacitación corporativa. Partner oficial Vyond para México y LATAM."
  section="Soluciones"
  page="vyond-mexico.html"
>
  <style is:global>

    /* ── Dropdown open state (JS-managed) ── */
    .nav-item.open > .mega-menu        { display: grid !important; }
    .nav-item.open > .simple-dropdown  { display: grid !important; }
    .nav-item.open > .nav-link         { background: var(--light); color: var(--blue); }
    .nav-item.open > .nav-link svg     { transform: rotate(180deg); }

    /* ── G2 SOCIAL PROOF ── */
    .g2-section { background: #F8FAFC; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 40px 5%; }
    .g2-inner { max-width: 900px; margin: 0 auto; display: flex; align-items: center; gap: 48px; flex-wrap: wrap; justify-content: center; }
    .g2-badge { display: flex; flex-direction: column; align-items: center; gap: 4px; min-width: 120px; }
    .g2-score { font-size: 52px; font-weight: 800; color: #111827; line-height: 1; }
    .g2-stars { color: #FF492C; font-size: 22px; letter-spacing: 2px; }
    .g2-label { font-size: 12px; color: #64748B; font-weight: 600; text-align: center; }
    .g2-logo { display: flex; align-items: center; gap: 6px; margin-top: 6px; }
    .g2-logo-circle { width: 28px; height: 28px; background: #FF492C; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 900; font-size: 14px; }
    .g2-divider { width: 1px; height: 80px; background: var(--border); }
    .g2-reviews { display: flex; flex-direction: column; gap: 16px; flex: 1; min-width: 280px; }
    .g2-quote { background: white; border: 1px solid var(--border); border-radius: 10px; padding: 14px 18px; }
    .g2-quote-text { font-size: 14px; font-weight: 600; color: #111827; margin-bottom: 4px; }
    .g2-quote-author { font-size: 12px; color: #64748B; }
    .g2-quote-stars { color: #FF492C; font-size: 12px; }
    .g2-cta { text-align: center; margin-top: 20px; }
    .g2-link { font-size: 12px; color: #64748B; text-decoration: underline; }
    .g2-link:hover { color: #FF492C; }

    /* ══ VYOND PAGE ══ */
    :root { --vy-orange:#C84D16; --vy-light:#FFF5F0; }

    /* Stats bar */
    .vy-stats { background:white; border-bottom:1px solid var(--border); padding:28px 5%; }
    .vy-stats-inner { max-width:900px; margin:0 auto; display:flex; justify-content:center; gap:56px; flex-wrap:wrap; }
    .vy-stat { text-align:center; }
    .vy-stat-num { font-size:32px; font-weight:800; color:var(--vy-orange); line-height:1; }
    .vy-stat-label { font-size:12px; color:#64748B; margin-top:4px; }

    /* Sections */
    .vy-section { padding:64px 5%; }
    .vy-section-alt { background:#F8FAFC; }
    .vy-section-inner { max-width:1100px; margin:0 auto; }
    .vy-section-title { font-size:clamp(22px,2.5vw,32px); font-weight:800; color:#111827; margin-bottom:12px; }
    .vy-section-sub { font-size:16px; color:#64748B; margin-bottom:40px; max-width:680px; }

    /* AI Features */
    .vy-ai-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:20px; }
    .vy-ai-card { background:white; border:1px solid var(--border); border-radius:12px; padding:22px; display:flex; gap:16px; }
    .vy-ai-icon { font-size:26px; flex-shrink:0; }
    .vy-ai-title { font-size:15px; font-weight:700; color:#111827; margin-bottom:6px; }
    .vy-ai-desc { font-size:13px; color:#475569; line-height:1.5; }

    /* Testimonial */
    .vy-testimonial { background:linear-gradient(135deg,#1a0a00,#3d1200); padding:56px 5%; text-align:center; }
    .vy-testimonial blockquote { max-width:720px; margin:0 auto; font-size:clamp(16px,2vw,22px); color:white; line-height:1.6; font-style:italic; margin-bottom:20px; }
    .vy-testimonial cite { font-size:13px; color:#FFCBA4; font-weight:700; font-style:normal; }

    /* Badges strip */
    .vy-badges { background:white; padding:40px 5%; border-top:1px solid var(--border); border-bottom:1px solid var(--border); }
    .vy-badges-inner { max-width:1100px; margin:0 auto; }
    .vy-badges-label { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1.2px; color:#94A3B8; text-align:center; margin-bottom:24px; }
    .vy-badges-row { display:flex; align-items:center; justify-content:center; gap:28px; flex-wrap:wrap; }
    .vy-badge-img { height:110px; width:auto; object-fit:contain; }
    .vy-partner-badge { height:130px; }

    /* Responsive */
    @media(max-width:768px){
      .vy-ai-grid { grid-template-columns:1fr; }
      .vy-stats-inner { gap:28px; }
    }

  </style>

<main id="main-content">

<!-- ══ HERO ══ -->
<HeroComercial
  theme="vyond"
  eyebrow="Vyond"
  titleHtml="La única plataforma <em>todo-en-uno</em> de creación de video con IA"
  subtitle="Crea videos animados, con personajes IA, grabaciones reales y contenido mixto. Todo desde una sola plataforma. TAEC es distribuidor autorizado de Vyond para México y LATAM."
  features={[
    "Licencias oficiales con factura en MXN (CFDI)",
    "Soporte técnico en español",
    "Onboarding y capacitación incluidos",
    "Pago en pesos al tipo de cambio oficial",
    "+18 años de experiencia en e-learning",
    "Acompañamiento en renovaciones"
  ]}
  primaryBtn={{ label: "Probar Vyond gratis →", url: "https://think.vyond.com/signup", target: "_blank" }}
  secondaryBtn={{ label: "Solicitar cotización", url: "/contacto" }}
  bottomText="✓ Sin tarjeta de crédito · ✓ Soporte en español · ✓ Factura mexicana (CFDI)"
  cardLogoSrc={`${base}assets/badges/vyond-certified-partner.webp`}
  cardLogoStyle="height:80px;width:auto;"
  cardBadgeText="Por qué elegir Vyond con TAEC"
/>

<!-- ══ STATS ══ -->
<div class="vy-stats">
  <div class="vy-stats-inner">
    <div class="vy-stat"><div class="vy-stat-num">70+</div><div class="vy-stat-label">Idiomas con traducción automática</div></div>
    <div class="vy-stat"><div class="vy-stat-num">40K+</div><div class="vy-stat-label">Personajes, props y acciones</div></div>
    <div class="vy-stat"><div class="vy-stat-num">4M+</div><div class="vy-stat-label">Imágenes, videos y clips de audio</div></div>
    <div class="vy-stat"><div class="vy-stat-num">20K+</div><div class="vy-stat-label">Empresas en todo el mundo</div></div>
  </div>
</div>

<!-- ══ TRES APLICACIONES ══ -->
<GridBeneficios
  theme="vyond"
  title="Con tu licencia Vyond obtienes tres aplicaciones"
  subtitle="Transición perfecta entre ellas según lo que necesites en cada momento."
  columns={3}
  cards={appsVyond}
/>

<!-- ══ IA FEATURES ══ -->
<section class="vy-section vy-section-alt">
  <div class="vy-section-inner">
    <h2 class="vy-section-title">Inteligencia artificial en cada paso</h2>
    <p class="vy-section-sub">Herramientas de IA que hacen el trabajo pesado para que tú te concentres en el mensaje.</p>
    <div class="vy-ai-grid">
      <div class="vy-ai-card">
        <div class="vy-ai-icon">🧑‍💻</div>
        <div>
          <div class="vy-ai-title">Avatares IA</div>
          <div class="vy-ai-desc">Olvídate de los costosos rodajes. Elige entre una amplia gama de avatares realistas que guían a tus aprendices en su propio idioma. Disponibles como add-on para mayor personalización.</div>
        </div>
      </div>
      <div class="vy-ai-card">
        <div class="vy-ai-icon">🎨</div>
        <div>
          <div class="vy-ai-title">Texto a imagen</div>
          <div class="vy-ai-desc">Describe lo que necesitas y Vyond lo genera en 6 estilos distintos: arte en papel, fotorrealismo, y más. Imágenes y fondos únicos para cada video sin salir de la plataforma.</div>
        </div>
      </div>
      <div class="vy-ai-card">
        <div class="vy-ai-icon">🌍</div>
        <div>
          <div class="vy-ai-title">Localización automática</div>
          <div class="vy-ai-desc">Texto a voz, subtítulos y guiones — tradúcelos directamente en tu flujo de trabajo. Más de 70 idiomas disponibles, con más en camino. Ideal para organizaciones globales.</div>
        </div>
      </div>
      <div class="vy-ai-card">
        <div class="vy-ai-icon">✂️</div>
        <div>
          <div class="vy-ai-title">Herramientas de edición IA</div>
          <div class="vy-ai-desc">Elimina fondos de fotos con un clic. Suprime ruido de voz automáticamente. Photo to Character y Video to Action convierten tus archivos en elementos animados al instante.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ TESTIMONIAL ══ -->
<section class="vy-testimonial">
  <blockquote>"Whenever training requires animated video, I reach for Vyond. The flexibility of their tool makes it easy to demonstrate the emotion of characters in real situations. Stories bring training to life. Vyond brings stories to life."</blockquote>
  <cite>— Rance Greene · Instructional Designer &amp; Storyteller</cite>
</section>

<!-- ══ G2 SOCIAL PROOF ══ -->
<section class="g2-section">
  <div class="g2-inner">
    <div class="g2-badge">
      <div class="g2-score">4.8</div>
      <div class="g2-stars">★★★★★</div>
      <div class="g2-label">466 reseñas verificadas</div>
      <div class="g2-logo">
        <div class="g2-logo-circle">G</div>
        <span style="font-size:13px;font-weight:700;color:#111827;">G2</span>
      </div>
    </div>
    <div class="g2-divider"></div>
    <div class="g2-reviews">
      <div class="g2-quote">
        <div class="g2-quote-stars">★★★★★</div>
        <div class="g2-quote-text">"Easy-to-Use, Powerful Tool for Polished Videos"</div>
        <div class="g2-quote-author">Usuario actual verificado · Empresa corporativa</div>
      </div>
      <div class="g2-quote">
        <div class="g2-quote-stars">★★★★★</div>
        <div class="g2-quote-text">"Transformational Tool for Training Videos with Excellent Support"</div>
        <div class="g2-quote-author">Deepika V. · Trainer · Empresa +1,000 empleados</div>
      </div>
    </div>
  </div>
  <div class="g2-cta">
    <a href="https://www.g2.com/products/vyond/reviews" target="_blank" rel="noopener noreferrer" class="g2-link">Ver todas las reseñas en G2 →</a>
  </div>
</section>

<!-- ══ BADGES / RECONOCIMIENTOS ══ -->
<section class="vy-badges">
  <div class="vy-badges-inner">
    <p class="vy-badges-label">Reconocimientos G2 Winter 2026</p>
    <div class="vy-badges-row">
      <img src={`${base}assets/badges/g2-leader-enterprise.png`}   alt="G2 Leader Enterprise Winter 2026"  class="vy-badge-img" />
      <img src={`${base}assets/badges/g2-best-results.avif`}       alt="G2 Best Results Enterprise"        class="vy-badge-img" />
      <img src={`${base}assets/badges/g2-best-usability.avif`}     alt="G2 Best Usability Enterprise"      class="vy-badge-img" />
      <img src={`${base}assets/badges/g2-best-roi.avif`}           alt="G2 Best Estimated ROI Enterprise"  class="vy-badge-img" />
      <img src={`${base}assets/badges/g2-most-implementable.avif`} alt="G2 Most Implementable Enterprise"  class="vy-badge-img" />
      <img src={`${base}assets/badges/g2-easiest-setup.avif`}      alt="G2 Easiest Setup Enterprise"       class="vy-badge-img" />
    </div>
  </div>
</section>

<!-- ══ PLANES ══ -->
<section id="planes" style="padding:72px 5%;background:#F8FAFC;">
  <div style="max-width:1100px;margin:0 auto;">
    <p style="font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--vy-orange);margin-bottom:10px;text-align:center;">Planes y precios</p>
    <h2 style="font-size:clamp(24px,2.8vw,36px);font-weight:800;color:#111827;text-align:center;margin-bottom:8px;">Planes Vyond</h2>
    <p style="text-align:center;color:#64748B;font-size:15px;margin-bottom:44px;">Precios en USD sin IVA · facturación anual · pago en MXN al tipo de cambio oficial</p>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:22px;align-items:start;">

      <!-- Demo gratuita -->
      <div style="background:white;border:1.5px solid var(--border);border-radius:16px;padding:32px 28px;display:flex;flex-direction:column;gap:0;">
        <div style="display:inline-flex;align-items:center;justify-content:center;width:48px;height:48px;background:var(--vy-orange);color:white;font-size:13px;font-weight:800;border-radius:12px;margin-bottom:16px;line-height:1.1;text-align:center;">DEMO<br>FREE</div>
        <p style="font-size:20px;font-weight:800;color:var(--vy-orange);margin-bottom:4px;">Demo gratuita</p>
        <p style="font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#64748B;margin-bottom:16px;">TODAS LAS HERRAMIENTAS</p>
        <p style="font-size:42px;font-weight:800;color:#111827;line-height:1;margin-bottom:4px;"><sup style="font-size:22px;vertical-align:top;margin-top:8px;">$</sup>0</p>
        <p style="font-size:12px;color:#94A3B8;margin-bottom:20px;">sin tarjeta de crédito</p>
        <a href="https://think.vyond.com/signup" target="_blank" rel="noopener noreferrer" style="display:block;text-align:center;background:#111827;color:white;font-weight:700;font-size:14px;padding:13px;border-radius:8px;margin-bottom:8px;">Comenzar demo gratis</a>
        <p style="text-align:center;font-size:11px;color:#94A3B8;margin-bottom:20px;">Sin tarjeta de crédito</p>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;">
          <li style="font-size:13px;color:#374151;display:flex;gap:8px;"><span style="color:var(--vy-orange);font-weight:700;flex-shrink:0;">✓</span>Acceso a Vyond Go, Studio y Mobile</li>
          <li style="font-size:13px;color:#374151;display:flex;gap:8px;"><span style="color:var(--vy-orange);font-weight:700;flex-shrink:0;">✓</span>IA: texto a video, avatares, estilos</li>
          <li style="font-size:13px;color:#374151;display:flex;gap:8px;"><span style="color:var(--vy-orange);font-weight:700;flex-shrink:0;">✓</span>Exporta y descarga tus videos</li>
        </ul>
      </div>

      <!-- Professional -->
      <div style="background:white;border:1.5px solid var(--border);border-radius:16px;padding:32px 28px;display:flex;flex-direction:column;gap:0;">
        <p style="font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:#64748B;margin-bottom:8px;">Professional</p>
        <p style="font-size:14px;font-weight:600;color:var(--vy-orange);margin-bottom:12px;">POR USUARIO · ANUAL</p>
        <p style="font-size:42px;font-weight:800;color:#111827;line-height:1;margin-bottom:2px;"><sup style="font-size:22px;vertical-align:top;margin-top:8px;">US$</sup>1,199</p>
        <p style="font-size:12px;color:#94A3B8;margin-bottom:20px;">por usuario · un solo pago al año</p>
        <a href={r('/contacto')} style="display:block;text-align:center;background:var(--vy-orange);color:white;font-weight:700;font-size:14px;padding:13px;border-radius:8px;margin-bottom:8px;">Solicitar cotización →</a>
        <a href="https://tienda.taec.com.mx" target="_blank" rel="noopener noreferrer" style="display:block;text-align:center;background:#F1F5F9;color:#111827;font-weight:700;font-size:14px;padding:13px;border-radius:8px;margin-bottom:8px;">🛒 Ver en Tienda</a>
        <p style="text-align:center;font-size:11px;color:#94A3B8;margin-bottom:20px;">Mismo precio en renovaciones</p>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;">
          <li style="font-size:13px;color:#374151;display:flex;gap:8px;"><span style="color:var(--vy-orange);font-weight:700;flex-shrink:0;">✓</span>Herramientas de colaboración en equipo</li>
          <li style="font-size:13px;color:#374151;display:flex;gap:8px;"><span style="color:var(--vy-orange);font-weight:700;flex-shrink:0;">✓</span>4M+ assets Shutterstock incluidos</li>
          <li style="font-size:13px;color:#374151;display:flex;gap:8px;"><span style="color:var(--vy-orange);font-weight:700;flex-shrink:0;">✓</span>Traducción instantánea a 80+ idiomas</li>
          <li style="font-size:13px;color:#374151;display:flex;gap:8px;"><span style="color:var(--vy-orange);font-weight:700;flex-shrink:0;">✓</span>Avatares generativos desde texto</li>
          <li style="font-size:13px;color:#374151;display:flex;gap:8px;"><span style="color:var(--vy-orange);font-weight:700;flex-shrink:0;">✓</span>20,000 créditos por usuario/mes</li>
        </ul>
      </div>

      <!-- Enterprise — destacado -->
      <div style="background:linear-gradient(145deg,#1a0a00,#3d1200);border:2px solid var(--vy-orange);border-radius:16px;padding:32px 28px;display:flex;flex-direction:column;gap:0;position:relative;">
        <div style="position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:var(--vy-orange);color:white;font-size:11px;font-weight:700;padding:4px 16px;border-radius:20px;white-space:nowrap;">⭐ Mejor opción para equipos</div>
        <p style="font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:#FFCBA4;margin-bottom:8px;">Enterprise</p>
        <p style="font-size:14px;font-weight:600;color:#FFCBA4;margin-bottom:12px;">POR USUARIO · ANUAL</p>
        <p style="font-size:42px;font-weight:800;color:white;line-height:1;margin-bottom:2px;"><sup style="font-size:22px;vertical-align:top;margin-top:8px;">US$</sup>1,649</p>
        <p style="font-size:12px;color:rgba(255,203,164,.5);margin-bottom:20px;">por usuario · un solo pago al año</p>
        <a href={r('/contacto')} style="display:block;text-align:center;background:var(--vy-orange);color:white;font-weight:700;font-size:14px;padding:13px;border-radius:8px;margin-bottom:8px;">Solicitar cotización →</a>
        <a href="https://tienda.taec.com.mx" target="_blank" rel="noopener noreferrer" style="display:block;text-align:center;background:rgba(255,255,255,.1);color:white;font-weight:700;font-size:14px;padding:13px;border-radius:8px;margin-bottom:8px;border:1px solid rgba(255,255,255,.2);">🛒 Ver en Tienda</a>
        <p style="text-align:center;font-size:11px;color:rgba(255,203,164,.5);margin-bottom:20px;">Mismo precio en renovaciones</p>
