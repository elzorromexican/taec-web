---
import CtaFinal from "../components/ui/CtaFinal.astro";
import FAQAccordion from "../components/ui/FAQAccordion.astro";
import HeroComercial from "../components/ui/HeroComercial.astro";
import { getBookingUrl } from "../data/contact";
import BaseLayout from "../layouts/BaseLayout.astro";

import { base } from "../utils/paths";

const faqsMoodle = [
	{
		question: "¿Moodle es realmente gratuito?",
		answerHtml:
			"El software Moodle es gratuito y de código abierto. Lo que tiene un costo es el hospedaje (hosting), la implementación y el soporte. El servicio SaaS de TAEC incluye todo eso: infraestructura en la nube, actualizaciones automáticas, backups diarios y soporte técnico en español — sin que tengas que preocuparte por los servidores.",
	},
	{
		question: "¿Qué incluye el hosting SaaS de Moodle con TAEC?",
		answerHtml:
			"El hosting SaaS incluye: servidor dedicado o compartido según el plan, dominio o subdominio personalizado, certificado SSL, actualizaciones de Moodle y plugins incluidos, backups diarios automatizados, monitoreo de disponibilidad 24/7 y soporte técnico en español en horario de oficina. También incluimos la instalación inicial y configuración básica de la plataforma.",
	},
	{
		question: "¿Cuánto tiempo tarda una implementación de Moodle?",
		answerHtml:
			"Una implementación estándar (hosting SaaS + configuración inicial + tema básico) está lista en 48 a 72 horas hábiles. Una implementación completa con personalización de tema, plugins a medida, migración de datos e integración con sistemas externos puede tomar entre 2 y 6 semanas dependiendo de la complejidad.",
	},
	{
		question: "¿Puedo migrar mi Moodle actual a TAEC?",
		answerHtml:
			"Sí. Realizamos migraciones desde otras instancias de Moodle (auto-hospedadas u hospedadas por otros proveedores) conservando cursos, usuarios, calificaciones, foros y toda la información de la plataforma. También podemos migrar desde otras plataformas LMS exportando el contenido en formatos estándar (SCORM, xAPI).",
	},
	{
		question: "¿Cuál es la diferencia entre Moodle LMS y Moodle Workplace?",
		answerHtml:
			"Moodle LMS es la plataforma open source estándar, ideal para instituciones educativas y empresas que necesitan un LMS robusto y flexible. Moodle Workplace es la edición enterprise construida sobre Moodle LMS, que agrega gestión multi-empresa, automatizaciones de RR.HH., flujos de trabajo corporativos, reportes avanzados y certificados digitales. Workplace es la opción recomendada para organizaciones con más de 500 usuarios o requerimientos de cumplimiento normativo complejos.",
	},
	{
		question: "¿Ofrecen capacitación para administradores de Moodle?",
		answerHtml:
			"Sí. TAEC ofrece cursos abiertos de Moodle para administradores de plataforma y cursos cerrados personalizados para equipos de e-learning. También incluimos una capacitación básica de administración en cada implementación nueva. Contáctanos para conocer el calendario de cursos abiertos.",
	},
];
---

<BaseLayout 
  title="Moodle en México – Hosting SaaS, implementación y soporte | TAEC"
  description="Partner oficial de Moodle en México y LATAM. Hosting SaaS gestionado, implementación, personalización y soporte en español. +18 años de experiencia en e-learning."
  section="Soluciones"
  page="moodle-mexico.html"
>
  <style>
    /* ── PRODUCT LOGO ── */
    .product-logo-wrap { display: inline-flex; align-items: center; justify-content: center; background: #ffffff; border-radius: 10px; padding: 10px 20px; margin-bottom: 20px; box-shadow: 0 2px 12px rgba(0,0,0,.15); }
    .product-logo { height: 36px; width: auto; display: block; }

    /* ── MOODLE VARS ── */
    :root { --moo:var(--logo-moodle); --moo-dark:#C46200; --moo-light:#FFB05A; }



    /* ── STATS ── */
    .moo-stats { background: #110400; padding: 0; }
    .moo-stats-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); }
    .moo-stat { padding: 28px 20px; text-align: center; border-right: 1px solid rgba(255,255,255,.08); }
    .moo-stat:last-child { border-right: none; }
    .moo-stat-num { font-size: clamp(28px, 3vw, 38px); font-weight: 800; color: var(--moo-light); line-height: 1; margin-bottom: 6px; }
    .moo-stat-lbl { font-size: 13px; color: rgba(255,255,255,.6); line-height: 1.4; }

    /* ── PRODUCTS ── */
    .moo-products { padding: 72px 5%; background: #F8FAFC; }
    .moo-products-inner { max-width: 1100px; margin: 0 auto; }
    .moo-section-label { font-size: 11px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; color: var(--moo-dark); margin-bottom: 10px; text-align: center; }
    .moo-section-title { font-family: var(--font-display); font-size: clamp(24px, 2.8vw, 36px); font-weight: 400; color: #111827; text-align: center; margin-bottom: 8px; }
    .moo-section-sub { text-align: center; color: #64748B; font-size: 15px; margin-bottom: 48px; margin-left: auto; margin-right: auto; }
    .moo-products-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .moo-product-card { background: white; border: 1.5px solid var(--border); border-radius: 16px; padding: 28px; display: flex; flex-direction: column; gap: 0; transition: box-shadow .2s, transform .2s; min-height: 480px; }
    .moo-product-card:hover { box-shadow: 0 8px 32px rgba(248,134,13,.12); transform: translateY(-2px); }
    .moo-product-icon { width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 26px; margin-bottom: 18px; }
    .moo-product-name { font-size: 18px; font-weight: 800; color: #111827; margin-bottom: 8px; }
    .moo-product-tag { font-size: 11px; font-weight: 700; letter-spacing: .8px; text-transform: uppercase; color: var(--moo-dark); margin-bottom: 12px; }
    .moo-product-desc { font-size: 14px; color: #64748B; line-height: 1.7; margin-bottom: 20px; flex: 1; }
    .moo-product-feats { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 7px; border-top: 1px solid var(--border); padding-top: 16px; }
    .moo-product-feats li { font-size: 13px; color: #374151; display: flex; gap: 8px; align-items: flex-start; }
    .moo-product-feats li::before { content: "✓"; color: var(--moo); font-weight: 700; flex-shrink: 0; }

    /* ── TAEC SERVICES ── */
    .moo-services { padding: 72px 5%; background: white; }
    .moo-services-inner { max-width: 1100px; margin: 0 auto; }
    .moo-services-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-top: 48px; }
    .moo-service-card { padding: 32px; border: 1.5px solid var(--border); border-radius: 14px; display: flex; gap: 20px; align-items: flex-start; transition: border-color .2s, box-shadow .2s; min-height: 180px; }
    .moo-service-card:hover { border-color: var(--moo); box-shadow: 0 4px 20px rgba(248,134,13,.08); }
    .moo-service-icon { font-size: 36px; flex-shrink: 0; }
    .moo-service-title { font-size: 17px; font-weight: 700; color: #111827; margin-bottom: 8px; }
    .moo-service-desc { font-size: 14px; color: #64748B; line-height: 1.7; }

    /* ── WHY MOODLE ── */
    .moo-why { padding: 72px 5%; background: #F8FAFC; }
    .moo-why-inner { max-width: 1100px; margin: 0 auto; }
    .moo-why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 48px; }
    .moo-why-card { padding: 28px; border: 1.5px solid var(--border); border-radius: 14px; background: white; transition: border-color .2s; min-height: 250px; }
    .moo-why-card:hover { border-color: var(--moo); }
    .moo-why-icon { font-size: 32px; margin-bottom: 14px; }
    .moo-why-title { font-size: 16px; font-weight: 700; color: #111827; margin-bottom: 8px; }
    .moo-why-desc { font-size: 14px; color: #64748B; line-height: 1.7; }

    /* ── G2 BADGES ── */
    .g2-badges-section { background: #F8FAFC; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 44px 5%; }
    .g2-badges-inner { max-width: 960px; margin: 0 auto; text-align: center; }
    .g2-badges-title { font-size: 13px; font-weight: 700; color: #64748B; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 28px; }
    .g2-badge-card { background: white; border: 1px solid #E2E8F0; border-radius: 10px; padding: 16px 14px; width: 130px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,.06); }
    .g2-badge-season { font-size: 9px; font-weight: 700; color: #64748B; letter-spacing: .5px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
    .g2-badge-g2 { background: #FF492C; color: white; font-size: 9px; font-weight: 900; padding: 2px 5px; border-radius: 3px; }
    .g2-badge-name { font-size: 15px; font-weight: 900; color: #111827; line-height: 1.2; margin-bottom: 6px; }
    .g2-badge-cat { font-size: 10px; color: #64748B; font-weight: 600; }
    .g2-badge-bar { height: 5px; border-radius: 0 0 6px 6px; margin: 10px -14px -16px; }
    .bar-leader { background: linear-gradient(90deg, #EF4444, #F97316); }
    .bar-usability { background: #EAB308; }
    .bar-momentum { background: var(--check-green); }
    .bar-results { background: #7C3AED; }
    .g2-badges-link { font-size: 13px; color: #64748B; text-decoration: underline; }
    .g2-badges-link:hover { color: #FF492C; }

    /* ── TESTIMONIAL ── */
    .moo-testimonial { background: linear-gradient(135deg, #1a0600, #3d1500); padding: 64px 5%; text-align: center; color: white; }
    .moo-quote { font-family: var(--font-display); font-size: clamp(18px, 2vw, 26px); font-weight: 400; color: white; line-height: 1.6; max-width: 780px; margin: 0 auto 28px; font-style: italic; }
    .moo-quote-author { font-size: 14px; font-weight: 600; color: var(--moo-light); }
    .moo-quote-role { font-size: 13px; color: rgba(255,255,255,.6); }


  </style>

  <main id="main-content">
    <!-- ══ HERO ══ -->
    <HeroComercial 
      theme="moo"
      eyebrow="Moodle"
      titleHtml="El LMS de código abierto <em>más usado del mundo</em>"
      subtitle="Implementamos, hospedamos y soportamos Moodle en México y LATAM desde 2007. Tu plataforma lista en días — sin preocuparte por servidores, actualizaciones ni seguridad."
      primaryBtn={{ label: "Solicitar demo →", url: "/contacto" }}
      secondaryBtn={{ label: "Hablar con un especialista", url: getBookingUrl('moodle') }}
      bottomText="✓ Hosting SaaS gestionado por TAEC · ✓ Soporte en español · ✓ +18 años de experiencia"
      cardLogoSrc={`${base}assets/logos/moodle.png`}
      cardBadgeText="Por qué Moodle con TAEC"
      features={[
        "Hosting SaaS — tu Moodle listo en 48 horas",
        "Actualizaciones, backups y seguridad incluidos",
        "Soporte técnico dedicado en español",
        "Personalización de tema e identidad de marca",
        "Factura electrónica mexicana (CFDI)",
        "Integración con Articulate 360 y Vyond"
      ]}
    />

    <!-- ══ STATS ══ -->
    <div class="moo-stats">
      <div class="moo-stats-inner">
        <div class="moo-stat"><div class="moo-stat-num">400M+</div><div class="moo-stat-lbl">usuarios en el mundo</div></div>
        <div class="moo-stat"><div class="moo-stat-num">100K+</div><div class="moo-stat-lbl">sitios activos globales</div></div>
        <div class="moo-stat"><div class="moo-stat-num">80+</div><div class="moo-stat-lbl">idiomas disponibles</div></div>
        <div class="moo-stat"><div class="moo-stat-num">100%</div><div class="moo-stat-lbl">código abierto</div></div>
      </div>
    </div>

    <!-- ══ PRODUCTOS ══ -->
    <section class="moo-products">
      <div class="moo-products-inner">
        <p class="moo-section-label">La suite Moodle</p>
        <h2 class="moo-section-title">Una plataforma para cada necesidad</h2>
        <p class="moo-section-sub">Desde el LMS clásico hasta una solución enterprise con automatizaciones y aprendizaje móvil — todo bajo el paraguas de Moodle.</p>
        <div class="moo-products-grid">
          <!-- Moodle LMS -->
          <div class="moo-product-card" style="border-color:var(--moo);">
            <div class="moo-product-icon" style="background:#FEF3E2;">🎓</div>
            <p class="moo-product-tag">LMS principal</p>
            <h3 class="moo-product-name">Moodle LMS</h3>
            <p class="moo-product-desc">El sistema de gestión del aprendizaje más utilizado del mundo. Flexible, personalizable y respaldado por una comunidad global de millones de usuarios y desarrolladores.</p>
            <ul class="moo-product-feats">
              <li>Cursos, quizzes y recursos multimedia</li>
              <li>Gamificación: insignias, puntos y rankings</li>
              <li>SCORM, xAPI (Tin Can), LTI y H5P</li>
              <li>Reportes y calificaciones avanzadas</li>
              <li>Miles de plugins gratuitos</li>
            </ul>
          </div>

          <!-- Moodle Workplace -->
          <div class="moo-product-card">
            <div class="moo-product-icon" style="background:#FEF3E2;">🏢</div>
            <p class="moo-product-tag">Edición enterprise</p>
            <h3 class="moo-product-name">Moodle Workplace</h3>
            <p class="moo-product-desc">La versión enterprise de Moodle, construida sobre Moodle LMS con automatizaciones de RR.HH., gestión multi-empresa y flujos de trabajo avanzados para organizaciones.</p>
            <ul class="moo-product-feats">
              <li>Gestión multi-empresa y multi-tenant</li>
              <li>Automatizaciones de onboarding y cumplimiento</li>
              <li>Certificados digitales automatizados</li>
              <li>Reportes corporativos y dashboards</li>
              <li>Integración con HRIS y SSO empresarial</li>
            </ul>
          </div>

          <!-- Moodle App -->
          <div class="moo-product-card">
            <div class="moo-product-icon" style="background:#FFF7ED;">📱</div>
            <p class="moo-product-tag">Aprendizaje móvil</p>
            <h3 class="moo-product-name">Moodle App</h3>
            <p class="moo-product-desc">Lleva el aprendizaje a cualquier lugar con la app oficial de Moodle. Disponible para iOS y Android con soporte para contenido offline — ideal para equipos en campo.</p>
            <ul class="moo-product-feats">
              <li>Acceso offline a cursos y materiales</li>
              <li>Notificaciones push de actividades y plazos</li>
              <li>Mensajería y foros desde el móvil</li>
              <li>Sincronización automática al reconectarse</li>
              <li>Compatible con Moodle LMS y Workplace</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ SERVICIOS TAEC ══ -->
    <section class="moo-services">
      <div class="moo-services-inner">
        <p class="moo-section-label">Lo que hacemos por ti</p>
        <h2 class="moo-section-title">Servicios TAEC para Moodle</h2>
        <p class="moo-section-sub">No solo vendemos Moodle — lo implementamos, lo mantenemos y te acompañamos durante toda la vida de tu plataforma.</p>
        <div class="moo-services-grid">
          <div class="moo-service-card">
            <div class="moo-service-icon">☁️</div>
            <div>
              <h3 class="moo-service-title">Hosting SaaS gestionado</h3>
              <p class="moo-service-desc">Tu Moodle en la nube — infraestructura, seguridad, actualizaciones y backups diarios a cargo de TAEC. Sin preocuparte por servidores. Disponible en 48 horas desde la contratación.</p>
            </div>
          </div>
          <div class="moo-service-card">
            <div class="moo-service-icon">🔧</div>
            <div>
              <h3 class="moo-service-title">Implementación y configuración</h3>
              <p class="moo-service-desc">Configuramos tu Moodle desde cero: tema con tu identidad visual, categorías de cursos, roles y permisos, plugins esenciales e integración con tu directorio de usuarios (LDAP/SSO).</p>
            </div>
          </div>
          <div class="moo-service-card">
            <div class="moo-service-icon">🎨</div>
            <div>
              <h3 class="moo-service-title">Personalización y desarrollo</h3>
              <p class="moo-service-desc">Desarrollamos plugins a medida, integraciones con sistemas de RR.HH. y ERP, temas visuales personalizados y flujos de trabajo específicos para tu organización.</p>
            </div>
          </div>
          <div class="moo-service-card">
            <div class="moo-service-icon">📞</div>
            <div>
              <h3 class="moo-service-title">Soporte técnico en español</h3>
              <p class="moo-service-desc">Soporte técnico por email, WhatsApp y videollamada en horario de oficina (México). Resolvemos incidencias, ayudamos a administradores y capacitamos a tu equipo.</p>
            </div>
          </div>
          <div class="moo-service-card">
            <div class="moo-service-icon">🎓</div>
            <div>
              <h3 class="moo-service-title">Capacitación para administradores</h3>
              <p class="moo-service-desc">Cursos abiertos y cerrados de Moodle para administradores de plataforma, diseñadores instruccionales y profesores. Con certificado de participación TAEC.</p>
            </div>
          </div>
          <div class="moo-service-card">
            <div class="moo-service-icon">🔄</div>
            <div>
              <h3 class="moo-service-title">Migración desde otra plataforma</h3>
              <p class="moo-service-desc">Migramos tu contenido, usuarios y calificaciones desde otra instancia de Moodle o plataforma LMS. Sin pérdida de datos y con continuidad del servicio durante la transición.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ POR QUÉ MOODLE ══ -->
    <section class="moo-why">
      <div class="moo-why-inner">
        <p class="moo-section-label">Ventajas clave</p>
        <h2 class="moo-section-title">Por qué las organizaciones eligen Moodle</h2>
        <p class="moo-section-sub">Más de 400 millones de usuarios en todo el mundo confían en Moodle para gestionar su formación.</p>
        <div class="moo-why-grid">
          <div class="moo-why-card">
            <div class="moo-why-icon">🔓</div>
            <h3 class="moo-why-title">Código abierto, sin lock-in</h3>
            <p class="moo-why-desc">Moodle es 100% open source bajo licencia GPL. Sin costos de licencia, sin dependencia de un proveedor único. Tu plataforma, tus datos, tus reglas.</p>
          </div>
          <div class="moo-why-card">
            <div class="moo-why-icon">⚙️</div>
            <h3 class="moo-why-title">Flexibilidad total</h3>
            <p class="moo-why-desc">Miles de plugins, temas y módulos disponibles. Se adapta a la educación corporativa, instituciones educativas, cumplimiento normativo y formación de clientes.</p>
          </div>
          <div class="moo-why-card">
            <div class="moo-why-icon">📈</div>
            <h3 class="moo-why-title">Escala a tu ritmo</h3>
            <p class="moo-why-desc">Desde 50 hasta 500,000 usuarios. La arquitectura de Moodle crece con tu organización sin necesidad de cambiar de plataforma ni migrar datos.</p>
          </div>
          <div class="moo-why-card">
            <div class="moo-why-icon">🔒</div>
            <h3 class="moo-why-title">Seguridad y privacidad</h3>
            <p class="moo-why-desc">Cumple con GDPR y normativas locales de privacidad. Tus datos permanecen en servidores que controlas. Actualizaciones de seguridad regulares y auditorías periódicas.</p>
          </div>
          <div class="moo-why-card">
            <div class="moo-why-icon">🌐</div>
            <h3 class="moo-why-title">Comunidad global activa</h3>
            <p class="moo-why-desc">Millones de usuarios, desarrolladores y expertos en todo el mundo. Documentación en español, foros activos y una red de partners certificados.</p>
          </div>
          <div class="moo-why-card">
            <div class="moo-why-icon">🔗</div>
            <h3 class="moo-why-title">Estándares de interoperabilidad</h3>
            <p class="moo-why-desc">Compatible con SCORM 1.2/2004, xAPI (Tin Can), LTI, H5P, LDAP y SAML2. Se integra con Microsoft 365, Google Workspace, Zoom y miles de herramientas más.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ G2 RATINGS ══ -->
    <div class="g2-badges-section">
      <div class="g2-badges-inner">
        <p class="g2-badges-title">Reconocimientos en G2 · Winter 2026</p>
        <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:24px;">
          <div class="g2-badge-card">
            <div class="g2-badge-season"><span>WINTER 2026</span><span class="g2-badge-g2">G2</span></div>
            <div class="g2-badge-name">Leader</div>
            <div class="g2-badge-cat">Learning Management Systems</div>
            <div class="g2-badge-bar bar-leader"></div>
          </div>
          <div class="g2-badge-card">
            <div class="g2-badge-season"><span>WINTER 2026</span><span class="g2-badge-g2">G2</span></div>
            <div class="g2-badge-name">Best Usability</div>
            <div class="g2-badge-cat">LMS Mid-Market</div>
            <div class="g2-badge-bar bar-usability"></div>
          </div>
          <div class="g2-badge-card">
            <div class="g2-badge-season"><span>WINTER 2026</span><span class="g2-badge-g2">G2</span></div>
            <div class="g2-badge-name">High Performer</div>
            <div class="g2-badge-cat">Online Course Platforms</div>
            <div class="g2-badge-bar bar-momentum"></div>
          </div>
          <div class="g2-badge-card">
            <div class="g2-badge-season"><span>WINTER 2026</span><span class="g2-badge-g2">G2</span></div>
            <div class="g2-badge-name">Best Results</div>
            <div class="g2-badge-cat">Learning Management</div>
            <div class="g2-badge-bar bar-results"></div>
          </div>
        </div>
        <a href="https://www.g2.com/products/moodle/reviews" target="_blank" rel="noopener noreferrer" class="g2-badges-link">Ver reseñas de Moodle en G2 →</a>
      </div>
    </div>

    <!-- ══ TESTIMONIAL ══ -->
    <section class="moo-testimonial">
      <p class="moo-quote">"Con TAEC no solo contratamos una plataforma — contratamos un equipo que entiende nuestras necesidades y nos acompaña en cada paso. Moodle con TAEC nos permitió escalar nuestra formación sin complicaciones técnicas."</p>
      <p class="moo-quote-author">Gerente de Capacitación</p>
