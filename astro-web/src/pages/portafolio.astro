---
import BaseLayout from '../layouts/BaseLayout.astro';
import PortfolioDynamicGrid from '../components/ui/PortfolioDynamicGrid';
import '../components/ui/PortfolioDynamicGrid.css';
---

<BaseLayout 
  title="Portafolio de Proyectos y Casos de Éxito | TAEC"
  description="Explora más de 120 casos de éxito reales donde hemos digitalizado el conocimiento corporativo en formato e-learning."
  section="Soluciones"
>
  <main class="portafolio-page">
    <PortfolioDynamicGrid client:load />
  </main>
</BaseLayout>

<style>
  .portafolio-page {
    padding-top: 100px; /* Previene superposición con el navbar fijo */
    min-height: 80vh;
    background-color: #ffffff;
  }
</style>
