---
/**
 * Landing Page de Totara LMS para México y LATAM.
 * 
 * @changelog
 * 2026-04-28 - issue #159: Añadidos casos de éxito de Clínica Alemana y Salud Digna en la sección testimonial.
 */
import CtaFinal from "../components/ui/CtaFinal.astro";
import FAQAccordion from "../components/ui/FAQAccordion.astro";
import GridBeneficios from "../components/ui/GridBeneficios.astro";
import HeroComercial from "../components/ui/HeroComercial.astro";
import { getBookingUrl } from "../data/contact";
import BaseLayout from "../layouts/BaseLayout.astro";

const ventajasTot = [
	{
		icon: "⚙️",
		title: "Personalización sin límites",
		description:
			"Código abierto y arquitectura flexible. Adapta la plataforma exactamente a tus procesos, marca y flujos de trabajo — sin depender del proveedor.",
	},
	{
		icon: "📋",
		title: "Cumplimiento normativo a escala",
		description:
			"Gestiona onboarding, certificaciones y cumplimiento regulatorio para miles de empleados. Automatiza asignaciones, recordatorios y reportes de vencimiento.",
	},
	{
		icon: "🌎",
		title: "Escala global, operación local",
		description:
			"35+ idiomas, zonas horarias múltiples y gestión multi-tenant. Crece de 100 a 100,000 usuarios sin cambiar de plataforma.",
	},
	{
		icon: "📊",
		title: "Impacto medible en el negocio",
		description:
			"Reportes avanzados y analíticas que conectan el aprendizaje con resultados de negocio. Demuestra el ROI de tu inversión en formación con datos concretos.",
	},
	{
		icon: "🔗",
		title: "Integración con tu ecosistema",
		description:
			"Se conecta con Microsoft Teams, HR, ERP, SSO y herramientas de autoría como Articulate 360 y Vyond. API robusta para integraciones personalizadas.",
	},
	{
		icon: "🤝",
		title: "Partner local con expertise global",
		description:
			"TAEC es partner oficial Totara para México y LATAM. Implementación, soporte en español, factura en MXN y acompañamiento durante toda la vida del contrato.",
	},
];

const faqsTot = [
	{
		question: "¿Qué diferencia a Totara de Moodle?",
		answerHtml:
			"Totara está basado en Moodle pero diseñado específicamente para entornos corporativos. Incluye gestión de desempeño (Totara Perform), audiencias dinámicas, rutas de aprendizaje avanzadas y soporte empresarial garantizado. Moodle es ideal para academia; Totara para empresa.",
	},
	{
		question: "¿Totara es open source?",
		answerHtml:
			"Sí. Totara tiene un núcleo de código abierto, lo que permite personalización total sin depender de un solo proveedor. TAEC ofrece la plataforma como SaaS gestionado — tú te concentras en el contenido, nosotros en la infraestructura.",
	},
	{
		question: "¿Puedo integrar Totara con Articulate 360 o Vyond?",
		answerHtml:
			"Sí. Totara es compatible con SCORM, xAPI y cmi5. Los cursos creados en Articulate Storyline, Rise 360 o videos de Vyond se publican directamente en Totara Learn. TAEC gestiona la integración completa.",
	},
	{
		question: "¿Cuánto tiempo toma implementar Totara?",
		answerHtml:
			"Con la implementación SaaS de TAEC, tu plataforma puede estar operativa en 2 a 4 semanas. Incluye configuración inicial, migración de usuarios, capacitación al equipo administrador y acompañamiento en los primeros 90 días.",
	},
	{
		question: "¿Puedo gestionar múltiples empresas o subsidiarias?",
		answerHtml:
			"Sí. Totara soporta arquitecturas multi-tenant y multi-organización. Ideal para corporativos con múltiples filiales, franquicias o para empresas que necesitan capacitar a clientes y partners externos.",
	},
	{
		question: "¿Cómo funciona el soporte de TAEC?",
		answerHtml:
			"El soporte incluye atención en español, mesa de ayuda por email y WhatsApp, tiempo de respuesta garantizado y acompañamiento proactivo en actualizaciones de la plataforma. Como partner oficial, tenemos acceso directo al equipo técnico de Totara.",
	},
];

import { base, r } from "../utils/paths";
---

<BaseLayout 
  title="Totara LMS en México – Partner oficial | TAEC"
  description="Totara Learn, Engage y Perform para empresas que necesitan un LMS flexible y extensible. SaaS gestionado por TAEC."
  section="Soluciones"
  page="totara-lms-mexico.html"
>
  <style is:global>

    /* ── STICKY BAR ANIMATIONS ── */
    @keyframes bounce-icon {
      0%,100% { transform: translateY(0); }
      30%      { transform: translateY(-8px); }
      60%      { transform: translateY(-4px); }
    }
    @keyframes pulse-btn {
      0%,100% { box-shadow: 0 0 0 0 rgba(168,219,217,.7); }
      50%      { box-shadow: 0 0 0 10px rgba(168,219,217,0); }
    }
    @keyframes glow-border {
      0%,100% { border-top-color: #A8DBD9; }
      50%      { border-top-color: #ffffff; }
    }
    .tot-sticky-icon  { animation: bounce-icon 1.6s ease-in-out infinite; display:inline-block; }
    .tot-sticky-btn   { animation: pulse-btn   1.8s ease-in-out infinite; }
    #tot-sticky-bar   { animation: glow-border 2s ease-in-out infinite; }

    /* ── G2 BADGES ── */
    .g2-badges-section { background: #F8FAFC; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 44px 5%; }
    .g2-badges-inner { max-width: 960px; margin: 0 auto; text-align: center; }
    .g2-badges-title { font-size: 13px; font-weight: 700; color: #64748B; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 28px; }
    .g2-badges-link { font-size: 13px; color: #64748B; text-decoration: underline; }
    .g2-badges-link:hover { color: #FF492C; }

    /* ── TOTARA VARS ── */
    :root { --tot:#004775; --tot-light:#0077b6; --tot-teal:#A8DBD9; --tot-dark:#001f3d; }

    /* ── STATS ── */
    .tot-stats{background:#001f3d;padding:0}
    .tot-stats-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr)}
    .tot-stat{padding:28px 20px;text-align:center;border-right:1px solid rgba(255,255,255,.08)}
    .tot-stat:last-child{border-right:none}
    .tot-stat-num{font-size:clamp(28px,3vw,38px);font-weight:800;color:var(--tot-teal);line-height:1;margin-bottom:6px}
    .tot-stat-lbl{font-size:13px;color:rgba(255,255,255,.6);line-height:1.4}

    /* ── PRODUCTS ── */
    .tot-products{padding:72px 5%;background:#F8FAFC}
    .tot-products-inner{max-width:1100px;margin:0 auto}
    .tot-section-label{font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--tot);margin-bottom:10px;text-align:center}
    .tot-section-title{font-family:var(--font-display);font-size:clamp(24px,2.8vw,36px);font-weight:400;color:#111827;text-align:center;margin-bottom:8px}
    .tot-section-sub{text-align:center;color:#64748B;font-size:15px;margin-bottom:48px;margin-left:auto;margin-right:auto}
    .tot-products-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
    .tot-product-card{background:white;border:1.5px solid var(--border);border-radius:16px;padding:28px;display:flex;flex-direction:column;gap:0;transition:box-shadow .2s,transform .2s; min-height: 360px;}
    .tot-product-card:hover{box-shadow:0 8px 32px rgba(0,71,117,.12);transform:translateY(-2px)}
    .tot-product-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:26px;margin-bottom:18px}
    .tot-product-name{font-size:18px;font-weight:800;color:#111827;margin-bottom:8px}
    .tot-product-tag{font-size:11px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--tot);margin-bottom:12px}
    .tot-product-desc{font-size:14px;color:#64748B;line-height:1.7;margin-bottom:20px;flex:1}
    .tot-product-feats{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:7px;border-top:1px solid var(--border);padding-top:16px}
    .tot-product-feats li{font-size:13px;color:#374151;display:flex;gap:8px;align-items:flex-start}
    .tot-product-feats li::before{content:"✓";color:var(--tot);font-weight:700;flex-shrink:0}

    /* ── TESTIMONIAL ── */
    .tot-testimonial{background:linear-gradient(135deg,#001f3d,#004775);padding:64px 5%;text-align:center;color:white}
    .tot-quote{font-family:var(--font-display);font-size:clamp(18px,2vw,26px);font-weight:400;color:white;line-height:1.6;max-width:780px;margin:0 auto 28px;font-style:italic}
    .tot-quote-author{font-size:14px;font-weight:600;color:var(--tot-teal)}
    .tot-quote-role{font-size:13px;color:rgba(255,255,255,.6)}

    /* ── PROD TABS ── */
    .prod-tabs{background:#F8FAFC;border-bottom:1px solid var(--border);padding:0 5%}
    .prod-tabs-inner{max-width:1100px;margin:0 auto;display:flex;gap:0;overflow-x:auto}
    .prod-tab{display:flex;align-items:center;gap:6px;padding:14px 20px;font-size:14px;font-weight:600;color:#64748B;text-decoration:none;border-bottom:3px solid transparent;white-space:nowrap;transition:color .15s,border-color .15s}
    .prod-tab:hover{color:#111827}
    .prod-tab.active{color:var(--tot)!important;border-bottom-color:var(--tot)!important;background:transparent!important;border-radius:0!important}
    .prod-tab-icon{font-size:16px}

    @media(max-width:768px){
      .tot-stats-inner{grid-template-columns:repeat(2,1fr)}
      .tot-products-grid{grid-template-columns:1fr}
    }
  </style>

  <!-- Formulario nativo SSR -->

  <main id="main-content">
    <!-- ══ TABS ══ -->
    <div class="prod-tabs"><div class="prod-tabs-inner">
      <a href={r('/totara-lms-mexico')} class="prod-tab active"><span class="prod-tab-icon">🏢</span>Totara</a>
    </div></div>

    <!-- ══ HERO ══ -->
    <HeroComercial
      theme="tot"
      eyebrow="Totara LMS"
      titleHtml="La plataforma LMS <em>más flexible</em> para empresas que crecen"
      subtitle="Unifica formación, colaboración y desempeño en un ecosistema potenciado por IA. La solución más innovadora para empresas que quieren escalar el aprendizaje sin límites."
      features={[
        "Implementación SaaS — tu plataforma lista en días",
        "Soporte técnico dedicado en español",
        "+500 clientes en 17 países",
        "Integración con Articulate 360 y Vyond",
        "Factura electrónica mexicana (CFDI)",
        "+18 años de experiencia en e-learning"
      ]}
      primaryBtn={{ label: "Solicitar demo →", url: "/contacto" }}
      secondaryBtn={{ label: "Hablar con un especialista", url: getBookingUrl('totara') }}
      bottomText="✓ Partner oficial Totara · México y LATAM · ✓ SaaS gestionado por TAEC · ✓ Soporte en español"
      cardLogoSrc={`${base}assets/logos/totara-reseller-vertical.png`}
      cardLogoStyle="height:90px;width:auto;"
      cardBadgeText="Por qué Totara con TAEC"
    />

    <!-- ══ STATS ══ -->
    <div class="tot-stats">
      <div class="tot-stats-inner">
        <div class="tot-stat"><div class="tot-stat-num">20M+</div><div class="tot-stat-lbl">usuarios activos</div></div>
        <div class="tot-stat"><div class="tot-stat-num">35+</div><div class="tot-stat-lbl">idiomas disponibles</div></div>
        <div class="tot-stat"><div class="tot-stat-num">500+</div><div class="tot-stat-lbl">empresas en el mundo</div></div>
        <div class="tot-stat"><div class="tot-stat-num">17</div><div class="tot-stat-lbl">países donde opera TAEC</div></div>
      </div>
    </div>

    <!-- ══ PRODUCTOS ══ -->
    <section class="tot-products">
      <div class="tot-products-inner">
        <p class="tot-section-label">La suite completa</p>
        <h2 class="tot-section-title">Tres soluciones, un ecosistema</h2>
        <p class="tot-section-sub">Totara Suite combina LMS, gestión del talento y aprendizaje móvil en una plataforma flexible — con Ayleen AI integrado en toda la suite.</p>
        <div class="tot-products-grid">

          <!-- Totara Learn -->
          <div class="tot-product-card">
            <div class="tot-product-icon" style="background:#EFF6FF;">🎓</div>
            <p class="tot-product-tag">LMS empresarial</p>
            <h3 class="tot-product-name">Totara Learn</h3>
            <p class="tot-product-desc">El LMS más personalizable del mercado. Gestiona formación, cumplimiento normativo y certificaciones a escala — sin los límites de las plataformas cerradas.</p>
            <ul class="tot-product-feats">
              <li>Rutas de aprendizaje personalizadas</li>
              <li>Gestión de cumplimiento y certificaciones</li>
              <li>Audiencias dinámicas y asignación automática</li>
              <li>App móvil Totara Learn</li>
              <li>Reportes y analíticas flexibles</li>
            </ul>
          </div>

          <!-- Totara Perform -->
          <div class="tot-product-card" style="border-color:#004775;">
            <div class="tot-product-icon" style="background:#F0FDF4;">🎯</div>
            <p class="tot-product-tag">Gestión del talento</p>
            <h3 class="tot-product-name">Totara Perform</h3>
            <p class="tot-product-desc">Alinea el desarrollo individual con los objetivos de la organización. Evaluaciones, metas, competencias y retroalimentación continua en un solo lugar.</p>
            <ul class="tot-product-feats">
              <li>Evaluaciones de desempeño 360°</li>
              <li>Gestión de metas y OKRs</li>
              <li>Marcos de competencias</li>
              <li>Check-ins y retroalimentación continua</li>
              <li>Análisis de brechas de habilidades</li>
            </ul>
          </div>

          <!-- Totara Mobile -->
          <div class="tot-product-card">
            <div class="tot-product-icon" style="background:#F0FDF4;">📱</div>
            <p class="tot-product-tag">Aprendizaje móvil</p>
            <h3 class="tot-product-name">Totara Mobile</h3>
            <p class="tot-product-desc">Lleva toda la potencia de Totara Learn a cualquier dispositivo. Permite el aprendizaje sin conexión, notificaciones push y acceso a cursos, tareas y logros desde el móvil.</p>
            <ul class="tot-product-feats">
              <li>Acceso offline a cursos y contenidos</li>
              <li>Notificaciones push de plazos y novedades</li>
              <li>Sincronización automática al reconectarse</li>
              <li>Misma experiencia en iOS y Android</li>
              <li>Marca personalizable con tu identidad corporativa</li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- ══ POR QUÉ TOTARA ══ -->
    <GridBeneficios
      theme="tot"
      eyebrow="Ventajas clave"
      title="Por qué las empresas eligen Totara"
      subtitle="Más de 500 organizaciones en todo el mundo confían en Totara para escalar su aprendizaje."
      columns={3}
      cards={ventajasTot}
    />

    <!-- ══ G2 BADGES ══ -->
    <div class="g2-badges-section">
      <div class="g2-badges-inner">
        <p class="g2-badges-title">Premios y reconocimientos</p>
        <div style="display:flex;align-items:center;justify-content:center;gap:28px;flex-wrap:wrap;margin-bottom:20px;">
          <img src="https://www.totara.com/wp-content/uploads/2025/10/Top-10_Best_Enterprise_LMS_2025_badge_.png"
               alt="Top 10 Best Enterprise LMS 2025 – Talented Learning"
               style="height:110px;width:auto;object-fit:contain;"
               class="totara-award-badge" />
          <img src="https://www.totara.com/wp-content/uploads/2026/01/Award-badges-website-elearningindustry-skills.png"
               alt="Top LMS Tools For Skills Development And Assessment 2026 – eLearning Industry"
               style="height:110px;width:auto;object-fit:contain;"
               class="totara-award-badge" />
          <img src="https://www.totara.com/wp-content/uploads/2026/02/Top-extended-enterprise-totara-lms-awards-badge.png"
               alt="Top Extended Enterprise LMS 2026 – eLearning Industry"
               style="height:110px;width:auto;object-fit:contain;"
               class="totara-award-badge" />
          <img src="https://www.totara.com/wp-content/uploads/2025/10/2025-top-20-lms-awards-badge.png"
               alt="Top 20 LMS 2025 – eLearning Industry"
               style="height:110px;width:auto;object-fit:contain;"
               class="totara-award-badge" />
          <img src="https://www.totara.com/wp-content/uploads/2025/08/Top-Performer-Badge-FeaturedCustomers.png"
               alt="Top Performer 2025 – FeaturedCustomers"
               style="height:110px;width:auto;object-fit:contain;"
               class="totara-award-badge" />
        </div>
        <script is:inline>
          document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.totara-award-badge').forEach(img => {
              img.addEventListener('error', function() { this.style.display = 'none'; });
            });
          });
        </script>
        <a href="https://www.totara.com/es/premios-y-reconocimientos/" target="_blank" rel="noopener noreferrer" class="g2-badges-link">Ver todos los reconocimientos →</a>
        &nbsp;&nbsp;
        <a href="https://www.g2.com/products/totara-lms/reviews" target="_blank" rel="noopener noreferrer" class="g2-badges-link">Ver reseñas en G2 →</a>
      </div>
    </div>

    <!-- ══ TESTIMONIAL & CASOS LATAM ══ -->
    <section class="tot-testimonial">
      <p class="tot-quote">"Totara no solo nos da una plataforma, nos da la llave para crecer, inspirar y desarrollar todo nuestro talento."</p>
      <p class="tot-quote-author">Isabel Flores</p>
      <p class="tot-quote-role" style="margin-bottom: 40px;">Corporate Training &amp; Learning Manager · ISDIN</p>
      
      <div style="border-top: 1px solid rgba(255,255,255,.15); padding-top: 40px; max-width: 900px; margin: 0 auto; text-align: left;">
        <h3 style="font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.2px; color: var(--tot-teal); margin-bottom: 24px; text-align: center;">Impacto real en Latinoamérica</h3>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px;">
          <div style="background: rgba(0,0,0,.2); padding: 24px; border-radius: 12px; border: 1px solid rgba(255,255,255,.05);">
            <p style="font-size: 16px; font-weight: 700; color: white; margin-bottom: 8px;">🏥 Clínica Alemana (Chile)</p>
            <p style="font-size: 14px; color: rgba(255,255,255,.8); line-height: 1.6; margin: 0;">Logró capacitar al 98% de su staff médico en 3 semanas, alcanzando un 100% de cumplimiento para su acreditación JCI mediante Totara.</p>
          </div>
          <div style="background: rgba(0,0,0,.2); padding: 24px; border-radius: 12px; border: 1px solid rgba(255,255,255,.05);">
            <p style="font-size: 16px; font-weight: 700; color: white; margin-bottom: 8px;">⚕️ Salud Digna (México)</p>
            <p style="font-size: 14px; color: rgba(255,255,255,.8); line-height: 1.6; margin: 0;">Gestionó más de 1 millón de cursos con un 93% de satisfacción, sumando integración con WhatsApp para alertar a los colaboradores.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ LEAD MAGNET ══ -->
    <section style="padding:64px 5%;background:white;border-top:1px solid var(--border);">
      <div style="max-width:920px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;">

        <!-- Info -->
        <div>
          <p style="font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--tot);margin-bottom:10px;">Recurso gratuito</p>
          <h2 style="font-family:var(--font-display);font-size:clamp(22px,2.2vw,30px);font-weight:400;color:#111827;margin-bottom:16px;">Descarga: Novedades de Totara V20</h2>
          <p style="font-size:15px;color:#64748B;line-height:1.7;margin-bottom:20px;">Todo lo nuevo en la versión 20 de Totara — IA con Ayleen, mejoras en Perform, Mobile y nuevas integraciones. PDF oficial en inglés.</p>
          <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:8px;">
            <li style="font-size:14px;color:#374151;display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--tot);font-weight:700;flex-shrink:0;">✓</span>Novedades Totara Learn V20</li>
            <li style="font-size:14px;color:#374151;display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--tot);font-weight:700;flex-shrink:0;">✓</span>Mejoras en Perform y Mobile</li>
            <li style="font-size:14px;color:#374151;display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--tot);font-weight:700;flex-shrink:0;">✓</span>IA integrada con Ayleen</li>
            <li style="font-size:14px;color:#374151;display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--tot);font-weight:700;flex-shrink:0;">✓</span>PDF oficial · 685 KB</li>
          </ul>
        </div>

        <!-- Formulario -->
        <div style="background:#F8FAFC;border:1.5px solid var(--border);border-radius:16px;padding:28px;">
          <p style="font-size:14px;font-weight:700;color:#111827;margin-bottom:20px;">Completa tus datos para descargar</p>
          <form id="tot-lead-form" style="display:flex;flex-direction:column;gap:12px;">
            <input type="text"  id="tot-nombre"  placeholder="Nombre completo *" required
              style="width:100%;padding:11px 14px;border:1.5px solid #E2E8F0;border-radius:8px;font-size:14px;font-family:inherit;outline:none;" class="tot-input" />
            <input type="text"  id="tot-empresa" placeholder="Empresa *" required
              style="width:100%;padding:11px 14px;border:1.5px solid #E2E8F0;border-radius:8px;font-size:14px;font-family:inherit;outline:none;" class="tot-input" />
            <input type="email" id="tot-email"   placeholder="Email corporativo *" required
              style="width:100%;padding:11px 14px;border:1.5px solid #E2E8F0;border-radius:8px;font-size:14px;font-family:inherit;outline:none;" class="tot-input" />
            <input type="text"  id="tot-cargo"   placeholder="Cargo"
              style="width:100%;padding:11px 14px;border:1.5px solid #E2E8F0;border-radius:8px;font-size:14px;font-family:inherit;outline:none;" class="tot-input" />
            <button type="submit" id="tot-lead-btn"
              style="background:var(--tot);color:white;font-weight:700;font-size:15px;padding:13px;border:none;border-radius:8px;cursor:pointer;transition:opacity .15s;">
              Descargar PDF gratuito →
            </button>
            <p id="tot-lead-msg" style="display:none;font-size:13px;text-align:center;margin-top:4px;"></p>
          </form>
