---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Totara LMS en México – Partner oficial | TAEC"
  description="Totara Learn, Engage y Perform para empresas que necesitan un LMS flexible y extensible. SaaS gestionado por TAEC."
  section="Soluciones"
  page="totara-lms-mexico.html"
>
  <style is:global>
    /* ── EN CONSTRUCCIÓN ── */
    .wip-tag {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(168,219,217,.15); color: var(--teal);
      font-size: 11px; font-weight: 700; letter-spacing: 1.5px;
      text-transform: uppercase; padding: 4px 14px; border-radius: 4px;
      margin-bottom: 20px;
    }
    .wip-icon {
      font-size: 64px; margin-bottom: 20px; display: block;
      filter: drop-shadow(0 4px 12px rgba(0,0,0,.3));
    }
    .wip-hero h1 {
      font-family: var(--font-display); font-size: 40px;
      color: var(--white); line-height: 1.2; margin-bottom: 16px;
    }
    .wip-hero p {
      font-size: 17px; color: #94A3B8; line-height: 1.75; margin-bottom: 32px;
    }
    .wip-card {
      background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12);
      border-radius: 16px; padding: 32px; margin-top: 40px; text-align: left;
    }
    .wip-card-title {
      font-size: 13px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 1px; color: var(--teal); margin-bottom: 16px;
    }
    .wip-features { display: flex; flex-direction: column; gap: 10px; }
    .wip-feature {
      display: flex; align-items: center; gap: 10px;
      font-size: 14px; color: #CBD5E1;
    }
    .wip-feature::before { content: "⚡"; flex-shrink: 0; }

    .wip-cta {
      background: var(--light); padding: 64px 5%; text-align: center;
    }
    .wip-cta-inner { max-width: 580px; margin: 0 auto; }
    .wip-cta h2 { font-family: var(--font-display); font-size: 28px; color: var(--navy); margin-bottom: 12px; }
    .wip-cta p { color: var(--dark); margin-bottom: 28px; line-height: 1.7; }
    .wip-cta-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .btn-primary { display: inline-block; background: var(--orange); color: var(--white); padding: 13px 26px; border-radius: 8px; font-weight: 700; font-size: 14px; transition: background .15s; }
    .btn-primary:hover { background: #d97b0e; }
    .btn-wa { display: inline-flex; align-items: center; gap: 8px; background: #25D366; color: var(--white); padding: 13px 22px; border-radius: 8px; font-weight: 700; font-size: 14px; transition: background .15s; }
    .btn-wa:hover { background: #1ebe5c; }
    .btn-wa svg { width: 18px; height: 18px; fill: white; flex-shrink: 0; }

    /* ── STICKY BAR ANIMATIONS ── */
    @keyframes bounce-icon {
      0%,100% { transform: translateY(0); }
      30%      { transform: translateY(-8px); }
      60%      { transform: translateY(-4px); }
    }
    @keyframes pulse-btn {
      0%,100% { box-shadow: 0 0 0 0 rgba(168,219,217,.7); }
      50%      { box-shadow: 0 0 0 10px rgba(168,219,217,0); }
    }
    @keyframes glow-border {
      0%,100% { border-top-color: #A8DBD9; }
      50%      { border-top-color: #ffffff; }
    }
    .tot-sticky-icon  { animation: bounce-icon 1.6s ease-in-out infinite; display:inline-block; }
    .tot-sticky-btn   { animation: pulse-btn   1.8s ease-in-out infinite; }
    #tot-sticky-bar   { animation: glow-border 2s ease-in-out infinite; }

    /* ── PRODUCT LOGO ── */
    .product-logo-wrap { display: inline-flex; align-items: center; justify-content: center; background: #ffffff; border-radius: 10px; padding: 10px 20px; margin-bottom: 22px; box-shadow: 0 2px 12px rgba(0,0,0,.15); }
    .product-logo { height: 36px; width: auto; display: block; }

    /* ── G2 BADGES ── */
    .g2-badges-section { background: #F8FAFC; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 44px 5%; }
    .g2-badges-inner { max-width: 960px; margin: 0 auto; text-align: center; }
    .g2-badges-title { font-size: 13px; font-weight: 700; color: #64748B; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 28px; }
    .g2-badges-grid { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-bottom: 20px; }
    .g2-badge-card { background: white; border: 1px solid #E2E8F0; border-radius: 10px; padding: 16px 14px; width: 130px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,.06); }
    .g2-badge-season { font-size: 9px; font-weight: 700; color: #64748B; letter-spacing: .5px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
    .g2-badge-g2 { background: #FF492C; color: white; font-size: 9px; font-weight: 900; padding: 2px 5px; border-radius: 3px; }
    .g2-badge-name { font-size: 15px; font-weight: 900; color: #111827; line-height: 1.2; margin-bottom: 6px; }
    .g2-badge-cat { font-size: 10px; color: #64748B; font-weight: 600; }
    .g2-badge-bar { height: 5px; border-radius: 0 0 6px 6px; margin: 10px -14px -16px; }
    .bar-leader    { background: linear-gradient(90deg, #EF4444, #F97316); }
    .bar-usability { background: #EAB308; }
    .bar-results   { background: #7C3AED; }
    .bar-roi       { background: #7C3AED; }
    .bar-setup     { background: #38BDF8; }
    .bar-implement { background: #3B82F6; }
    .g2-badges-link { font-size: 13px; color: #64748B; text-decoration: underline; }
    .g2-badges-link:hover { color: #FF492C; }

    /* ── TOTARA VARS ── */
    :root { --tot:#004775; --tot-light:#0077b6; --tot-teal:#A8DBD9; --tot-dark:#001f3d; }

    /* ── HERO ── */
    .tot-hero{background:linear-gradient(135deg,#001f3d 0%,#004775 60%,#0077b6 100%);padding:72px 5% 80px;color:white}
    .tot-hero-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center}
    .tot-eyebrow{font-size:clamp(22px,2.4vw,32px);font-weight:900;color:var(--tot-teal);letter-spacing:-.01em;margin-bottom:10px;line-height:1}
    .tot-hero h1{font-family:var(--font-display);font-size:clamp(32px,4vw,52px);font-weight:400;color:white;line-height:1.15;margin-bottom:20px}
    .tot-hero h1 em{color:var(--tot-teal);font-style:normal}
    .tot-hero-sub{font-size:17px;color:rgba(255,255,255,.8);line-height:1.7;margin-bottom:28px}
    .tot-hero-btns{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:16px}
    .btn-tot-primary{background:var(--tot-teal);color:#001f3d;font-weight:700;font-size:15px;padding:14px 28px;border-radius:8px;display:inline-flex;align-items:center;gap:8px;transition:opacity .15s}
    .btn-tot-primary:hover{opacity:.9}
    .btn-tot-ghost{background:transparent;color:white;font-weight:600;font-size:15px;padding:13px 24px;border-radius:8px;border:1.5px solid rgba(255,255,255,.4);display:inline-flex;align-items:center;gap:8px;transition:border-color .15s}
    .btn-tot-ghost:hover{border-color:white}
    .tot-hero-card{background:rgba(255,255,255,.08);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.15);border-radius:20px;padding:28px 28px 24px}
    .tot-hero-feat{display:flex;flex-direction:column;gap:10px;margin-top:16px}
    .tot-feat-item{font-size:14px;color:rgba(255,255,255,.9);display:flex;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.07)}
    .tot-feat-item:last-child{border-bottom:none}
    .tot-feat-item::before{content:"✓";color:var(--tot-teal);font-weight:700;flex-shrink:0;margin-top:1px}

    /* ── STATS ── */
    .tot-stats{background:#001f3d;padding:0}
    .tot-stats-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr)}
    .tot-stat{padding:28px 20px;text-align:center;border-right:1px solid rgba(255,255,255,.08)}
    .tot-stat:last-child{border-right:none}
    .tot-stat-num{font-size:clamp(28px,3vw,38px);font-weight:800;color:var(--tot-teal);line-height:1;margin-bottom:6px}
    .tot-stat-lbl{font-size:13px;color:rgba(255,255,255,.6);line-height:1.4}

    /* ── PRODUCTS ── */
    .tot-products{padding:72px 5%;background:#F8FAFC}
    .tot-products-inner{max-width:1100px;margin:0 auto}
    .tot-section-label{font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--tot);margin-bottom:10px;text-align:center}
    .tot-section-title{font-family:var(--font-display);font-size:clamp(24px,2.8vw,36px);font-weight:400;color:#111827;text-align:center;margin-bottom:8px}
    .tot-section-sub{text-align:center;color:#64748B;font-size:15px;margin-bottom:48px}
    .tot-products-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
    .tot-product-card{background:white;border:1.5px solid var(--border);border-radius:16px;padding:28px;display:flex;flex-direction:column;gap:0;transition:box-shadow .2s,transform .2s}
    .tot-product-card:hover{box-shadow:0 8px 32px rgba(0,71,117,.12);transform:translateY(-2px)}
    .tot-product-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:26px;margin-bottom:18px}
    .tot-product-name{font-size:18px;font-weight:800;color:#111827;margin-bottom:8px}
    .tot-product-tag{font-size:11px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--tot);margin-bottom:12px}
    .tot-product-desc{font-size:14px;color:#64748B;line-height:1.7;margin-bottom:20px;flex:1}
    .tot-product-feats{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:7px;border-top:1px solid var(--border);padding-top:16px}
    .tot-product-feats li{font-size:13px;color:#374151;display:flex;gap:8px;align-items:flex-start}
    .tot-product-feats li::before{content:"✓";color:var(--tot);font-weight:700;flex-shrink:0}

    /* ── WHY TOTARA ── */
    .tot-why{padding:72px 5%;background:white}
    .tot-why-inner{max-width:1100px;margin:0 auto}
    .tot-why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:48px}
    .tot-why-card{padding:28px;border:1.5px solid var(--border);border-radius:14px;transition:border-color .2s}
    .tot-why-card:hover{border-color:var(--tot)}
    .tot-why-icon{font-size:32px;margin-bottom:14px}
    .tot-why-title{font-size:16px;font-weight:700;color:#111827;margin-bottom:8px}
    .tot-why-desc{font-size:14px;color:#64748B;line-height:1.7}

    /* ── TESTIMONIAL ── */
    .tot-testimonial{background:linear-gradient(135deg,#001f3d,#004775);padding:64px 5%;text-align:center;color:white}
    .tot-quote{font-family:var(--font-display);font-size:clamp(18px,2vw,26px);font-weight:400;color:white;line-height:1.6;max-width:780px;margin:0 auto 28px;font-style:italic}
    .tot-quote-author{font-size:14px;font-weight:600;color:var(--tot-teal)}
    .tot-quote-role{font-size:13px;color:rgba(255,255,255,.6)}

    /* ── FAQ ── */
    .tot-faq{padding:64px 5%;background:#F8FAFC}
    .tot-faq-inner{max-width:800px;margin:0 auto}
    .tot-faq details{border-bottom:1px solid var(--border);padding:18px 0}
    .tot-faq summary{font-size:15px;font-weight:700;color:#111827;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:16px}
    .tot-faq summary::after{content:"＋";color:var(--tot);font-size:20px;flex-shrink:0;transition:transform .2s}
    .tot-faq details[open] summary::after{content:"－"}
    .tot-faq details p{font-size:14px;color:#4B5563;line-height:1.8;padding-top:12px}

    /* ── CTA BAND ── */
    .tot-cta-band{background:var(--tot);padding:56px 5%;text-align:center;color:white}
    .tot-cta-band h2{font-family:var(--font-display);font-size:clamp(24px,2.8vw,36px);font-weight:400;margin-bottom:12px}
    .tot-cta-band p{font-size:16px;opacity:.85;margin-bottom:32px}
    .tot-cta-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}

    /* ── PROD TABS ── */
    .prod-tabs{background:#F8FAFC;border-bottom:1px solid var(--border);padding:0 5%}
    .prod-tabs-inner{max-width:1100px;margin:0 auto;display:flex;gap:0;overflow-x:auto}
    .prod-tab{display:flex;align-items:center;gap:6px;padding:14px 20px;font-size:14px;font-weight:600;color:#64748B;text-decoration:none;border-bottom:3px solid transparent;white-space:nowrap;transition:color .15s,border-color .15s}
    .prod-tab:hover{color:#111827}
    .prod-tab.active{color:var(--tot)!important;border-bottom-color:var(--tot)!important;background:transparent!important;border-radius:0!important}
    .prod-tab-icon{font-size:16px}

    @media(max-width:768px){
      .tot-hero-inner{grid-template-columns:1fr}
      .tot-hero-card{display:none}
      .tot-stats-inner{grid-template-columns:repeat(2,1fr)}
      .tot-products-grid{grid-template-columns:1fr}
      .tot-why-grid{grid-template-columns:1fr}
    }
  </style>

  <!-- EmailJS -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
  <script is:inline>emailjs.init('wiGRbwHK6dyZcHrUK');</script>

  <main id="main-content">
    <!-- ══ TABS ══ -->
    <div class="prod-tabs"><div class="prod-tabs-inner">
      <a href="/totara-lms-mexico" class="prod-tab active"><span class="prod-tab-icon">🏢</span>Totara</a>
    </div></div>

    <!-- ══ HERO ══ -->
    <section class="tot-hero">
      <div class="tot-hero-inner">
        <div>
          <p class="tot-eyebrow">Totara LMS</p>
          <h1>La plataforma LMS <em>más flexible</em> para empresas que crecen</h1>
          <p class="tot-hero-sub">Unifica formación, colaboración y desempeño en un ecosistema potenciado por IA. La solución más innovadora para empresas que quieren escalar el aprendizaje sin límites.</p>
          <div class="tot-hero-btns">
            <a href="/contacto" class="btn-tot-primary">Solicitar demo gratuita →</a>
            <a href="/contacto" class="btn-tot-ghost">Hablar con un especialista</a>
          </div>
          <p style="margin-top:12px;font-size:12px;color:rgba(255,255,255,.5);">✓ Partner oficial Totara · México y LATAM &nbsp;·&nbsp; ✓ SaaS gestionado por TAEC &nbsp;·&nbsp; ✓ Soporte en español</p>
        </div>
        <div class="tot-hero-card">
          <div style="display:flex;justify-content:center;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid rgba(255,255,255,.1);">
            <img src="/assets/logos/totara-reseller-vertical.png" alt="Totara Authorized Reseller" style="height:90px;width:auto;" />
          </div>
          <p style="font-size:12px;font-weight:700;color:var(--tot-teal);text-transform:uppercase;letter-spacing:1px;margin-bottom:16px;">Por qué Totara con TAEC</p>
          <div class="tot-hero-feat">
            <div class="tot-feat-item">Implementación SaaS — tu plataforma lista en días</div>
            <div class="tot-feat-item">Soporte técnico dedicado en español</div>
            <div class="tot-feat-item">+500 clientes en 17 países</div>
            <div class="tot-feat-item">Integración con Articulate 360 y Vyond</div>
            <div class="tot-feat-item">Factura electrónica mexicana (CFDI)</div>
            <div class="tot-feat-item">+18 años de experiencia en e-learning</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ STATS ══ -->
    <div class="tot-stats">
      <div class="tot-stats-inner">
        <div class="tot-stat"><div class="tot-stat-num">20M+</div><div class="tot-stat-lbl">usuarios activos</div></div>
        <div class="tot-stat"><div class="tot-stat-num">35+</div><div class="tot-stat-lbl">idiomas disponibles</div></div>
        <div class="tot-stat"><div class="tot-stat-num">500+</div><div class="tot-stat-lbl">empresas en el mundo</div></div>
        <div class="tot-stat"><div class="tot-stat-num">17</div><div class="tot-stat-lbl">países donde opera TAEC</div></div>
      </div>
    </div>

    <!-- ══ PRODUCTOS ══ -->
    <section class="tot-products">
      <div class="tot-products-inner">
        <p class="tot-section-label">La suite completa</p>
        <h2 class="tot-section-title">Tres soluciones, un ecosistema</h2>
        <p class="tot-section-sub">Totara Suite combina LMS, gestión del talento y aprendizaje móvil en una plataforma flexible — con Ayleen AI integrado en toda la suite.</p>
        <div class="tot-products-grid">

          <!-- Totara Learn -->
          <div class="tot-product-card">
            <div class="tot-product-icon" style="background:#EFF6FF;">🎓</div>
            <p class="tot-product-tag">LMS empresarial</p>
            <h3 class="tot-product-name">Totara Learn</h3>
            <p class="tot-product-desc">El LMS más personalizable del mercado. Gestiona formación, cumplimiento normativo y certificaciones a escala — sin los límites de las plataformas cerradas.</p>
            <ul class="tot-product-feats">
              <li>Rutas de aprendizaje personalizadas</li>
              <li>Gestión de cumplimiento y certificaciones</li>
              <li>Audiencias dinámicas y asignación automática</li>
              <li>App móvil Totara Learn</li>
              <li>Reportes y analíticas flexibles</li>
            </ul>
          </div>

          <!-- Totara Perform -->
          <div class="tot-product-card" style="border-color:#004775;">
            <div class="tot-product-icon" style="background:#F0FDF4;">🎯</div>
            <p class="tot-product-tag">Gestión del talento</p>
            <h3 class="tot-product-name">Totara Perform</h3>
            <p class="tot-product-desc">Alinea el desarrollo individual con los objetivos de la organización. Evaluaciones, metas, competencias y retroalimentación continua en un solo lugar.</p>
            <ul class="tot-product-feats">
              <li>Evaluaciones de desempeño 360°</li>
              <li>Gestión de metas y OKRs</li>
              <li>Marcos de competencias</li>
              <li>Check-ins y retroalimentación continua</li>
              <li>Análisis de brechas de habilidades</li>
            </ul>
          </div>

          <!-- Totara Mobile -->
          <div class="tot-product-card">
            <div class="tot-product-icon" style="background:#F0FDF4;">📱</div>
            <p class="tot-product-tag">Aprendizaje móvil</p>
            <h3 class="tot-product-name">Totara Mobile</h3>
            <p class="tot-product-desc">Lleva toda la potencia de Totara Learn a cualquier dispositivo. Permite el aprendizaje sin conexión, notificaciones push y acceso a cursos, tareas y logros desde el móvil.</p>
            <ul class="tot-product-feats">
              <li>Acceso offline a cursos y contenidos</li>
              <li>Notificaciones push de plazos y novedades</li>
              <li>Sincronización automática al reconectarse</li>
              <li>Misma experiencia en iOS y Android</li>
              <li>Marca personalizable con tu identidad corporativa</li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- ══ POR QUÉ TOTARA ══ -->
    <section class="tot-why">
      <div class="tot-why-inner">
        <p class="tot-section-label">Ventajas clave</p>
        <h2 class="tot-section-title">Por qué las empresas eligen Totara</h2>
        <p class="tot-section-sub">Más de 500 organizaciones en todo el mundo confían en Totara para escalar su aprendizaje.</p>
        <div class="tot-why-grid">
          <div class="tot-why-card">
            <div class="tot-why-icon">⚙️</div>
            <h3 class="tot-why-title">Personalización sin límites</h3>
            <p class="tot-why-desc">Código abierto y arquitectura flexible. Adapta la plataforma exactamente a tus procesos, marca y flujos de trabajo — sin depender del proveedor.</p>
          </div>
          <div class="tot-why-card">
            <div class="tot-why-icon">📋</div>
            <h3 class="tot-why-title">Cumplimiento normativo a escala</h3>
            <p class="tot-why-desc">Gestiona onboarding, certificaciones y cumplimiento regulatorio para miles de empleados. Automatiza asignaciones, recordatorios y reportes de vencimiento.</p>
          </div>
          <div class="tot-why-card">
            <div class="tot-why-icon">🌎</div>
            <h3 class="tot-why-title">Escala global, operación local</h3>
            <p class="tot-why-desc">35+ idiomas, zonas horarias múltiples y gestión multi-tenant. Crece de 100 a 100,000 usuarios sin cambiar de plataforma.</p>
          </div>
          <div class="tot-why-card">
            <div class="tot-why-icon">📊</div>
            <h3 class="tot-why-title">Impacto medible en el negocio</h3>
            <p class="tot-why-desc">Reportes avanzados y analíticas que conectan el aprendizaje con resultados de negocio. Demuestra el ROI de tu inversión en formación con datos concretos.</p>
          </div>
          <div class="tot-why-card">
            <div class="tot-why-icon">🔗</div>
            <h3 class="tot-why-title">Integración con tu ecosistema</h3>
            <p class="tot-why-desc">Se conecta con Microsoft Teams, HR, ERP, SSO y herramientas de autoría como Articulate 360 y Vyond. API robusta para integraciones personalizadas.</p>
          </div>
          <div class="tot-why-card">
            <div class="tot-why-icon">🤝</div>
            <h3 class="tot-why-title">Partner local con expertise global</h3>
            <p class="tot-why-desc">TAEC es partner oficial Totara para México y LATAM. Implementación, soporte en español, factura en MXN y acompañamiento durante toda la vida del contrato.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ G2 BADGES ══ -->
    <div class="g2-badges-section">
      <div class="g2-badges-inner">
