---
import CtaFinal from "../components/ui/CtaFinal.astro";
import FAQAccordion from "../components/ui/FAQAccordion.astro";
import GridBeneficios from "../components/ui/GridBeneficios.astro";
import HeroComercial from "../components/ui/HeroComercial.astro";
import LogosGrid from "../components/ui/LogosGrid.astro";
import { getBookingUrl } from "../data/contact";
import {
	ddcBeneficios,
	ddcCta,
	ddcFaqs,
	ddcHero,
	ddcLogos,
	ddcProceso,
	ddcServicios,
} from "../data/ddc";
// CHANGELOG: 2026-03-20 - Nueva landing DDC (Desarrollo de Contenidos).
// Fuente de contenido: src/data/ddc.ts · PDF "Info DDC para sitio web"
import BaseLayout from "../layouts/BaseLayout.astro";

import { r } from "../utils/paths";

const bookingUrl = getBookingUrl();
---

<BaseLayout
  title="Desarrollo de Contenidos e-Learning | Articulate + Vyond + IA | TAEC"
  description="Cursos a medida con Articulate 360, Vyond e IA generativa. Metodología ADDIE + Agile SAM, Project Manager dedicado y archivos editables garantizados. TAEC DDC · México y LATAM."
  section="Soluciones"
  page="desarrollo-de-contenidos.html"
>

  <!-- ── HERO ── -->
  <HeroComercial
    eyebrow={ddcHero.eyebrow}
    titleHtml={ddcHero.titleHtml}
    subtitle={ddcHero.subtitle}
    features={ddcHero.features}
    primaryBtn={{ label: "Solicitar demo de contenidos →", url: bookingUrl, target: "_blank" }}
    secondaryBtn={{ label: "Ver portafolio de clientes", url: r('/clientes') }}
    cardBadgeText={ddcHero.cardBadgeText}
    theme={ddcHero.theme}
  />

  <!-- ── LOGOS — Prueba social ── -->
  <LogosGrid
    eyebrow="Empresas que confían en TAEC DDC"
    logos={ddcLogos}
    theme="general"
  />

  <!-- ── QUÉ INCLUYE ── -->
  <section class="ddc-servicios">
    <div class="section-inner">
      <p class="section-label">Nuestros servicios</p>
      <h2 class="section-title">Desde un microlearning hasta un programa blended completo</h2>
      <p class="section-sub">Combinamos los mejores servicios según tus necesidades de aprendizaje, presupuesto y complejidad.</p>
      <div class="servicios-grid">
        {ddcServicios.map(s => (
          <div class="servicio-card">
            <div class="serv-icon">{s.icon}</div>
            <h3>{s.label}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
      <p class="scorm-note">Todos los entregables pueden publicarse en <strong>SCORM 1.2 · SCORM 2004 · xAPI</strong> — compatibles con cualquier LMS o LXP.</p>
    </div>
  </section>

  <!-- ── PORTAFOLIO DE DEMOS (CTA hacia la nueva página) ── -->
  <section class="ddc-portafolio-cta">
    <div class="cta-banner">
      <h2 class="cta-banner-title">Transformamos la teoría en experiencias memorables</h2>
      <p class="cta-banner-text">Explora más de 120 casos de éxito reales donde hemos digitalizado el conocimiento corporativo usando las herramientas líderes del mercado.</p>
      <a href="/portafolio" class="btn-portafolio">Explorar Portafolio Interactivo →</a>
    </div>
  </section>

  <!-- ── BENEFICIOS ── -->
  <GridBeneficios
    eyebrow={ddcBeneficios.eyebrow}
    title={ddcBeneficios.title}
    subtitle={ddcBeneficios.subtitle}
    cards={ddcBeneficios.cards}
    columns={ddcBeneficios.columns}
    theme={ddcBeneficios.theme}
  />

  <!-- ── PROCESO ── -->
  <section class="ddc-proceso">
    <div class="section-inner">
      <p class="section-label">Cómo trabajamos</p>
      <h2 class="section-title">Proceso Alfa → Beta → Gold</h2>
      <p class="section-sub">ADDIE para diseño instruccional · Agile SAM para producción multimedia · Tu PM controla tiempos y calidad.</p>
      <div class="proceso-image-container">
        <!-- Imagen original: Cómo trabajamos.jpeg con bloqueo CLS -->
        <img src="/assets/como-trabajamos.jpeg" alt="Cómo trabajamos" class="proceso-image" width="1600" height="900" loading="lazy" />
      </div>

    </div>
  </section>

  <!-- ── PARA QUIÉN ── -->
  <section class="ddc-para-quien">
    <div class="section-inner">
      <p class="section-label">Cliente ideal</p>
      <h2 class="section-title">¿Para quién es TAEC DDC?</h2>
      <div class="pq-grid">
        <div class="pq-card">
          <span class="pq-icon">🏢</span>
          <h3>Responsables de L&D y Capacitación</h3>
          <p>Que necesitan un socio estratégico confiable para ejecutar su plan de formación anual, con certeza en calidad y tiempos.</p>
        </div>
        <div class="pq-card">
          <span class="pq-icon">🌎</span>
          <h3>Empresas con audiencias multiregión</h3>
          <p>Corporativos con operaciones en México, LATAM, USA o Europa que necesitan contenido en múltiples idiomas y adaptado culturalmente.</p>
        </div>
        <div class="pq-card">
          <span class="pq-icon">⚡</span>
          <h3>Equipos que quieren aprender</h3>
          <p>Organizaciones que además de contratar producción quieren entender e-learning e innovación en capacitación para crecer su expertise interno.</p>
        </div>
        <div class="pq-card pq-card--highlight">
          <span class="pq-icon">🤝</span>
          <h3>El 50% de nuestros proyectos son internacionales</h3>
          <p>USA, España, Centroamérica y América del Sur. DDC cuenta con clientes en todos los continentes. La gran mayoría regresa tras el primer proyecto.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <FAQAccordion
    eyebrow="Preguntas frecuentes"
    title="Todo lo que necesitas saber antes de cotizar"
    subtitle="¿Más dudas? Escríbenos o agenda una sesión sin costo."
    subtitleLink={{ text: "Agendar ahora →", url: bookingUrl }}
    faqs={ddcFaqs}
    theme="general"
  />

  <!-- ── CTA ── -->
  <CtaFinal
    title={ddcCta.title}
    subtitle={ddcCta.subtitle}
    primaryBtnText={ddcCta.primaryBtnText}
    primaryBtnUrl={bookingUrl}
    primaryBtnTarget="_blank"
    theme={ddcCta.theme}
  />

</BaseLayout>

<style is:global>
/* ── SHARED ── */
.ddc-servicios,
.ddc-proceso,
.ddc-para-quien { padding: 72px 5%; }
.ddc-servicios { background: #F8FAFC; }
.ddc-proceso   { background: white; }
.ddc-para-quien{ background: #F8FAFC; }

.section-inner  { max-width: 1100px; margin: 0 auto; }
.section-label  { font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: #f97316; margin-bottom: 10px; text-align: center; }
.section-title  { font-family: var(--font-display); font-size: clamp(24px, 2.8vw, 36px); color: #111827; text-align: center; margin-bottom: 8px; }
.section-sub    { text-align: center; color: #64748B; font-size: 15px; line-height: 1.75; margin-bottom: 48px; max-width: 680px; margin-left: auto; margin-right: auto; }

/* ── SERVICIOS ── */
.servicios-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
  margin-top: 40px;
}
.servicio-card {
  background: white;
  border: 1.5px solid #E2E8F0;
  border-radius: 14px;
  padding: 28px 24px;
  transition: border-color .2s;
}
.servicio-card:hover { border-color: #f97316; }
.serv-icon { font-size: 32px; margin-bottom: 12px; }
.servicio-card h3 { font-size: 16px; font-weight: 700; color: #111827; margin-bottom: 10px; }
.servicio-card p  { font-size: 14px; color: #64748B; line-height: 1.7; }
.scorm-note {
  margin-top: 32px; text-align: center; font-size: 13px;
  color: #64748B; background: white; border: 1px solid #E2E8F0;
  border-radius: 8px; padding: 12px 20px; display: inline-block;
  width: 100%; box-sizing: border-box;
}

/* ── PROCESO ── */
.proceso-image-container {
  margin-top: 40px;
  text-align: center;
}
.proceso-image {
  max-width: 100%;
  height: auto;
  border-radius: 16px;
  border: 1.5px solid #E2E8F0;
  box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
  display: block;
  margin: 0 auto;
}


/* ── PARA QUIÉN ── */
.pq-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  margin-top: 40px;
}
.pq-card {
  background: white;
  border: 1.5px solid #E2E8F0;
  border-radius: 14px;
  padding: 28px 22px;
}
.pq-card--highlight {
  border-color: #f97316;
  background: #FFF7ED;
}
.pq-icon { font-size: 28px; display: block; margin-bottom: 12px; }
.pq-card h3 { font-size: 15px; font-weight: 700; color: #111827; margin-bottom: 8px; }
.pq-card p  { font-size: 14px; color: #4B5563; line-height: 1.7; }

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .servicios-grid { grid-template-columns: repeat(2, 1fr); }
  .pq-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 768px) {
  .servicios-grid { grid-template-columns: 1fr; }
  .pq-grid { grid-template-columns: 1fr; }
}

/* ── BANNER PORTAFOLIO CTA ── */
.ddc-portafolio-cta {
  padding: 80px 5%;
  background: #f8fafc;
  display: flex;
  justify-content: center;
}
.cta-banner {
  background: linear-gradient(135deg, #1e293b 0%, var(--navy-slate) 100%);
  border-radius: 20px;
  padding: 60px 40px;
  max-width: 900px;
  text-align: center;
  color: white;
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
}
.cta-banner-title {
  font-size: clamp(1.8rem, 4vw, 2.5rem);
  font-weight: 800;
  margin-bottom: 20px;
  background: linear-gradient(to right, #f97316, #fb923c);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
.cta-banner-text {
  font-size: 1.1rem;
  color: #cbd5e1;
  margin-bottom: 30px;
  line-height: 1.6;
  max-width: 700px;
  margin-left: auto;
  margin-right: auto;
}
.btn-portafolio {
  display: inline-block;
  background: #f97316;
  color: white;
  padding: 16px 32px;
  font-size: 1.1rem;
  font-weight: 700;
  border-radius: 12px;
  text-decoration: none;
  transition: all 0.3s ease;
  box-shadow: 0 4px 6px -1px rgba(249, 115, 22, 0.3);
}
.btn-portafolio:hover {
  background: #ea580c;
  transform: translateY(-3px);
  box-shadow: 0 10px 15px -3px rgba(249, 115, 22, 0.4);
}
</style>
