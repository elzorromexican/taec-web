---
// CHANGELOG: 2026-03-20 - Nueva landing Pifini Learn / NetExam LMS+ · v2 con contenido completo.
// Fuentes: pifini.ai · netexam.com · PDF Craig Weiss Group Top 10 (Dic 2025)
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroComercial from '../components/ui/HeroComercial.astro';
import GridBeneficios from '../components/ui/GridBeneficios.astro';
import LogosGrid from '../components/ui/LogosGrid.astro';
import FAQAccordion from '../components/ui/FAQAccordion.astro';
import CtaFinal from '../components/ui/CtaFinal.astro';
import { getBookingUrl } from '../data/contact';

const bookingUrl = getBookingUrl();

const modulos = [
  { icon: "🎓", label: "Enterprise LMS+", desc: "Plataforma de aprendizaje completa para capacitación externa: canales, clientes y socios. Base tecnológica de 20 años como NetExam." },
  { icon: "🤖", label: "AI Content Creator", desc: "Generación rápida de cursos, exámenes, flashcards y listas de observación con inteligencia artificial." },
  { icon: "🎯", label: "Sales Roleplay IA", desc: "Simulaciones de ventas con retroalimentación en tiempo real. Practica objeciones, precios y cierres antes de la llamada real." },
  { icon: "📞", label: "Live Call Copilot", desc: "IA que escucha en tiempo real durante llamadas de ventas y proporciona guía instantánea para cerrar más tratos." },
  { icon: "📊", label: "Training Impact Analysis", desc: "Conecta el aprendizaje con resultados reales: más ventas, menos tickets de soporte, ROI medible de cada programa." },
  { icon: "🏆", label: "Certification Engine", desc: "Motor de certificaciones con exámenes dinámicos, vouchers y control de cumplimiento para canales y distribuidores." },
  { icon: "🤝", label: "Partner Enablement Hub", desc: "Centro de habilitación para revendedores, distribuidores y alianzas. Mantiene a tus socios vendiendo con el conocimiento correcto." },
  { icon: "🛒", label: "eCommerce + Integraciones", desc: "Venta de capacitación, 100+ integraciones (CRM, HRMS, SSO), reportes avanzados ETL y apps móviles." }
];

const beneficios = [
  { icon: "💰", title: "$50 USD/usuario/año — todo incluido", description: "Pifini.ai incluye LMS, IA de ventas, roleplay, call copilot y analytics en un solo precio. Competidores como Seismic o Bigtincan cobran $300–$600/usuario/año solo por el LMS." },
  { icon: "🏆", title: "#7 mundial Craig Weiss 2025", description: "El analista independiente más respetado del sector LMS nombró a Pifini Learn el #7 sistema de aprendizaje del mundo, destacando su IA y enfoque en capacitación de canales." },
  { icon: "🌐", title: "Especialista en formación externa", description: "Diseñado específicamente para capacitar canales, distribuidores, revendedores y clientes. No es un LMS de RR.HH. adaptado: es la plataforma correcta para el reto correcto." },
  { icon: "📈", title: "AMD: +2x participación, −40 días admin/año", description: "Caso real documentado: AMD duplicó la participación en su programa de capacitación y eliminó 40 días de trabajo administrativo al año con NetExam LMS+." }
];

const faqs = [
  {
    question: "¿Pifini Learn y NetExam son lo mismo?",
    answerHtml: "Son de la misma empresa pero productos distintos. <strong>NetExam LMS+</strong> es el sistema de gestión de aprendizaje especializado en formación externa, con casi 20 años en el mercado. <strong>Pifini Learn / Pifini.ai</strong> es la suite completa que incluye NetExam LMS+ más herramientas de IA para ventas: roleplay, call copilot, digital sales rooms y partner hub — todo por <strong>$50 USD/usuario/año</strong>."
  },
  {
    question: "¿Cuánto cuesta Pifini Learn?",
    answerHtml: "<strong>Pifini.ai: $50 USD/usuario/año</strong> — plataforma completa sin costos adicionales. <br><strong>NetExam LMS+</strong> tiene dos modelos: <em>por usuario</em> (tarifa plana, acceso ilimitado a cursos) o <em>por curso</em> (pago por consumo, ideal para bibliotecas pequeñas o grupos reducidos). Las sedes de administradores son gratuitas en ambos modelos. Contáctanos para una cotización a la medida de tu organización."
  },
  {
    question: "¿Para qué tipo de organizaciones es ideal?",
    answerHtml: "Para empresas que necesitan capacitar <strong>audiencias externas</strong>: canales de distribución, revendedores, franquiciados, clientes y socios comerciales. También para asociaciones que necesitan mantener actualizados a sus miembros. Si el reto es <strong>sales enablement o partner training</strong>, Pifini/NetExam es la solución correcta."
  },
  {
    question: "¿Qué diferencia a NetExam/Pifini de Moodle o Totara?",
    answerHtml: "Moodle y Totara son excelentes para formación interna de empleados. <strong>NetExam LMS+ está ingeniado específicamente para formación externa</strong>: gestión multi-organización, certificaciones de canal, eCommerce de capacitación, vouchers y métricas que conectan el aprendizaje con el desempeño de ventas. No es un LMS genérico adaptado — es una plataforma construida para este caso de uso."
  },
  {
    question: "¿Qué capacidades de IA incluye?",
    answerHtml: "NetExam LMS+ incluye: <strong>AI Content Creator</strong> (cursos y exámenes en minutos), <strong>AI Tutor</strong>, <strong>AI Exam Generation</strong>, <strong>AI Flashcard Generator</strong>, <strong>AI Report Bot</strong>, <strong>AI SME Bot</strong>, <strong>AI Interactive Simulation</strong> y <strong>AI Impact Analyzer</strong>. La suite Pifini.ai añade <strong>Sales Roleplay IA</strong>, <strong>Live Call Copilot</strong> y <strong>AI CAM Avatar</strong> para soporte de canales en tiempo real."
  },
  {
    question: "¿TAEC puede implementar y dar soporte en México?",
    answerHtml: "Sí. TAEC es el partner de Pifini / NetExam LMS+ en México y LATAM. Ofrecemos: implementación completa, configuración de la plataforma, integración con tu CRM o HRMS, capacitación de administradores y <strong>soporte técnico en español en horario de oficina CDMX</strong>. También gestionamos el contrato en pesos mexicanos con factura CFDI."
  },
  {
    question: "¿Puedo ver una demo con casos reales del sector?",
    answerHtml: "Sí. Agenda una sesión con nuestro equipo y te mostramos la plataforma con casos reales de canales y distribución en México y LATAM. La demo es sin costo y sin compromiso. <a href='" + bookingUrl + "' target='_blank' rel='noopener noreferrer' style='color:#f97316'>Agenda aquí →</a>"
  }
];

const logos = [
  { type: "text" as const, text: "AMD" },
  { type: "text" as const, text: "Sabre" },
  { type: "text" as const, text: "Stanley" },
  { type: "text" as const, text: "Omron" },
  { type: "text" as const, text: "Hexagon" },
  { type: "text" as const, text: "Qlik" },
  { type: "text" as const, text: "Bobcat" },
  { type: "text" as const, text: "ABBYY" },
  { type: "text" as const, text: "AVIXA" },
  { type: "text" as const, text: "BlueCross" }
];
---

<BaseLayout
  title="Pifini Learn / NetExam LMS en México — #7 Mundial, $50/usuario/año | TAEC"
  description="Pifini Learn (antes NetExam LMS+) es el #7 sistema de aprendizaje mundial (Craig Weiss 2025). LMS especialista en partner training, sales enablement e IA. Desde $50 USD/usuario/año. TAEC: implementación y soporte en español · México."
  section="Soluciones"
  page="pifini-mexico.html"
>

  <!-- ── HERO ── -->
  <HeroComercial
    eyebrow="Pifini Learn · NetExam LMS+"
    titleHtml={`El LMS <em>#7 mundial</em> para canales y sales enablement`}
    subtitle="Pifini Learn —antes NetExam, casi 20 años de liderazgo— es la plataforma diseñada para capacitar canales, distribuidores y clientes. IA nativa, certificaciones de canal y métricas que impactan revenue. Desde $50 USD/usuario/año."
    features={[
      "#7 Top Learning Systems — Craig Weiss 2025",
      "$50 USD/usuario/año · todo incluido sin add-ons",
      "Sales roleplay IA + Live Call Copilot",
      "Especialista en partner y customer training",
      "AMD: 2x participación · −40 días admin/año",
      "Implementación y soporte en español · CDMX"
    ]}
    primaryBtn={{ label: "Solicitar demo →", url: bookingUrl, target: "_blank" }}
    secondaryBtn={{ label: "Ver plataforma en pifini.ai", url: "https://pifini.ai", target: "_blank" }}
    cardBadgeText="LMS · PARTNER TRAINING · SALES AI"
    theme="general"
  />

  <!-- ── RECONOCIMIENTO + PRECIO ── -->
  <section class="pifini-stats">
    <div class="ps-inner">
      <div class="ps-stat">
        <span class="ps-num">#7</span>
        <span class="ps-lbl">Top Learning Systems<br>Craig Weiss 2025</span>
      </div>
      <div class="ps-divider"></div>
      <div class="ps-stat">
        <span class="ps-num">$50</span>
        <span class="ps-lbl">USD/usuario/año<br>plataforma completa</span>
      </div>
      <div class="ps-divider"></div>
      <div class="ps-stat">
        <span class="ps-num">20</span>
        <span class="ps-lbl">años liderando<br>formación externa</span>
      </div>
      <div class="ps-divider"></div>
      <div class="ps-stat">
        <span class="ps-num">2x</span>
        <span class="ps-lbl">participación en AMD<br>caso documentado</span>
      </div>
    </div>
  </section>

  <!-- ── PRECIO vs COMPETIDORES ── -->
  <section class="precio-vs">
    <div class="pv-inner">
      <p class="section-label">Precio transparente</p>
      <h2 class="section-title">10× más asequible que los competidores</h2>
      <p class="section-sub">Pifini.ai incluye LMS, IA de ventas, roleplay, call copilot y analytics. Sin add-ons, sin sorpresas.</p>
      <div class="pv-grid">
        <div class="pv-card pv-card--winner">
          <div class="pv-badge">✓ Recomendado</div>
          <div class="pv-logo">Pifini.ai</div>
          <div class="pv-price">$50<span>/usuario/año</span></div>
          <ul class="pv-features">
            <li>LMS completo (NetExam)</li>
            <li>IA: roleplay, call copilot, tutor</li>
            <li>Partner enablement hub</li>
            <li>Digital sales rooms</li>
            <li>Analytics de impacto en revenue</li>
            <li>100+ integraciones incluidas</li>
          </ul>
        </div>
        <div class="pv-card pv-card--comp">
          <div class="pv-logo pv-logo--comp">Seismic</div>
          <div class="pv-price pv-price--comp">$300–500<span>/usuario/año</span></div>
          <ul class="pv-features pv-features--comp">
            <li>Solo gestión de contenido</li>
            <li>LMS como add-on extra</li>
            <li>Implementación adicional</li>
            <li>Sin partner training nativo</li>
          </ul>
        </div>
        <div class="pv-card pv-card--comp">
          <div class="pv-logo pv-logo--comp">Bigtincan</div>
          <div class="pv-price pv-price--comp">$300<span>/usuario/año</span></div>
          <ul class="pv-features pv-features--comp">
            <li>Gestión de contenido</li>
            <li>Módulos de readiness separados</li>
            <li>Sin IA de ventas en tiempo real</li>
            <li>Implementación y admin extra</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ── LOGOS ── -->
  <LogosGrid
    eyebrow="Empresas que confían en NetExam / Pifini"
    logos={logos}
    theme="general"
  />

  <!-- ── EL PROBLEMA ── -->
  <section class="pifini-problema">
    <div class="pp-inner">
      <p class="section-label">El reto real</p>
      <h2 class="section-title">El reto no es solo capacitar canales.<br>El reto es lograr que vendan mejor.</h2>
      <p class="section-sub">Muchas organizaciones ya tienen un LMS. Lo que no tienen es una forma de conectar ese aprendizaje con el desempeño comercial de sus distribuidores y socios.</p>
      <div class="problema-grid">
        <div class="prob-card">
          <span class="prob-icon">📦</span>
          <h3>Canales sin conocimiento actualizado</h3>
          <p>Tus distribuidores y revendedores venden tu producto sin conocerlo bien. La capacitación llega tarde, es genérica o simplemente no llega.</p>
        </div>
        <div class="prob-card">
          <span class="prob-icon">🏆</span>
          <h3>Certificaciones que no se sostienen</h3>
          <p>Los programas de certificación de canal son difíciles de gestionar a escala: rutas distintas, niveles diferentes, cumplimiento disperso y sin trazabilidad real.</p>
        </div>
        <div class="prob-card">
          <span class="prob-icon">📊</span>
          <h3>Aprendizaje desconectado del revenue</h3>
          <p>No sabes si el partner que tomó el curso vende más. El LMS registra completaciones, no resultados de negocio. No hay forma de cerrar ese ciclo.</p>
        </div>
        <div class="prob-card">
          <span class="prob-icon">🤖</span>
          <h3>IA de ventas fuera del alcance</h3>
          <p>Roleplay con IA, coaching en llamadas en vivo y análisis de impacto comercial son herramientas que hoy cuestan $300–$600/usuario/año en plataformas separadas.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PERFIL IDEAL ── -->
  <section class="pifini-perfil">
    <div class="ppf-inner">
      <p class="section-label">¿Para quién es?</p>
      <h2 class="section-title">Pifini encaja mejor cuando tienes canales, partners o clientes que capacitar</h2>
      <div class="perfil-grid">
        <div class="perfil-col">
          <h3>Perfil de organización ideal</h3>
          <ul>
            <li>Fabricantes con red de distribuidores o revendedores</li>
            <li>Empresas que venden a través de canales indirectos</li>
            <li>Marcas que necesitan certificar partners o clientes externos</li>
            <li>Organizaciones con programas de habilitación comercial</li>
            <li>Asociaciones que actualizan a sus miembros de forma continua</li>
          </ul>
        </div>
        <div class="perfil-col">
          <h3>Casos de uso principales</h3>
          <ul>
            <li>Channel partner enablement y certificación</li>
            <li>Customer education — de onboarding a advocacy</li>
            <li>Sales enablement para equipos y socios comerciales</li>
            <li>Compliance y certificación regulatoria externa</li>
            <li>Habilitación de asociaciones y membresías</li>
          </ul>
        </div>
        <div class="perfil-col perfil-col--taec">
          <h3>Lo que TAEC hace por ti</h3>
          <ul>
            <li>Lectura consultiva de tu caso de canal</li>
            <li>Definición del alcance y arquitectura del programa</li>
            <li>Apoyo para mapear certificación, rutas y habilitación</li>
            <li>Implementación y soporte en español · CDMX</li>
            <li>Facturación en pesos mexicanos con CFDI</li>
          </ul>
          <p class="perfil-cierre">No se trata de comprar una plataforma con muchas funciones. Se trata de alinear capacitación, certificación y desempeño comercial en un mismo sistema.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── MÓDULOS ── -->
  <section class="pifini-modulos">
    <div class="pm-inner">
      <p class="section-label">Suite completa</p>
      <h2 class="section-title">Todo lo que necesitas en una sola plataforma</h2>
      <p class="section-sub">NetExam LMS+ incluye más de 13 herramientas especializadas. Pifini.ai las amplía con IA de ventas en tiempo real.</p>
      <div class="modulos-grid">
        {modulos.map(m => (
          <div class="modulo-card">
            <span class="mod-icon">{m.icon}</span>
            <h3>{m.label}</h3>
            <p>{m.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── BENEFICIOS ── -->
  <GridBeneficios
    eyebrow="Por qué Pifini / NetExam con TAEC"
    title="El LMS que convierte capacitación en ventas"
    subtitle="Para organizaciones que entrenan audiencias externas y necesitan medir el impacto en el negocio."
    cards={beneficios}
    columns={2}
    theme="general"
  />

  <!-- ── QUOTE CRAIG WEISS ── -->
  <section class="pifini-quote">
    <div class="pq-inner">
      <blockquote>
        "La integración de capacidades avanzadas de IA, combinada con su enfoque innovador en la capacitación de clientes y socios, representa una evolución refrescante en el panorama del aprendizaje. Este sistema tiene el potencial de emerger como líder en la industria."
        <cite>— Craig Weiss · The Craig Weiss Group · Diciembre 2025</cite>
      </blockquote>
      <div class="pq-meta">
        <strong>#7 Top Learning Systems 2025</strong>
        <span>El ranking independiente más respetado del sector LMS a nivel mundial</span>
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <FAQAccordion
    eyebrow="Preguntas frecuentes"
    title="Todo sobre Pifini Learn y NetExam LMS+ en México"
    faqs={faqs}
    theme="general"
  />

  <!-- ── CTA ── -->
  <CtaFinal
    title="¿Listo para ver Pifini en acción?"
    subtitle="Agenda una demo personalizada con nuestro equipo en CDMX. Te mostramos la plataforma con casos reales de canales y distribuidores — sin costo, sin compromiso."
    primaryBtnText="Solicitar demo →"
    primaryBtnUrl={bookingUrl}
    primaryBtnTarget="_blank"
    theme="general"
  />

</BaseLayout>

<style is:global>
/* ── STATS BAR ── */
.pifini-stats {
  background: var(--navy-slate); padding: 0;
}
.ps-inner {
  max-width: 1100px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
  align-items: center;
}
.ps-stat { padding: 32px 20px; text-align: center; }
.ps-num { display: block; font-size: clamp(32px, 3vw, 44px); font-weight: 900; color: #f97316; line-height: 1; margin-bottom: 6px; }
.ps-lbl { font-size: 12px; color: rgba(255,255,255,.55); line-height: 1.5; }
.ps-divider { width: 1px; height: 48px; background: rgba(255,255,255,.1); }

/* ── PRECIO VS ── */
.precio-vs { background: #F8FAFC; padding: 72px 5%; }
.pv-inner { max-width: 960px; margin: 0 auto; }
.section-label { font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: #f97316; margin-bottom: 10px; text-align: center; }
.section-title { font-family: var(--font-display); font-size: clamp(24px, 2.8vw, 36px); color: #111827; text-align: center; margin-bottom: 8px; }
.section-sub { text-align: center; color: #64748B; font-size: 15px; line-height: 1.75; margin-bottom: 48px; }

.pv-grid { display: grid; grid-template-columns: 1.2fr 1fr 1fr; gap: 20px; align-items: start; }
.pv-card {
  background: white; border: 1.5px solid #E2E8F0; border-radius: 16px;
  padding: 28px 24px; position: relative;
}
.pv-card--winner { border-color: #f97316; box-shadow: 0 8px 32px rgba(249,115,22,.15); }
.pv-card--comp   { opacity: .75; }
.pv-badge {
  position: absolute; top: -13px; left: 50%; transform: translateX(-50%);
  background: #f97316; color: white; font-size: 11px; font-weight: 700;
  padding: 4px 14px; border-radius: 20px; white-space: nowrap;
}
.pv-logo { font-size: 18px; font-weight: 800; color: #111827; margin-bottom: 12px; }
.pv-logo--comp { color: #94A3B8; }
.pv-price { font-size: 36px; font-weight: 900; color: #f97316; line-height: 1; margin-bottom: 20px; }
.pv-price span { font-size: 14px; font-weight: 500; color: #64748B; }
.pv-price--comp { color: #94A3B8; font-size: 28px; }
.pv-features { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 9px; border-top: 1px solid #E2E8F0; padding-top: 16px; }
.pv-features li { font-size: 13px; color: #374151; display: flex; gap: 8px; align-items: flex-start; }
.pv-features li::before { content: "✓"; color: #f97316; font-weight: 700; flex-shrink: 0; }
.pv-features--comp li { color: #94A3B8; }
.pv-features--comp li::before { content: "–"; color: #CBD5E1; }

/* ── EL PROBLEMA ── */
.pifini-problema { background: #F8FAFC; padding: 72px 5%; }
.pp-inner { max-width: 1100px; margin: 0 auto; }
.problema-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 40px; }
.prob-card { background: white; border: 1.5px solid #E2E8F0; border-radius: 14px; padding: 28px 22px; }
.prob-icon { font-size: 26px; display: block; margin-bottom: 12px; }
.prob-card h3 { font-size: 14px; font-weight: 700; color: #111827; margin-bottom: 8px; line-height: 1.4; }
.prob-card p  { font-size: 13px; color: #64748B; line-height: 1.65; }

/* ── PERFIL IDEAL ── */
.pifini-perfil { background: var(--navy-slate); padding: 72px 5%; }
.ppf-inner { max-width: 1100px; margin: 0 auto; }
.pifini-perfil .section-label { color: #f97316; }
.pifini-perfil .section-title { color: white; margin-bottom: 40px; }
.perfil-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 32px; }
.perfil-col h3 { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #94A3B8; margin-bottom: 16px; }
.perfil-col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
.perfil-col ul li { font-size: 14px; color: #CBD5E1; line-height: 1.5; padding-left: 18px; position: relative; }
.perfil-col ul li::before { content: "→"; position: absolute; left: 0; color: #f97316; font-weight: 700; }
.perfil-col--taec { background: rgba(255,255,255,.04); border: 1px solid rgba(249,115,22,.2); border-radius: 14px; padding: 24px; }
.perfil-cierre { margin-top: 20px; font-size: 13px; color: rgba(255,255,255,.4); line-height: 1.7; font-style: italic; border-top: 1px solid rgba(255,255,255,.08); padding-top: 16px; }

/* ── MÓDULOS ── */
.pifini-modulos { background: white; padding: 72px 5%; }
.pm-inner { max-width: 1100px; margin: 0 auto; }
.modulos-grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 20px; margin-top: 40px;
}
.modulo-card {
  background: #F8FAFC; border: 1.5px solid #E2E8F0;
  border-radius: 14px; padding: 24px 20px; transition: border-color .2s;
}
.modulo-card:hover { border-color: #f97316; }
.mod-icon { font-size: 28px; display: block; margin-bottom: 10px; }
.modulo-card h3 { font-size: 14px; font-weight: 700; color: #111827; margin-bottom: 8px; }
.modulo-card p  { font-size: 13px; color: #64748B; line-height: 1.65; }

/* ── QUOTE ── */
.pifini-quote { background: var(--navy-slate); padding: 56px 5%; }
.pq-inner {
  max-width: 800px; margin: 0 auto;
  display: flex; flex-direction: column; gap: 24px; align-items: center; text-align: center;
