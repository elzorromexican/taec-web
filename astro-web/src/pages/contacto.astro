---
import { contactData, getBookingUrl } from "../data/contact";
import BaseLayout from "../layouts/BaseLayout.astro";

// Valores usados en el template HTML y en atributos data-* del formulario.
// El script cliente los lee via form.dataset — NO se usa define:vars.
const formEndpoint = "/api/submit-contact"; // Internal SSR Endpoint
const bookingUrl = getBookingUrl(); // URL de agenda activa o fallback de desarrollo
const contactEmail = contactData.email;
const whatsappUrl = contactData.whatsapp.url;
---

<BaseLayout
  title="Contacto – TAEC | Habla con un especialista en e-learning"
  description="Habla con un especialista TAEC. Diagnóstico gratuito para tu estrategia de capacitación corporativa. Respondemos en menos de 24 horas."
  section=""
  page="contacto.html"
>
  <style is:global>

  /* ── PAGE HERO ── */
    .page-hero {
      background: linear-gradient(135deg, var(--navy) 0%, #00355a 100%);
      padding: 56px 5% 60px;
      text-align: center;
    }
    .page-hero-inner { max-width: 640px; margin: 0 auto; }
    .page-hero-tag {
      display: inline-block;
      background: rgba(168,219,217,.15); color: var(--teal);
      font-size: 11px; font-weight: 700; letter-spacing: 1.5px;
      text-transform: uppercase; padding: 4px 12px; border-radius: 4px;
      margin-bottom: 16px;
    }
    .page-hero h1 {
      font-family: var(--font-display);
      font-size: 38px; color: var(--white); line-height: 1.15;
      margin-bottom: 14px;
    }
    .page-hero p {
      color: #94A3B8; font-size: 16px; line-height: 1.75;
    }

    /* ── CONTACT LAYOUT ── */
    .contact-section {
      padding: 64px 5%;
      background: var(--light);
    }
    .contact-inner {
      max-width: 1080px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1.6fr; gap: 48px;
      align-items: start;
    }

    /* ── INFO SIDEBAR ── */
    .contact-info { display: flex; flex-direction: column; gap: 28px; }

    .info-block h3 {
      font-size: 13px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 1px; color: var(--muted); margin-bottom: 12px;
    }

    .info-item {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 16px; background: var(--white);
      border: 1px solid var(--border); border-radius: 10px;
      margin-bottom: 10px;
    }
    .info-item:last-child { margin-bottom: 0; }
    .info-icon {
      width: 38px; height: 38px; border-radius: 8px;
      background: var(--light); display: flex; align-items: center;
      justify-content: center; font-size: 16px; flex-shrink: 0;
    }
    .info-content { flex: 1; }
    .info-content strong {
      display: block; font-size: 13px; font-weight: 600;
      color: var(--text); margin-bottom: 2px;
    }
    .info-content a, .info-content span {
      font-size: 13px; color: var(--muted);
    }
    .info-content a:hover { color: var(--blue); }

    .response-badge {
      display: flex; align-items: center; gap: 10px;
      background: #EFF8F7; border: 1px solid #C6E8E7;
      border-radius: 10px; padding: 14px 16px;
    }
    .response-badge .dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: #2ECC71; flex-shrink: 0;
      box-shadow: 0 0 0 3px rgba(46,204,113,.2);
    }
    .response-badge p {
      font-size: 13px; color: var(--dark); line-height: 1.4;
    }
    .response-badge strong { color: var(--navy); }

    /* ── BOOKING CTA ── */
    .booking-block { display: flex; flex-direction: column; gap: 10px; }
    .booking-block h3 {
      font-size: 13px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 1px; color: var(--muted); margin-bottom: 2px;
    }
    .btn-booking {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      background: var(--navy); color: var(--white);
      font-size: 14px; font-weight: 700;
      padding: 13px 20px; border-radius: 10px;
      border: none; transition: background .15s;
    }
    .btn-booking:hover { background: #00355a; color: var(--white); }
    .btn-booking-sub {
      font-size: 12px; color: var(--muted); text-align: center;
    }

    /* ── FORM CARD ── */
    .form-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 16px; padding: 36px;
    }
    .form-card h2 {
      font-family: var(--font-display);
      font-size: 24px; color: var(--navy);
      margin-bottom: 6px;
    }
    .form-card .form-subtitle {
      font-size: 14px; color: var(--muted); margin-bottom: 28px;
    }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

    .field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 18px; }
    .field label {
      font-size: 13px; font-weight: 600; color: var(--dark);
    }
    .field label .req { color: var(--coral); margin-left: 2px; }
    .field input, .field select, .field textarea {
      font-family: var(--font-body); font-size: 14px;
      color: var(--text); background: var(--white);
      border: 1.5px solid var(--border); border-radius: 8px;
      padding: 10px 14px; transition: border-color .15s, box-shadow .15s;
      outline: none;
    }
    .field input:focus, .field select:focus, .field textarea:focus {
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(49,121,194,.1);
    }
    .field input[aria-invalid="true"],
    .field select[aria-invalid="true"],
    .field textarea[aria-invalid="true"] {
      border-color: #EF4444;
    }
    .field-error {
      font-size: 12px; color: #EF4444; margin-top: 2px;
      display: none;
    }
    .field-error.visible { display: block; }
    .field textarea { resize: vertical; min-height: 110px; }
    .field select { cursor: pointer; }

    .form-footer {
      display: flex; align-items: center; justify-content: space-between;
      gap: 16px; flex-wrap: wrap; margin-top: 8px;
    }
    .form-note { font-size: 12px; color: var(--muted); }

    .btn-submit {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--orange); color: var(--white);
      font-family: var(--font-body); font-size: 14px; font-weight: 700;
      padding: 12px 28px; border-radius: 8px; border: none;
      cursor: pointer; transition: background .15s;
    }
    .btn-submit:hover:not(:disabled) { background: #d97b0e; }
    .btn-submit:disabled { background: #94A3B8; cursor: not-allowed; }

    /* ── SUCCESS / ERROR STATES ── */
    .form-status {
      display: none; padding: 16px;
      border-radius: 10px; font-size: 14px; font-weight: 500;
      margin-top: 20px;
    }
    .form-status.success {
      display: flex; align-items: center; gap: 14px;
      background: #EFF8F7; border: 1px solid #C6E8E7; color: #1a7a6e;
      animation: slideDownFade 0.4s ease-out forwards;
    }
    .form-status.error {
      display: block;
      background: #FEF2F2; border: 1px solid #FECACA; color: #b91c1c;
      animation: slideDownFade 0.4s ease-out forwards;
    }

    @keyframes slideDownFade {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      .contact-inner { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
      .page-hero h1 { font-size: 28px; }
      .form-card { padding: 24px; }
      .form-row { grid-template-columns: 1fr; }
      .form-footer { flex-direction: column; align-items: stretch; }
      .btn-submit { justify-content: center; }
    }

  </style>

<main id="main-content">

<!-- ══ HERO ══ -->
<section class="page-hero">
  <div class="page-hero-inner">
    <span class="page-hero-tag">Contacto</span>
    <h1>Hablemos de tu proyecto</h1>
    <p>Cuéntanos qué necesitas — en menos de 24 horas un especialista te responde con ideas concretas, sin compromiso.</p>
  </div>
</section>

<!-- ══ FORMULARIO ══ -->
<section class="contact-section">
  <div class="contact-inner">

    <!-- Info lateral -->
    <div class="contact-info">

      <div class="info-block">
        <h3>Escríbenos</h3>
        <div class="info-item">
          <div class="info-icon">✉</div>
          <div class="info-content">
            <strong>Correo electrónico</strong>
            <a href={`mailto:${contactData.email}`}>{contactData.email}</a>
          </div>
        </div>
        <div class="info-item">
          <div class="info-icon">📞</div>
          <div class="info-content">
            <strong>Teléfono CDMX</strong>
            <a href={`tel:${contactData.phone.replace(/ /g,'')}`}>{contactData.phone}</a>
          </div>
        </div>
        <div class="info-item">
          <div class="info-icon">💬</div>
          <div class="info-content">
            <strong>WhatsApp</strong>
            <a href={contactData.whatsapp.url} target="_blank" rel="noopener noreferrer">+52 1 55 2775 8279</a>
          </div>
        </div>
        <div class="info-item">
          <div class="info-icon">in</div>
          <div class="info-content">
            <strong>LinkedIn</strong>
            <a href={contactData.socials.linkedin} target="_blank" rel="noopener noreferrer">linkedin.com/company/taec</a>
          </div>
        </div>
      </div>

      <div class="response-badge">
        <div class="dot"></div>
        <p><strong>Respondemos en menos de 24 h</strong><br>Lunes a viernes, 9:00 – 18:00 (CDMX)</p>
      </div>

      <!-- CTA de agenda — Zoho Bookings -->
      {bookingUrl && (
        <div class="booking-block">
          <h3>¿Prefieres una llamada?</h3>
          <a href={bookingUrl} target="_blank" rel="noopener noreferrer" class="btn-booking">
            📅 Agendar llamada de 30 min
          </a>
          <p class="btn-booking-sub">Sin compromiso · Agenda directo en el calendario</p>
        </div>
      )}

    </div><!-- /contact-info -->

    <!-- Formulario -->
    <div class="form-card">
      <h2>Cuéntanos qué necesitas</h2>
      <p class="form-subtitle">Diagnóstico gratuito · Sin compromiso · Respuesta en menos de 24 h</p>

      <!-- GAS Endpoint: Se expone por diseño (arquitectura estática) al no contar con backend intermedio -->
      <form id="contactForm" novalidate
        data-endpoint={formEndpoint}
        data-email={contactEmail}
        data-whatsapp={whatsappUrl}
      >

        <!-- Campos ocultos: trazabilidad del lead -->
        <input type="hidden" id="pagina_origen" name="pagina_origen" value="/contacto" />
        <input type="hidden" id="cta_origen"    name="cta_origen"    value="formulario-contacto" />

        <div class="form-row">
          <div class="field">
            <label for="nombre">Nombre <span class="req" aria-hidden="true">*</span></label>
            <input type="text" id="nombre" name="nombre" placeholder="Tu nombre"
              required aria-required="true" autocomplete="given-name" />
            <span class="field-error" id="err-nombre">Por favor ingresa tu nombre.</span>
          </div>
          <div class="field">
            <label for="empresa">Empresa <span class="req" aria-hidden="true">*</span></label>
            <input type="text" id="empresa" name="empresa" placeholder="Nombre de tu organización"
              required aria-required="true" autocomplete="organization" />
            <span class="field-error" id="err-empresa">Por favor ingresa tu empresa.</span>
          </div>
        </div>

        <div class="form-row">
          <div class="field">
            <label for="correo">Correo electrónico <span class="req" aria-hidden="true">*</span></label>
            <input type="email" id="correo" name="correo" placeholder="tu@empresa.com"
              required aria-required="true" autocomplete="email" />
            <span class="field-error" id="err-correo">Por favor ingresa un correo válido.</span>
          </div>
          <div class="field">
            <label for="telefono">Teléfono / WhatsApp</label>
            <input type="tel" id="telefono" name="telefono" placeholder="+52 55 …" autocomplete="tel" />
          </div>
        </div>

        <div class="form-row">
          <div class="field">
            <label for="pais">País <span class="req" aria-hidden="true">*</span></label>
            <select id="pais" name="pais" required aria-required="true">
              <option value="" disabled selected>Tu país</option>
              <option value="México" data-code="MX">🇲🇽 México</option>
              <option value="Colombia" data-code="CO">🇨🇴 Colombia</option>
              <option value="Chile" data-code="CL">🇨🇱 Chile</option>
              <option value="Argentina" data-code="AR">🇦🇷 Argentina</option>
              <option value="Perú" data-code="PE">🇵🇪 Perú</option>
              <option value="España" data-code="ES">🇪🇸 España</option>
              <option value="Estados Unidos" data-code="US">🇺🇸 Estados Unidos</option>
              <option disabled>──────────</option>
              <option value="Ecuador" data-code="EC">Ecuador</option>
              <option value="Bolivia" data-code="BO">Bolivia</option>
              <option value="Costa Rica" data-code="CR">Costa Rica</option>
              <option value="Panamá" data-code="PA">Panamá</option>
              <option value="Uruguay" data-code="UY">Uruguay</option>
              <option value="Guatemala" data-code="GT">Guatemala</option>
              <option value="El Salvador" data-code="SV">El Salvador</option>
              <option value="Honduras" data-code="HN">Honduras</option>
              <option value="Nicaragua" data-code="NI">Nicaragua</option>
              <option value="Paraguay" data-code="PY">Paraguay</option>
              <option value="Venezuela" data-code="VE">Venezuela</option>
              <option value="República Dominicana" data-code="DO">República Dominicana</option>
              <option value="Puerto Rico" data-code="PR">Puerto Rico</option>
              <option value="Cuba" data-code="CU">Cuba</option>
              <option value="Canadá" data-code="CA">Canadá</option>
              <option value="Brasil" data-code="BR">Brasil</option>
              <option disabled>──────────</option>
              <option value="Alemania" data-code="DE">Alemania</option>
              <option value="Francia" data-code="FR">Francia</option>
              <option value="Reino Unido" data-code="GB">Reino Unido</option>
              <option value="Italia" data-code="IT">Italia</option>
              <option value="Japón" data-code="JP">Japón</option>
              <option value="China" data-code="CN">China</option>
              <option value="Otro">Otro país del mundo</option>
            </select>
            <span class="field-error" id="err-pais">Por favor selecciona tu país.</span>
          </div>
          <div class="field">
            <label for="interes">¿En qué podemos ayudarte? <span class="req" aria-hidden="true">*</span></label>
            <select id="interes" name="interes" required aria-required="true">
              <option value="" disabled selected>Selecciona</option>
              <option value="Articulate 360">Articulate 360 — licencias / capacitación</option>
              <option value="Moodle / LMS">Moodle / LMS — implementación y soporte</option>
              <option value="Vyond">Vyond — licencias y producción de videos</option>
              <option value="Totara LMS">Totara LMS — plataforma enterprise</option>
              <option value="Cursos a medida">Cursos a medida (diseño instruccional)</option>
              <option value="Consultoría L&D">Consultoría L&D / estrategia</option>
              <option value="Otro">Otro</option>
            </select>
            <span class="field-error" id="err-interes">Por favor selecciona un tema.</span>
          </div>
        </div>

        <div class="field">
          <label for="mensaje">Cuéntanos más (Opcional)</label>
          <textarea id="mensaje" name="mensaje"
            placeholder="¿Cuántas personas? ¿Qué herramientas usan hoy? ¿Cuál es el reto principal?…"></textarea>
          <span class="field-error" id="err-mensaje">Por favor escribe tu mensaje.</span>
        </div>

        <div class="form-footer">
          <span class="form-note">🔒 Tu información es confidencial. No hacemos spam.</span>
          <button type="submit" class="btn-submit" id="submitBtn">
            Enviar mensaje →
          </button>
        </div>

        <div class="form-status" id="formStatus" role="alert" aria-live="polite"></div>

      </form>
    </div><!-- /form-card -->

  </div><!-- /contact-inner -->
</section>

</main>

<script is:inline>
  // ── Formulario de contacto → Google Apps Script Web App
  // Para ser compatible con Astro View Transitions, corremos en cada page-load
  document.addEventListener('astro:page-load', function () {

    const form   = document.getElementById('contactForm');
    if (!form) return;

    const formEndpoint = form.dataset.endpoint  || '';
    const contactEmail = form.dataset.email     || '';
    const _whatsappUrl  = form.dataset.whatsapp  || '';

    const btn    = document.getElementById('submitBtn');
    const status = document.getElementById('formStatus');

    // Rellenar pagina_origen con la URL real del browser
    const origenEl = document.getElementById('pagina_origen');
    if (origenEl) origenEl.value = window.location.pathname;

    // ── Helpers de validación
    function setError(id, errId, show) {
      const el  = document.getElementById(id);
      const err = document.getElementById(errId);
      if (!el || !err) return;
      if (show) {
        el.setAttribute('aria-invalid', 'true');
        err.classList.add('visible');
      } else {
        el.removeAttribute('aria-invalid');
        err.classList.remove('visible');
      }
    }

    function validateForm(data) {
      let ok = true;
      const checks = [
        ['nombre',  'err-nombre',  v => !!v.trim()],
        ['empresa', 'err-empresa', v => !!v.trim()],
        ['correo',  'err-correo',  v => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim())],
        ['pais',    'err-pais',    v => !!v],
        ['interes', 'err-interes', v => !!v]
      ];
      checks.forEach(([id, errId, test]) => {
        const val = data.get(id) || '';
        const pass = test(val);
        setError(id, errId, !pass);
        if (!pass) ok = false;
      });
      return ok;
    }

    // ── Submit
    form.addEventListener('submit', async function (e) {
      e.preventDefault();

      const data = new FormData(form);
      if (!validateForm(data)) return;

      // Envío omitido de "!" para endpoint, ya que siempre se definirá estáticamente en el lado interno.

      // ── Envío a API Serverless Interna
      btn.disabled    = true;
      btn.textContent = 'Enviando…';
      status.className = 'form-status';
      status.textContent = '';

      /** Payload completo del lead */
      const payload = {
        nombre:        data.get('nombre'),
        empresa:       data.get('empresa'),
        correo:        data.get('correo'),
        telefono:      data.get('telefono') || '',
        pais:          data.get('pais'),
        interes:       data.get('interes'),
        mensaje:       data.get('mensaje'),
        pagina_origen: data.get('pagina_origen') || '/contacto',
        cta_origen:    data.get('cta_origen')    || 'formulario-contacto',
      };

      try {
        // Se cambia el hack de text/plain por el header correcto para API Serverless nativa
        const res = await fetch(formEndpoint, {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify(payload),
        });

        let result = { success: false };
        try { result = await res.json(); } catch (_) {}

        if (result.success) {
          status.className   = 'form-status success';
          status.innerHTML   = `
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink: 0; margin-top: 2px;">
              <circle cx="12" cy="12" r="10" fill="#E0F2F1" stroke="#1a7a6e" stroke-width="1.5"/>
              <path d="M8 12.5L10.5 15L16 9" stroke="#1a7a6e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <div>
              <strong style="display:block; font-size: 15px; margin-bottom: 2px;">¡Mensaje enviado con éxito!</strong>
              <span style="font-size: 13px; font-weight: 400; color: #1a7a6e;">Un especialista analizará tus requerimientos y te contactará en menos de 24 horas.</span>
            </div>
          `;
          
          // Ocultar todos los campos del formulario para que no ocupe espacio y no "empuje" hacia abajo
          Array.from(form.children).forEach(child => {
            if (child.id !== 'formStatus' && child.tagName !== 'INPUT' && child.type !== 'hidden') {
              child.style.display = 'none';
            }
          });
          
          form.reset();
          form.querySelectorAll('[aria-invalid]').forEach(el => el.removeAttribute('aria-invalid'));
          form.querySelectorAll('.field-error.visible').forEach(el => el.classList.remove('visible'));
        } else {
          throw new Error(result.error || 'Error del servidor');
        }

      } catch (_err) {
        status.className  = 'form-status error';
        status.innerHTML = '';
        const wrn2 = document.createElement('span');
        wrn2.textContent = '✗ Hubo un problema al enviar. Escríbenos directamente a: ';
        const lnk2 = document.createElement('a');
        lnk2.href = 'mailto:' + contactEmail;
        lnk2.style.color = 'inherit';
        lnk2.textContent = contactEmail;
        status.appendChild(wrn2);
        status.appendChild(lnk2);
      } finally {
        btn.disabled    = false;
        btn.textContent = 'Enviar mensaje →';
      }
    });

    // ── Validación en vivo (blur)
    ['nombre','empresa','correo','pais','interes'].forEach(id => {
      const el = document.getElementById(id);
      if (!el) return;
      el.addEventListener('blur', () => {
        const val   = el.value;
        const errId = 'err-' + id;
        if (id === 'correo') {
          setError(id, errId, !val.trim() || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val.trim()));
        } else {
          setError(id, errId, !val || !val.trim());
        }
      });
    });

    // ── Autodetección Geográfica del País (Non-blocking y Centralizada)
    fetch('/api/get-promo')
      .then(res => res.json())
      .then(data => {
        const sel = document.getElementById('pais');
        if (!sel || sel.value !== "") return; // Fallback: si el usuario ya escogió algo, no forzamos
        const code = data.countryCode === 'mock' ? 'MX' : data.countryCode;
        if (code) {
          const targetOpt = Array.from(sel.options).find(o => o.dataset.code === code);
          if (targetOpt) {
            sel.value = targetOpt.value;
            setError('pais', 'err-pais', false);
          }
        }
      }).catch(err => console.log('Geoloc silenciada: ', err));

  });
</script>

</BaseLayout>
