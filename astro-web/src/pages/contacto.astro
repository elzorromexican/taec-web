---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Contacto – TAEC | Habla con un especialista en e-learning"
  description="Habla con un especialista TAEC. Diagnóstico gratuito para tu estrategia de capacitación corporativa. Respondemos en menos de 24 horas."
  section=""
  page="contacto.html"
>
  <style is:global>

  /* ── PAGE HERO ── */
    .page-hero {
      background: linear-gradient(135deg, var(--navy) 0%, #00355a 100%);
      padding: 56px 5% 60px;
      text-align: center;
    }
    .page-hero-inner { max-width: 640px; margin: 0 auto; }
    .page-hero-tag {
      display: inline-block;
      background: rgba(168,219,217,.15); color: var(--teal);
      font-size: 11px; font-weight: 700; letter-spacing: 1.5px;
      text-transform: uppercase; padding: 4px 12px; border-radius: 4px;
      margin-bottom: 16px;
    }
    .page-hero h1 {
      font-family: var(--font-display);
      font-size: 38px; color: var(--white); line-height: 1.15;
      margin-bottom: 14px;
    }
    .page-hero p {
      color: #94A3B8; font-size: 16px; line-height: 1.75;
    }

    /* ── CONTACT LAYOUT ── */
    .contact-section {
      padding: 64px 5%;
      background: var(--light);
    }
    .contact-inner {
      max-width: 1080px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1.6fr; gap: 48px;
      align-items: start;
    }

    /* ── INFO SIDEBAR ── */
    .contact-info { display: flex; flex-direction: column; gap: 28px; }

    .info-block h3 {
      font-size: 13px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 1px; color: var(--muted); margin-bottom: 12px;
    }

    .info-item {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 16px; background: var(--white);
      border: 1px solid var(--border); border-radius: 10px;
      margin-bottom: 10px;
    }
    .info-item:last-child { margin-bottom: 0; }
    .info-icon {
      width: 38px; height: 38px; border-radius: 8px;
      background: var(--light); display: flex; align-items: center;
      justify-content: center; font-size: 16px; flex-shrink: 0;
    }
    .info-content { flex: 1; }
    .info-content strong {
      display: block; font-size: 13px; font-weight: 600;
      color: var(--text); margin-bottom: 2px;
    }
    .info-content a, .info-content span {
      font-size: 13px; color: var(--muted);
    }
    .info-content a:hover { color: var(--blue); }

    .response-badge {
      display: flex; align-items: center; gap: 10px;
      background: #EFF8F7; border: 1px solid #C6E8E7;
      border-radius: 10px; padding: 14px 16px;
    }
    .response-badge .dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: #2ECC71; flex-shrink: 0;
      box-shadow: 0 0 0 3px rgba(46,204,113,.2);
    }
    .response-badge p {
      font-size: 13px; color: var(--dark); line-height: 1.4;
    }
    .response-badge strong { color: var(--navy); }

    /* ── FORM CARD ── */
    .form-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 16px; padding: 36px;
    }
    .form-card h2 {
      font-family: var(--font-display);
      font-size: 24px; color: var(--navy);
      margin-bottom: 6px;
    }
    .form-card .form-subtitle {
      font-size: 14px; color: var(--muted); margin-bottom: 28px;
    }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

    .field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 18px; }
    .field label {
      font-size: 13px; font-weight: 600; color: var(--dark);
    }
    .field label .req { color: var(--coral); margin-left: 2px; }
    .field input, .field select, .field textarea {
      font-family: var(--font-body); font-size: 14px;
      color: var(--text); background: var(--white);
      border: 1.5px solid var(--border); border-radius: 8px;
      padding: 10px 14px; transition: border-color .15s, box-shadow .15s;
      outline: none;
    }
    .field input:focus, .field select:focus, .field textarea:focus {
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(49,121,194,.1);
    }
    .field textarea { resize: vertical; min-height: 110px; }
    .field select { cursor: pointer; }

    .form-footer {
      display: flex; align-items: center; justify-content: space-between;
      gap: 16px; flex-wrap: wrap; margin-top: 8px;
    }
    .form-note { font-size: 12px; color: var(--muted); }

    .btn-submit {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--orange); color: var(--white);
      font-family: var(--font-body); font-size: 14px; font-weight: 700;
      padding: 12px 28px; border-radius: 8px; border: none;
      cursor: pointer; transition: background .15s;
    }
    .btn-submit:hover { background: #d97b0e; }
    .btn-submit:disabled { background: #ccc; cursor: not-allowed; }

    /* ── SUCCESS / ERROR STATES ── */
    .form-status {
      display: none; padding: 14px 16px;
      border-radius: 8px; font-size: 14px; font-weight: 500;
      margin-top: 16px;
    }
    .form-status.success {
      display: block;
      background: #EFF8F7; border: 1px solid #C6E8E7; color: #1a7a6e;
    }
    .form-status.error {
      display: block;
      background: #FEF2F2; border: 1px solid #FECACA; color: #b91c1c;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      nav, .btn-tienda { display: none; }
      .hamburger { display: flex; }
      .contact-inner { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 768px) {
      .page-hero h1 { font-size: 28px; }
      .form-card { padding: 24px; }
      .form-row { grid-template-columns: 1fr; }
      .form-footer { flex-direction: column; align-items: stretch; }
      .btn-submit { justify-content: center; }
      .footer-grid { grid-template-columns: 1fr; gap: 28px; }
    }
    @media (max-width: 480px) {
      .header-actions .btn-tienda { display: none; }
    }

    /* ── Dropdown open state (JS-managed) ── */
    .nav-item.open > .mega-menu        { display: grid !important; }
    .nav-item.open > .simple-dropdown  { display: grid !important; }
    .nav-item.open > .nav-link         { background: var(--light); color: var(--blue); }
    .nav-item.open > .nav-link svg     { transform: rotate(180deg); }
  
  </style>

  <script is:inline src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js" is:inline></script>

<main id="main-content">

<!-- ══ HERO ══ -->
<section class="page-hero">
  <div class="page-hero-inner">
    <span class="page-hero-tag">Contacto</span>
    <h1>Hablemos de tu proyecto</h1>
    <p>Cuéntanos qué necesitas — en menos de 24 horas un especialista te responde con ideas concretas, sin compromiso.</p>
  </div>
</section>

<!-- ══ FORMULARIO ══ -->
<section class="contact-section">
  <div class="contact-inner">

    <!-- Info lateral -->
    <div class="contact-info">

      <div class="info-block">
        <h3>Escríbenos</h3>
        <div class="info-item">
          <div class="info-icon">✉</div>
          <div class="info-content">
            <strong>Correo electrónico</strong>
            <a href="mailto:info@taec.com.mx">info@taec.com.mx</a>
          </div>
        </div>
        <div class="info-item">
          <div class="info-icon">📞</div>
          <div class="info-content">
            <strong>Teléfono CDMX</strong>
            <a href="tel:5568223300">55 6822 3300</a>
          </div>
        </div>
        <div class="info-item">
          <div class="info-icon">💬</div>
          <div class="info-content">
            <strong>WhatsApp</strong>
            <a href="https://wa.me/5215527758279" target="_blank" rel="noopener noreferrer">+52 1 55 2775 8279</a>
          </div>
        </div>
        <div class="info-item">
          <div class="info-icon">in</div>
          <div class="info-content">
            <strong>LinkedIn</strong>
            <a href="https://www.linkedin.com/company/taec" target="_blank" rel="noopener noreferrer">linkedin.com/company/taec</a>
          </div>
        </div>
      </div>

      <div class="response-badge">
        <div class="dot"></div>
        <p><strong>Respondemos en menos de 24 h</strong><br>Lunes a viernes, 9:00 – 18:00 (CDMX)</p>
      </div>

    </div><!-- /contact-info -->

    <!-- Formulario -->
    <div class="form-card">
      <h2>Cuéntanos qué necesitas</h2>
      <p class="form-subtitle">Diagnóstico gratuito · Sin compromiso · Respuesta en menos de 24 h</p>

      <form id="contactForm" novalidate>

        <div class="form-row">
          <div class="field">
            <label for="nombre">Nombre <span class="req">*</span></label>
            <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required aria-required="true" />
          </div>
          <div class="field">
            <label for="empresa">Empresa <span class="req">*</span></label>
            <input type="text" id="empresa" name="empresa" placeholder="Nombre de tu organización" required aria-required="true" />
          </div>
        </div>

        <div class="form-row">
          <div class="field">
            <label for="email">Correo electrónico <span class="req">*</span></label>
            <input type="email" id="email" name="email" placeholder="tu@empresa.com" required aria-required="true" />
          </div>
          <div class="field">
            <label for="telefono">Teléfono / WhatsApp</label>
            <input type="tel" id="telefono" name="telefono" placeholder="+52 55 …" />
          </div>
        </div>

        <div class="field">
          <label for="tema">¿En qué podemos ayudarte? <span class="req">*</span></label>
          <select id="tema" name="tema" required aria-required="true">
            <option value="" disabled selected>Selecciona una opción</option>
            <option value="Articulate 360">Articulate 360 — licencias / capacitación</option>
            <option value="Moodle / LMS">Moodle / LMS — implementación y soporte</option>
            <option value="Vyond">Vyond — licencias y producción de videos</option>
            <option value="Totara LMS">Totara LMS — plataforma enterprise</option>
            <option value="Cursos a medida">Cursos a medida (diseño instruccional)</option>
            <option value="Consultoría L&D">Consultoría L&D / estrategia de capacitación</option>
            <option value="Otro">Otro</option>
          </select>
        </div>

        <div class="field">
          <label for="mensaje">Cuéntanos más <span class="req">*</span></label>
          <textarea id="mensaje" name="mensaje" placeholder="¿Cuántas personas? ¿Qué herramientas usan hoy? ¿Cuál es el reto principal?…" required aria-required="true"></textarea>
        </div>

        <div class="form-footer">
          <span class="form-note">🔒 Tu información es confidencial. No hacemos spam.</span>
          <button type="submit" class="btn-submit" id="submitBtn">
            Enviar mensaje →
          </button>
        </div>

        <div class="form-status" id="formStatus"></div>

      </form>
    </div><!-- /form-card -->

  </div><!-- /contact-inner -->
</section>

</main>
<a href="https://wa.me/5215527758279" target="_blank" rel="noopener noreferrer" class="wa-float" title="WhatsApp TAEC">
  <span class="wa-tooltip">¿Hablamos?</span>
  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
</a>
</BaseLayout>
