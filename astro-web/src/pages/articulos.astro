---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Artículos – Diseño instruccional, LMS e IA en e-learning | TAEC"
  description="Análisis de fondo sobre diseño instruccional, implementación de LMS, accesibilidad, IA en el aprendizaje y estrategia L&D. Para profesionales de e-learning en México y LATAM."
  section="Recursos"
  page="articulos.html"
>
  <style is:global>

    .nav-item::after { display: none !important; }
    .nav-item.open > .mega-menu { display: grid !important; }
    .nav-item.open > .simple-dropdown { display: grid !important; }
    .nav-item.open > .nav-link { background: var(--light); color: var(--blue); }
    .nav-item.open > .nav-link svg { transform: rotate(180deg); }

    /* ── HERO ── */
    .art-hero { background: linear-gradient(135deg, #001f3d 0%, #004775 60%, #0077b6 100%); padding: 56px 5% 64px; color: white; }
    .art-hero-inner { max-width: 1100px; margin: 0 auto; }
    .art-breadcrumb { font-size: 13px; color: rgba(255,255,255,.5); margin-bottom: 20px; }
    .art-breadcrumb a { color: rgba(255,255,255,.5); transition: color .15s; }
    .art-breadcrumb a:hover { color: white; }
    .art-breadcrumb span { margin: 0 6px; }
    .art-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--teal); margin-bottom: 12px; }
    .art-hero h1 { font-family: var(--font-display); font-size: clamp(28px, 3.5vw, 44px); font-weight: 400; color: white; line-height: 1.2; margin-bottom: 12px; }
    .art-hero-sub { font-size: 16px; color: rgba(255,255,255,.7); max-width: 600px; }

    /* ── CONTROLES ── */
    .art-controls { background: var(--white); border-bottom: 1px solid var(--border); padding: 20px 5%; position: sticky; top: 68px; z-index: 100; }
    .art-controls-inner { max-width: 1100px; margin: 0 auto; display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
    .art-search { flex: 1; min-width: 200px; position: relative; }
    .art-search input { width: 100%; border: 1.5px solid var(--border); border-radius: 8px; padding: 10px 16px 10px 40px; font-size: 14px; font-family: var(--font-body); color: var(--text); background: var(--light); outline: none; transition: border-color .15s; }
    .art-search input:focus { border-color: var(--blue); background: white; }
    .art-search svg { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: #94A3B8; pointer-events: none; }
    .art-count { font-size: 13px; color: #64748B; white-space: nowrap; flex-shrink: 0; }

    /* ── FILTROS ── */
    .art-filters { padding: 16px 5% 0; background: var(--white); }
    .art-filters-inner { max-width: 1100px; margin: 0 auto; display: flex; gap: 8px; flex-wrap: wrap; padding-bottom: 16px; border-bottom: 1px solid var(--border); }
    .filter-tag { font-size: 12px; font-weight: 600; padding: 5px 12px; border-radius: 20px; border: 1.5px solid var(--border); color: #64748B; background: var(--white); cursor: pointer; transition: all .15s; white-space: nowrap; }
    .filter-tag:hover { border-color: var(--blue); color: var(--blue); }
    .filter-tag.active { background: var(--navy); color: white; border-color: var(--navy); }

    /* ── ARTÍCULOS LISTA ── */
    .art-main { padding: 40px 5% 72px; }
    .art-main-inner { max-width: 860px; margin: 0 auto; display: flex; flex-direction: column; gap: 0; }

    /* ── ARTICLE CARD (expandible) ── */
    .art-card { border: 1.5px solid var(--border); border-radius: 14px; overflow: hidden; margin-bottom: 16px; transition: box-shadow .2s, border-color .2s; }
    .art-card:hover { border-color: #CBD5E1; box-shadow: 0 4px 16px rgba(0,0,0,.06); }
    .art-card.open { border-color: var(--navy); }
    .art-card-header { padding: 24px 28px; cursor: pointer; display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; }
    .art-card-header-left { flex: 1; }
    .art-card-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; flex-wrap: wrap; }
    .art-tag { font-size: 10px; font-weight: 700; letter-spacing: .8px; text-transform: uppercase; padding: 3px 8px; border-radius: 4px; background: #EFF6FF; color: var(--blue); border: 1px solid #BFDBFE; }
    .art-date { font-size: 12px; color: #94A3B8; }
    .art-card-title { font-size: 17px; font-weight: 700; color: var(--text); line-height: 1.4; margin-bottom: 8px; }
    .art-card-excerpt { font-size: 14px; color: #64748B; line-height: 1.7; }
    .art-toggle-icon { width: 32px; height: 32px; border-radius: 8px; border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 18px; color: var(--blue); background: var(--light); transition: all .2s; margin-top: 2px; }
    .art-card.open .art-toggle-icon { background: var(--navy); color: white; border-color: var(--navy); transform: rotate(45deg); }
    .art-card-body { display: none; padding: 0 28px 28px; border-top: 1px solid var(--border); }
    .art-card.open .art-card-body { display: block; }
    .art-card-body-content { padding-top: 24px; font-size: 14px; color: #374151; line-height: 1.85; }
    .art-card-body-content h3 { font-size: 15px; font-weight: 700; color: var(--text); margin: 20px 0 8px; }
    .art-card-body-content h4 { font-size: 14px; font-weight: 700; color: var(--navy); margin: 16px 0 6px; }
    .art-card-body-content p { margin-bottom: 14px; }
    .art-card-body-content ul, .art-card-body-content ol { padding-left: 20px; margin-bottom: 14px; }
    .art-card-body-content li { margin-bottom: 6px; }
    .art-card-body-content strong { color: var(--text); }

    /* ── EMPTY STATE ── */
    .art-empty { text-align: center; padding: 64px 24px; display: none; }
    .art-empty p { font-size: 15px; color: #94A3B8; }

    /* ── REC TABS ── */
    .rec-tabs{background:#F8FAFC;border-bottom:1px solid var(--border);padding:0 5%;overflow-x:auto}
    .rec-tabs-inner{max-width:1100px;margin:0 auto;display:flex;gap:0}
    .rec-tab{display:inline-flex;align-items:center;padding:14px 18px;font-size:13px;font-weight:600;color:#64748B;border-bottom:3px solid transparent;transition:color .15s,border-color .15s;white-space:nowrap;text-decoration:none}
    .rec-tab:hover{color:var(--blue)}
    .rec-tab.active{color:var(--navy);border-bottom-color:var(--navy)}
  
  </style>

<main id="main-content">

<!-- ══ HERO ══ -->
<section class="art-hero">
  <div class="art-hero-inner">
    <p class="art-breadcrumb"><a href="/recursos">Recursos</a><span>›</span>Artículos</p>
    <p class="art-eyebrow">Artículos</p>
    <h1>Análisis de fondo para profesionales L&D</h1>
    <p class="art-hero-sub">Diseño instruccional, estrategia de aprendizaje, IA en e-learning y más. Para quienes quieren ir más allá de las tendencias.</p>
  </div>
</section>

<!-- ══ CONTROLES ══ -->
<div class="art-controls">
  <div class="art-controls-inner">
    <div class="art-search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="search" id="artSearch" placeholder="Buscar por título o tema…" aria-label="Buscar artículos" />
    </div>
    <span class="art-count" id="artCount"></span>
  </div>
</div>

<!-- ══ FILTROS ══ -->
<div class="art-filters">
  <div class="art-filters-inner" id="artFilterBar">
    <!-- Generado por JS -->
  </div>
</div>

<!-- ══ ARTÍCULOS ══ -->
<section class="art-main">
  <div class="art-main-inner" id="artList">
    <!-- contenido inyectado desde data/articulos.json -->
  </div>
  <div class="art-empty" id="artEmpty">
    <p>No se encontraron artículos con ese criterio.</p>
  </div>
</section>

</main>
</BaseLayout>
