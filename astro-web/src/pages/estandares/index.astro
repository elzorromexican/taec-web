---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroComercial from '../../components/ui/HeroComercial.astro';
import { getCollection } from 'astro:content';
import { r } from '../../utils/paths';

const items = await getCollection('estandares');
// Sort by title alphabetically
items.sort((a, b) => a.data.title.localeCompare(b.data.title));

const categories = [...new Set(items.map(p => p.data.category).filter(Boolean))].sort();
---

<BaseLayout 
  title="Estándares de eLearning | TAEC"
  description="Fichas y guías sobre estándares de e-learning: SCORM, xAPI, LTI y normas ISO."
  section="Recursos"
  page="estandares.html"
>
  <HeroComercial 
    eyebrow="TAEC · Recursos"
    titleHtml="Fichas de <span class='text-accent'>Estándares</span>"
    subtitle="Referencia rápida sobre normas de interoperabilidad, accesibilidad y cumplimiento corporativo."
    theme="general"
  />

  <main style="max-width: 1080px; margin: 64px auto; padding: 0 24px 80px;">
    
    <div style="background: #ffffff; border: 1px solid #e7e3db; padding: 32px; border-radius: 12px; box-shadow: 0 4px 16px rgba(0,0,0,0.05); margin-bottom: 48px;">
      <div style="margin-bottom: 24px; position: relative;">
        <svg style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); width: 20px; height: 20px; color: #a8a29e;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input 
          type="text" 
          id="search-input"
          autocomplete="off"
          spellcheck="false" 
          placeholder="Buscar un estándar por acrónimo o descripción..." 
          style="width: 100%; padding: 16px 20px 16px 48px; font-size: 16px; border: 1.5px solid #e7e3db; border-radius: 8px; outline: none; font-family: var(--font-body, sans-serif); transition: border-color 0.2s;"
        />
      </div>

      <div style="display: flex; flex-wrap: wrap; gap: 8px; justify-content: center;">
        <button class="filter-btn active" data-cat="ALL">Todos</button>
        {categories.map(cat => (
          <button class="filter-btn" data-cat={cat}>{cat}</button>
        ))}
      </div>
    </div>

    <div style="display: flex; align-items: baseline; justify-content: space-between; border-bottom: 2px solid #1c1917; padding-bottom: 10px; margin-bottom: 32px;">
      <h2 style="font-family: var(--font-display, Georgia, serif); font-size: 1.5rem; font-weight: 700;">Todos los Estándares</h2>
      <span style="font-family: monospace; font-size: 11px; color: #78716c; text-transform: uppercase;" id="results-count">{items.length} disponibles</span>
    </div>

    <div id="grid-results" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
      {items.map(item => {
        const destLink = item.data.link || r(`/estandares/${item.id.replace(/\.mdx?$/, '')}`);
        const isExternal = !!item.data.link;
        return (
          <a class="grid-item" href={destLink} target={isExternal ? "_blank" : "_self"} rel={isExternal ? "noopener noreferrer" : ""} data-title={`${item.data.acronym||''} ${item.data.title}`.toLowerCase()} data-desc={item.data.description?.toLowerCase() || ''} data-cat={item.data.category || ''} style="text-decoration: none; color: inherit; display: block;">
            <article style="background: #ffffff; border: 1px solid #e7e3db; padding: 20px 24px; border-radius: 8px; box-shadow: 0 1px 4px rgba(0,0,0,0.07); height: 100%; transition: transform 0.2s, box-shadow 0.2s; display: flex; flex-direction: column;">
              <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 12px;">
                {item.data.category && (
                   <span style="font-family: monospace; font-size: 10px; background: #fffbeb; color: #b45309; border: 1px solid #fde68a; padding: 2px 8px; border-radius: 3px; text-transform: uppercase;">
                    {item.data.category}
                  </span>
                )}
              </div>
              
              <div style="font-family: monospace; font-size: 1.3rem; font-weight: 600; color: #1d4ed8; margin-bottom: 4px; letter-spacing: 0.02em;">
                {item.data.acronym}
              </div>

              <h3 style="font-family: var(--font-body, sans-serif); font-size: 0.95rem; font-weight: 600; margin-bottom: 8px; line-height: 1.35; color: #1c1917;">
                {item.data.title}
              </h3>
              
              {item.data.description && (
                <p style="font-size: 13px; color: #44403c; line-height: 1.5; margin-bottom: 14px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; flex-grow: 1;">
                  {item.data.description}
                </p>
              )}
              
              {item.data.version && (
                <div style="font-family: monospace; font-size: 11px; color: #78716c; margin-top: auto; margin-bottom: 12px; padding-top: 12px; border-top: 1px dashed #e7e3db;">
                  Ref: <strong>{item.data.version}</strong>
                </div>
              )}

              <span style="font-family: monospace; font-size: 11px; text-transform: uppercase; color: #1d4ed8; font-weight: 600;">
                {isExternal ? 'Documentación oficial →' : 'Ver más →'}
              </span>
            </article>
          </a>
        )
      })}
    </div>
    <div id="no-results" style="display: none; text-align: center; padding: 64px 20px; background: #ffffff; border: 1.5px dashed #e7e3db; border-radius: 8px; margin-top: 20px;">
      <h3 style="margin: 0 0 8px; color: #1c1917; font-size: 18px;">Sin resultados</h3>
      <p style="margin: 0; color: #78716c; font-size: 14px;">Intenta buscar otra palabra o cambia el filtro de categoría.</p>
    </div>
  </main>
</BaseLayout>

<style>
.filter-btn { background: transparent; border: 1px solid #e7e3db; border-radius: 4px; font-family: monospace; font-size: 11px; text-transform: uppercase; padding: 6px 12px; cursor: pointer; color: #44403c; transition: all 0.2s ease; }
.filter-btn:hover { background: #f3f4f6; }
.filter-btn.active { background: #1c1917; color: #ffffff; border-color: #1c1917; font-weight: 600; }
input:focus { border-color: #1d4ed8 !important; box-shadow: 0 0 0 3px rgba(29, 78, 216, 0.1); }
.grid-item article:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); border-color: #dce7f9; }
.grid-item article:hover span:last-child { color: #1e3a8a; text-decoration: underline; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search-input');
    const filterBtns = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.grid-item');
    const noResults = document.getElementById('no-results');
    const resultsCount = document.getElementById('results-count');
    
    let currentSearch = '';
    let currentCat = 'ALL';

    const normalize = (str) => str.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();

    function filterItems() {
      let visibleCount = 0;
      const searchNorm = normalize(currentSearch);

      items.forEach(item => {
        const titleStr = normalize(item.getAttribute('data-title') || '');
        const descStr = normalize(item.getAttribute('data-desc') || '');
        const catStr = item.getAttribute('data-cat') || '';
        
        let matchesSearch = searchNorm ? (titleStr.includes(searchNorm) || descStr.includes(searchNorm)) : true;
        let matchesCat = currentCat !== 'ALL' ? (catStr === currentCat) : true;
        
        if (matchesSearch && matchesCat) {
          item.style.display = 'block';
          visibleCount++;
        } else {
          item.style.display = 'none';
        }
      });
      
      resultsCount.textContent = `${visibleCount} estándar` + (visibleCount !== 1 ? 'es' : '');
      if(noResults) noResults.style.display = visibleCount === 0 ? 'block' : 'none';
    }

    if(searchInput) {
      searchInput.addEventListener('input', (e) => {
        currentSearch = e.target.value.trim();
        filterItems();
      });
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        filterBtns.forEach(b => b.classList.remove('active'));
        e.target.classList.add('active');
        currentCat = e.target.getAttribute('data-cat');
        
        if (searchInput) {
          searchInput.value = '';
          currentSearch = '';
        }
        
        filterItems();
      });
    });
  });
</script>
