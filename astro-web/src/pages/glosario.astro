---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Glosario de e-learning – 232 términos en español | TAEC"
  description="Diccionario completo de e-learning con 232 términos: SCORM, xAPI, LMS, Kirkpatrick, diseño instruccional y más. Referencia rápida para profesionales L&D en México y LATAM."
  section="Recursos"
  page="glosario.html"
>
  <style is:global>

    .nav-item::after { display: none !important; }
    .nav-item.open > .mega-menu { display: grid !important; }
    .nav-item.open > .simple-dropdown { display: grid !important; }
    .nav-item.open > .nav-link { background: var(--light); color: var(--blue); }
    .nav-item.open > .nav-link svg { transform: rotate(180deg); }

    /* ── HERO ── */
    .glo-hero { background: linear-gradient(135deg, #001f3d 0%, #004775 60%, #0077b6 100%); padding: 56px 5% 64px; color: white; }
    .glo-hero-inner { max-width: 1100px; margin: 0 auto; }
    .glo-breadcrumb { font-size: 13px; color: rgba(255,255,255,.5); margin-bottom: 20px; }
    .glo-breadcrumb a { color: rgba(255,255,255,.5); transition: color .15s; }
    .glo-breadcrumb a:hover { color: white; }
    .glo-breadcrumb span { margin: 0 6px; }
    .glo-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--teal); margin-bottom: 12px; }
    .glo-hero h1 { font-family: var(--font-display); font-size: clamp(28px, 3.5vw, 44px); font-weight: 400; color: white; line-height: 1.2; margin-bottom: 12px; }
    .glo-hero-sub { font-size: 16px; color: rgba(255,255,255,.7); max-width: 560px; }

    /* ── CONTROLES ── */
    .glo-controls { background: var(--white); border-bottom: 1px solid var(--border); padding: 20px 5%; position: sticky; top: 68px; z-index: 100; }
    .glo-controls-inner { max-width: 1100px; margin: 0 auto; display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
    .glo-search { flex: 1; min-width: 200px; position: relative; }
    .glo-search input { width: 100%; border: 1.5px solid var(--border); border-radius: 8px; padding: 10px 16px 10px 40px; font-size: 14px; font-family: var(--font-body); color: var(--text); background: var(--light); outline: none; transition: border-color .15s; }
    .glo-search input:focus { border-color: var(--blue); background: white; }
    .glo-search svg { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: #94A3B8; pointer-events: none; }
    .glo-count { font-size: 13px; color: #64748B; white-space: nowrap; flex-shrink: 0; }

    /* ── ÍNDICE ALFABÉTICO ── */
    .glo-alpha { padding: 16px 5% 0; background: var(--white); }
    .glo-alpha-inner { max-width: 1100px; margin: 0 auto; display: flex; gap: 4px; flex-wrap: wrap; padding-bottom: 16px; border-bottom: 1px solid var(--border); }
    .alpha-btn { font-size: 12px; font-weight: 700; width: 34px; height: 34px; border-radius: 6px; border: 1.5px solid var(--border); color: #64748B; background: var(--white); cursor: pointer; transition: all .15s; display: flex; align-items: center; justify-content: center; }
    .alpha-btn:hover { border-color: var(--blue); color: var(--blue); }
    .alpha-btn.active { background: var(--navy); color: white; border-color: var(--navy); }
    .alpha-btn:disabled { opacity: .35; cursor: default; }

    /* ── GLOSARIO CONTENIDO ── */
    .glo-main { padding: 40px 5% 72px; }
    .glo-main-inner { max-width: 860px; margin: 0 auto; }

    /* ── GRUPO DE LETRA ── */
    .glo-group { margin-bottom: 40px; }
    .glo-group-letter { font-family: var(--font-display); font-size: 32px; font-weight: 400; color: var(--navy); margin-bottom: 16px; padding-bottom: 8px; border-bottom: 2px solid var(--border); }

    /* ── TÉRMINO ── */
    .glo-term { border: 1.5px solid var(--border); border-radius: 10px; margin-bottom: 10px; overflow: hidden; transition: border-color .15s; }
    .glo-term:hover { border-color: #CBD5E1; }
    .glo-term-header { padding: 16px 20px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
    .glo-term-name { font-size: 15px; font-weight: 700; color: var(--text); }
    .glo-term-toggle { width: 24px; height: 24px; border-radius: 6px; border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 14px; color: var(--blue); flex-shrink: 0; transition: all .2s; }
    .glo-term.open .glo-term-toggle { background: var(--navy); color: white; border-color: var(--navy); transform: rotate(45deg); }
    .glo-term-body { display: none; padding: 0 20px 16px; border-top: 1px solid var(--border); }
    .glo-term.open .glo-term-body { display: block; }
    .glo-term-def { font-size: 14px; color: #4B5563; line-height: 1.8; padding-top: 14px; }
    .glo-term-relacionados { margin-top: 10px; font-size: 12px; color: #94A3B8; }
    .glo-term-relacionados a { color: var(--blue); text-decoration: underline; }

    /* ── EMPTY ── */
    .glo-empty { text-align: center; padding: 64px 24px; display: none; }
    .glo-empty p { font-size: 15px; color: #94A3B8; }

    /* ── REC TABS ── */
    .rec-tabs{background:#F8FAFC;border-bottom:1px solid var(--border);padding:0 5%;overflow-x:auto}
    .rec-tabs-inner{max-width:1100px;margin:0 auto;display:flex;gap:0}
    .rec-tab{display:inline-flex;align-items:center;padding:14px 18px;font-size:13px;font-weight:600;color:#64748B;border-bottom:3px solid transparent;transition:color .15s,border-color .15s;white-space:nowrap;text-decoration:none}
    .rec-tab:hover{color:var(--blue)}
    .rec-tab.active{color:var(--navy);border-bottom-color:var(--navy)}
  
  </style>

<main id="main-content">

<!-- ══ HERO ══ -->
<section class="glo-hero">
  <div class="glo-hero-inner">
    <p class="glo-breadcrumb"><a href="/recursos">Recursos</a><span>›</span>Glosario</p>
    <p class="glo-eyebrow">Glosario e-learning</p>
    <h1>232 términos del aprendizaje digital en español</h1>
    <p class="glo-hero-sub">Desde SCORM hasta xAPI, de Kirkpatrick al modelo ADDIE — referencia rápida para profesionales L&D en México y LATAM.</p>
  </div>
</section>

<!-- ══ CONTROLES ══ -->
<div class="glo-controls">
  <div class="glo-controls-inner">
    <div class="glo-search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="search" id="gloSearch" placeholder="Buscar término o definición…" aria-label="Buscar en el glosario" />
    </div>
    <span class="glo-count" id="gloCount"></span>
  </div>
</div>

<!-- ══ ÍNDICE ALFABÉTICO ══ -->
<div class="glo-alpha">
  <div class="glo-alpha-inner" id="alphaIndex">
    <!-- Generado por JS -->
  </div>
</div>

<!-- ══ TÉRMINOS ══ -->
<section class="glo-main">
  <div class="glo-main-inner" id="gloContent">
    <!-- INICIO_GLOSARIO — generado por Apps Script -->
    <!-- FIN_GLOSARIO -->
  </div>
  <div class="glo-empty" id="gloEmpty">
    <p>No se encontraron términos con ese criterio.</p>
  </div>
</section>

</main>
</BaseLayout>
