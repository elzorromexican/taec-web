---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroComercial from '../../components/ui/HeroComercial.astro';
import { getCollection } from 'astro:content';
import { r } from '../../utils/paths';

const posts = await getCollection('blog');
posts.sort((a, b) => (b.data.date || '').localeCompare(a.data.date || ''));

// Extraer tags únicos
const tags = [...new Set(posts.flatMap(p => p.data.tags || []))].sort();
---

<BaseLayout 
  title="Blog e-learning | TAEC"
  description="Artículos de opinión, tendencias y novedades del mundo corporativo de L&D."
  section="Recursos"
  page="blog.html"
>
  <HeroComercial 
    eyebrow="TAEC · Recursos"
    titleHtml="Blog de <span class='text-accent'>Tendencias</span>"
    subtitle="Artículos, opiniones y breves análisis sobre el presente y futuro de la formación corporativa."
    theme="general"
  />

  <main style="max-width: 1080px; margin: 64px auto; padding: 0 24px 80px;">
    
    <div style="background: #ffffff; border: 1px solid #e7e3db; padding: 32px; border-radius: 12px; box-shadow: 0 4px 16px rgba(0,0,0,0.05); margin-bottom: 48px;">
      <div style="margin-bottom: 24px; position: relative;">
        <svg style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); width: 20px; height: 20px; color: #a8a29e;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input 
          type="text" 
          id="search-input" 
          placeholder="Buscar artículos en el blog..." 
          style="width: 100%; padding: 16px 20px 16px 48px; font-size: 16px; border: 1.5px solid #e7e3db; border-radius: 8px; outline: none; font-family: var(--font-body, sans-serif); transition: border-color 0.2s; -webkit-appearance: none;"
        />
      </div>

      <div style="display: flex; flex-wrap: wrap; gap: 8px; justify-content: center;">
        <button class="filter-btn active" data-tag="ALL">Todos</button>
        {tags.map(tag => (
          <button class="filter-btn" data-tag={tag}>{tag}</button>
        ))}
      </div>
    </div>

    <div style="display: flex; align-items: baseline; justify-content: space-between; border-bottom: 2px solid #1c1917; padding-bottom: 10px; margin-bottom: 32px;">
      <h2 style="font-family: var(--font-display, Georgia, serif); font-size: 1.5rem; font-weight: 700;">Últimas publicaciones</h2>
      <span style="font-family: monospace; font-size: 11px; color: #78716c; text-transform: uppercase;" id="results-count">{posts.length} posts</span>
    </div>

    <div id="grid-results" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
      {posts.map(post => {
        const destLink = post.data.link || r(`/blog/${post.id.replace(/\.mdx?$/, '')}`);
        const isExternal = !!post.data.link;
        return (
          <a class="grid-item" href={destLink} target={isExternal ? "_blank" : "_self"} rel={isExternal ? "noopener noreferrer" : ""} data-title={post.data.title?.toLowerCase() || ''} data-desc={post.data.description?.toLowerCase() || ''} data-tags={(post.data.tags || []).join(' ')} style="text-decoration: none; color: inherit; display: block;">
            <article style="background: #ffffff; border: 1px solid #e7e3db; padding: 20px 24px; border-radius: 8px; box-shadow: 0 1px 4px rgba(0,0,0,0.07); height: 100%; transition: transform 0.2s, box-shadow 0.2s; display: flex; flex-direction: column;">
              <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px;">
                {(post.data.tags || []).slice(0,3).map((tag: string) => (
                  <span style="font-family: monospace; font-size: 10px; background: #f0fdf4; color: #166534; padding: 2px 8px; border-radius: 3px; text-transform: uppercase;">
                    {tag}
                  </span>
                ))}
              </div>
              <div style="font-family: monospace; font-size: 11px; color: #78716c; margin-bottom: 8px;">
                {post.data.date} · {post.data.author || 'TAEC'}
              </div>
              <h3 style="font-family: var(--font-body, sans-serif); font-size: 0.95rem; font-weight: 700; margin-bottom: 8px; line-height: 1.35; color: #1c1917; flex-grow: 1;">
                {post.data.title}
              </h3>
              {post.data.description && (
                <p style="font-size: 13px; color: #44403c; line-height: 1.5; margin-bottom: 14px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                  {post.data.description}
                </p>
              )}
              <span style="font-family: monospace; font-size: 11px; text-transform: uppercase; color: #1d4ed8; font-weight: 600; margin-top: auto;">
                {isExternal ? 'Leer en Blog externo →' : 'Leer post →'}
              </span>
            </article>
          </a>
        )
      })}
    </div>
    <div id="no-results" style="display: none; text-align: center; padding: 64px 20px; background: #ffffff; border: 1.5px dashed #e7e3db; border-radius: 8px; margin-top: 20px;">
      <h3 style="margin: 0 0 8px; color: #1c1917; font-size: 18px;">Sin resultados</h3>
      <p style="margin: 0; color: #78716c; font-size: 14px;">Intenta buscar otra palabra o cambia el filtro.</p>
    </div>
  </main>
</BaseLayout>

<style>
.filter-btn { background: transparent; border: 1px solid #e7e3db; border-radius: 4px; font-family: monospace; font-size: 12px; text-transform: uppercase; padding: 6px 12px; cursor: pointer; color: #44403c; transition: all 0.2s ease; }
.filter-btn:hover { background: #f5f5f4; border-color: #d6d3d1; }
.filter-btn.active { background: #1c1917; color: #ffffff; border-color: #1c1917; font-weight: 600; }
input:focus { border-color: #1d4ed8 !important; box-shadow: 0 0 0 3px rgba(29, 78, 216, 0.1); }
.grid-item article:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); border-color: #dce7f9; }
.grid-item article:hover span:last-child { color: #1e3a8a; text-decoration: underline; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search-input');
    const filterBtns = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.grid-item');
    const noResults = document.getElementById('no-results');
    const resultsCount = document.getElementById('results-count');
    
    let currentSearch = '';
    let currentTag = 'ALL';

    const normalize = (str) => str.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();

    function filterItems() {
      let visibleCount = 0;
      const searchNorm = normalize(currentSearch);

      items.forEach(item => {
        const titleStr = normalize(item.getAttribute('data-title') || '');
        const descStr = normalize(item.getAttribute('data-desc') || '');
        const tagsStr = item.getAttribute('data-tags') || '';
        
        let matchesSearch = searchNorm ? (titleStr.includes(searchNorm) || descStr.includes(searchNorm)) : true;
        let matchesTag = currentTag !== 'ALL' ? (tagsStr.includes(currentTag)) : true;
        
        if (matchesSearch && matchesTag) {
          item.style.display = 'block';
          visibleCount++;
        } else {
          item.style.display = 'none';
        }
      });
      
      resultsCount.textContent = `${visibleCount} post` + (visibleCount !== 1 ? 's' : '');
      if(noResults) noResults.style.display = visibleCount === 0 ? 'block' : 'none';
    }

    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        currentSearch = e.target.value.trim();
        filterItems();
      });
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        filterBtns.forEach(b => b.classList.remove('active'));
        e.target.classList.add('active');
        currentTag = e.target.getAttribute('data-tag');
        filterItems();
      });
    });
  });
</script>
