---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroComercial from '../../components/ui/HeroComercial.astro';
import { getCollection } from 'astro:content';
import { r } from '../../utils/paths';

const posts = await getCollection('blog');
posts.sort((a, b) => (b.data.date || '').localeCompare(a.data.date || ''));

// Extraer los 6 tags más utilizados para no saturar la interfaz de usuario (Feedback del cliente)
const tagCounts: Record<string, number> = {};
posts.forEach(p => (p.data.tags || []).forEach(t => tagCounts[t] = (tagCounts[t] || 0) + 1));
const tags = Object.entries(tagCounts).sort((a,b) => b[1] - a[1]).slice(0, 6).map(e => e[0]).sort();
---

<BaseLayout 
  title="Blog e-learning | TAEC"
  description="Artículos de opinión, tendencias y novedades del mundo corporativo de L&D."
  section="Recursos"
  page="blog.html"
>
  <HeroComercial 
    eyebrow="TAEC · Recursos"
    titleHtml="Blog de <span class='text-accent'>Tendencias</span>"
    subtitle="Artículos, opiniones y breves análisis sobre el presente y futuro de la formación corporativa."
    theme="general"
    cardBadgeText="Insights L&D 💡"
    features={[
      "El 94% de los empleados afirman que permanecerían más tiempo en una empresa si esta invirtiera en su aprendizaje.",
      "Las organizaciones con fuertes culturas de aprendizaje son 92% más propensas a desarrollar innovaciones.",
      "El microlearning puede mejorar el enfoque y aumentar la retención de conocimientos hasta en un 80% frente a enfoques tradicionales."
    ]}
  />

  <main style="max-width: 1080px; margin: 64px auto; padding: 0 24px 80px;">
    
    <div style="background: #ffffff; border: 1px solid #e7e3db; padding: 32px; border-radius: 12px; box-shadow: 0 4px 16px rgba(0,0,0,0.05); margin-bottom: 48px;">
      <div class="search-container">
        <svg style="position: absolute; left: 20px; top: 50%; transform: translateY(-50%); width: 22px; height: 22px; color: #94a3b8;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input 
          type="text" 
          id="search-input" 
          autocomplete="off"
          name="search-query-taec-blog"
          spellcheck="false"
          placeholder="Buscar artículos en el blog..." 
        />
      </div>

      <div style="display: flex; flex-wrap: wrap; gap: 8px; justify-content: center;">
        <button class="filter-btn active" data-tag="ALL">Todos</button>
        {tags.map(tag => (
          <button class="filter-btn" data-tag={tag}>{tag}</button>
        ))}
      </div>
    </div>

    <div style="display: flex; align-items: baseline; justify-content: space-between; border-bottom: 2px solid #e2e8f0; padding-bottom: 12px; margin-bottom: 40px;">
      <h2 style="font-family: var(--font-display, Georgia, serif); font-size: 1.75rem; font-weight: 700; color: var(--navy-slate);">Últimas publicaciones</h2>
      <span style="font-family: monospace; font-size: 12px; color: #64748b; text-transform: uppercase;" id="results-count">{posts.length} posts</span>
    </div>

    <div id="grid-results" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 32px;">
      {posts.map(post => {
        const destLink = post.data.link || r(`/blog/${post.id.replace(/\.mdx?$/, '')}`);
        const isExternal = !!post.data.link;
        // Inyector de Imagen Dummy seguro
        const coverImage = post.data.image ? r(post.data.image.startsWith('/') ? post.data.image : `/${post.data.image}`) : null;
        
        return (
          <a class="grid-item" href={destLink} target={isExternal ? "_blank" : "_self"} rel={isExternal ? "noopener noreferrer" : ""} data-title={post.data.title?.toLowerCase() || ''} data-desc={post.data.description?.toLowerCase() || ''} data-tags={(post.data.tags || []).join(' ')} style="text-decoration: none; color: inherit; display: block;">
            <article class="premium-blog-card" style="background: #ffffff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.03); height: 100%; transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1); display: flex; flex-direction: column; overflow: hidden;">
              
              <div class="card-cover-wrapper" style="width: 100%; height: 200px; background: #f1f5f9; position: relative; overflow: hidden; border-bottom: 1px solid #e2e8f0;">
                {coverImage ? (
                  <img src={coverImage} alt={post.data.title} style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;" class="card-cover-img" loading="lazy" />
                ) : (
                  <div class="card-cover-img" style="width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%); color: #94a3b8; transition: transform 0.5s ease;">
                    <svg width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                    </svg>
                    <span style="font-family: monospace; font-size: 11px; margin-top: 8px; font-weight: 600;">ARTÍCULO TAEC</span>
                  </div>
                )}
              </div>

              <div style="padding: 24px; display: flex; flex-direction: column; flex-grow: 1;">
                <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 12px;">
                  {(post.data.tags || []).slice(0,2).map((tag: string) => (
                    <span style="font-family: monospace; font-size: 11px; background: #f0fdf4; color: #166534; padding: 4px 10px; border-radius: 6px; font-weight: 600; text-transform: uppercase;">
                      {tag}
                    </span>
                  ))}
                </div>
                
                <div style="font-family: monospace; font-size: 12px; color: #64748b; margin-bottom: 12px; display: flex; align-items: center; justify-content: space-between; gap: 8px;">
                  <span>{post.data.date}</span>
                  <span style="color: #334155; font-weight: 700; background: #f1f5f9; padding: 3px 8px; border-radius: 4px; display: inline-flex; align-items: center; gap: 4px;">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"></path></svg>
                    {Math.max(1, Math.ceil((post.body ? post.body.trim().split(/\s+/).length : 500) / 200))} min
                  </span>
                </div>
                <h3 style="font-family: var(--font-body, sans-serif); font-size: 1.15rem; font-weight: 800; margin-bottom: 12px; line-height: 1.4; color: var(--navy-slate); flex-grow: 1; text-wrap: balance;">
                  {post.data.title}
                </h3>
                {post.data.description && (
                  <p style="font-size: 14px; color: #475569; line-height: 1.6; margin-bottom: 20px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                    {post.data.description}
                  </p>
                )}
                <span style="font-family: monospace; font-size: 12px; text-transform: uppercase; color: #2563eb; font-weight: 700; margin-top: auto; display: flex; align-items: center; gap: 6px;" class="read-more-btn">
                  {isExternal ? 'Leer en Blog externo' : 'Leer artículo'} &rarr;
                </span>
              </div>
            </article>
          </a>
        )
      })}
    </div>
    <div id="no-results" style="display: none; text-align: center; padding: 64px 20px; background: #ffffff; border: 1.5px dashed #e7e3db; border-radius: 8px; margin-top: 20px;">
      <h3 style="margin: 0 0 8px; color: #1c1917; font-size: 18px;">Sin resultados</h3>
      <p style="margin: 0; color: #78716c; font-size: 14px;">Intenta buscar otra palabra o cambia el filtro.</p>
    </div>
  </main>
</BaseLayout>

<style>
/* Estética Premium UI/UX */
.filter-btn { background: transparent; border: 1px solid #cbd5e1; border-radius: 6px; font-family: monospace; font-size: 12px; text-transform: uppercase; padding: 8px 16px; cursor: pointer; color: #475569; transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); }
.filter-btn:hover { background: #f8fafc; border-color: #94a3b8; transform: translateY(-1px); }
.filter-btn.active { background: var(--navy-slate); color: #ffffff; border-color: var(--navy-slate); font-weight: 700; transform: none; box-shadow: 0 4px 12px rgba(15, 23, 42, 0.15); }

/* Efecto Glass y Búsqueda */
.search-container { position: relative; margin-bottom: 32px; }
input[type="text"] { width: 100%; padding: 18px 20px 18px 56px; font-size: 16px; color: #1e293b; background: rgba(255,255,255,0.7); backdrop-filter: blur(8px); border: 1.5px solid #cbd5e1; border-radius: 12px; outline: none; transition: all 0.3s ease; box-shadow: inset 0 2px 4px rgba(0,0,0,0.02); }
input[type="text"]:focus { border-color: #3b82f6; box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15); background: #ffffff; }

/* Micro-Animaciones Cards */
.grid-item article.premium-blog-card:hover { transform: translateY(-6px); box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04); border-color: #bfdbfe; }
.grid-item article.premium-blog-card:hover .card-cover-img { transform: scale(1.05); }
.grid-item article.premium-blog-card:hover .read-more-btn { color: #1e40af; }
</style>

<script src="../../scripts/content-filter.ts"></script>
