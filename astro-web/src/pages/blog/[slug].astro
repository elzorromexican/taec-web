---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { r } from '../../utils/paths';

const monthMap: Record<string, number> = {
  'enero': 1, 'febrero': 2, 'marzo': 3, 'abril': 4, 'mayo': 5, 'junio': 6,
  'julio': 7, 'agosto': 8, 'septiembre': 9, 'octubre': 10, 'noviembre': 11, 'diciembre': 12
};

function parseDate(dateStr: string) {
  if (!dateStr) return 0;
  const match = dateStr.match(/(\d+)\s+(?:de\s+)?([a-z]+)[,\s]+(\d+)/i);
  if (match) {
    const day = parseInt(match[1], 10);
    const month = monthMap[match[2].toLowerCase()] || 1;
    const year = parseInt(match[3], 10);
    return new Date(year, month - 1, day).getTime();
  }
  return 0;
}

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  // Sort posts descending by date
  posts.sort((a, b) => parseDate(b.data.date) - parseDate(a.data.date));

  return posts.map((post, i) => ({
    params: { slug: post.id.replace(/\.mdx?$/, '') },
    props: { 
      post,
      prevPost: i < posts.length - 1 ? posts[i + 1] : null,
      nextPost: i > 0 ? posts[i - 1] : null
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout 
  title={`${post.data.title} - Blog e-learning | TAEC`}
  description={post.data.description || post.data.title}
  section="Recursos"
>
  <main style="background: #faf8f3; min-height: 70vh; padding: 64px 24px 80px;">
    <article style="max-width: 680px; margin: 0 auto; background: #ffffff; border: 1px solid #e7e3db; border-radius: 8px; padding: 48px; box-shadow: 0 4px 16px rgba(0,0,0,0.05);">
      
      <a href={r('/blog')} style="font-family: monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; text-decoration: none; color: #78716c; margin-bottom: 32px; display: inline-block; transition: color 0.15s;">
        &larr; Volver al Blog
      </a>
      
      <header style="margin-bottom: 32px; border-bottom: 1px solid #e7e3db; padding-bottom: 24px;">
        <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px;">
          {(post.data.tags || []).map((tag: string) => (
            <span style="font-family: monospace; background: #f0fdf4; color: #166534; padding: 4px 12px; border-radius: 4px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.04em;">
              {tag}
            </span>
          ))}
        </div>
        
        <h1 style="font-family: var(--font-display, Georgia, serif); font-size: clamp(2rem, 3.5vw, 2.5rem); font-weight: 700; color: #1c1917; margin-top: 0; margin-bottom: 16px; line-height: 1.15; letter-spacing: -0.01em;">
          {post.data.title}
        </h1>

        <div style="font-family: monospace; font-size: 11px; color: #78716c; text-transform: uppercase; letter-spacing: 0.05em;">
          {post.data.date} · {post.data.author || 'TAEC'}
        </div>
      </header>
      
      {post.data.description && (
        <div style="font-size: 1.15rem; line-height: 1.6; color: #44403c; font-style: italic; margin-bottom: 32px; padding-left: 20px; border-left: 4px solid #1d4ed8;">
          {post.data.description}
        </div>
      )}
      
      {post.data.link && (
        <div style="margin-bottom: 32px; padding: 16px 20px; background: #eff6ff; border-radius: 8px; border: 1px solid #bfdbfe;">
           <span style="font-family: monospace; font-size: 12px; font-weight: 600; color: #1e40af;">Nota:</span> 
           <span style="color: #1e40af; font-size: 14px; margin-left: 8px;">Este artículo está publicado externamente. 
             <a href={post.data.link} target="_blank" rel="noopener noreferrer" style="color: #1d4ed8; text-decoration: underline; font-weight: 600;">Léelo aquí &rarr;</a>
           </span>
        </div>
      )}

      <!-- Contenido Markdown -->
      <div class="prose-content" style="font-family: var(--font-body, sans-serif); font-size: 1.05rem; line-height: 1.75; color: #1c1917;">
        <Content />
      </div>

      <nav style="display: flex; flex-direction: column; gap: 24px; margin-top: 64px; padding-top: 32px; border-top: 1px solid #e7e3db; sm:flex-row; justify-content: space-between;">
        <div style="flex: 1; padding-right: 16px;">
          {prevPost && (
            <a href={r(`/blog/${prevPost.id.replace(/\.mdx?$/, '')}`)} style="display: block; text-decoration: none; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">
              <span style="font-family: monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: #78716c;">&larr; Artículo Anterior</span>
              <h4 style="margin-top: 8px; font-family: var(--font-display, Georgia, serif); font-size: 1.1rem; color: #1c1917; line-height: 1.4;">{prevPost.data.title}</h4>
            </a>
          )}
        </div>
        
        {prevPost && nextPost && (
           <div style="width: 1px; background: #e7e3db; display: none; @media(min-width: 640px) { display: block; }"></div>
        )}
        
        <div style="flex: 1; text-align: left; padding-left: 0; border-top: 1px solid #e7e3db; padding-top: 24px; @media(min-width: 640px) { text-align: right; border-top: none; padding-top: 0; padding-left: 16px; border-left: 1px solid #e7e3db; }">
          {nextPost && (
            <a href={r(`/blog/${nextPost.id.replace(/\.mdx?$/, '')}`)} style="display: block; text-decoration: none; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">
              <span style="font-family: monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: #78716c;">Siguiente Artículo &rarr;</span>
              <h4 style="margin-top: 8px; font-family: var(--font-display, Georgia, serif); font-size: 1.1rem; color: #1c1917; line-height: 1.4;">{nextPost.data.title}</h4>
            </a>
          )}
        </div>
      </nav>

    </article>
  </main>
</BaseLayout>

<style is:global>
/* Minimal prose styles for the markdown body */
.prose-content h2 { font-family: var(--font-display, Georgia, serif); font-size: 1.8rem; margin-top: 2em; margin-bottom: 0.8em; color: #1c1917; }
.prose-content h3 { font-size: 1.3rem; margin-top: 1.5em; margin-bottom: 0.6em; color: #1c1917; }
.prose-content p { margin-bottom: 1.5em; overflow-wrap: break-word; }
.prose-content a { color: #1d4ed8; text-decoration: underline; overflow-wrap: break-word; word-break: break-word; }
.prose-content ul, .prose-content ol { margin-bottom: 1.5em; padding-left: 1.5em; }
.prose-content li { margin-bottom: 0.5em; }
.prose-content hr { border: none; border-top: 1px solid #e7e3db; margin: 3em 0; }
.prose-content img { max-width: 100%; height: auto; border-radius: 8px; box-shadow: 0 4px 16px rgba(0,0,0,0.05); }
</style>
