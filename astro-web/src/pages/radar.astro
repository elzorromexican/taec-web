---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Radar eLearning TAEC – Tendencias e innovación en L&amp;D | TAEC"
  description="Informe periódico de tendencias en e-learning y L&D para México y LATAM. 6 ediciones del Radar eLearning TAEC con análisis de tecnologías emergentes y cambios del mercado."
  section="Recursos"
  page="radar.html"
>
  <style is:global>

    .nav-item::after { display: none !important; }
    .nav-item.open > .mega-menu { display: grid !important; }
    .nav-item.open > .simple-dropdown { display: grid !important; }
    .nav-item.open > .nav-link { background: var(--light); color: var(--blue); }
    .nav-item.open > .nav-link svg { transform: rotate(180deg); }

    /* ── HERO ── */
    .glo-hero { background: linear-gradient(135deg, #001f3d 0%, #004775 60%, #0077b6 100%); padding: 56px 5% 64px; color: white; }
    .glo-hero-inner { max-width: 1100px; margin: 0 auto; }
    .glo-breadcrumb { font-size: 13px; color: rgba(255,255,255,.5); margin-bottom: 20px; }
    .glo-breadcrumb a { color: rgba(255,255,255,.5); transition: color .15s; }
    .glo-breadcrumb a:hover { color: white; }
    .glo-breadcrumb span { margin: 0 6px; }
    .glo-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--teal); margin-bottom: 12px; }
    .glo-hero h1 { font-family: var(--font-display); font-size: clamp(28px, 3.5vw, 44px); font-weight: 400; color: white; line-height: 1.2; margin-bottom: 12px; }
    .glo-hero-sub { font-size: 16px; color: rgba(255,255,255,.7); max-width: 580px; }

    /* ── CONTROLES ── */
    .glo-controls { background: var(--white); border-bottom: 1px solid var(--border); padding: 20px 5%; position: sticky; top: 68px; z-index: 100; }
    .glo-controls-inner { max-width: 1100px; margin: 0 auto; display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
    .glo-search { flex: 1; min-width: 200px; position: relative; }
    .glo-search input { width: 100%; border: 1.5px solid var(--border); border-radius: 8px; padding: 10px 16px 10px 40px; font-size: 14px; font-family: var(--font-body); color: var(--text); background: var(--light); outline: none; transition: border-color .15s; }
    .glo-search input:focus { border-color: var(--blue); background: white; }
    .glo-search svg { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: #94A3B8; pointer-events: none; }
    .glo-count { font-size: 13px; color: #64748B; white-space: nowrap; flex-shrink: 0; }

    /* ── RADAR MAIN ── */
    .rad-main { padding: 40px 5% 72px; }
    .rad-main-inner { max-width: 1100px; margin: 0 auto; }
    .rad-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    @media (max-width: 720px) { .rad-grid { grid-template-columns: 1fr; } }

    /* ── RAD CARD ── */
    .rad-card { border: 1.5px solid var(--border); border-radius: 14px; overflow: hidden; display: flex; flex-direction: column; transition: border-color .15s, box-shadow .2s; background: var(--white); }
    .rad-card:hover { border-color: var(--blue); box-shadow: 0 6px 24px rgba(0,71,117,.1); }
    .rad-card-top { background: linear-gradient(135deg, var(--navy) 0%, #0077b6 100%); padding: 20px 22px 18px; display: flex; align-items: flex-start; gap: 14px; }
    .rad-edition-badge { background: rgba(255,255,255,.15); border: 1px solid rgba(255,255,255,.25); color: white; font-size: 10px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; border-radius: 6px; padding: 3px 9px; white-space: nowrap; flex-shrink: 0; margin-top: 2px; }
    .rad-card-title { font-family: var(--font-display); font-size: 18px; font-weight: 400; color: white; line-height: 1.3; flex: 1; }
    .rad-card-body { padding: 18px 22px; flex: 1; display: flex; flex-direction: column; gap: 12px; }
    .rad-card-date { font-size: 12px; color: #94A3B8; font-weight: 600; letter-spacing: .3px; }
    .rad-card-desc { font-size: 13px; color: #4B5563; line-height: 1.75; flex: 1; }
    .rad-card-link { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 700; color: var(--blue); transition: color .15s; margin-top: 4px; align-self: flex-start; }
    .rad-card-link:hover { color: var(--navy); }

    /* ── EMPTY ── */
    .glo-empty { text-align: center; padding: 64px 24px; display: none; }
    .glo-empty p { font-size: 15px; color: #94A3B8; }

    /* ── REC TABS ── */
    .rec-tabs{background:#F8FAFC;border-bottom:1px solid var(--border);padding:0 5%;overflow-x:auto}
    .rec-tabs-inner{max-width:1100px;margin:0 auto;display:flex;gap:0}
    .rec-tab{display:inline-flex;align-items:center;padding:14px 18px;font-size:13px;font-weight:600;color:#64748B;border-bottom:3px solid transparent;transition:color .15s,border-color .15s;white-space:nowrap;text-decoration:none}
    .rec-tab:hover{color:var(--blue)}
    .rec-tab.active{color:var(--navy);border-bottom-color:var(--navy)}
  
  </style>

<main id="main-content">

<!-- ══ HERO ══ -->
<section class="glo-hero">
  <div class="glo-hero-inner">
    <p class="glo-breadcrumb"><a href="/recursos">Recursos</a><span>›</span>Radar eLearning</p>
    <p class="glo-eyebrow">Radar eLearning</p>
    <h1>Tendencias e innovación en aprendizaje corporativo</h1>
    <p class="glo-hero-sub">Publicación periódica de TAEC con análisis de las tecnologías, metodologías y cambios de mercado que están transformando el sector L&amp;D en México y LATAM.</p>
  </div>
</section>

<!-- ══ CONTROLES ══ -->
<div class="glo-controls">
  <div class="glo-controls-inner">
    <div class="glo-search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="search" id="radSearch" placeholder="Buscar edición…" aria-label="Buscar edición del Radar" />
    </div>
    <span class="glo-count" id="radCount"></span>
  </div>
</div>

<!-- ══ RADAR ══ -->
<section class="rad-main">
  <div class="rad-main-inner">
    <div class="rad-grid" id="radContent">
      <!-- INICIO_RADAR — generado por Apps Script -->
      <!-- FIN_RADAR -->
    </div>
    <div class="glo-empty" id="radEmpty">
      <p>No se encontraron ediciones con ese criterio.</p>
    </div>
  </div>
</section>

</main>
<a href="https://wa.me/5215527758279" target="_blank" rel="noopener noreferrer" class="wa-float" title="WhatsApp TAEC" aria-label="Contactar por WhatsApp">
  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
</a>
</BaseLayout>
