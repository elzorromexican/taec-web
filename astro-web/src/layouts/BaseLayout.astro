---
/**
 * @name BaseLayout
 * @version 1.1
 * @description Layout principal que provee la estructura HTML, el <head> global con SEO, Header y Footer.
 * @inputs title, description, section, page, image
 * @outputs Estructura HTML completa 
 * @dependencies Header.astro, Footer.astro, MobileNav.astro
 * @created 2026-03-22
 * @updated 2026-03-22
 */
// CHANGELOG: 19/03/2026 - Centralized SEO logic and dynamic canonical URLs
// CHANGELOG: 19/03/2026 - Use BASE_URL for asset paths to support GitHub Pages staging
import Header from '../components/Header.astro';
import FooterDock from '../components/experiments/FooterDock.astro';
import MobileNav from '../components/MobileNav.astro';
import { ClientRouter } from 'astro:transitions';

const {
  title = "TAEC – Partner e-learning para empresas | México y LATAM",
  description = "18 años ayudando a empresas en México y LATAM a implementar e-learning.",
  section = "",
  page = "",
  image = "",
  robots = "index, follow",
  footerTheme = "default"
} = Astro.props;

import { base } from '../utils/paths';

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://nuevo.taec.com.mx');
// BASE_URL = '/' prod, '/taec-web/' staging — use it to build the absolute OG image URL
const ogImageURL = new URL(image ? (image.startsWith('http') ? image : `${base}${image.replace(/^\//,'')}`) : `${base}assets/logos/taec-og.png`, Astro.site || 'https://nuevo.taec.com.mx');

/**
 * import.meta.env.BASE_URL always ends with '/':
 *   production  → '/'
 *   staging     → '/taec-web/'
 * Use it to prefix public-folder asset paths (no leading slash on the path).
 */
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={robots} />
  
  <!-- Geo & Regional Tags -->
  <meta name="geo.region" content="MX" />
  <meta name="geo.placename" content="Ciudad de México" />
  <link rel="alternate" hreflang="es-419" href={Astro.site || 'https://nuevo.taec.com.mx/'} />

  <link rel="sitemap" type="application/xml" href={`${base}sitemap-index.xml`} />

  <link rel="canonical" href={canonicalURL} />
  
  <ClientRouter />

  <!-- OpenGraph / Social -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="TAEC Corporativo" />
  <meta property="og:locale" content="es_MX" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL} />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={canonicalURL} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <link rel="stylesheet" href={`${base}assets/css/base.css`} />
  <link rel="stylesheet" href={`${base}assets/css/header.css`} />
  <link rel="stylesheet" href={`${base}assets/css/footer.css`} />

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" is:inline set:html={`
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "TAEC",
    "url": "https://nuevo.taec.com.mx",
    "logo": "https://nuevo.taec.com.mx/assets/logo.svg",
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+52-55-2775-8279",
      "contactType": "customer service"
    }
  }
  `} />

  <!-- Breadcrumbs Dinámicos -->
  {() => {
    const pathParts = Astro.url.pathname.split('/').filter(Boolean);
    if (pathParts.length === 0) return null;
    
    const breadcrumbItems = pathParts.map((part, index) => {
      const url = `https://nuevo.taec.com.mx/${pathParts.slice(0, index + 1).join('/')}/`;
      const name = part.charAt(0).toUpperCase() + part.slice(1).replace(/-/g, ' ');
      return {
        "@type": "ListItem",
        "position": index + 1,
        "name": name,
        "item": url
      };
    });

    const breadcrumbSchema = {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbItems
    };

    return <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />;
  }}
  <!-- Portal Hermético CMS: Script de Netlify Identity -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>

  <slot name="head" />
</head>
<body data-section={section} data-page={page} data-base={base} class="has-footer-dock">
  <a class="skip-link" href="#main-content">Ir al contenido principal</a>
  
  <Header />
  <MobileNav />
  
  <slot />
  
  <FooterDock theme={footerTheme} />
  
  <script is:inline src={`${base}assets/js/nav.js`} defer></script>
  <script>
    let globalRevealObserver = null;

    function globalInitReveal() {
      // Limpiar observer anterior para evitar Memory Leaks en View Transitions
      if (globalRevealObserver) globalRevealObserver.disconnect();

      const reveals = document.querySelectorAll('.reveal-up:not(.is-revealed)');
      if (!reveals.length) return;
      
      globalRevealObserver = new IntersectionObserver((entries, obs) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-revealed');
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      
      reveals.forEach(el => globalRevealObserver.observe(el));
    }
    
    // Astro Module Scripts se ejecutan SOLO UNA VEZ. Por lo tanto, registramos astro:page-load de forma segura.
    document.addEventListener('astro:page-load', globalInitReveal);
  </script>
</body>
</html>
