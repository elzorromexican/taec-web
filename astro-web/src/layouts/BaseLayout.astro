---
/**
 * @name BaseLayout
 * @version 1.1
 * @description Layout principal que provee la estructura HTML, el <head> global con SEO, Header y Footer.
 * @inputs title, description, section, page, image
 * @outputs Estructura HTML completa 
 * @dependencies Header.astro, Footer.astro, MobileNav.astro
 * @created 2026-03-22
 * @updated 2026-03-22
 */
// CHANGELOG: 19/03/2026 - Centralized SEO logic and dynamic canonical URLs
// CHANGELOG: 19/03/2026 - Use BASE_URL for asset paths to support GitHub Pages staging
import Header from '../components/Header.astro';
import ChatAgent from '../components/chat/ChatAgent';
import { contactData } from '../data/contact';
import FooterDock from '../components/experiments/FooterDock.astro';
import MobileNav from '../components/MobileNav.astro';
import { ClientRouter } from 'astro:transitions';

const {
  title = "TAEC – Partner e-learning para empresas | México y LATAM",
  description = "18 años ayudando a empresas en México y LATAM a implementar e-learning.",
  section = "",
  page = "",
  image = "",
  robots = "index, follow",
  footerTheme = "default",
  isApp = false
} = Astro.props;

import { base } from '../utils/paths';

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://nuevo.taec.com.mx');
// BASE_URL = '/' prod, '/taec-web/' staging — use it to build the absolute OG image URL
const ogImageURL = new URL(image ? (image.startsWith('http') ? image : `${base}${image.replace(/^\//,'')}`) : `${base}assets/logos/taec-og.png`, Astro.site || 'https://nuevo.taec.com.mx');

/**
 * import.meta.env.BASE_URL always ends with '/':
 *   production  → '/'
 *   staging     → '/taec-web/'
 * Use it to prefix public-folder asset paths (no leading slash on the path).
 */
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={robots} />
  
  <!-- Geo & Regional Tags -->
  <meta name="geo.region" content="MX" />
  <meta name="geo.placename" content="Ciudad de México" />
  <link rel="alternate" hreflang="es-419" href={canonicalURL} />

  <link rel="sitemap" type="application/xml" href={`${base}sitemap-index.xml`} />

  <link rel="canonical" href={canonicalURL} />
  
  <ClientRouter />

  <!-- OpenGraph / Social -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="TAEC Corporativo" />
  <meta property="og:locale" content="es_MX" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL} />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={canonicalURL} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;500;600;700;800&display=optional" rel="stylesheet" />

  <link rel="stylesheet" href={`${base}assets/css/base.css`} />
  <link rel="stylesheet" href={`${base}assets/css/header.css?v=nuevaCapa`} />
  <link rel="stylesheet" href={`${base}assets/css/footer.css`} />

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "TAEC",
    "url": (Astro.site || 'https://nuevo.taec.com.mx').toString().replace(/\/$/, ''),
    "logo": new URL(`${base}assets/logo.svg`, Astro.site || 'https://nuevo.taec.com.mx').toString(),
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+52-55-2775-8279",
      "contactType": "customer service"
    }
  })} />

  <!-- Breadcrumbs Dinámicos -->
  {() => {
    const pathParts = Astro.url.pathname.split('/').filter(Boolean);
    if (pathParts.length === 0) return null;
    
    const siteRoot = (Astro.site || 'https://nuevo.taec.com.mx').toString().replace(/\/$/, '');
    const breadcrumbItems = pathParts.map((part, index) => {
      const url = `${siteRoot}/${pathParts.slice(0, index + 1).join('/')}/`;
      const name = part.charAt(0).toUpperCase() + part.slice(1).replace(/-/g, ' ');
      return {
        "@type": "ListItem",
        "position": index + 1,
        "name": name,
        "item": url
      };
    });

    const breadcrumbSchema = {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbItems
    };

    return <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />;
  }}
  <!-- Portal Hermético CMS: Script de Netlify Identity -->

  <slot name="head" />
</head>
<body data-section={section} data-page={page} data-base={base} class={isApp ? "is-app-mode" : "has-footer-dock"}>
  <a class="skip-link" href="#main-content">Ir al contenido principal</a>
  
  {!isApp && <Header />}
  {!isApp && <MobileNav />}
  
  <slot />
  
  {!isApp && <FooterDock theme={footerTheme} />}
  
  <!-- ══ WHATSAPP FLOTANTE (Restaurado) ══ -->
  {!isApp && (
  <a href={contactData.whatsapp.url} target="_blank" rel="noopener noreferrer" class="wa-float" title="WhatsApp TAEC" style="z-index: 9998; bottom: 30px; left: 30px; right: auto;">
    <span class="wa-tooltip" style="right: auto; left: 70px; top: 15px;">¿Hablamos?</span>
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
  </a>
  )}

  <ChatAgent client:load isApp={isApp} userName={Astro.locals?.user?.name || Astro.locals?.name || 'Visitante'} />
  <script is:inline src={`${base}assets/js/nav.js`} defer></script>
  <script>
    let globalRevealObserver = null;

    function globalInitReveal() {
      // Limpiar observer anterior para evitar Memory Leaks en View Transitions
      if (globalRevealObserver) globalRevealObserver.disconnect();

      const reveals = document.querySelectorAll('.reveal-up:not(.is-revealed)');
      if (!reveals.length) return;
      
      globalRevealObserver = new IntersectionObserver((entries, obs) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-revealed');
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      
      reveals.forEach(el => globalRevealObserver.observe(el));
    }
    
    // Astro Module Scripts se ejecutan SOLO UNA VEZ. Por lo tanto, registramos astro:page-load de forma segura.
    document.addEventListener('astro:page-load', globalInitReveal);
  </script>
</body>
</html>
