---
// CHANGELOG: 19/03/2026 - Refactored to use centralized data from src/data/navigation.ts and src/data/contact.ts
// CHANGELOG: 19/03/2026 - Use r() helper to prefix internal links with BASE_URL for staging
import { mainNav } from '../data/navigation';
import { contactData, getBookingUrl } from '../data/contact';

const base = import.meta.env.BASE_URL; // '/' prod, '/taec-web/' staging

/**
 * Resolve a URL:
 * - External (starts with http/https//) → return as-is
 * - Internal (starts with /) → prefix with base, removing trailing slash from base
 */
function r(url: string): string {
  if (!url || url.startsWith('http://') || url.startsWith('https://') || url.startsWith('//')) {
    return url;
  }
  return base.replace(/\/$/, '') + url;
}
---
<header style="position: sticky; top: 0; z-index: 999999; background: #ffffff;">
  <div class="header-inner">
    <a href={r('/')} class="logo-link">
      <img src={`${base}assets/logo.svg`} alt="TAEC" />
    </a>
    <nav>
      {mainNav.map((item) => {
        if (item.type === "link") {
          return <a href={r(item.url)}>{item.label}</a>;
        }
        
        if (item.type === "mega") {
          return (
            <div class="nav-item">
              <button class="nav-link" aria-haspopup="true" aria-expanded="false">
                {item.label}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="mega-menu">
                {item.columns?.map((col) => (
                  <div class="mega-col">
                    <span class="mega-head">{col.title}</span>
                    {col.items.map((link) => {
                      if (link.isDivider) return <div class="mega-divider"></div>;
                      if (link.isSubtitle) return <span class="mega-head" style="margin-top:4px">{link.label}</span>;
                      
                      return (
                        <>
                          <a href={r(link.url)}>
                            {link.label}
                            {link.badge && <span class={`badge-${link.badge.type}`}>{link.badge.text}</span>}
                            {link.subtext && <small style="color:var(--muted);font-weight:400">{link.subtext}</small>}
                          </a>
                          {link.subItems && (
                            <div class="mega-sub">
                              {link.subItems.map((sub) => (
                                <a href={r(sub.url)}>
                                  {sub.label}
                                  {sub.badge && <span class={`badge-${sub.badge.type}`}>{sub.badge.text}</span>}
                                </a>
                              ))}
                            </div>
                          )}
                        </>
                      );
                    })}
                  </div>
                ))}
              </div>
            </div>
          );
        }

        if (item.type === "dropdown") {
          return (
            <div class="nav-item">
              <button class="nav-link" aria-haspopup="true" aria-expanded="false">
                {item.label}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="simple-dropdown">
                {item.columns?.map((col) => (
                  <div class="mega-col">
                    {col.title && <span class="mega-head">{col.title}</span>}
                    {col.items.map((link) => {
                      if (link.isDivider) return <div class="mega-divider"></div>;
                      return <a href={r(link.url)}>{link.label}</a>;
                    })}
                    {col.bottomLink && (
                      <a href={r(col.bottomLink.url)} style="color:var(--blue);font-weight:600;margin-top:4px">{col.bottomLink.label}</a>
                    )}
                  </div>
                ))}
              </div>
            </div>
          );
        }
      })}
    </nav>
    <div class="header-actions">
      <a href={contactData.storeUrl} target="_blank" rel="noopener noreferrer" class="btn-tienda">Tienda</a>
      <a href={getBookingUrl()} target="_blank" rel="noopener noreferrer" class="btn-cta">Agendar diagnóstico →</a>
    </div>
    <button class="hamburger" id="menuBtn" aria-label="Abrir menú">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
