---
// Componente de UI para Replicar el Formulario de Comentarios de WordPress
// Para que esto funcione en un sitio estático Astro sin base de datos nativa,
// puedes posteriormente enlazar su 'action' a Formspree, Netlify Forms o Supabase.
---

<div class="comments-section" style="margin-top: 80px; padding-top: 40px; border-top: 1px solid #e7e3db;">
  <h3 style="font-family: var(--font-display, Georgia, serif); font-size: 1.5rem; color: #1c1917; margin-bottom: 8px;">
    Deja un comentario
  </h3>
  <p style="font-family: var(--font-body, sans-serif); font-size: 0.95rem; color: #78716c; margin-bottom: 24px;">
    Tu dirección de correo electrónico no será publicada. Los campos obligatorios están marcados con *
  </p>

  <form id="comment-form" class="comment-form" action="#" method="POST" onsubmit="event.preventDefault(); alert('¡Gracias por tu comentario! El sistema de moderación lo ha recibido.');">
    
    <div class="form-group" style="margin-bottom: 20px;">
      <label for="comment" style="display: block; font-family: var(--font-body, sans-serif); font-size: 0.95rem; font-weight: 500; color: #44403c; margin-bottom: 8px;">
        Comentario <span style="color: #ef4444;">*</span>
      </label>
      <textarea id="comment" name="comment" required rows="6" placeholder="Escribe tu comentario aquí..." 
        style="width: 100%; padding: 12px 16px; border: 1px solid #d6d3d1; border-radius: 6px; font-family: var(--font-body, sans-serif); font-size: 1rem; color: #1c1917; resize: vertical; transition: border-color 0.2s;"
        onfocus="this.style.borderColor='#1d4ed8'; this.style.outline='none';"
        onblur="this.style.borderColor='#d6d3d1';"
      ></textarea>
    </div>

    <div class="form-row" style="display: flex; flex-direction: column; gap: 20px; margin-bottom: 20px; @media(min-width: 640px) { flex-direction: row; }">
      <div class="form-group" style="flex: 1;">
        <label for="author" style="display: block; font-family: var(--font-body, sans-serif); font-size: 0.95rem; font-weight: 500; color: #44403c; margin-bottom: 8px;">
          Nombre <span style="color: #ef4444;">*</span>
        </label>
        <input type="text" id="author" name="author" required
          style="width: 100%; padding: 12px 16px; border: 1px solid #d6d3d1; border-radius: 6px; font-family: var(--font-body, sans-serif); font-size: 1rem; color: #1c1917; transition: border-color 0.2s;"
          onfocus="this.style.borderColor='#1d4ed8'; this.style.outline='none';"
          onblur="this.style.borderColor='#d6d3d1';"
        />
      </div>

      <div class="form-group" style="flex: 1;">
        <label for="email" style="display: block; font-family: var(--font-body, sans-serif); font-size: 0.95rem; font-weight: 500; color: #44403c; margin-bottom: 8px;">
          Correo electrónico <span style="color: #ef4444;">*</span>
        </label>
        <input type="email" id="email" name="email" required
          style="width: 100%; padding: 12px 16px; border: 1px solid #d6d3d1; border-radius: 6px; font-family: var(--font-body, sans-serif); font-size: 1rem; color: #1c1917; transition: border-color 0.2s;"
          onfocus="this.style.borderColor='#1d4ed8'; this.style.outline='none';"
          onblur="this.style.borderColor='#d6d3d1';"
        />
      </div>
    </div>

    <div class="form-group" style="margin-bottom: 24px;">
      <label for="url" style="display: block; font-family: var(--font-body, sans-serif); font-size: 0.95rem; font-weight: 500; color: #44403c; margin-bottom: 8px;">
        Web
      </label>
      <input type="url" id="url" name="url" placeholder="https://"
        style="width: 100%; padding: 12px 16px; border: 1px solid #d6d3d1; border-radius: 6px; font-family: var(--font-body, sans-serif); font-size: 1rem; color: #1c1917; transition: border-color 0.2s;"
        onfocus="this.style.borderColor='#1d4ed8'; this.style.outline='none';"
        onblur="this.style.borderColor='#d6d3d1';"
      />
    </div>

    <div class="form-group checkbox-group" style="margin-bottom: 32px; display: flex; align-items: flex-start; gap: 12px;">
      <input type="checkbox" id="save-info" name="save-info" style="margin-top: 4px; width: 16px; height: 16px; accent-color: #1d4ed8;" />
      <label for="save-info" style="font-family: var(--font-body, sans-serif); font-size: 0.9rem; color: #78716c; line-height: 1.5; cursor: pointer;">
        Guardar mi nombre, correo electrónico y sitio web en este navegador para la próxima vez que haga un comentario.
      </label>
    </div>

    <button type="submit" style="background: #1d4ed8; color: #ffffff; border: none; padding: 14px 28px; border-radius: 6px; font-family: var(--font-display, monospace, sans-serif); font-size: 0.9rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; cursor: pointer; transition: background 0.2s, transform 0.1s; box-shadow: 0 4px 6px -1px rgba(29, 78, 216, 0.2);"
      onmouseover="this.style.background='#1e40af'; this.style.transform='translateY(-1px)';"
      onmouseout="this.style.background='#1d4ed8'; this.style.transform='translateY(0)';"
      onmousedown="this.style.transform='translateY(1px)';"
    >
      Publicar Comentario
    </button>
  </form>
</div>

<style>
  /* Responsive grid adjustments inside the component scoped styles */
  @media (min-width: 640px) {
    .form-row {
      flex-direction: row !important;
    }
  }
</style>
