---
/**
 * @name BlogComments.astro
 * @version 1.1.0
 * @description Componente de UI interactivo para renderizar y capturar comentarios de blog.
 * @inputs N/A
 * @outputs Formulario y lista de comentarios validada.
 * @dependencies Cloudflare Turnstile, Supabase REST API
 * @created 2026-03-23
 * @updated 2026-03-23 12:05:00
 */
// Componente de UI para Replicar el Formulario de Comentarios de WordPress
// Para que esto funcione en un sitio estático Astro sin base de datos nativa,
// puedes posteriormente enlazar su 'action' a Formspree, Netlify Forms o Supabase.
---

<div class="comments-section" style="margin-top: 80px; padding-top: 40px; border-top: 1px solid #e7e3db;">
  <h3 style="font-family: var(--font-display, Georgia, serif); font-size: 1.5rem; color: #1c1917; margin-bottom: 8px;">
    Deja un comentario
  </h3>
  <p style="font-family: var(--font-body, sans-serif); font-size: 0.95rem; color: #78716c; margin-bottom: 24px;">
    Tu dirección de correo electrónico no será publicada. Los campos obligatorios están marcados con *
  </p>

  <!-- Contenedor Dinámico para renderizar comentarios aprobados -->
  <div id="comments-list" style="margin-bottom: 40px; display: flex; flex-direction: column; gap: 24px;">
    <!-- Los comentarios se inyectarán aquí vía JS -->
  </div>

  <form id="comment-form" class="comment-form" action="#" method="POST">
    
    <div class="form-group" style="margin-bottom: 20px;">
      <label for="comment" style="display: block; font-family: var(--font-body, sans-serif); font-size: 0.95rem; font-weight: 500; color: #44403c; margin-bottom: 8px;">
        Comentario <span style="color: #ef4444;">*</span>
      </label>
      <textarea id="comment" name="comment" required rows="6" placeholder="Escribe tu comentario aquí..." 
        class="comment-input" style="resize: vertical;"
      ></textarea>
    </div>

    <div class="form-row" style="display: flex; flex-direction: column; gap: 20px; margin-bottom: 20px; @media(min-width: 640px) { flex-direction: row; }">
      <div class="form-group" style="flex: 1;">
        <label for="author" style="display: block; font-family: var(--font-body, sans-serif); font-size: 0.95rem; font-weight: 500; color: #44403c; margin-bottom: 8px;">
          Nombre <span style="color: #ef4444;">*</span>
        </label>
        <input type="text" id="author" name="author" required class="comment-input" />
      </div>

      <div class="form-group" style="flex: 1;">
        <label for="email" style="display: block; font-family: var(--font-body, sans-serif); font-size: 0.95rem; font-weight: 500; color: #44403c; margin-bottom: 8px;">
          Correo electrónico <span style="color: #ef4444;">*</span>
        </label>
        <input type="email" id="email" name="email" required class="comment-input" />
      </div>
    </div>

    <div class="form-group" style="margin-bottom: 24px;">
      <label for="url" style="display: block; font-family: var(--font-body, sans-serif); font-size: 0.95rem; font-weight: 500; color: #44403c; margin-bottom: 8px;">
        Web
      </label>
      <input type="url" id="url" name="url" placeholder="https://" class="comment-input" />
    </div>

    <div class="form-group checkbox-group" style="margin-bottom: 32px; display: flex; align-items: flex-start; gap: 12px;">
      <input type="checkbox" id="save-info" name="save-info" style="margin-top: 4px; width: 16px; height: 16px; accent-color: #1d4ed8;" />
      <label for="save-info" style="font-family: var(--font-body, sans-serif); font-size: 0.9rem; color: #78716c; line-height: 1.5; cursor: pointer;">
        Guardar mi nombre, correo electrónico y sitio web en este navegador para la próxima vez que haga un comentario.
      </label>
    </div>

    <!-- Cloudflare Turnstile Widget -->
    <!-- Reemplazar el data-sitekey con la llave pública de Cloudflare -->
    <div class="form-group" style="margin-bottom: 24px;">
      <div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_CF_TURNSTILE_KEY} data-theme="light"></div>
    </div>

    <div id="form-feedback" style="display: none; margin-bottom: 20px; padding: 12px; border-radius: 6px; font-family: var(--font-body, sans-serif); font-size: 0.9rem;"></div>

    <button type="submit" id="submit-btn" class="comment-btn">
      Publicar comentario
    </button>
  </form>
</div>

<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('comment-form');
    const submitBtn = document.getElementById('submit-btn');
    const feedbackBox = document.getElementById('form-feedback');
    const commentsList = document.getElementById('comments-list');

    // Extraer slug del artículo actual (ej: /blog/el-rol-del-liderazgo -> el-rol-del-liderazgo)
    const urlParts = window.location.pathname.split('/').filter(Boolean);
    const postSlug = urlParts[urlParts.length - 1];

    // Variables de Entorno Supabase (Definidas por Astro en compilación o window.env)
    // Para que esto funcione en GitHub Pages, debes añadir estas variables a tu .env
    // PUBLIC_SUPABASE_URL=https://tuid.supabase.co
    // PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

    // --- 1. CARGA DE COMENTARIOS APROBADOS ---
    async function loadComments() {
      if (!supabaseUrl || !supabaseAnonKey) return;
      
      try {
        const response = await fetch(`${supabaseUrl}/rest/v1/comments?post_slug=eq.${postSlug}&status=eq.approved&select=*&order=created_at.asc`, {
          headers: {
            'apikey': supabaseAnonKey,
            'Authorization': `Bearer ${supabaseAnonKey}`
          }
        });
        
        if (!response.ok) throw new Error('Error al cargar comentarios');
        const comments = await response.json();
        
        if (comments.length > 0) {
          commentsList.innerHTML = `<h4 style="font-family: var(--font-display, serif); font-size: 1.25rem; color: #1c1917; margin-bottom: 12px;">${comments.length} Comentario(s)</h4>`;
          comments.forEach(c => {
            const date = new Date(c.created_at).toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' });
            commentsList.innerHTML += `
              <div style="background: #fdfbf9; padding: 20px; border: 1px solid #e7e3db; border-radius: 8px;">
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                  <div style="width: 40px; height: 40px; background: #e7e3db; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; color: #44403c; font-family: var(--font-display, serif);">
                    ${c.author_name.charAt(0).toUpperCase()}
                  </div>
                  <div>
                    <strong style="display: block; font-family: var(--font-body, sans-serif); color: #1c1917;">
                      ${c.author_url ? `<a href="${c.author_url}" target="_blank" rel="nofollow noopener" style="color: inherit; text-decoration: none;">${c.author_name}</a>` : c.author_name}
                    </strong>
                    <span style="font-size: 0.85rem; color: #78716c; font-family: var(--font-body, sans-serif);">${date}</span>
                  </div>
                </div>
                <p style="font-family: var(--font-body, sans-serif); color: #44403c; line-height: 1.6; margin: 0; white-space: pre-wrap;">${c.content.replace(/</g, "&lt;").replace(/>/g, "&gt;")}</p>
              </div>
            `;
          });
        }
      } catch (err) {
        console.error('No se pudieron cargar los comentarios:', err);
      }
    }
    
    // Iniciar carga al montar
    loadComments();

    // --- 2. ENVÍO DE COMENTARIOS ---
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const turnstileToken = formData.get('cf-turnstile-response');

      if (!turnstileToken) {
        showFeedback('Por favor, completa la verificación de seguridad.', 'error');
        return;
      }

      if (!supabaseUrl || !supabaseAnonKey) {
        showFeedback('El sistema de comentarios no está configurado (Faltan variables de entorno).', 'error');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando...';
      submitBtn.style.opacity = '0.7';

      const payload = {
        post_slug:               postSlug,
        author_name:             formData.get('author'),
        author_email:            formData.get('email'),
        author_url:              formData.get('url') || '',
        content:                 formData.get('comment'),
        'cf-turnstile-response': turnstileToken,
      };

      try {
        const response = await fetch('/api/submit-comment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        if (response.ok) {
          showFeedback('¡Gracias! Tu comentario ha sido enviado y está pendiente de moderación.', 'success');
          form.reset();
          if (window.turnstile) turnstile.reset();
        } else {
          throw new Error('Error en el servidor Supabase');
        }
      } catch (error) {
        console.error('Error enviando comentario:', error);
        showFeedback('Ocurrió un error al enviar el comentario. Inténtalo más tarde.', 'error');
        if (window.turnstile) turnstile.reset();
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Publicar comentario';
        submitBtn.style.opacity = '1';
      }
    });

    function showFeedback(msg, type) {
      feedbackBox.style.display = 'block';
      feedbackBox.textContent = msg;
      if (type === 'success') {
        feedbackBox.style.backgroundColor = '#ecfdf5';
        feedbackBox.style.color = '#047857';
        feedbackBox.style.border = '1px solid #a7f3d0';
      } else {
        feedbackBox.style.backgroundColor = '#fef2f2';
        feedbackBox.style.color = '#b91c1c';
        feedbackBox.style.border = '1px solid #fecaca';
      }
    }
  });
</script>

<style>
  /* Responsive grid adjustments inside the component scoped styles */
  @media (min-width: 640px) {
    .form-row {
      flex-direction: row !important;
    }
  }
  .comment-input {
    width: 100%; padding: 12px 16px; border: 1px solid #d6d3d1; border-radius: 6px; font-family: var(--font-body, sans-serif); font-size: 1rem; color: #1c1917; transition: border-color 0.2s; outline: none;
  }
  .comment-input:focus-visible {
    border-color: #1d4ed8;
  }
  .comment-btn {
    background: #1d4ed8; color: #ffffff; border: none; padding: 14px 28px; border-radius: 6px; font-family: var(--font-display, monospace, sans-serif); font-size: 0.9rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; cursor: pointer; transition: background 0.2s, transform 0.1s; box-shadow: 0 4px 6px -1px rgba(29, 78, 216, 0.2);
  }
  .comment-btn:hover, .comment-btn:focus-visible {
    background: #1e40af; transform: translateY(-1px); outline: none;
  }
  .comment-btn:active {
    transform: translateY(1px);
  }
</style>
