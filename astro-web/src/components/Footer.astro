---
// CHANGELOG: 19/03/2026 - Refactored to use centralized data from src/data/navigation.ts and src/data/contact.ts
// CHANGELOG: 19/03/2026 - Use r() to prefix internal links with BASE_URL for staging support
// CHANGELOG: 2026-03-20 - Version badge: package.json version + git commit hash + build date
//   → Eliminar las 3 constantes buildHash/buildDate/buildVersion antes de ir a producción
import { footerLinks } from '../data/navigation';
import { contactData, getBookingUrl } from '../data/contact';

import { r, base } from '../utils/paths';

const currentYear = new Date().getFullYear();

// ── BUILD INFO (solo staging — eliminar antes de producción) ──────────────────
const buildHash   = (import.meta.env.PUBLIC_BUILD_HASH  || 'local').slice(0, 7);
const buildRaw    = import.meta.env.PUBLIC_BUILD_DATE || '';
const buildDate   = buildRaw
  ? new Date(buildRaw).toLocaleDateString('es-MX', { day: '2-digit', month: 'short', year: 'numeric' })
  : 'local';
const buildVersion = '4.0.0'; // Sincronizar con package.json · npm version patch|minor|major para subir

const { theme = 'default' } = Astro.props;
---
<footer class={theme === 'dark' ? 'footer--dark' : ''}>
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href={r('/')} class="logo-link"><img src={`${base}assets/logo.svg`} alt="TAEC" /></a>
        <p>Aprendizaje corporativo para organizaciones que necesitan resultados medibles. Desde 2007 en CDMX para México y LATAM.</p>
        <div class="footer-contact">
          <a href={`mailto:${contactData.email}`}>✉ {contactData.email}</a>
          <a href={`tel:${contactData.phone.replace(/ /g, '')}`}>📞 {contactData.phone}</a>
          <a href={contactData.whatsapp.url} target="_blank" rel="noopener noreferrer">💬 {contactData.whatsapp.label}</a>
        </div>
      </div>
      
      {footerLinks.map((col) => (
        <div class="footer-col">
          <h4>{col.title}</h4>
          <ul>
            {col.items.map((link) => (
              <li><a href={r(link.url)} {...(link.url.startsWith('http') ? {target: "_blank", rel: "noopener noreferrer"} : {})}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    
    <div class="footer-latam">
      <span class="footer-latam-label">También en:</span>
      {contactData.regional.map((reg) => (
        <a href={reg.url} target="_blank" rel="noopener noreferrer" title={`TAEC ${reg.country}`}>
          {reg.emoji} {reg.country} &mdash; {reg.domain}
        </a>
      ))}
    </div>

    <div class="footer-cta" style="text-align: center; margin: 32px 0 16px;">
      <a href={getBookingUrl()} target="_blank" rel="noopener noreferrer" style="display: inline-block; background: var(--orange, #ff6b35); color: #fff; padding: 12px 24px; border-radius: 8px; font-weight: 600; font-size: 14px; text-decoration: none; transition: background 0.2s;">
        Agendar diagnóstico gratuito →
      </a>
    </div>
    
    <div class="footer-bottom">
      <p>© {currentYear} TAEC &middot; Ciudad de México &middot; <a href="https://www.taec.com.mx/privacidad.php" target="_blank" rel="noopener noreferrer" style="opacity:.6; color: inherit; text-decoration: underline;">Aviso de privacidad</a> 
      {!import.meta.env.PROD && <span class="build-badge">v{buildVersion} · {buildHash} · {buildDate}</span>}</p>
      <div class="footer-social">
        <a href={contactData.socials.linkedin} target="_blank" rel="noopener noreferrer" title="LinkedIn" aria-label="LinkedIn">in</a>
        <a href={contactData.socials.youtube} target="_blank" rel="noopener noreferrer" title="YouTube" aria-label="YouTube">YT</a>
        <a href={contactData.socials.facebook} target="_blank" rel="noopener noreferrer" title="Facebook" aria-label="Facebook">fb</a>
        <a href={contactData.whatsapp.url} target="_blank" rel="noopener noreferrer" title="WhatsApp" aria-label="WhatsApp">WA</a>
      </div>
    </div>
  </div>
</footer>

<!-- ══ WHATSAPP FLOTANTE ══ -->
<a href={contactData.whatsapp.url} target="_blank" rel="noopener noreferrer" class="wa-float" title="WhatsApp TAEC">
  <span class="wa-tooltip">¿Hablamos?</span>
  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
</a>
