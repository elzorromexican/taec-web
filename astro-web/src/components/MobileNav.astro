---
// CHANGELOG: 19/03/2026 - Refactored to use centralized data from src/data/navigation.ts and src/data/contact.ts
// CHANGELOG: 19/03/2026 - Use r() to prefix internal links with BASE_URL for staging support
import { mainNav } from '../data/navigation';
import { contactData, getBookingUrl } from '../data/contact';

import { r, base } from '../utils/paths';
---
<nav class="mobile-nav" id="mobileNav">
  {mainNav.map((item, i) => {
    if (item.type === "link") {
      return <a href={r(item.url || '#')}>{item.label}</a>;
    }

    if (item.type === "mega" || item.type === "dropdown") {
      const mobId = `mob${i}`;
      const secId = `mobSec${i}`;
      return (
        <>
          {/* Desarrollo actual: acordeón móvil solo de primer nivel.
              Los subItems se muestran como enlaces hijos indentados dentro de la sección abierta. */}
          <button class="mob-toggle" id={mobId} aria-expanded="false" aria-controls={secId} type="button">
            {item.label}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="mob-section" id={secId}>
            {item.columns?.map((col) => (
              <>
                {col.title && <span class="mob-cat">{col.title}</span>}
                {col.items.map((link) => {
                  if (link.isDivider || link.isSubtitle) return null;
                  return (
                    <>
                      <a href={r(link.url)}>
                        {link.label}
                        {link.badge && <span class={`badge-${link.badge.type}`}>{link.badge.text}</span>}
                      </a>
                      {link.subItems?.map((sub) => (
                        <a href={r(sub.url)} class="mob-sub-link">
                          {sub.label}
                          {sub.badge && <span class={`badge-${sub.badge.type}`}>{sub.badge.text}</span>}
                        </a>
                      ))}
                    </>
                  );
                })}
                {col.bottomLink && (
                  <a href={r(col.bottomLink.url)} style="color:var(--blue);font-weight:600;">{col.bottomLink.label}</a>
                )}
              </>
            ))}
          </div>
        </>
      );
    }
  })}
  <a href={contactData.storeUrl} target="_blank" rel="noopener noreferrer">Tienda</a>
  <a href={getBookingUrl()} target="_blank" rel="noopener noreferrer">Agendar diagnóstico</a>
  <a href={contactData.whatsapp.url} target="_blank" rel="noopener noreferrer" class="btn-cta">WhatsApp →</a>
</nav>
<script is:inline>
  function bindMobileNavAccordions() {
    document.querySelectorAll('#mobileNav .mob-toggle').forEach(function (btn) {
      if (btn.dataset.bound === 'true') return;
      btn.dataset.bound = 'true';
      btn.addEventListener('click', function () {
        var secId = btn.getAttribute('aria-controls');
        var sec = secId ? document.getElementById(secId) : null;
        if (!sec) return;
        var isOpen = sec.classList.toggle('open');
        btn.classList.toggle('open', isOpen);
        btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bindMobileNavAccordions, { once: true });
  } else {
    bindMobileNavAccordions();
  }
</script>
