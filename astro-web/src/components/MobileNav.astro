---
// CHANGELOG: 19/03/2026 - Refactored to use centralized data from src/data/navigation.ts and src/data/contact.ts
import { mainNav } from '../data/navigation';
import { contactData } from '../data/contact';
---
<nav class="mobile-nav" id="mobileNav">
  {mainNav.map((item, i) => {
    if (item.type === "link") {
      return <a href={item.url}>{item.label}</a>;
    }

    if (item.type === "mega" || item.type === "dropdown") {
      const mobId = `mob${i}`;
      const secId = `mobSec${i}`;
      return (
        <>
          <button class="mob-toggle" id={mobId} aria-expanded="false" aria-controls={secId} onclick={`toggleMob('${secId}','${mobId}')`}>
            {item.label}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="mob-section" id={secId}>
            {item.columns?.map((col) => (
              <>
                {col.title && <span class="mob-cat">{col.title}</span>}
                {col.items.map((link) => {
                  if (link.isDivider || link.isSubtitle) return null;
                  return (
                    <>
                      <a href={link.url}>
                        {link.label}
                        {link.badge && <span class={`badge-${link.badge.type}`}>{link.badge.text}</span>}
                      </a>
                      {link.subItems?.map((sub) => (
                        <a href={sub.url} class="mob-sub-link" style="padding-left:16px;">
                          {sub.label}
                          {sub.badge && <span class={`badge-${sub.badge.type}`}>{sub.badge.text}</span>}
                        </a>
                      ))}
                    </>
                  );
                })}
                {col.bottomLink && (
                  <a href={col.bottomLink.url} style="color:var(--blue);font-weight:600;">{col.bottomLink.label}</a>
                )}
              </>
            ))}
          </div>
        </>
      );
    }
  })}
  <a href={contactData.storeUrl} target="_blank" rel="noopener noreferrer">Tienda</a>
  <a href={contactData.whatsapp.url} target="_blank" rel="noopener noreferrer" class="btn-cta">WhatsApp →</a>
</nav>
