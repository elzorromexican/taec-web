---
// CHANGELOG: 19/03/2026 - Extracted HeroComercial component to remove duplication across product pages.
// CHANGELOG: 19/03/2026 - Use r() to prefix internal URLs with BASE_URL for staging support.
export interface Props {
  eyebrow: string;
  titleHtml: string;
  subtitle: string;
  features?: string[];
  primaryBtn?: { label: string; url: string; target?: string };
  secondaryBtn?: { label: string; url: string; target?: string };
  bottomText?: string;
  cardLogoSrc?: string;
  cardLogoStyle?: string;
  cardBadgeText?: string;
  theme?: 'moo' | 'tot' | 'art' | 'vyond' | 'general';
  brandColor?: string;   // Sobreescribe --hero-primary y --hero-accent
  btnTextDark?: boolean; // true = texto oscuro en botón (para colores claros como amarillo/ámbar)
}

const {
  eyebrow, titleHtml, subtitle, features, primaryBtn, secondaryBtn,
  bottomText, cardLogoSrc, cardLogoStyle = "height:44px;width:auto;", cardBadgeText,
  theme = 'general', brandColor, btnTextDark = false
} = Astro.props;

const brandStyle = brandColor
  ? `--hero-primary:${brandColor};--hero-accent:${brandColor};${btnTextDark ? '--btn-text:#0f172a;' : ''}`
  : '';

import { r, base } from '../../utils/paths';
---
<section class={`hero-comercial theme-${theme}`} style={brandStyle}>
  <div class="hero-inner">
    <div>
      <p class="hero-eyebrow">{eyebrow}</p>
      <!-- trusted internal data only -->
      <h1 set:html={titleHtml}></h1>
      <p class="hero-sub">{subtitle}</p>
      {(primaryBtn || secondaryBtn) && (
      <div class="hero-btns">
        {primaryBtn && <a href={r(primaryBtn.url)} class="btn-primary" target={primaryBtn.target} rel={primaryBtn.target === '_blank' ? 'noopener noreferrer' : undefined}>{primaryBtn.label}</a>}
        {secondaryBtn && <a href={r(secondaryBtn.url)} class="btn-ghost" target={secondaryBtn.target} rel={secondaryBtn.target === '_blank' ? 'noopener noreferrer' : undefined}>{secondaryBtn.label}</a>}
      </div>
      )}
      {bottomText && <p class="hero-bottom-text">{bottomText}</p>}
    </div>
    <div class="hero-card">
      {cardLogoSrc && (
        <div class="card-logo-wrap">
          <img src={cardLogoSrc} alt={cardBadgeText || "Logo representativo del producto"} style={cardLogoStyle} width="200" height="64" />
        </div>
      )}
      {cardBadgeText && <p class="card-badge">{cardBadgeText}</p>}
      {features && features.length > 0 && (
      <div class="hero-features">
        {features.map((feat) => <div class="feat-item">{feat}</div>)}
      </div>
      )}
    </div>
  </div>
</section>

<style>
.hero-comercial {
  background: var(--hero-bg, #0f172a);
  padding: 72px 5% 80px;
  color: white;
}
.hero-inner {
  max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center;
}
.hero-eyebrow {
  font-size: clamp(22px, 2.4vw, 32px); font-weight: 900; color: var(--hero-accent, #38bdf8); letter-spacing: -.01em; margin-bottom: 10px; line-height: 1;
}
h1 {
  font-family: var(--font-display); font-size: clamp(32px, 4vw, 52px); font-weight: 400; color: white; line-height: 1.15; margin-bottom: 20px;
}
h1 :global(em) { color: var(--hero-accent, #38bdf8); font-style: normal; }
.hero-sub {
  font-size: 17px; color: rgba(255,255,255,.8); line-height: 1.7; margin-bottom: 28px;
}
.hero-btns { display: flex; gap: 12px; flex-wrap: nowrap; margin-bottom: 16px; align-items: center; }
.btn-primary {
  background: var(--hero-primary, #c2410c); color: var(--btn-text, white); font-weight: 700; font-size: 15px; padding: 14px 28px; border-radius: 8px; display: inline-flex; align-items: center; gap: 8px; transition: opacity .15s;
}
.btn-primary:hover { opacity: .9; }
.btn-ghost {
  background: transparent; color: white; font-weight: 600; font-size: 15px; padding: 13px 24px; border-radius: 8px; border: 1.5px solid rgba(255,255,255,.4); display: inline-flex; align-items: center; gap: 8px; transition: border-color .15s;
}
.btn-ghost:hover { border-color: white; }
.hero-bottom-text { margin-top: 12px; font-size: 12px; color: rgba(255,255,255,.5); }

.hero-card {
  background: rgba(255,255,255,.08); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,.15); border-radius: 20px; padding: 28px;
}
.card-logo-wrap {
  display: flex; justify-content: center; margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid rgba(255,255,255,.1);
}
.card-badge {
  font-size: 12px; font-weight: 700; color: var(--hero-accent, #38bdf8); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 16px;
}
.hero-features { display: flex; flex-direction: column; gap: 10px; margin-top: 16px; }
.feat-item {
  font-size: 14px; color: rgba(255,255,255,.9); display: flex; align-items: flex-start; gap: 10px; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,.07);
}
.feat-item:last-child { border-bottom: none; }
.feat-item::before { content: "✓"; color: var(--hero-accent, #38bdf8); font-weight: 700; flex-shrink: 0; margin-top: 1px; }

/* THEMES */
.theme-moo { 
  --hero-bg: linear-gradient(135deg, #1a0600 0%, #3d1500 55%, #7a2e00 100%);
  --hero-accent: #FFB05A;
  --hero-primary: #c2410c;
}
.theme-tot {
  --hero-bg: linear-gradient(135deg, #001f3d 0%, #004775 60%, #0077b6 100%);
  --hero-accent: #A8DBD9;
  --hero-primary: #A8DBD9;
  --btn-text: #001f3d;
}
.theme-art {
  --hero-bg: linear-gradient(135deg, #0f172a 0%, #00355a 100%);
  --hero-accent: #7DD3FC;
  --hero-primary: #c2410c;
}
.theme-vyond {
  --hero-bg: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
  --hero-accent: #f472b6;
  --hero-primary: #ec4899;
}

@media (max-width: 1024px) {
  .hero-inner { grid-template-columns: 1fr; gap: 40px; }
  .hero-card { display: none; /* In original Totara it was hidden on mobile */ }
}
</style>
