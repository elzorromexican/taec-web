---
// CHANGELOG: 19/03/2026 - Extracted CtaFinal component to enforce global CTA policy.
import { contactData } from '../../data/contact';

export interface Props {
  title: string;
  subtitle: string;
  primaryBtnText?: string;
  primaryBtnUrl?: string;
  primaryBtnTarget?: string;
  theme?: 'moo' | 'tot' | 'art' | 'vyond' | 'general';
}

const {
  title,
  subtitle,
  primaryBtnText = "Solicitar propuesta →",
  primaryBtnUrl = "/contacto",
  primaryBtnTarget,
  theme = 'general'
} = Astro.props;
---
<section class={`cta-band theme-${theme}`}>
  <div class="cta-inner">
    <h2>{title}</h2>
    <p>{subtitle}</p>
    <div class="cta-btns">
      <a href={primaryBtnUrl} class="btn-primary" target={primaryBtnTarget} rel={primaryBtnTarget === '_blank' ? 'noopener noreferrer' : undefined}>{primaryBtnText}</a>
      <a href={contactData.whatsapp.url} target="_blank" rel="noopener noreferrer" class="btn-wa">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>
        WhatsApp
      </a>
      <a href={contactData.bookingUrl} target="_blank" rel="noopener noreferrer" class="btn-ghost">Agendar diagnóstico gratuito</a>
    </div>
  </div>
</section>

<style>
.cta-band {
  background: var(--cta-bg, #1e293b);
  padding: 56px 5%; text-align: center; color: white;
}
.cta-inner { max-width: 900px; margin: 0 auto; }
h2 { font-family: var(--font-display); font-size: clamp(24px, 2.8vw, 36px); font-weight: 400; margin-bottom: 12px; color: white; }
p { font-size: 16px; opacity: .85; margin-bottom: 32px; color: white; }
.cta-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
.btn-primary {
  background: var(--cta-primary, white); color: var(--cta-primary-text, #0f172a); font-weight: 700; font-size: 15px; padding: 14px 28px; border-radius: 8px; transition: opacity .15s;
}
.btn-primary:hover { opacity: .9; }
.btn-wa {
  display: inline-flex; align-items: center; gap: 8px; background: #25D366; color: white; font-weight: 700; font-size: 15px; padding: 14px 24px; border-radius: 8px; transition: background .15s;
}
.btn-wa:hover { background: #1ebe5c; }
.btn-wa svg { width: 18px; height: 18px; fill: white; flex-shrink: 0; }
.btn-ghost {
  display: inline-flex; align-items: center; gap: 8px; background: transparent; color: white; font-weight: 600; font-size: 15px; padding: 13px 24px; border-radius: 8px; border: 1.5px solid rgba(255,255,255,.5); transition: border-color .15s;
}
.btn-ghost:hover { border-color: white; }

/* THEMES */
.theme-moo { --cta-bg: #C46200; --cta-primary: white; --cta-primary-text: #C46200; }
.theme-tot { --cta-bg: #004775; --cta-primary: #A8DBD9; --cta-primary-text: #001f3d; }
.theme-art { --cta-bg: linear-gradient(135deg, #00355a 0%, #0f172a 100%); --cta-primary: #f97316; --cta-primary-text: white; }
.theme-vyond { --cta-bg: #312e81; --cta-primary: #ec4899; --cta-primary-text: white; }
.theme-general { --cta-bg: linear-gradient(135deg, #1e3a8a 0%, #0f172a 100%); --cta-primary: #f97316; --cta-primary-text: white; }
</style>
