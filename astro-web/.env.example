# TAEC Web - Plantilla de Variables de Entorno
# ----------------------------------------------------
# Instrucciones:
# 1. Duplica este archivo y renómbralo a `.env`
# 2. Reemplaza los valores con las credenciales reales
# (El archivo `.env` está ignorado en Git por seguridad)

# Cotizador DDC - Tarifarios Internos (No exponer al cliente)
DDC_BASE_RATE_STORYLINE=0.0
DDC_BASE_RATE_VYOND=0.0
DDC_BASE_RATE_RISE=0.0

# Zoho CRM / Contacto (Webhooks)
ZOHO_WEBHOOK_URL="https://flow.zoho.com/..."
ZOHO_API_KEY="your_api_key_here"

# Supabase Envs (Auth PII / Intranet)
PUBLIC_SUPABASE_URL="https://tu-proyecto.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="tu-anon-key-publica"
